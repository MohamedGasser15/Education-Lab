@model List<EduLab_MVC.Models.DTOs.Course.CourseDTO>
@using EduLab_MVC.Models.DTOs.Course

@{
    string FormatDuration(int totalSeconds)
    {
        if (totalSeconds <= 0)
            return Localizer["DurationZero"].Value;

        var hours = totalSeconds / 3600;
        var remainingSeconds = totalSeconds % 3600;
        var minutes = remainingSeconds / 60;
        var seconds = remainingSeconds % 60;

        if (hours > 0 && minutes > 0 && seconds > 0)
            return string.Format(Localizer["DurationFull"].Value, hours, minutes, seconds);
        else if (hours > 0 && minutes > 0)
            return string.Format(Localizer["DurationHoursMinutes"].Value, hours, minutes);
        else if (hours > 0 && seconds > 0)
            return string.Format(Localizer["DurationHoursSeconds"].Value, hours, seconds);
        else if (minutes > 0 && seconds > 0)
            return string.Format(Localizer["DurationMinutesSeconds"].Value, minutes, seconds);
        else if (hours > 0)
            return string.Format(Localizer["DurationHours"].Value, hours);
        else if (minutes > 0)
            return string.Format(Localizer["DurationMinutes"].Value, minutes);
        else
            return string.Format(Localizer["DurationSeconds"].Value, seconds);
    }
    ViewData["Title"] = Localizer["CourseManagement"];
}

<style>
    /* Premium Modal Enhancements */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background-color: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        padding: 1.5rem;
    }

    .modal-overlay:not(.hidden) {
        display: flex;
    }

    .modal-container {
        width: 100%;
        max-width: 40rem;
        animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes modalSlideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Modern Pagination */
    .pagination-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 12px;
        background: white;
        border: 1px solid #f1f5f9;
        color: #64748b;
        font-weight: 700;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .dark .pagination-btn {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.05);
        color: #94a3b8;
    }

    .pagination-btn:hover:not(.disabled) {
        background: #2563eb;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2);
    }

    .pagination-btn.active {
        background: #2563eb;
        color: white;
        border-color: #2563eb;
    }

    .pagination-btn.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* Custom Checkbox Premium */
    .custom-checkbox {
        width: 1.3rem;
        height: 1.3rem;
        border-radius: 6px;
        border: 2px solid #e2e8f0;
        appearance: none;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
    }

    .dark .custom-checkbox {
        border-color: rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.05);
    }

    .custom-checkbox:checked {
        background: #2563eb;
        border-color: #2563eb;
    }

    .custom-checkbox:checked::after {
        content: "✓";
        position: absolute;
        color: white;
        font-weight: 900;
        font-size: 0.8rem;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }
</style>

<!-- Premium Course Page Container -->
<div class="space-y-8 animate-in fade-in duration-1000">

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-2">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight"><span class="text-primary-600">@Localizer["CourseManagement"]</span> <i class="fas fa-book-open text-primary-600/50 mr-2"></i></h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 font-medium">@Localizer["CoursePageSubtitle"]</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Create" asp-controller="Course" asp-area="Instructor" class="flex items-center gap-2 px-5 py-3 rounded-2xl bg-primary-600 text-white font-bold text-sm shadow-lg shadow-primary-600/30 hover:bg-primary-700 hover:scale-105 transition-all">
                <i class="fas fa-plus"></i>
                <span>@Localizer["AddNewCourse"]</span>
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["TotalCourses"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count</h3>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-primary-600 flex items-center justify-center shadow-lg shadow-primary-600/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-book-open text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-emerald-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["ActiveCourses"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(c => c.Status == "Approved")</h3>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-check-circle text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-amber-500/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["PendingReview"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(c => c.Status == "Pending")</h3>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-amber-500 flex items-center justify-center shadow-lg shadow-amber-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-clock text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-rose-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["RejectedCourses"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(c => c.Status == "Rejected")</h3>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-rose-500 flex items-center justify-center shadow-lg shadow-rose-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-times-circle text-white text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Modern Filter Bar -->
    <div class="glass-card rounded-3xl p-6 mb-8">
        <div class="flex flex-col lg:flex-row gap-4 items-center">
            <div class="relative flex-1 w-full">
                <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-gray-400">
                    <i class="fas fa-search"></i>
                </div>
                <input type="text" id="searchInput"
                       class="w-full pr-11 pl-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white transition-all font-medium"
                       placeholder="@Localizer["SearchCoursePlaceholder"]">
            </div>

            <div class="relative w-full md:w-64">
                <select id="categoryFilter" class="w-full px-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white transition-all font-medium appearance-none">
                    <option value="">@Localizer["AllCategories"]</option>
                    @if (ViewBag.Categories != null)
                    {
                        @foreach (var category in ViewBag.Categories as List<SelectListItem>)
                        {
                            <option value="@category.Text">@category.Text</option>
                        }
                    }
                </select>
                <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-gray-400">
                    <i class="fas fa-chevron-down text-xs"></i>
                </div>
            </div>

            <button id="resetFilters" class="w-full lg:w-auto px-6 py-3 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-bold text-sm hover:bg-primary-600 hover:text-white transition-all duration-300">
                <i class="fas fa-undo-alt ml-2"></i>
                @Localizer["ResetFilters"]
            </button>
        </div>
    </div>

    <!-- رسائل التنبيه -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 p-4 mb-6 rounded-2xl flex items-center shadow-sm">
            <i class="fas fa-check-circle text-xl ml-3"></i>
            <div>
                <p class="font-bold">@TempData["Success"]</p>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-rose-500/10 border border-rose-500/20 text-rose-600 dark:text-rose-400 p-4 mb-6 rounded-2xl flex items-center shadow-sm">
            <i class="fas fa-exclamation-circle text-xl ml-3"></i>
            <div>
                <p class="font-bold">@TempData["Error"]</p>
            </div>
        </div>
    }

    <!-- Premium Bulk Actions -->
    <div id="bulkActionsContainer" class="hidden animate-in slide-in-from-top-4 duration-500">
        <div class="bg-primary-600 text-white px-6 py-4 rounded-2xl shadow-xl shadow-primary-600/20 flex flex-col md:flex-row items-center justify-between gap-4 mb-6">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center">
                    <i class="fas fa-check-double text-white"></i>
                </div>
                <div>
                    <p class="text-xs font-bold opacity-80 uppercase tracking-widest">@Localizer["BulkActions"]</p>
                    <h4 class="text-sm font-black"><span id="selectedCount">0</span> @Localizer["SelectedCourses"]</h4>
                </div>
            </div>
            <div class="flex items-center gap-3 w-full md:w-auto">
                <select id="bulkAction" class="bg-white/20 text-white border-0 rounded-xl px-4 py-2 outline-none appearance-none font-bold text-sm">
                    <option value="" class="text-gray-900">@Localizer["ChooseAction"]</option>
                    <option value="delete" class="text-gray-900">@Localizer["DeleteSelected"]</option>
                </select>
                <button id="applyBulkAction" class="px-6 py-2 bg-rose-500 text-white font-black text-sm rounded-xl hover:bg-rose-600 transition-colors shadow-lg shadow-rose-600/20">
                    @Localizer["Apply"]
                </button>
            </div>
        </div>
    </div>

    <!-- Premium Courses Table Area -->
    <div class="glass-card rounded-3xl overflow-hidden shadow-2xl">
        <div class="overflow-x-auto">
            <table class="admin-table w-full border-collapse">
                <thead>
                    <tr class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest bg-gray-50/50 dark:bg-white/5">
                        <th class="px-8 py-5 w-16">
                            <input type="checkbox" id="selectAll" class="custom-checkbox">
                        </th>
                        <th class="px-8 py-5">@Localizer["TableCourseTitle"]</th>
                        <th class="px-8 py-5">@Localizer["TableCategory"]</th>
                        <th class="px-8 py-5">@Localizer["TablePrice"]</th>
                        <th class="px-8 py-5">@Localizer["TableDuration"]</th>
                        <th class="px-8 py-5">@Localizer["TableStatus"]</th>
                        <th class="px-8 py-5 text-center">@Localizer["TableActions"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var course in Model)
                        {
                            <tr class="hover:bg-gray-50/50 dark:hover:bg-white/5 transition-colors group border-b border-gray-100 dark:border-white/5" data-course-id="@course.Id" data-category="@course.CategoryName" data-status="@course.Status">
                                <td class="px-8 py-5">
                                    <input type="checkbox" class="row-checkbox custom-checkbox" value="@course.Id">
                                </td>
                                <td class="px-8 py-5">
                                    <div class="flex items-center gap-4">
                                        <div class="w-14 h-14 rounded-2xl overflow-hidden bg-gray-100 dark:bg-white/5 flex items-center justify-center shadow-sm shrink-0">
                                            @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                                            {
                                                <img class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-500" src="@course.ThumbnailUrl" alt="@course.Title">
                                            }
                                            else
                                            {
                                                <i class="fas fa-book text-gray-400 text-xl group-hover:scale-110 transition-transform"></i>
                                            }
                                        </div>
                                        <div>
                                            <h4 class="text-sm font-black text-gray-900 dark:text-white group-hover:text-primary-600 transition-colors line-clamp-1">@course.Title</h4>
                                            <p class="text-[11px] text-gray-400 font-bold uppercase tracking-widest mt-1">@course.CreatedAt.ToString("yyyy-MM-dd")</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-8 py-5">
                                    <span class="text-xs font-bold text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-white/10 px-3 py-1 rounded-full">@(course.CategoryName ?? Localizer["Unknown"].Value)</span>
                                </td>
                                <td class="px-8 py-5">
                                    <div class="flex flex-col">
                                        <span class="text-sm font-black text-gray-900 dark:text-white">@course.Price.ToString("C")</span>
                                        @if (course.Discount > 0)
                                        {
                                            <span class="text-[11px] text-rose-500 line-through font-bold">@((course.Price + (course.Discount ?? 0)).ToString("C"))</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-8 py-5">
                                    <div class="flex flex-col gap-1">
                                        <span class="text-xs font-black text-primary-600"><i class="fas fa-clock ml-1"></i>@FormatDuration(course.Duration)</span>
                                        <span class="text-[11px] text-gray-400 font-bold"><i class="fas fa-list-ul ml-1"></i>@course.TotalLectures @Localizer["Lecture"]</span>
                                    </div>
                                </td>
                                <td class="px-8 py-5">
                                    @if (course.Status == "Draft")
                                    {
                                        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-gray-500/10 text-gray-500 border border-gray-500/20">
                                            <span class="text-xs font-bold uppercase tracking-widest">@Localizer["StatusDraft"]</span>
                                        </div>
                                    }
                                    else if (course.Status == "Pending")
                                    {
                                        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-500/10 text-amber-500 border border-amber-500/20">
                                            <div class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></div>
                                            <span class="text-xs font-bold uppercase tracking-widest">@Localizer["StatusPending"]</span>
                                        </div>
                                    }
                                    else if (course.Status == "Approved")
                                    {
                                        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-500 border border-emerald-500/20">
                                            <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                                            <span class="text-xs font-bold uppercase tracking-widest">@Localizer["StatusApproved"]</span>
                                        </div>
                                    }
                                    else if (course.Status == "Rejected")
                                    {
                                        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-rose-500/10 text-rose-500 border border-rose-500/20">
                                            <div class="w-1.5 h-1.5 rounded-full bg-rose-500"></div>
                                            <span class="text-xs font-bold uppercase tracking-widest">@Localizer["StatusRejected"]</span>
                                        </div>
                                    }
                                </td>
                                <td class="px-8 py-5">
                                    <div class="flex items-center justify-center gap-2">
                                        <button class="w-9 h-9 rounded-xl bg-blue-500/10 text-blue-500 flex items-center justify-center hover:bg-blue-500 hover:text-white transition-all shadow-sm view-details" data-course-id="@course.Id" title="@Localizer["ViewTooltip"]">
                                            <i class="fas fa-eye text-xs"></i>
                                        </button>
                                        @if (course.Status == "Draft")
                                        {
                                            <a asp-action="Curriculum" asp-controller="Course" asp-area="Instructor" asp-route-id="@course.Id" class="w-9 h-9 rounded-xl bg-purple-500/10 text-purple-500 flex items-center justify-center hover:bg-purple-500 hover:text-white transition-all shadow-sm" title="@Localizer["Curriculum"]">
                                                <i class="fas fa-list-ul text-xs"></i>
                                            </a>
                                            <button class="w-9 h-9 rounded-xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center hover:bg-emerald-500 hover:text-white transition-all shadow-sm publish-course" data-course-id="@course.Id" title="@Localizer["Publish"]">
                                                <i class="fas fa-upload text-xs"></i>
                                            </button>
                                        }
                                        <a asp-action="Settings" asp-controller="Course" asp-area="Instructor" asp-route-id="@course.Id" class="w-9 h-9 rounded-xl bg-amber-500/10 text-amber-500 flex items-center justify-center hover:bg-amber-500 hover:text-white transition-all shadow-sm" title="@Localizer["EditTooltip"]">
                                            <i class="fas fa-pencil-alt text-xs"></i>
                                        </a>
                                        <button class="w-9 h-9 rounded-xl bg-rose-500/10 text-rose-500 flex items-center justify-center hover:bg-rose-500 hover:text-white transition-all shadow-sm delete-course" data-course-id="@course.Id" data-course-name="@course.Title" title="@Localizer["DeleteTooltip"]">
                                            <i class="fas fa-trash-alt text-xs"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="px-8 py-16 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="w-24 h-24 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center mb-4 text-gray-300 dark:text-gray-600">
                                        <i class="fas fa-book-open text-4xl"></i>
                                    </div>
                                    <h3 class="text-lg font-black text-gray-900 dark:text-white mb-2">@Localizer["NoCoursesAvailable"]</h3>
                                    <p class="text-sm text-gray-500 dark:text-gray-400 font-medium mb-6">@Localizer["NoSearchResults"]</p>
                                    <a asp-action="Create" asp-controller="Course" asp-area="Instructor" class="px-6 py-3 rounded-2xl bg-primary-600 text-white font-bold text-sm shadow-xl shadow-primary-600/30 hover:bg-primary-700 hover:scale-105 transition-all">
                                        <i class="fas fa-plus ml-2"></i> @Localizer["AddNewCourse"]
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Premium Pagination -->
        @if (Model != null && Model.Any())
        {
            <div class="px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-6 bg-gray-50/50 dark:bg-white/5 border-t border-gray-100 dark:border-white/5">
                <div class="text-sm font-bold text-gray-500 dark:text-gray-400 order-2 md:order-1">
                    @Localizer["ShowingFromToPrefix"] <span id="showing-from" class="text-primary-600">1</span> @Localizer["To"] <span id="showing-to" class="text-primary-600">@Math.Min(5, Model.Count)</span> @Localizer["Of"] <span id="total-courses" class="text-gray-900 dark:text-white">@Model.Count</span> @Localizer["CoursesLower"]
                </div>

                <div class="flex items-center gap-4 order-1 md:order-2">
                    <div class="pagination-controls flex items-center gap-2">
                        <button id="prev-page" class="pagination-btn disabled" title="@Localizer["Previous"]">
                            <i class="fas fa-chevron-right text-xs"></i>
                        </button>
                        <div id="pagination-numbers" class="flex gap-2">
                            <button class="pagination-btn active">1</button>
                        </div>
                        <button id="next-page" class="pagination-btn @(Model.Count <= 10 ? "disabled" : "")" title="@Localizer["Next"]">
                            <i class="fas fa-chevron-left text-xs"></i>
                        </button>
                    </div>

                    <div class="h-8 w-px bg-gray-200 dark:bg-white/10 hidden sm:block"></div>

                    <select id="rows-per-page" class="px-3 py-2 bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl text-xs font-black text-gray-600 dark:text-gray-300 focus:ring-2 focus:ring-primary-600 outline-none transition-all appearance-none pr-8">
                        <option value="5" selected>5 @Localizer["PerPage"]</option>
                        <option value="10">10 @Localizer["PerPage"]</option>
                        <option value="20">20 @Localizer["PerPage"]</option>
                        <option value="50">50 @Localizer["PerPage"]</option>
                    </select>
                </div>
            </div>
        }
    </div>
</div>

<!-- Course Details Modal -->
<div id="courseDetailsModal" class="modal-overlay hidden">
    <div class="modal-container glass-card p-0 rounded-2xl shadow-2xl overflow-hidden w-[95vw] max-w-6xl border border-gray-100 dark:border-gray-700">
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-blue-600 text-white flex items-center justify-center shadow-md">
                    <i class="fas fa-info-circle text-lg"></i>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">@Localizer["CourseDetails"]</h3>
                    <p class="text-xs text-gray-500 dark:text-gray-400 font-medium">@Localizer["QuickLookContent"]</p>
                </div>
            </div>
            <button id="closeDetailsModalBtnHeader" class="w-9 h-9 rounded-xl bg-gray-100 dark:bg-gray-700 text-gray-400 hover:text-rose-500 transition-all flex items-center justify-center">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="p-6 max-h-[70vh] overflow-y-auto custom-scrollbar modal-body" dir="rtl">
            <!-- سيتم تعبئته عبر الجافاسكربت -->
        </div>

        <div class="px-6 py-3 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-700 flex justify-end">
            <button id="closeDetailsModalBtn" class="px-5 py-2 rounded-xl bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium text-sm hover:bg-gray-300 dark:hover:bg-gray-600 transition-all">
                <i class="fas fa-times ml-1.5"></i> @Localizer["Close"]
            </button>
        </div>
    </div>
</div>

<!-- Publish Confirmation Modal -->
<div id="publishCourseModal" class="modal-overlay hidden">
    <div class="modal-container glass-card p-8 rounded-[2.5rem] border border-white/20 shadow-2xl text-center">
        <div class="w-24 h-24 rounded-[2rem] mx-auto flex items-center justify-center text-4xl mb-6 bg-emerald-500/10 text-emerald-500">
            <i class="fas fa-upload"></i>
        </div>
        <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2">@Localizer["PublishConfirmationTitle"]</h3>
        <p class="text-gray-500 font-bold mb-8">@Localizer["PublishConfirmationText"]</p>

        <div id="publishErrorList" class="hidden mb-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-2xl p-4 text-right">
            <ul id="publishErrorUl" class="list-disc list-inside text-sm text-red-600 dark:text-red-400 font-medium space-y-1"></ul>
        </div>

        <div class="flex items-center gap-3">
            <button id="cancelPublishBtn" class="flex-1 py-4 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-black text-sm hover:bg-gray-200 dark:hover:bg-white/10 transition-colors">@Localizer["Cancel"]</button>
            <form id="publishCourseForm" method="post" class="flex-[2]">
                @Html.AntiForgeryToken()
                <input type="hidden" id="publishCourseId" name="courseId">
                <button type="submit" class="w-full py-4 rounded-2xl bg-emerald-500 text-white font-black text-sm shadow-xl shadow-emerald-500/20 hover:bg-emerald-600 transition-all">
                    <i class="fas fa-check ml-2"></i> @Localizer["Publish"]
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteCourseModal" class="modal-overlay hidden">
    <div class="modal-container glass-card p-8 rounded-[2.5rem] border border-white/20 shadow-2xl text-center">
        <div class="w-24 h-24 rounded-[2rem] mx-auto flex items-center justify-center text-4xl mb-6 bg-rose-500/10 text-rose-500">
            <i class="fas fa-trash-alt"></i>
        </div>
        <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2">@Localizer["ConfirmDelete"]</h3>
        <p class="text-gray-500 font-bold mb-8">@Localizer["DeleteConfirmationPrefix"] <span id="deleteCourseName" class="text-rose-600"></span>@Localizer["QuestionMark"]<br><span class="text-[10px] text-gray-400 mt-2 block">@Localizer["IrreversibleAction"]</span></p>

        <div class="flex items-center gap-3">
            <button id="cancelDeleteBtn" class="flex-1 py-4 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-black text-sm hover:bg-gray-200 dark:hover:bg-white/10 transition-colors">@Localizer["Cancel"]</button>
            <form id="deleteCourseForm" method="post" class="flex-[2]">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteCourseId" name="id">
                <button type="submit" class="w-full py-4 rounded-2xl bg-rose-500 text-white font-black text-sm shadow-xl shadow-rose-500/20 hover:bg-rose-600 transition-all">
                    <i class="fas fa-check ml-2"></i> @Localizer["ConfirmDeleteButton"]
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Bulk Delete Modal -->
<div id="bulkDeleteModal" class="modal-overlay hidden">
    <div class="modal-container glass-card p-8 rounded-[2.5rem] border border-white/20 shadow-2xl text-center">
        <div class="w-24 h-24 rounded-[2rem] mx-auto flex items-center justify-center text-4xl mb-6 bg-rose-600 text-white shadow-xl shadow-rose-600/30">
            <i class="fas fa-folders"></i>
        </div>
        <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2">@Localizer["BulkDelete"]</h3>
        <p class="text-gray-500 font-bold mb-8">@Localizer["BulkDeleteConfirmationPrefix"] <span id="bulkDeleteCount" class="text-rose-600">0</span> @Localizer["BulkDeleteConfirmationSuffix"]<br><span class="text-[10px] text-gray-400 mt-2 block">@Localizer["IrreversibleActionShort"]</span></p>

        <div class="flex items-center gap-3">
            <button id="cancelBulkDeleteBtn" class="flex-1 py-4 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-black text-sm hover:bg-gray-200 dark:hover:bg-white/10 transition-colors">@Localizer["Cancel"]</button>
            <form id="bulkDeleteForm" method="post" action="/Instructor/Course/BulkDelete" class="flex-[2]">
                @Html.AntiForgeryToken()
                <input type="hidden" id="bulkDeleteIds" name="ids">
                <button type="submit" class="w-full py-4 rounded-2xl bg-rose-500 text-white font-black text-sm shadow-xl shadow-rose-500/20 hover:bg-rose-700 transition-all">
                    <i class="fas fa-check ml-2"></i> @Localizer["ConfirmDeleteButton"]
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            let rowsPerPage = 5;
            let currentPage = 1;
            let filteredRows = Array.from(document.querySelectorAll('tbody tr[data-course-id]'));
            const totalCourses = document.getElementById('total-courses');
            const showingFrom = document.getElementById('showing-from');
            const showingTo = document.getElementById('showing-to');
            const paginationNumbers = document.getElementById('pagination-numbers');
            const prevButton = document.getElementById('prev-page');
            const nextButton = document.getElementById('next-page');
            const searchInput = document.getElementById('searchInput');
            const categoryFilter = document.getElementById('categoryFilter');
            const resetFiltersBtn = document.getElementById('resetFilters');
            const rowsPerPageSelect = document.getElementById('rows-per-page');

            function filterCourses() {
                const searchTerm = searchInput.value.toLowerCase();
                const categoryValue = categoryFilter.value;

                filteredRows = Array.from(document.querySelectorAll('tbody tr[data-course-id]')).filter(row => {
                    const titleElement = row.querySelector('h4');
                    const title = titleElement ? titleElement.textContent.toLowerCase() : '';
                    const category = row.getAttribute('data-category');

                    const matchesSearch = title.includes(searchTerm);
                    const matchesCategory = !categoryValue || category === categoryValue;

                    return matchesSearch && matchesCategory;
                });

                if (totalCourses) totalCourses.textContent = filteredRows.length;
                currentPage = 1;
                updateTable();
                setupPagination();
            }

            function updateTable() {
                const start = (currentPage - 1) * rowsPerPage;
                const end = start + rowsPerPage;

                document.querySelectorAll('tbody tr[data-course-id]').forEach(row => {
                    row.style.display = 'none';
                });

                filteredRows.slice(start, end).forEach(row => {
                    row.style.display = 'table-row';
                });

                if (showingFrom) showingFrom.textContent = filteredRows.length === 0 ? 0 : start + 1;
                if (showingTo) showingTo.textContent = Math.min(end, filteredRows.length);
            }

            function setupPagination() {
                if (!paginationNumbers) return;
                const pageCount = Math.ceil(filteredRows.length / rowsPerPage);
                paginationNumbers.innerHTML = '';

                if (pageCount <= 1) return;

                addPageButton(1);

                const startPage = Math.max(2, currentPage - 1);
                const endPage = Math.min(pageCount - 1, currentPage + 1);

                if (startPage > 2) {
                    paginationNumbers.innerHTML += '<span class="px-3 py-1 text-gray-500">...</span>';
                }

                for (let i = startPage; i <= endPage; i++) {
                    addPageButton(i);
                }

                if (endPage < pageCount - 1) {
                    paginationNumbers.innerHTML += '<span class="px-3 py-1 text-gray-500">...</span>';
                }

                if (pageCount > 1) {
                    addPageButton(pageCount);
                }

                updatePaginationButtons();
            }

            function addPageButton(pageNumber) {
                const pageButton = document.createElement('button');
                pageButton.className = `pagination-btn ${pageNumber === currentPage ? 'active' : ''}`;
                pageButton.textContent = pageNumber;
                pageButton.addEventListener('click', () => {
                    currentPage = pageNumber;
                    updateTable();
                    setupPagination();
                });
                paginationNumbers.appendChild(pageButton);
            }

            function updatePaginationButtons() {
                if (!prevButton || !nextButton) return;
                const pageCount = Math.ceil(filteredRows.length / rowsPerPage);

                prevButton.disabled = currentPage === 1;
                nextButton.disabled = currentPage === pageCount || pageCount === 0;

                if (prevButton.disabled) {
                    prevButton.classList.add('disabled');
                } else {
                    prevButton.classList.remove('disabled');
                }

                if (nextButton.disabled) {
                    nextButton.classList.add('disabled');
                } else {
                    nextButton.classList.remove('disabled');
                }
            }

            searchInput?.addEventListener('input', filterCourses);
            categoryFilter?.addEventListener('change', filterCourses);
            resetFiltersBtn?.addEventListener('click', function() {
                searchInput.value = '';
                categoryFilter.value = '';
                filterCourses();
            });

            rowsPerPageSelect?.addEventListener('change', function() {
                rowsPerPage = parseInt(this.value);
                currentPage = 1;
                updateTable();
                setupPagination();
            });

            prevButton?.addEventListener('click', () => {
                if (currentPage > 1) {
                    currentPage--;
                    updateTable();
                    setupPagination();
                }
            });

            nextButton?.addEventListener('click', () => {
                const pageCount = Math.ceil(filteredRows.length / rowsPerPage);
                if (currentPage < pageCount) {
                    currentPage++;
                    updateTable();
                    setupPagination();
                }
            });

            const bulkActionsContainer = document.getElementById('bulkActionsContainer');
            const selectAllCheckbox = document.getElementById('selectAll');
            const rowCheckboxes = document.querySelectorAll('.row-checkbox');
            const selectedCountSpan = document.getElementById('selectedCount');
            const bulkActionSelect = document.getElementById('bulkAction');
            const applyBulkActionBtn = document.getElementById('applyBulkAction');

            function updateSelectedCount() {
                const selectedCount = document.querySelectorAll('.row-checkbox:checked').length;
                if(selectedCountSpan) selectedCountSpan.textContent = selectedCount;

                if (selectedCount > 0) {
                    bulkActionsContainer?.classList.remove('hidden');
                    if(selectAllCheckbox) selectAllCheckbox.checked = selectedCount === rowCheckboxes.length;
                } else {
                    bulkActionsContainer?.classList.add('hidden');
                    if(selectAllCheckbox) selectAllCheckbox.checked = false;
                }
            }

            selectAllCheckbox?.addEventListener('change', function() {
                const isChecked = this.checked;
                rowCheckboxes.forEach(checkbox => {
                    checkbox.checked = isChecked;
                });
                updateSelectedCount();
            });

            rowCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', updateSelectedCount);
            });

            applyBulkActionBtn?.addEventListener('click', function() {
                const action = bulkActionSelect.value;
                if (!action) {
                    Swal.fire('@Localizer["Alert"]', '@Localizer["PleaseSelectAction"]', 'warning');
                    return;
                }

                const selectedCheckboxes = document.querySelectorAll('.row-checkbox:checked');
                if (selectedCheckboxes.length === 0) {
                    Swal.fire('@Localizer["Alert"]', '@Localizer["NoCoursesSelected"]', 'warning');
                    return;
                }

                const selectedIds = Array.from(selectedCheckboxes).map(checkbox => {
                    const row = checkbox.closest('tr');
                    return parseInt(row.getAttribute('data-course-id'));
                }).filter(id => !isNaN(id));

                if (selectedIds.length === 0) return;

                if (action === 'delete') {
                    showBulkDeleteModal(selectedIds);
                }
            });

            function showBulkDeleteModal(selectedIds) {
                document.getElementById('bulkDeleteCount').textContent = selectedIds.length;
                document.getElementById('bulkDeleteIds').value = selectedIds.join(',');
                document.getElementById('bulkDeleteModal').classList.remove('hidden');
            }

            // View Details Modal functionality
            document.addEventListener('click', function(e) {
                if (e.target.closest('.view-details')) {
                    const courseId = e.target.closest('.view-details').getAttribute('data-course-id');
                    fetchCourseDetails(courseId);
                }
            });

            async function fetchCourseDetails(courseId) {
                try {
                    const modalBody = document.querySelector('#courseDetailsModal .modal-body');
                    modalBody.innerHTML = `
                        <div class="flex justify-center items-center h-64">
                            <div class="animate-spin rounded-full h-12 w-12 border-t-4 border-b-4 border-blue-600"></div>
                        </div>
                    `;

                    document.getElementById('courseDetailsModal').classList.remove('hidden');

                    const response = await fetch(`/Instructor/Course/Details/${courseId}`);
                    const data = await response.json();

                    if (!data.success) {
                        showAlert('error', data.message || '@Localizer["ErrorOccurred"]');
                        document.getElementById('courseDetailsModal').classList.add('hidden');
                        return;
                    }

                    const course = data.course;
                    
                    let modalContent = `
                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                            <div class="col-span-1 space-y-6">
                                <div class="rounded-2xl overflow-hidden bg-gray-100 dark:bg-white/5 h-52 flex items-center justify-center shadow-sm relative group">
                                    ${course.thumbnailUrl 
                                        ? `<img src="${course.thumbnailUrl}" class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-500">`
                                        : `<i class="fas fa-image text-gray-400 text-5xl group-hover:scale-110 transition-transform duration-500"></i>`
                                    }
                                </div>
                                
                                <div class="bg-gray-50 dark:bg-white/5 p-5 rounded-2xl border border-gray-100 dark:border-white/10 shadow-sm">
                                    <h4 class="text-base font-bold text-gray-900 dark:text-white mb-3 flex items-center gap-2">
                                        <i class="fas fa-info-circle text-primary-600"></i> @Localizer["CourseBasics"]
                                    </h4>
                                    <div class="space-y-4">
                                        <div class="pb-3 border-b border-gray-100 dark:border-white/10">
                                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">@Localizer["CourseTitleLabel"]</p>
                                            <p class="text-sm font-black text-gray-900 dark:text-white">${course.title || '-'}</p>
                                        </div>
                                        <div class="pb-3 border-b border-gray-100 dark:border-white/10">
                                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">@Localizer["ShortDescription"]</p>
                                            <p class="text-sm font-medium text-gray-600 dark:text-gray-300">${course.shortDescription || '-'}</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="lg:col-span-3 space-y-6">
                                <div class="bg-gray-50 dark:bg-white/5 p-5 rounded-2xl border border-gray-100 dark:border-white/10 shadow-sm">
                                    <h4 class="text-base font-bold text-gray-900 dark:text-white mb-3 flex items-center gap-2">
                                        <i class="fas fa-info-circle text-primary-600"></i> @Localizer["CourseBasics"]
                                    </h4>
                                    <div class="space-y-4">
                                        <div class="pb-3 border-b border-gray-100 dark:border-white/10">
                                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">@Localizer["Level"]</p>
                                            <p class="text-sm font-black text-gray-900 dark:text-white">${course.level || '-'}</p>
                                        </div>
                                        <div class="pb-3 border-b border-gray-100 dark:border-white/10">
                                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">@Localizer["Language"]</p>
                                            <p class="text-sm font-black text-gray-900 dark:text-white">${course.language === 'ar' ? '@Localizer["Arabic"]' : '@Localizer["English"]'}</p>
                                        </div>
                                        <div class="pb-3 border-b border-gray-100 dark:border-white/10">
                                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">@Localizer["Duration"]</p>
                                            <p class="text-sm font-black text-gray-900 dark:text-white">${formatDuration(course.duration)}</p>
                                        </div>
                                        <div>
                                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">@Localizer["LecturesCount"]</p>
                                            <p class="text-sm font-black text-gray-900 dark:text-white">${course.totalLectures || 0}</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-span-1 space-y-6">
                                <div class="bg-gray-50 dark:bg-white/5 p-6 rounded-3xl border border-gray-100 dark:border-white/10 shadow-sm h-full">
                                    <h4 class="text-lg font-black text-gray-900 dark:text-white mb-4 flex items-center gap-2">
                                        <i class="fas fa-tag text-amber-500"></i> @Localizer["Pricing"]
                                    </h4>
                                    <div class="space-y-4">
                                        <div class="pb-3 border-b border-gray-100 dark:border-white/10">
                                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">@Localizer["OriginalPrice"]</p>
                                            <p class="text-sm font-black text-gray-900 dark:text-white">${course.price ? course.price.toFixed(2) + ' @Localizer["CurrencyEGP"]' : '@Localizer["Free"]'}</p>
                                        </div>
                                        <div class="pb-3 border-b border-gray-100 dark:border-white/10">
                                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">@Localizer["Discount"]</p>
                                            <p class="text-sm font-black text-rose-500">${course.discount > 0 ? course.discount.toFixed(2) + ' @Localizer["CurrencyEGP"]' : '@Localizer["None"]'}</p>
                                        </div>
                                        <div>
                                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">@Localizer["FinalPrice"]</p>
                                            <p class="text-2xl font-black text-emerald-500">${(course.price - (course.discount || 0)).toFixed(2)} <span class="text-sm">@Localizer["CurrencyEGP"]</span></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-6">
                            <div class="bg-gray-50 dark:bg-white/5 p-6 rounded-3xl border border-gray-100 dark:border-white/10 shadow-sm">
                                <h4 class="text-lg font-black text-gray-900 dark:text-white mb-4 flex items-center gap-2">
                                        <i class="fas fa-list-ul text-purple-500"></i> @Localizer["CourseContent"]
                                </h4>
                                <div class="space-y-3">
                    `;

                    if (course.sections && course.sections.length > 0) {
                        course.sections.forEach(section => {
                            modalContent += `
                                <div class="border border-gray-200 dark:border-white/10 rounded-2xl overflow-hidden bg-white dark:bg-gray-800 shadow-sm">
                                    <div class="bg-gray-50 dark:bg-white/5 px-5 py-4 flex items-center justify-between border-b border-gray-200 dark:border-white/10">
                                        <h5 class="font-black text-gray-900 dark:text-white flex items-center gap-2 text-sm">
                                            <i class="fas fa-folder text-primary-500"></i> ${section.title}
                                        </h5>
                                        <span class="text-[10px] font-bold bg-primary-500/10 text-primary-600 px-3 py-1 rounded-full">${section.lectures.length} @Localizer["Lessons"]</span>
                                    </div>
                                    <div class="divide-y divide-gray-100 dark:divide-white/5 bg-white dark:bg-transparent max-h-48 overflow-y-auto custom-scrollbar">
                            `;

                            section.lectures.forEach(lecture => {
                                modalContent += `
                                        <div class="px-5 py-3 flex items-center justify-between hover:bg-gray-50/50 dark:hover:bg-white/5 transition-colors">
                                            <div class="flex items-center gap-3">
                                                <i class="fas ${lecture.contentType === 'video' ? 'fa-play-circle text-blue-500' : 'fa-file-alt text-amber-500'}"></i>
                                                <span class="text-sm font-bold text-gray-700 dark:text-gray-300">${lecture.title}</span>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <span class="text-xs font-bold text-gray-400"><i class="fas fa-clock mr-1"></i>${formatDuration(lecture.duration)}</span>
                                                ${lecture.isFreePreview ? '<span class="text-[10px] bg-emerald-500/10 text-emerald-500 px-2 py-1 rounded-full font-bold">@Localizer["FreePreview"]</span>' : ''}
                                            </div>
                                        </div>
                                `;
                            });

                            modalContent += `
                                    </div>
                                </div>
                            `;
                        });
                    } else {
                        modalContent += '<p class="text-sm font-bold text-gray-500 text-center py-6">@Localizer["NoSectionsYet"]</p>';
                    }

                    modalContent += `
                                </div>
                            </div>
                        </div>
                    `;

                    modalBody.innerHTML = modalContent;

                } catch (error) {
                    showAlert('error', '@Localizer["ErrorFetchingDetails"]');
                    document.getElementById('courseDetailsModal').classList.add('hidden');
                }
            }

            function formatDuration(totalSeconds) {
                if (!totalSeconds || totalSeconds <= 0) return '@Localizer["DurationJSZero"].Value';
                const hours = Math.floor(totalSeconds / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = (totalSeconds % 3600) % 60;
                const parts = [];
                if (hours > 0) parts.push(`${hours}@Localizer["DurationHoursAbbrev"].Value`);
                if (minutes > 0) parts.push(`${minutes}@Localizer["DurationMinutesAbbrev"].Value`);
                if (seconds > 0 || parts.length === 0) parts.push(`${seconds}@Localizer["DurationSecondsAbbrev"].Value`);
                return parts.join('@Localizer["DurationAnd"].Value');
            }

            // Delete Course Modal
            document.addEventListener('click', function(e) {
                if (e.target.closest('.delete-course')) {
                    const btn = e.target.closest('.delete-course');
                    const courseId = btn.getAttribute('data-course-id');
                    const courseName = btn.getAttribute('data-course-name');

                    document.getElementById('deleteCourseId').value = courseId;
                    document.getElementById('deleteCourseName').textContent = courseName;
                    document.getElementById('deleteCourseModal').classList.remove('hidden');
                }
            });

            // Forms submissions
            document.getElementById('deleteCourseForm')?.addEventListener('submit', async function (e) {
                e.preventDefault();
                const courseId = document.getElementById('deleteCourseId').value;
                const confirmBtn = this.querySelector('button[type="submit"]');
                const originalContent = confirmBtn.innerHTML;

                confirmBtn.innerHTML = `<i class="fas fa-circle-notch fa-spin ml-2"></i> @Localizer["Deleting"]`;
                confirmBtn.disabled = true;

                try {
                    const response = await fetch(`/Instructor/Course/Delete/${courseId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    });

                    const data = await response.json();
                    if (data.success) {
                        Swal.fire('@Localizer["Done"]', '@Localizer["CourseDeletedSuccessfully"]', 'success');
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        confirmBtn.innerHTML = originalContent;
                        confirmBtn.disabled = false;
                        Swal.fire('@Localizer["Error"]', '@Localizer["ErrorDeleting"]', 'error');
                    }
                } catch (error) {
                    confirmBtn.innerHTML = originalContent;
                    confirmBtn.disabled = false;
                    Swal.fire('@Localizer["Error"]', '@Localizer["ErrorDeleting"]', 'error');
                }
            });

            document.getElementById('bulkDeleteForm')?.addEventListener('submit', async function(e) {
                e.preventDefault();
                const ids = document.getElementById('bulkDeleteIds').value.split(',').map(id => parseInt(id)).filter(id => !isNaN(id));

                try {
                    const response = await fetch('/Instructor/Course/BulkDelete', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(ids)
                    });

                    const data = await response.json();
                    if (data.success) {
                        Swal.fire('@Localizer["Done"]', data.message || '@Localizer["BulkDeletedSuccessfully"]', 'success');
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        Swal.fire('@Localizer["Error"]', data.message || '@Localizer["ErrorBulkDeleting"]', 'error');
                    }
                } catch (error) {
                    Swal.fire('@Localizer["Error"]', '@Localizer["ErrorBulkDeleting"]', 'error');
                }
            });

            // Modal Closers
            function closeModal(id) {
                document.getElementById(id)?.classList.add('hidden');
            }

            document.querySelectorAll('.modal-overlay').forEach(modal => {
                modal.addEventListener('click', function(e) {
                    if (e.target === this) closeModal(this.id);
                });
            });

            ['closeDetailsModalBtn', 'closeDetailsModalBtnHeader'].forEach(id => {
                document.getElementById(id)?.addEventListener('click', () => closeModal('courseDetailsModal'));
            });

            document.getElementById('cancelDeleteBtn')?.addEventListener('click', () => closeModal('deleteCourseModal'));
            document.getElementById('cancelPublishBtn')?.addEventListener('click', () => closeModal('publishCourseModal'));
            document.getElementById('cancelBulkDeleteBtn')?.addEventListener('click', () => closeModal('bulkDeleteModal'));

            // Publish Course Modal
            document.addEventListener('click', function(e) {
                if (e.target.closest('.publish-course')) {
                    const courseId = e.target.closest('.publish-course').getAttribute('data-course-id');
                    document.getElementById('publishCourseId').value = courseId;
                    document.getElementById('publishCourseModal').classList.remove('hidden');
                }
            });

            document.getElementById('publishCourseForm')?.addEventListener('submit', async function (e) {
                e.preventDefault();
                const courseId = document.getElementById('publishCourseId').value;
                const confirmBtn = this.querySelector('button[type="submit"]');
                const originalContent = confirmBtn.innerHTML;
                const errorContainer = document.getElementById('publishErrorList');
                const errorUl = document.getElementById('publishErrorUl');

                errorContainer.classList.add('hidden');
                errorUl.innerHTML = '';
                confirmBtn.innerHTML = `<i class="fas fa-circle-notch fa-spin ml-2"></i> @Localizer["Publishing"]`;
                confirmBtn.disabled = true;

                try {
                    const response = await fetch('/Instructor/Course/Publish?courseId=' + courseId, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        }
                    });
                    const data = await response.json();
                    if (data.success) {
                        confirmBtn.innerHTML = originalContent;
                        confirmBtn.disabled = false;
                        closeModal('publishCourseModal');
                        showAlert('success', data.message || '@Localizer["CoursePublished"]');
                        setTimeout(function() { location.reload(); }, 2000);
                    } else if (data.errors && data.errors.length > 0) {
                        confirmBtn.innerHTML = originalContent;
                        confirmBtn.disabled = false;
                        data.errors.forEach(function(err) {
                            var li = document.createElement('li');
                            li.textContent = err;
                            errorUl.appendChild(li);
                        });
                        errorContainer.classList.remove('hidden');
                    } else {
                        confirmBtn.innerHTML = originalContent;
                        confirmBtn.disabled = false;
                        var li = document.createElement('li');
                        li.textContent = data.message || '@Localizer["ErrorOccurred"]';
                        errorUl.appendChild(li);
                        errorContainer.classList.remove('hidden');
                    }
                } catch (err) {
                    confirmBtn.innerHTML = originalContent;
                    confirmBtn.disabled = false;
                    var li = document.createElement('li');
                    li.textContent = '@Localizer["ErrorOccurred"]';
                    errorUl.appendChild(li);
                    errorContainer.classList.remove('hidden');
                }
            });

            // Initial Filter
            filterCourses();
        });
    </script>
}