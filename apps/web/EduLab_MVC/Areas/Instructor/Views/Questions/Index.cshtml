@model List<QuestionGroupDTO>
@using System.Globalization
@inject IStringLocalizer<SharedResources> Localizer
@using EduLab_MVC.Resources
@using Microsoft.Extensions.Localization
@using EduLab_MVC.Models.DTOs.Instructor
@{
    ViewData["Title"] = "أسئلة الطلاب";

    var currentCulture = CultureInfo.CurrentUICulture.Name;
    var isArabic = currentCulture.StartsWith("ar");

    var totalQuestions = Model.Sum(g => g.TotalCount);
    var totalUnanswered = Model.Sum(g => g.UnansweredCount);
    var allQuestions = Model.SelectMany(g => g.Questions).ToList();
}

<style>
    .q-card { transition: opacity 0.25s ease, transform 0.25s ease; }
    .q-card.q-hidden { display: none; }
    @@keyframes slideReplies { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
    .q-replies { display: none; }
    .q-replies.open { display: block; animation: slideReplies 0.25s ease; }
    .reply-box { display: none; }
    .reply-box.open { display: block; animation: slideReplies 0.25s ease; }
    .q-unanswered { border-right: 3px solid #f59e0b; }
    .course-chip { transition: all 0.25s ease; cursor: pointer; border: 2px solid transparent; }
    .course-chip:hover { border-color: color-mix(in srgb, var(--primary) 30%, transparent); }
    .course-chip.active { border-color: var(--primary); background: color-mix(in srgb, var(--primary) 8%, transparent); }
</style>

<div class="space-y-8 animate-in fade-in duration-1000">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-2">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">
                <i class="fas fa-question-circle text-amber-500/50 ml-2"></i> أسئلة الطلاب
            </h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 font-medium">تصفح أسئلة طلابك حسب الدورة</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="glass-card rounded-2xl px-4 py-1.5 flex items-center gap-3">
                <i class="fas fa-search text-primary-600 text-sm"></i>
                <input type="text" id="searchInput" placeholder="بحث..."
                       class="bg-transparent border-none outline-none text-sm font-bold text-gray-900 dark:text-white placeholder:text-gray-400 py-2 w-48">
                <button onclick="clearSearch()" id="clearSearchBtn" class="text-gray-400 hover:text-gray-600 hidden text-xs"><i class="fas fa-times"></i></button>
            </div>
            <span id="resultsCount" class="text-xs font-bold text-gray-400 hidden"></span>
        </div>
    </div>

    <!-- Stats -->
    <div class="flex flex-wrap items-center gap-6">
        <div class="flex items-center gap-2">
            <span class="text-2xl font-black text-gray-900 dark:text-white tabular-nums">@totalQuestions</span>
            <span class="text-xs font-bold text-gray-400">إجمالي</span>
        </div>
        <div class="w-px h-6 bg-gray-200 dark:bg-white/10"></div>
        <div class="flex items-center gap-2">
            <span class="text-2xl font-black text-amber-500 tabular-nums">@totalUnanswered</span>
            <span class="text-xs font-bold text-gray-400">بانتظار الرد</span>
        </div>
        <div class="w-px h-6 bg-gray-200 dark:bg-white/10"></div>
        <div class="flex items-center gap-2">
            <span class="text-2xl font-black text-emerald-500 tabular-nums">@Model.Count</span>
            <span class="text-xs font-bold text-gray-400">دورة</span>
        </div>
    </div>

    <!-- Course Chips from model -->
    <div class="flex flex-wrap gap-3" id="courseChips">
        <button class="course-chip active flex items-center gap-2.5 px-4 py-2.5 rounded-2xl bg-gray-50 dark:bg-white/5 text-gray-700 dark:text-gray-300 font-bold text-sm"
                data-course="all" onclick="selectCourse('all')">
            <i class="fas fa-layer-group text-gray-500 text-xs"></i>
            <span>الكل</span>
            <span class="text-[10px] text-gray-400 bg-gray-200/50 dark:bg-white/5 px-1.5 py-0.5 rounded-full">@totalQuestions</span>
        </button>
        @foreach (var g in Model)
        {
            <button class="course-chip flex items-center gap-2.5 px-4 py-2.5 rounded-2xl bg-gray-50 dark:bg-white/5 text-gray-700 dark:text-gray-300 font-bold text-sm"
                    data-course="@g.CourseId" onclick="selectCourse('@g.CourseId')">
                <i class="fas @g.CourseIcon text-@(g.CourseColor)-500 text-xs"></i>
                <span>@g.CourseName</span>
                <span class="text-[10px] @(g.UnansweredCount > 0 ? "text-amber-500" : "text-gray-400") bg-gray-200/50 dark:bg-white/5 px-1.5 py-0.5 rounded-full">@g.TotalCount</span>
            </button>
        }
    </div>

    <!-- Questions from model -->
    <div class="grid grid-cols-1 xl:grid-cols-5 gap-6">
        <div class="xl:col-span-3 space-y-3" id="questionsCol">
            @if (allQuestions.Any())
            {
                foreach (var q in allQuestions)
                {
                    <div class="q-card glass-card rounded-3xl p-5 @(!q.IsAnswered ? "q-unanswered" : "")" data-course="@q.CourseId">
                        <div class="flex gap-3.5">
                            <div class="w-10 h-10 rounded-xl bg-primary-600/10 text-primary-600 flex items-center justify-center text-sm font-black shrink-0 mt-0.5">
                                @q.StudentName.Substring(0, 1)
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between gap-3 mb-1">
                                    <div class="flex items-center gap-2.5">
                                        <h4 class="text-sm font-black text-gray-900 dark:text-white">@q.StudentName</h4>
                                        <span class="text-[10px] font-bold text-gray-400">@q.TimeAgo</span>
                                        <span class="text-[10px] font-bold text-gray-500 bg-gray-100 dark:bg-white/5 px-2 py-0.5 rounded-full">@q.LectureName</span>
                                    </div>
                                    @if (q.IsAnswered)
                                    {
                                        <span class="text-[10px] font-bold text-emerald-600 bg-emerald-500/10 px-2.5 py-1 rounded-full shrink-0 whitespace-nowrap">@q.RepliesCount ردود</span>
                                    }
                                    else
                                    {
                                        <span class="text-[10px] font-bold text-amber-600 bg-amber-500/10 px-2.5 py-1 rounded-full shrink-0 whitespace-nowrap">معلق</span>
                                    }
                                </div>
                                <p class="text-sm font-medium text-gray-600 dark:text-gray-400 leading-relaxed mb-3">@q.Content</p>

                                <!-- Replies -->
                                @if (q.Replies.Any())
                                {
                                    <div class="mr-6 mb-3 space-y-2 border-r-2 border-primary-200 dark:border-primary-800/30 pr-4">
                                        @foreach (var r in q.Replies)
                                        {
                                            <div class="flex gap-2.5 py-2">
                                                <div class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400 text-xs font-black shrink-0">
                                                    @r.StudentName.Substring(0, 1)
                                                </div>
                                                <div class="flex-1">
                                                    <div class="flex items-center gap-2">
                                                        <span class="text-xs font-bold text-gray-900 dark:text-white">@r.StudentName</span>
                                                        @if (r.IsInstructorReply)
                                                        {
                                                            <span class="text-[9px] font-bold text-blue-600 bg-blue-100 dark:bg-blue-900/40 px-1.5 py-0.5 rounded-full">مدرب</span>
                                                        }
                                                        <span class="text-[9px] font-bold text-gray-400">@r.TimeAgo</span>
                                                    </div>
                                                    <p class="text-xs font-medium text-gray-600 dark:text-gray-400 mt-0.5">@r.Content</p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }

                                <div class="flex items-center justify-between">
                                    <div>
                                        @if (q.RepliesCount > 0)
                                        {
                                            <span class="text-xs font-bold text-gray-400 flex items-center gap-1.5">
                                                <i class="fas fa-comment-dots"></i> @q.RepliesCount ردود
                                            </span>
                                        }
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <button onclick="openReply(@q.Id)" class="px-4 py-2 rounded-xl bg-primary-600 text-white font-bold text-xs hover:bg-primary-700 transition-all shadow-lg shadow-primary-600/30">رد</button>
                                    </div>
                                </div>

                                <!-- Reply Box -->
                                <div class="reply-box mt-4" id="replybox-@q.Id">
                                    <div class="pr-4 border-r-2 border-primary-600/30">
                                        <div class="flex gap-3">
                                            <div class="w-9 h-9 rounded-xl bg-primary-600/10 text-primary-600 flex items-center justify-center text-xs font-black shrink-0">أ</div>
                                            <div class="flex-1">
                                                <textarea rows="2" placeholder="اكتب ردك..." class="w-full px-4 py-3 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 outline-none focus:ring-2 focus:ring-primary-600 resize-none text-sm font-medium text-gray-900 dark:text-white placeholder:text-gray-400"></textarea>
                                                <div class="flex justify-end gap-2 mt-2">
                                                    <button onclick="closeReply(@q.Id)" class="px-4 py-2 rounded-xl text-gray-500 font-bold text-xs hover:bg-gray-100 dark:hover:bg-white/5 transition-all">إلغاء</button>
                                                    <button onclick="sendReply(@q.Id)" class="px-4 py-2 rounded-xl bg-primary-600 text-white font-bold text-xs hover:bg-primary-700 transition-all shadow-lg shadow-primary-600/30">إرسال</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="glass-card rounded-3xl p-12 text-center">
                    <div class="w-20 h-20 rounded-full bg-gray-100 dark:bg-white/5 flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-comments text-gray-300 dark:text-gray-600 text-3xl"></i>
                    </div>
                    <h3 class="text-lg font-black text-gray-900 dark:text-white mb-2">لا توجد أسئلة بعد</h3>
                    <p class="text-sm text-gray-400 font-medium">عندما يطرح طلابك أسئلة، ستظهر هنا</p>
                </div>
            }
        </div>

        <!-- Side Panel -->
        <div class="xl:col-span-2 hidden xl:block">
            <div class="glass-card rounded-3xl p-6 sticky" style="top: 7rem;">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-2xl bg-primary-600/10 flex items-center justify-center">
                        <i class="fas fa-chart-simple text-primary-600"></i>
                    </div>
                    <div>
                        <h3 class="text-base font-black text-gray-900 dark:text-white">نظرة سريعة</h3>
                        <p class="text-xs font-bold text-gray-400">إحصائيات الأسئلة</p>
                    </div>
                </div>
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-gray-500">إجمالي الأسئلة</span>
                        <span class="text-sm font-black text-gray-900 dark:text-white">@totalQuestions</span>
                    </div>
                    <div class="h-px bg-gray-100 dark:bg-white/5"></div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-gray-500">بانتظار الرد</span>
                        <span class="text-sm font-black text-amber-500">@totalUnanswered</span>
                    </div>
                    <div class="h-px bg-gray-100 dark:bg-white/5"></div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-gray-500">عدد الدورات</span>
                        <span class="text-sm font-black text-gray-900 dark:text-white">@Model.Count</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var activeCourse = 'all';

    function selectCourse(id) {
        activeCourse = id;
        document.querySelectorAll('.course-chip').forEach(function(c) { c.classList.toggle('active', c.dataset.course === id); });
        document.querySelectorAll('.q-card').forEach(function(q) {
            q.classList.toggle('q-hidden', !(id === 'all' || q.dataset.course === id));
        });
    }

    function doSearch() {
        var q = document.getElementById('searchInput').value.toLowerCase().trim();
        var btn = document.getElementById('clearSearchBtn');
        var count = document.getElementById('resultsCount');
        var visible = 0;
        btn.classList.toggle('hidden', !q);
        document.querySelectorAll('.q-card').forEach(function(c) {
            var match = !q || c.textContent.toLowerCase().includes(q);
            var courseMatch = activeCourse === 'all' || c.dataset.course === activeCourse;
            c.classList.toggle('q-hidden', !(match && courseMatch));
            if (match && courseMatch) visible++;
        });
        count.classList.toggle('hidden', !q);
        if (q) count.textContent = visible + ' نتيجة';
    }

    document.getElementById('searchInput')?.addEventListener('input', doSearch);

    function clearSearch() { document.getElementById('searchInput').value = ''; doSearch(); document.getElementById('searchInput').focus(); }

    function openReply(id) { document.getElementById('replybox-' + id).classList.add('open'); document.getElementById('replybox-' + id).querySelector('textarea').focus(); }
    function closeReply(id) { document.getElementById('replybox-' + id).classList.remove('open'); }
    function sendReply(id) {
        var box = document.getElementById('replybox-' + id);
        var ta = box.querySelector('textarea');
        if (!ta.value.trim()) return;
        var btn = box.querySelector('button:last-child');
        var orig = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

        fetch('/Instructor/Questions/Reply?id=' + id, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content: ta.value.trim() })
        })
        .then(function(r) { return r.json(); })
        .then(function(res) {
            if (res.success) {
                if (typeof showAlert === 'function') showAlert('success', 'تم إرسال الرد');
                setTimeout(function() { location.reload(); }, 800);
            } else {
                btn.innerHTML = orig;
                btn.disabled = false;
                alert(res.message || 'فشل الإرسال');
            }
        })
        .catch(function() {
            btn.innerHTML = orig;
            btn.disabled = false;
            alert('حدث خطأ في الاتصال');
        });
    }
</script>
