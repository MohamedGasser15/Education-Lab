@model List<EduLab_MVC.Models.DTOs.History.HistoryDTO>
@inject IStringLocalizer<SharedResources> Localizer
@using EduLab_MVC.Resources
@using Microsoft.Extensions.Localization
@{
    ViewData["Title"] = Localizer["HistoryTitle"];

    // حساب الإحصائيات مسبقاً لتحسين الأداء
    var todayEvents = Model.Count(h => h.Date == DateOnly.FromDateTime(DateTime.Today));
    var uniqueOperations = Model.Select(h => h.Operation).Distinct().Count();
    var latestEvent = Model.OrderByDescending(h => h.Date).ThenByDescending(h => h.Time).FirstOrDefault();
}

<link rel="stylesheet" href="~/css/Admin/users.css">
<style>
    /* Operation Badges */
    .op-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.8rem;
        border-radius: 10px;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.025em;
    }
    .op-create { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
    .op-update { background: rgba(37, 99, 235, 0.1); color: #2563eb; border: 1px solid rgba(37, 99, 235, 0.2); }
    .op-delete { background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }
    .op-login { background: rgba(124, 58, 237, 0.1); color: #7c3aed; border: 1px solid rgba(124, 58, 237, 0.2); }
    .op-default { background: rgba(100, 116, 139, 0.1); color: #64748b; border: 1px solid rgba(100, 116, 139, 0.2); }
</style>

<div class="space-y-8 animate-in fade-in duration-1000">

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-2">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">@Html.Raw(Localizer["HistoryTitleFormatted"]) <i class="fas fa-history text-primary-600/50 mr-2"></i></h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 font-medium">@Localizer["HistoryDescription"]</p>
        </div>
    </div>

    <!-- Statistics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["TotalEvents"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count</h3>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-primary-600 flex items-center justify-center shadow-lg shadow-primary-600/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-list-ul text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-emerald-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["TodayEvents"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@todayEvents</h3>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-bolt text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-purple-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["ActiveUsers"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Select(h => h.UserName).Distinct().Count()</h3>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-purple-600 flex items-center justify-center shadow-lg shadow-purple-600/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-user-shield text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-rose-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["OperationTypes"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@uniqueOperations</h3>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-rose-500 flex items-center justify-center shadow-lg shadow-rose-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-cogs text-white text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Modern Filter Bar -->
    <div class="glass-card rounded-3xl p-6 mb-8">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 items-end">
            <div class="lg:col-span-2 space-y-2">
                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">@Localizer["SearchLogs"]</label>
                <div class="relative w-full">
                    <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-gray-400">
                        <i class="fas fa-search"></i>
                    </div>
                    <input type="text" id="searchInput"
                           class="w-full pr-11 pl-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white transition-all font-medium"
                           placeholder="@Localizer["SearchPlaceholder"]">
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">@Localizer["FilterByUser"]</label>
                <select id="userFilter" class="w-full px-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white font-bold text-sm transition-all">
                    <option value="">@Localizer["AllUsers"]</option>
                    @foreach (var user in Model.Select(h => h.UserName).Distinct())
                    {
                        <option value="@user">@user</option>
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">@Localizer["TimeRange"]</label>
                <select id="dateRangeFilter" class="w-full px-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white font-bold text-sm transition-all">
                    <option value="all">@Localizer["AllDates"]</option>
                    <option value="today">@Localizer["Today"]</option>
                    <option value="yesterday">@Localizer["Yesterday"]</option>
                    <option value="week">@Localizer["Last7Days"]</option>
                    <option value="month">@Localizer["Last30Days"]</option>
                    <option value="custom">@Localizer["CustomRange"]</option>
                </select>
            </div>
        </div>

        <!-- Custom Date Range (Hidden) -->
        <div id="customDateRangeContainer" class="hidden mt-6 animate-in slide-in-from-top-2 duration-300">
            <div class="flex flex-col md:flex-row items-center gap-4 p-4 rounded-2xl bg-primary-600/5 border border-primary-600/10">
                <div class="flex-1 w-full space-y-1">
                    <label class="text-[10px] font-bold text-primary-600 uppercase mr-1">@Localizer["FromDate"]</label>
                    <input type="date" id="fromDate" class="w-full px-4 py-2 rounded-xl border-none bg-white dark:bg-gray-800 text-sm font-bold shadow-sm">
                </div>
                <div class="flex-1 w-full space-y-1">
                    <label class="text-[10px] font-bold text-primary-600 uppercase mr-1">@Localizer["ToDate"]</label>
                    <input type="date" id="toDate" class="w-full px-4 py-2 rounded-xl border-none bg-white dark:bg-gray-800 text-sm font-bold shadow-sm">
                </div>
                <button id="applyCustomDate" class="mt-5 md:mt-0 px-6 py-2 bg-primary-600 text-white rounded-xl text-xs font-black shadow-lg shadow-primary-600/20">@Localizer["ApplyBtn"]</button>
            </div>
        </div>
    </div>

    <!-- Premium History Table Area -->
    <div class="glass-card rounded-3xl shadow-2xl overflow-hidden">
        <div>
            <table id="historyTable" class="admin-table w-full border-collapse">
                <thead>
                    <tr class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest bg-gray-50/50 dark:bg-white/5">
                        <th class="px-8 py-5 w-20">ID</th>
                        <th class="px-8 py-5">@Localizer["AdminRole"]</th>
                        <th class="px-8 py-5">@Localizer["PerformedOperation"]</th>
                        <th class="px-8 py-5">@Localizer["DateTimeCol"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var log in Model.OrderByDescending(h => h.Date).ThenByDescending(h => h.Time))
                        {
                            <tr class="history-row hover:bg-gray-50/50 dark:hover:bg-white/5 transition-colors group border-b border-gray-100 dark:border-white/5"
                                data-user="@log.UserName"
                                data-date="@log.Date.ToString("yyyy-MM-dd")"
                                data-operation="@log.Operation">

                                <td class="px-8 py-5">
                                    <span class="text-xs font-black text-gray-400">#@log.Id</span>
                                </td>

                                <td class="px-8 py-5">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-xl bg-primary-600/10 text-primary-600 flex items-center justify-center overflow-hidden shadow-sm">
                                            @if (!string.IsNullOrEmpty(log.ProfileImageUrl))
                                            {
                                                <img src="@log.ProfileImageUrl" class="w-full h-full object-cover">
                                            }
                                            else
                                            {
                                                <i class="fas fa-user-shield text-sm"></i>
                                            }
                                        </div>
                                        <div>
                                            <h4 class="text-sm font-black text-gray-900 dark:text-white group-hover:text-primary-600 transition-colors">@log.UserName</h4>
                                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">@Localizer["AdminUserLabel"]</p>
                                        </div>
                                    </div>
                                </td>

                                <td class="px-8 py-5">
                                    @{
                                        var op = log.Operation.ToLower();
                                        var opClass = op.Contains("create") || op.Contains("إضافة") ? "op-create" :
                                                     op.Contains("update") || op.Contains("تعديل") ? "op-update" :
                                                     op.Contains("delete") || op.Contains("حذف") ? "op-delete" :
                                                     op.Contains("login") || op.Contains("دخول") ? "op-login" : "op-default";
                                        var icon = op.Contains("create") || op.Contains("إضافة") ? "fa-plus-circle" :
                                                   op.Contains("update") || op.Contains("تعديل") ? "fa-edit" :
                                                   op.Contains("delete") || op.Contains("حذف") ? "fa-trash-alt" :
                                                   op.Contains("login") || op.Contains("دخول") ? "fa-sign-in-alt" : "fa-info-circle";
                                    }
                                    <span class="op-badge @opClass">
                                        <i class="fas @icon text-[10px]"></i>
                                        @log.Operation
                                    </span>
                                </td>

                                <td class="px-8 py-5">
                                    <div class="flex flex-col">
                                        <span class="text-xs font-black text-gray-700 dark:text-gray-300">@log.Date.ToString("yyyy-MM-dd")</span>
                                        <span class="text-[10px] text-gray-400 font-bold italic tracking-tighter">
                                            <i class="far fa-clock ml-1"></i> @log.Time.ToString("HH:mm:ss")
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-8 py-16 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="w-24 h-24 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center mb-4 text-gray-300 dark:text-gray-600">
                                        <i class="fas fa-history text-4xl"></i>
                                    </div>
                                    <h3 class="text-lg font-black text-gray-900 dark:text-white mb-2">@Localizer["NoEventsTitle"]</h3>
                                    <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">@Localizer["NoEventsDescription"]</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Premium Pagination -->
        <div class="px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-6 bg-gray-50/50 dark:bg-white/5 border-t border-gray-100 dark:border-white/5">
            <div class="text-sm font-bold text-gray-500 dark:text-gray-400 order-2 md:order-1">
                @Localizer["Showing"] <span id="showingFrom" class="text-primary-600">1</span> @Localizer["To"] <span id="showingTo" class="text-primary-600">10</span> @Localizer["OutOf"] <span id="totalRecords" class="text-gray-900 dark:text-white">@Model.Count</span> @Localizer["EventUnit"]
            </div>

            <div class="flex items-center gap-4 order-1 md:order-2">
                <div class="pagination-controls flex items-center gap-2">
                    <button id="prevPage" class="pagination-btn disabled" title="@Localizer["Previous"]">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </button>
                    <div id="pageNumbers" class="flex gap-2"></div>
                    <button id="nextPage" class="pagination-btn" title="@Localizer["Next"]">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </button>
                </div>

                <div class="h-8 w-px bg-gray-200 dark:bg-white/10 hidden sm:block"></div>

                <select id="pageSize" class="px-3 py-2 bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl text-xs font-black text-gray-600 dark:text-gray-300 focus:ring-2 focus:ring-primary-600 outline-none transition-all">
                    <option value="10">10 @Localizer["PerPage"]</option>
                    <option value="20">20 @Localizer["PerPage"]</option>
                    <option value="50">50 @Localizer["PerPage"]</option>
                    <option value="100">100 @Localizer["PerPage"]</option>
                </select>
            </div>
        </div>
    </div>
</div>

    <script>
        $(document).ready(function() {
            // Initialize variables
            let currentPage = 1;
            let pageSize = 10;
            let totalPages = Math.ceil(@Model.Count / pageSize);

            // Initialize page size dropdown
            $('#pageSize').val(pageSize);

            // Update pagination controls
            function updatePagination() {
                const rows = $('.history-row:visible');
                totalPages = Math.ceil(rows.length / pageSize);

                // Update showing records info
                const from = ((currentPage - 1) * pageSize) + 1;
                const to = Math.min(currentPage * pageSize, rows.length);
                $('#showingFrom').text(from);
                $('#showingTo').text(to);
                $('#totalRecords').text(rows.length);

                // Update page numbers
                $('#pageNumbers').empty();
                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);

                for (let i = startPage; i <= endPage; i++) {
                    $('#pageNumbers').append(
                        `<button class="pagination-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`
                    );
                }

                // Update prev/next buttons
                $('#prevPage').toggleClass('disabled', currentPage === 1);
                $('#nextPage').toggleClass('disabled', currentPage === totalPages);

                // Show/hide rows based on current page
                rows.hide();
                rows.slice((currentPage - 1) * pageSize, currentPage * pageSize).show();
            }

            // Page size change handler
            $('#pageSize').change(function() {
                pageSize = parseInt($(this).val());
                currentPage = 1;
                updatePagination();
            });

            // Page navigation handlers
            $(document).on('click', '.pagination-btn:not(.active)', function() {
                if ($(this).attr('id') === 'prevPage') {
                    if (currentPage > 1) currentPage--;
                } else if ($(this).attr('id') === 'nextPage') {
                    if (currentPage < totalPages) currentPage++;
                } else {
                    currentPage = parseInt($(this).data('page'));
                }
                updatePagination();
            });

            // Search functionality
            $('#searchInput').on('keyup', function() {
                const searchText = $(this).val().toLowerCase();
                $('.history-row').each(function() {
                    const rowText = $(this).text().toLowerCase();
                    $(this).toggle(rowText.includes(searchText));
                });
                currentPage = 1;
                updatePagination();
            });

            // User filter
            $('#userFilter').change(function() {
                const selectedUser = $(this).val();
                if (selectedUser === "") {
                    $('.history-row').show();
                } else {
                    $('.history-row').each(function() {
                        $(this).toggle($(this).data('user') === selectedUser);
                    });
                }
                currentPage = 1;
                updatePagination();
            });

            // Date range filter
            $('#dateRangeFilter').change(function() {
                const range = $(this).val();
                const today = new Date();
                today.setHours(0, 0, 0, 0);

                $('#customDateRangeContainer').toggle(range === 'custom');

                if (range === 'all') {
                    $('.history-row').show();
                } else {
                    $('.history-row').each(function() {
                        const rowDate = new Date($(this).data('date'));
                        let showRow = false;

                        switch(range) {
                            case 'today':
                                showRow = rowDate.getTime() === today.getTime();
                                break;
                            case 'yesterday':
                                const yesterday = new Date(today);
                                yesterday.setDate(yesterday.getDate() - 1);
                                showRow = rowDate.getTime() === yesterday.getTime();
                                break;
                            case 'week':
                                const weekAgo = new Date(today);
                                weekAgo.setDate(weekAgo.getDate() - 7);
                                showRow = rowDate >= weekAgo && rowDate <= today;
                                break;
                            case 'month':
                                const monthAgo = new Date(today);
                                monthAgo.setDate(monthAgo.getDate() - 30);
                                showRow = rowDate >= monthAgo && rowDate <= today;
                                break;
                            case 'custom':
                                const fromDate = new Date($('#fromDate').val());
                                const toDate = new Date($('#toDate').val());
                                if ($('#fromDate').val() && $('#toDate').val()) {
                                    showRow = rowDate >= fromDate && rowDate <= toDate;
                                } else {
                                    showRow = true;
                                }
                                break;
                        }

                        $(this).toggle(showRow);
                    });
                }

                currentPage = 1;
                updatePagination();
            });

            // Custom date range change handlers
            $('#applyCustomDate').click(function() {
                if ($('#dateRangeFilter').val() === 'custom') {
                    $('#dateRangeFilter').trigger('change');
                }
            });

            $('#fromDate, #toDate').change(function() {
                if ($('#dateRangeFilter').val() === 'custom') {
                    // Wait for both dates
                }
            });

            // Initialize pagination
            updatePagination();
        });
    </script>
