@using System.Globalization
@functions {
    public string IsActive(string controller, params string[] actions)
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        bool isActive = currentController != null && currentAction != null && 
                       currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) &&
                       actions.Any(a => a.Equals(currentAction, StringComparison.OrdinalIgnoreCase));

        return isActive ? "sidebar-link active" : "sidebar-link";
    }

    public string IsActiveDropdownItem(string controller, string action)
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        bool isActive = currentController != null && currentAction != null &&
                       currentController.Equals(controller, StringComparison.OrdinalIgnoreCase) &&
                       currentAction.Equals(action, StringComparison.OrdinalIgnoreCase);

        return isActive 
            ? "flex items-center p-2.5 rounded-xl text-primary-600 dark:text-primary-300 font-bold bg-[#eef2ff] dark:bg-primary-600/15 shadow-sm transition-all duration-200"
            : "flex items-center p-2.5 rounded-xl text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 font-medium transition-all duration-200";
    }
}
@using EduLab_MVC.Services.ServiceInterfaces
@inject IUserService _userService
@inject IConfiguration Configuration
@{
    var user = await _userService.GetCurrentUserAsync();
    var fullName = user?.FullName;
    var role = user?.Role;
    var profileImage = user?.ProfileImageUrl;
    var baseUrl = Configuration["ApiBaseUrl"];
    if (!string.IsNullOrEmpty(profileImage) && !profileImage.StartsWith("http"))
    {
        profileImage = baseUrl.TrimEnd('/') + "/" + profileImage.TrimStart('/');
    }

    var currentCulture = CultureInfo.CurrentUICulture.Name;
    var isArabic = currentCulture.StartsWith("ar");

    var languages = new List<(string Name, string Code)>
    {
        ("English", "en"),
        ("العربية", "ar"),
        ("中文", "zh"),
        ("Nederlands", "nl"),
        ("Français", "fr"),
        ("Deutsch", "de"),
        ("हिन्दी", "hi"),
        ("Bahasa Indonesia", "id"),
        ("Italiano", "it"),
        ("日本語", "ja"),
        ("한국어", "ko"),
        ("Bahasa Melayu", "ms"),
        ("Português (Brasil)", "pt"),
        ("Русский", "ru"),
        ("Español", "es"),
        ("Tiếng Việt", "vi"),
        ("Türkçe", "tr"),
        ("Українська", "uk"),
        ("اردو", "ur"),
        ("Polski", "pl")
    };
}
<!DOCTYPE html>
<html lang="@currentCulture" dir="@(isArabic ? "rtl" : "ltr")" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>@ViewData["Title"] - EduLab Instructor</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ['Tajawal', 'sans-serif'] },
                    colors: {
                        primary: { 50: '#eff6ff', 100: '#dbeafe', 200: '#bfdbfe', 300: '#93c5fd', 400: '#60a5fa', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8', 800: '#1e40af', 900: '#1e3a8a' }
                    },
                    borderRadius: { '2xl': '1rem', '3xl': '1.5rem' }
                }
            }
        }
    </script>

    <!-- Font Awesome & Tooltips -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/tippy.js@6/dist/tippy.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="~/css/Admin/site.css">
    <link rel="icon" type="image/x-icon" href="~/Img/Logo/favicon.ico">
    <link rel="icon" type="image/png" sizes="16x16" href="~/Img/Logo/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="~/Img/Logo/favicon-32x32.png">
    <link rel="apple-touch-icon" sizes="180x180" href="~/Img/Logo/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="~/Img/Logo/android-chrome-192x192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="~/Img/Logo/android-chrome-512x512.png">
    <link rel="manifest" href="~/manifest.json">
    
    <style>
        body { 
            overflow-x: hidden;
            background-image: radial-gradient(circle at top right, rgba(37, 99, 235, 0.05), transparent 400px),
                              radial-gradient(circle at bottom left, rgba(37, 99, 235, 0.05), transparent 400px);
        }

        .navbar-floating {
            top: 1.25rem;
            width: auto;
            border-radius: 1.25rem;
            margin: 0 auto;
        }
        [dir="ltr"] .navbar-floating { left: calc(20rem + 1.25rem); right: 1.25rem; }
        [dir="rtl"] .navbar-floating { right: calc(20rem + 1.25rem); left: 1.25rem; }

        .glass-nav {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.25);
        }
        .dark .glass-nav {
            background: rgba(15, 23, 42, 0.75);
            border: 1px solid rgba(255, 255, 255, 0.04);
        }
        .glass-nav::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 2rem;
            right: 2rem;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(37, 99, 235, 0.15), transparent);
        }
        .dark .glass-nav::after {
            background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.1), transparent);
        }

        @@media (max-width: 1024px) {
            [dir="ltr"] .navbar-floating { left: 1.25rem; right: 1.25rem; }
            [dir="rtl"] .navbar-floating { right: 1.25rem; left: 1.25rem; }
        }

        .search-input:focus { box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1), 0 0 20px rgba(37, 99, 235, 0.05); }
        .search-results {
            max-height: 0;
            opacity: 0;
            overflow: hidden;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            pointer-events: none;
        }
        .search-results.show {
            max-height: 480px;
            opacity: 1;
            pointer-events: auto;
        }
        .search-highlight { background: rgba(37, 99, 235, 0.08); }

        .glass-sidebar {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        .dark .glass-sidebar {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.97) 0%, rgba(15, 23, 42, 0.95) 100%);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.04);
            box-shadow: 4px 0 24px rgba(0, 0, 0, 0.3);
        }

        #sidebar {
            top: 0;
            height: 100vh;
            width: 20rem;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        [dir="rtl"] #sidebar { right: 0; border-left: 1px solid rgba(0,0,0,0.05); }
        [dir="ltr"] #sidebar { left: 0; border-right: 1px solid rgba(0,0,0,0.05); }

        .dark [dir="rtl"] #sidebar { border-left-color: rgba(255,255,255,0.04); }
        .dark [dir="ltr"] #sidebar { border-right-color: rgba(255,255,255,0.04); }

        #main-content {
            padding-top: 6.5rem;
            min-height: 100vh;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        [dir="rtl"] #main-content { margin-right: 20rem; }
        [dir="ltr"] #main-content { margin-left: 20rem; }

        @@media (max-width: 1024px) {
            #sidebar { width: 22rem; max-width: 85vw; }
            [dir="rtl"] #sidebar { transform: translateX(100%); z-index: 100; }
            [dir="ltr"] #sidebar { transform: translateX(-100%); z-index: 100; }
            #sidebar.show { transform: translateX(0); }
            [dir="rtl"] #main-content { margin-right: 0; }
            [dir="ltr"] #main-content { margin-left: 0; }
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            margin: 0.25rem 0.75rem;
            border-radius: 0.75rem;
            color: #64748b;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-weight: 500;
        }

        .dark .sidebar-link { color: #94a3b8; }

        .sidebar-link:hover {
            background: rgba(37, 99, 235, 0.08);
            color: #2563eb;
        }
        .dark .sidebar-link:hover {
            background: rgba(59, 130, 246, 0.1);
            color: #60a5fa;
        }
        [dir="rtl"] .sidebar-link:hover { transform: translateX(-4px); }
        [dir="ltr"] .sidebar-link:hover { transform: translateX(4px); }

        .sidebar-link.active {
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            color: white !important;
            box-shadow: 0 8px 25px -5px rgba(37, 99, 235, 0.35), 0 2px 5px -2px rgba(37, 99, 235, 0.2);
        }
        .dark .sidebar-link.active {
            background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
            box-shadow: 0 8px 25px -5px rgba(37, 99, 235, 0.15);
        }

        .sidebar-link.active .sidebar-icon { color: white !important; }

        .sidebar-icon {
            font-size: 1rem;
            width: 1.25rem;
            text-align: center;
            transition: transform 0.3s ease;
            margin-left: 0.75rem;
        }
        [dir="ltr"] .sidebar-icon { margin-left: 0; margin-right: 0.75rem; }

        .sidebar-link:hover .sidebar-icon {
            transform: scale(1.1);
        }

        .loading-screen {
            position: fixed;
            inset: 0;
            background: white;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s ease;
        }

        .dark .loading-screen { background: #0f172a; }

        /* Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { 
            background: rgba(37, 99, 235, 0.1); 
            border-radius: 10px; 
        }
        .dark .custom-scrollbar::-webkit-scrollbar-thumb { 
            background: rgba(59, 130, 246, 0.15); 
        }
        .dark .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(59, 130, 246, 0.25);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
        }
        .dark .glass-card {
            background: rgba(30, 41, 59, 0.5);
            border-color: rgba(255, 255, 255, 0.05);
        }

        /* Tables */
        [dir="ltr"] .admin-table { text-align: left; }
        [dir="rtl"] .admin-table { text-align: right; }
        .admin-table { table-layout: auto; }
        .admin-table thead th {
            padding: 1rem 1rem;
            font-size: 0.625rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #9ca3af;
            background: rgba(249, 250, 251, 0.5);
            white-space: nowrap;
            vertical-align: middle;
        }
        .dark .admin-table thead th {
            color: #6b7280;
            background: rgba(255, 255, 255, 0.03);
        }
        .admin-table tbody td {
            padding: 1rem 1rem;
            vertical-align: middle;
        }
        .admin-table tbody tr {
            border-bottom: 1px solid rgba(0,0,0,0.05);
            transition: all 0.2s ease;
        }
        .admin-table tbody tr:hover {
            background: rgba(249, 250, 251, 0.5);
        }
        .dark .admin-table tbody tr {
            border-bottom-color: rgba(255,255,255,0.03);
        }
        .dark .admin-table tbody tr:hover {
            background: rgba(255,255,255,0.03);
        }

        .alert-container {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10000;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        [dir="rtl"] .alert-container {
            left: auto;
            right: 50%;
            transform: translateX(50%);
        }
        .alert {
            position: relative;
            width: 320px;
            padding: 16px 20px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
            display: flex;
            align-items: center;
            opacity: 0;
            transform: translateY(-20px);
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.27, 1.55);
            overflow: hidden;
            font-size: 0.95rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .alert.show {
            opacity: 1;
            transform: translateY(0);
        }
        .alert.hide {
            opacity: 0;
            transform: translateY(-20px);
        }
        .alert-success { background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white; }
        .alert-error { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white; }
        .alert-info { background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; }
        .alert-warning { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; }
        .alert-icon { margin-inline-end: 12px; font-size: 1.2rem; flex-shrink: 0; }
        .alert-content { flex-grow: 1; line-height: 1.5; padding-inline-end: 8px; font-weight: 500; }
        .alert-close {
            background: none; border: none; cursor: pointer; color: rgba(255,255,255,0.8);
            transition: all 0.2s; flex-shrink: 0; font-size: 1rem; padding: 4px;
            border-radius: 50%; width: 28px; height: 28px; display: flex;
            align-items: center; justify-content: center;
        }
        .alert-close:hover { color: white; background: rgba(255,255,255,0.2); }
        .alert-progress {
            position: absolute; bottom: 0; inset-inline-start: 0; height: 3px;
            background-color: rgba(255,255,255,0.3); width: 100%;
            border-radius: 0 0 12px 12px; overflow: hidden;
        }
        .alert-progress-bar {
            height: 100%; width: 100%; transition: width linear;
            background: rgba(255,255,255,0.7); border-radius: 0 0 12px 12px;
        }
        .dark .alert { box-shadow: 0 10px 25px rgba(0,0,0,0.5); border-color: rgba(255,255,255,0.15); }
        .dark .alert-success { background: linear-gradient(135deg, #059669 0%, #047857 100%); }
        .dark .alert-error { background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%); }
        .dark .alert-info { background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); }
        .dark .alert-warning { background: linear-gradient(135deg, #d97706 0%, #b45309 100%); }
        @@media (max-width: 640px) {
            .alert-container { width: calc(100% - 40px); left: 50%; transform: translateX(-50%); top: 15px; }
            [dir="rtl"] .alert-container { left: auto; right: 50%; transform: translateX(50%); }
            .alert { width: 100%; max-width: 100%; }
        }

        /* Language Modal */
        .lang-modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 200;
            background: rgba(0, 0, 0, 0.5);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }
        .lang-modal-overlay.active { display: flex; }

        .lang-modal-box {
            background: white;
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            width: 100%;
            max-width: 560px;
            overflow: hidden;
            animation: langFadeIn 0.2s ease-out;
        }
        .dark .lang-modal-box { background: #1f2937; }

        @@keyframes langFadeIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }

        .lang-modal-title {
            padding: 20px 20px 16px;
            text-align: center;
            font-size: 18px;
            font-weight: 700;
            color: #111827;
            border-bottom: 1px solid #f3f4f6;
        }
        .dark .lang-modal-title { color: white; border-bottom-color: #374151; }

        .lang-modal-grid {
            padding: 12px;
            max-height: 380px;
            overflow-y: auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }

        .lang-opt {
            display: block;
            padding: 10px 4px;
            text-align: center;
            border-radius: 10px;
            color: #374151;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.15s;
            text-decoration: none;
            cursor: pointer;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .dark .lang-opt { color: #e5e7eb; }
        .lang-opt:hover { background: #f3f4f6; }
        .dark .lang-opt:hover { background: #374151; }
        .lang-opt.active { background: #eff6ff; color: #2563eb; font-weight: 700; }
        .dark .lang-opt.active { background: #1e3a5f; color: #60a5fa; }

        @@media (max-width: 640px) {
            .lang-modal-grid { grid-template-columns: repeat(2, 1fr); }
            .lang-opt { font-size: 12px; padding: 8px 2px; }
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-[#0f172a] text-gray-900 dark:text-gray-100 font-sans">
    
    <!-- Loading Screen -->
    <div class="loading-screen" id="loadingScreen">
        <div class="relative w-24 h-24">
            <div class="absolute inset-0 border-4 border-primary-600/20 rounded-full"></div>
            <div class="absolute inset-0 border-4 border-primary-600 border-t-transparent rounded-full animate-spin"></div>
            <div class="absolute inset-0 flex items-center justify-center">
                <i class="fas fa-graduation-cap text-primary-600 text-3xl"></i>
            </div>
        </div>
        <div class="mt-4 font-bold text-primary-600 tracking-widest animate-pulse">EDULAB INSTRUCTOR</div>
        <div class="hyper-loader mt-4 w-48 opacity-50"></div>
    </div>

    <!-- Mobile Overlay -->
    <div id="mobile-overlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden" onclick="toggleSidebar()"></div>

    <!-- Navbar -->
    <header class="navbar-floating fixed z-40 glass-nav shadow-sm">
        <div class="px-5 h-16 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-primary-600 flex items-center justify-center shadow-lg shadow-primary-600/30">
                        <i class="fas fa-graduation-cap text-white text-xl"></i>
                    </div>
                    <span class="text-xl font-extrabold bg-gradient-to-@(isArabic ? "l" : "r") from-primary-600 to-primary-400 bg-clip-text text-transparent">EduLab Instructor</span>
                </div>
            </div>

            <div class="flex items-center gap-2">
                <!-- Search / Navigator -->
                <div class="relative hidden sm:block" id="searchContainer">
                    <div class="relative">
                        <input type="text" id="globalSearch" autocomplete="off"
                               placeholder="@Localizer["SearchPlaceholder"]"
                               class="search-input w-80 h-10 @(isArabic ? "pr-10 pl-10" : "pl-10 pr-10") rounded-2xl border border-gray-200/60 dark:border-white/5 bg-gray-100/60 dark:bg-gray-800/40 focus:border-primary-600/30 focus:bg-white dark:focus:bg-gray-800/60 transition-all text-sm outline-none placeholder:text-gray-400">
                        <i class="fas fa-search absolute @(isArabic ? "right-3.5" : "left-3.5") top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <span class="search-shortcut absolute @(isArabic ? "left-3.5" : "right-3.5") top-1/2 -translate-y-1/2 text-[10px] font-bold text-gray-400/80 bg-gray-200/80 dark:bg-gray-700/80 px-1.5 py-0.5 rounded-md">/</span>
                    </div>

                    <!-- Search Results -->
                    <div class="search-results absolute top-full left-0 right-0 mt-2 z-50" id="searchResults">
                        <div class="bg-white/95 dark:bg-gray-900/95 backdrop-blur-xl border border-white/20 dark:border-white/5 rounded-2xl shadow-2xl overflow-hidden">
                            <div class="px-4 py-2.5 border-b border-gray-100 dark:border-white/5">
                                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest" id="searchResultTitle">@Localizer["QuickNavigation"]</span>
                            </div>
                            <div class="max-h-72 overflow-y-auto" id="searchResultsList"></div>
                            <div class="px-4 py-3 flex items-center justify-between border-t border-gray-100 dark:border-white/5">
                                <div class="flex items-center gap-3 text-[10px] text-gray-400">
                                    <span><kbd class="bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono text-[9px] font-bold">↑↓</kbd> @Localizer["Navigate"]</span>
                                    <span><kbd class="bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono text-[9px] font-bold">↵</kbd> @Localizer["Open"]</span>
                                </div>
                                <span class="text-[10px] text-gray-400"><kbd class="bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono text-[9px] font-bold">Esc</kbd> @Localizer["Close"]</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Language Switch -->
                <button type="button" id="langBtnInstructor"
                   class="cursor-pointer w-10 h-10 flex items-center justify-center rounded-xl border border-gray-200/50 dark:border-white/5 bg-gray-100/50 dark:bg-gray-800/50 hover:bg-primary-600 hover:border-primary-600 hover:text-white dark:hover:bg-primary-600 transition-all duration-300 text-gray-600 dark:text-gray-400">
                    <i class="fas fa-globe text-sm"></i>
                </button>

                <!-- Theme Toggle -->
                <button id="theme-toggle" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-all duration-300">
                    <i id="theme-toggle-dark-icon" class="fas fa-moon hidden text-gray-600"></i>
                    <i id="theme-toggle-light-icon" class="fas fa-sun hidden text-yellow-500"></i>
                </button>

                <!-- Notifications -->
                <div x-data="{ open: false }" class="relative">
                    <button @@click="open = !open" @@click.outside="open = false"
