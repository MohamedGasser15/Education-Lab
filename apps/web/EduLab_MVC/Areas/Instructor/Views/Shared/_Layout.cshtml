    <!-- Toaster / Alert Container -->
    <div id="alert-container" class="alert-container"></div>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Admin/site.js"></script>

    <script>
        // Sidebar Toggle
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobile-overlay');
            sidebar.classList.toggle('show');
            overlay.classList.toggle('hidden');
            if(sidebar.classList.contains('show')) {
                document.body.style.overflow = 'hidden';
            } else {
                document.body.style.overflow = '';
            }
        }

        // Loading Logic
        window.addEventListener('load', () => {
            const loader = document.getElementById('loadingScreen');
            loader.style.opacity = '0';
            setTimeout(() => loader.style.display = 'none', 500);
        });

        // Theme Toggle
        const themeToggleBtn = document.getElementById('theme-toggle');
        const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
        const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');

        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
            themeToggleLightIcon.classList.remove('hidden');
        } else {
            document.documentElement.classList.remove('dark');
            themeToggleDarkIcon.classList.remove('hidden');
        }

        themeToggleBtn.addEventListener('click', function() {
            themeToggleDarkIcon.classList.toggle('hidden');
            themeToggleLightIcon.classList.toggle('hidden');

            if (localStorage.getItem('color-theme')) {
                if (localStorage.getItem('color-theme') === 'light') {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('color-theme', 'dark');
                } else {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('color-theme', 'light');
                }
            } else {
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('color-theme', 'light');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('color-theme', 'dark');
                }
            }
        });

        // Toaster / Alert System
        document.addEventListener('DOMContentLoaded', function() {
            @if (TempData["Success"] != null)
            {
                <text>showAlert('success', '@Html.Raw(TempData["Success"])');</text>
            }
            @if (TempData["Error"] != null)
            {
                <text>showAlert('error', '@Html.Raw(TempData["Error"])');</text>
            }
            @if (TempData["Warning"] != null)
            {
                <text>showAlert('warning', '@Html.Raw(TempData["Warning"])');</text>
            }
            @if (TempData["Info"] != null)
            {
                <text>showAlert('info', '@Html.Raw(TempData["Info"])');</text>
            }
        });

        function showAlert(type, message, duration = 5000) {
            const alertContainer = document.getElementById('alert-container');
            if (!alertContainer) return;

            alertContainer.innerHTML = "";

            const alertElement = document.createElement('div');
            alertElement.className = `alert alert-${type}`;
            alertElement.setAttribute('role', 'alert');

            let icon = '';
            switch(type) {
                case 'success': icon = 'fa-check-circle'; break;
                case 'error': icon = 'fa-exclamation-circle'; break;
                case 'info': icon = 'fa-info-circle'; break;
                case 'warning': icon = 'fa-exclamation-triangle'; break;
                default: icon = 'fa-info-circle';
            }

            alertElement.innerHTML = `
                <i class="fas ${icon} alert-icon"></i>
                <div class="alert-content">${message}</div>
                <button class="alert-close" onclick="closeAlert(this.parentElement)">
                    <i class="fas fa-times"></i>
                </button>
                <div class="alert-progress">
                    <div class="alert-progress-bar"></div>
                </div>
            `;

            alertContainer.appendChild(alertElement);

            setTimeout(() => {
                alertElement.classList.add('show');
                const progressBar = alertElement.querySelector('.alert-progress-bar');
                if (progressBar) {
                    progressBar.style.width = '100%';
                    setTimeout(() => {
                        progressBar.style.transition = `width ${duration}ms linear`;
                        progressBar.style.width = '0%';
                    }, 50);
                }
            }, 10);

            const autoHide = setTimeout(() => {
                closeAlert(alertElement);
            }, duration);

            alertElement.addEventListener('mouseenter', () => {
                clearTimeout(autoHide);
                const progressBar = alertElement.querySelector('.alert-progress-bar');
                if (progressBar) {
                    progressBar.style.transition = 'none';
                    const currentWidth = parseFloat(getComputedStyle(progressBar).width);
                    progressBar.dataset.currentWidth = currentWidth;
                }
            });

            alertElement.addEventListener('mouseleave', () => {
                const progressBar = alertElement.querySelector('.alert-progress-bar');
                if (progressBar) {
                    const currentWidth = parseFloat(progressBar.dataset.currentWidth || '100');
                    const remainingTime = (currentWidth / 100) * duration;
                    progressBar.style.transition = `width ${remainingTime}ms linear`;
                    progressBar.style.width = '0%';
                    setTimeout(() => {
                        closeAlert(alertElement);
                    }, remainingTime);
                }
            });
        }

        function closeAlert(alertElement) {
            if (!alertElement) return;
            alertElement.classList.remove('show');
            alertElement.classList.add('hide');
            setTimeout(() => {
                if (alertElement.parentNode) {
                    alertElement.parentNode.removeChild(alertElement);
                }
            }, 400);
        }

        function showSuccess(message, duration) { showAlert('success', message, duration); }
        function showError(message, duration) { showAlert('error', message, duration); }
        function showInfo(message, duration) { showAlert('info', message, duration); }
        function showWarning(message, duration) { showAlert('warning', message, duration); }

        window.showAlert = showAlert;
        window.showSuccess = showSuccess;
        window.showError = showError;
        window.showInfo = showInfo;
        window.showWarning = showWarning;
        window.closeAlert = closeAlert;

        // Client-side Pagination System
        window.initPagination = function(containerId, itemClass, pageSize = 8) {
            const container = document.getElementById(containerId);
            const items = Array.from(container.querySelectorAll(itemClass));
            const totalPages = Math.ceil(items.length / pageSize);
            
            if (totalPages <= 1) return;

            let currentPage = 1;
            const paginationId = `pagination-${containerId}`;
            let paginationWrapper = document.getElementById(paginationId);
            
            if (!paginationWrapper) {
                paginationWrapper = document.createElement('div');
                paginationWrapper.id = paginationId;
                paginationWrapper.className = 'flex items-center justify-center gap-2 mt-12 pb-8';
                container.parentNode.insertBefore(paginationWrapper, container.nextSibling);
            }

            function showPage(page) {
                currentPage = page;
                const start = (page - 1) * pageSize;
                const end = start + pageSize;

                items.forEach((item, index) => {
                    item.style.display = (index >= start && index < end) ? '' : 'none';
                });

                renderControls();
                window.scrollTo({ top: container.offsetTop - 100, behavior: 'smooth' });
            }

            function renderControls() {
                paginationWrapper.innerHTML = '';
                
                // Prev
                const prevBtn = createPageBtn('<i class="fas fa-chevron-right"></i>', currentPage > 1, () => showPage(currentPage - 1));
                paginationWrapper.appendChild(prevBtn);

                // Pages
                for (let i = 1; i <= totalPages; i++) {
                    if (totalPages > 7 && i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1) {
                        if (i === 3 || i === totalPages - 2) {
                            const dots = document.createElement('span');
                            dots.textContent = '...';
                            dots.className = 'px-2 text-gray-400';
                            paginationWrapper.appendChild(dots);
                        }
                        continue;
                    }
                    const pageBtn = createPageBtn(i, true, () => showPage(i), i === currentPage);
                    paginationWrapper.appendChild(pageBtn);
                }

                // Next
                const nextBtn = createPageBtn('<i class="fas fa-chevron-left"></i>', currentPage < totalPages, () => showPage(currentPage + 1));
                paginationWrapper.appendChild(nextBtn);
            }

            function createPageBtn(content, enabled, onClick, active = false) {
                const btn = document.createElement('button');
                btn.innerHTML = content;
                btn.disabled = !enabled;
                btn.className = `w-10 h-10 rounded-xl font-bold transition-all flex items-center justify-center ${active ? 'bg-primary-600 text-white shadow-lg shadow-primary-600/20' : 'bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700'} ${!enabled ? 'opacity-30 cursor-not-allowed' : ''}`;
                if (enabled) btn.onclick = onClick;
                return btn;
            }

            showPage(1);
        };

        // ===== Global Search / Navigator =====
        var L = {
            dashboard: '@Localizer["Dashboard"]',
            courses: '@Localizer["AllCourses"]',
            addCourse: '@Localizer["AddNewCourse"]',
            editCourse: '@Localizer["EditCourse"]',
            students: '@Localizer["MyStudents"]',
            reviews: '@Localizer["Reviews"]',
            questions: '@Localizer["StudentQuestions"]',
            revenue: '@Localizer["MyEarnings"]',
            history: '@Localizer["OperationsLog"]',
            reports: '@Localizer["Reports"]',
            settings: '@Localizer["Settings"]'
        };
        var T = { quickNav: '@Localizer["QuickNavigation"]', results: '@Localizer["SearchResults"]', noResults: '@Localizer["NoResultsFound"]' };

        var searchData = [
            // Dashboard
            { key: 'dashboard', path: '/Instructor/Dashboard', icon: 'fa-th-large', kw: 'home main statistics dashboard لوحة التحكم' },
            // Courses
            { key: 'courses', path: '/Instructor/Course/Index', icon: 'fa-book-open', kw: 'courses classes lessons list index manage all دورات' },
            { key: 'addCourse', path: '/Instructor/Course/Create', icon: 'fa-plus-circle', kw: 'add course create new upload إضافة دورة' },
            { key: 'editCourse', path: '/Instructor/Course/Edit', icon: 'fa-edit', kw: 'edit course update modify change تعديل' },
            // Students
            { key: 'students', path: '/Instructor/Students', icon: 'fa-users', kw: 'students people list طلابي' },
            // Reviews
            { key: 'reviews', path: '/Instructor/Reviews', icon: 'fa-star', kw: 'reviews ratings تقييمات' },
            // Questions
            { key: 'questions', path: '/Instructor/Questions', icon: 'fa-question-circle', kw: 'questions qna students أسئلة' },
            // Revenue
            { key: 'revenue', path: '/Instructor/Revenue', icon: 'fa-dollar-sign', kw: 'revenue earnings money إيراداتي' },
            // History
            { key: 'history', path: '/Instructor/History/Index', icon: 'fa-stream', kw: 'history logs activity سجلات' },
            // Reports
            { key: 'reports', path: '/Instructor/Reports', icon: 'fa-chart-pie', kw: 'reports analytics تقارير' },
            // Settings
            { key: 'settings', path: '/Instructor/Settings', icon: 'fa-sliders-h', kw: 'settings config preferences إعدادات' }
        ];

        var searchMock = [
            { label: '@Localizer["MockStudentName"]', sub: '@Localizer["MockStudentSub"]', icon: 'fa-user' },
            { label: '@Localizer["MockCourseWeb"]', sub: '@Localizer["MockCourseWebSub"]', icon: 'fa-book-open' },
            { label: '@Localizer["MockCourseUI"]', sub: '@Localizer["MockCourseUISub"]', icon: 'fa-book-open' },
            { label: '@Localizer["MockCoursePython"]', sub: '@Localizer["MockCoursePythonSub"]', icon: 'fa-book-open' },
            { label: '@Localizer["MockCourseDataScience"]', sub: '@Localizer["MockCourseDataScienceSub"]', icon: 'fa-book-open' }
        ];

        var searchInput = document.getElementById('globalSearch');
        var searchResults = document.getElementById('searchResults');
        var resultsList = document.getElementById('searchResultsList');
        var resultTitle = document.getElementById('searchResultTitle');

        if (searchInput && searchResults) {
            function renderSearch(term) {
                var t = (term || '').toLowerCase().trim();
                resultsList.innerHTML = '';

                var pages = searchData.filter(function(d) {
                    return L[d.key].toLowerCase().includes(t) || d.kw.includes(t) || d.path.toLowerCase().includes(t);
                });
                var items = t ? searchMock.filter(function(d) {
                    return d.label.toLowerCase().includes(t) || d.sub.toLowerCase().includes(t);
                }) : [];

                if (!t) {
                    pages.forEach(function(d) { resultsList.appendChild(pageEl(d)); });
                    resultTitle.textContent = T.quickNav; return;
                }

                var count = 0;
                pages.forEach(function(d) { resultsList.appendChild(pageEl(d)); count++; });
                items.forEach(function(d) { resultsList.appendChild(mockEl(d)); count++; });

                resultTitle.textContent = count + ' ' + T.results;
                if (!count) resultsList.innerHTML = '<div class="px-4 py-8 text-center text-xs text-gray-400 font-bold">' + T.noResults + '</div>';
            }

            function pageEl(d) {
                var a = document.createElement('a'); a.href = d.path;
                a.className = 'flex items-center gap-3 px-4 py-3 hover:bg-gray-50 dark:hover:bg-white/5 transition-colors border-b border-gray-50 dark:border-white/5';
                a.innerHTML = '<div class="w-8 h-8 rounded-xl bg-primary-600/10 text-primary-600 flex items-center justify-center text-xs"><i class="fas ' + d.icon + '"></i></div><div class="min-w-0 flex-1"><p class="text-xs font-bold text-gray-700 dark:text-gray-200">' + L[d.key] + '</p><p class="text-[10px] text-gray-400">' + d.path + '</p></div>';
                return a;
            }

            function mockEl(d) {
                var div = document.createElement('div');
                div.className = 'flex items-center gap-3 px-4 py-3 border-b border-gray-50 dark:border-white/5 cursor-default hover:bg-gray-50 dark:hover:bg-white/5 transition-colors';
                div.innerHTML = '<div class="w-8 h-8 rounded-xl bg-primary-600/10 text-primary-600 flex items-center justify-center text-xs"><i class="fas ' + d.icon + '"></i></div><div class="min-w-0 flex-1"><p class="text-xs font-bold text-gray-700 dark:text-gray-200">' + d.label + '</p><p class="text-[10px] text-gray-400">' + d.sub + '</p></div>';
                return div;
            }

            searchInput.addEventListener('focus', function() { renderSearch(this.value); searchResults.classList.add('show'); var sh = this.parentElement.querySelector('.search-shortcut'); if (sh) sh.style.display = 'none'; });
            searchInput.addEventListener('blur', function() { var self = this; setTimeout(function() { searchResults.classList.remove('show'); var sh = self.parentElement.querySelector('.search-shortcut'); if (sh) sh.style.display = ''; }, 200); });
            searchInput.addEventListener('input', function() { renderSearch(this.value); if (!searchResults.classList.contains('show')) searchResults.classList.add('show'); });

            document.addEventListener('keydown', function(e) {
                if (e.key === '/' && !['INPUT', 'TEXTAREA', 'SELECT'].includes(e.target.tagName)) { e.preventDefault(); searchInput?.focus(); }
                if (e.key === 'Escape' && document.activeElement === searchInput) { searchInput.blur(); searchResults.classList.remove('show'); }
            });

            // Keyboard navigation inside results
            document.addEventListener('keydown', function(e) {
                if (!searchResults.classList.contains('show')) return;
                const items = resultsList.querySelectorAll('a, div.group');
                if (!items.length) return;

                const active = document.activeElement;
                if (active === searchInput && e.key === 'ArrowDown') {
                    e.preventDefault();
                    items[0]?.focus();
                    items[0]?.classList.add('search-highlight');
                    return;
                }
                const idx = Array.from(items).indexOf(active);
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    const next = Math.min(idx + 1, items.length - 1);
                    items[next]?.focus();
                    items[next]?.classList.add('search-highlight');
                    if (idx >= 0) items[idx]?.classList.remove('search-highlight');
                }
                if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    if (idx <= 0) { searchInput?.focus(); if (idx >= 0) items[idx]?.classList.remove('search-highlight'); return; }
                    const prev = idx - 1;
                    items[prev]?.focus();
                    items[prev]?.classList.add('search-highlight');
                    if (idx >= 0) items[idx]?.classList.remove('search-highlight');
                }
            });
        }

        // Initialize Tooltips
        document.querySelectorAll('[title]').forEach(el => {
            if (!el.hasAttribute('data-tooltip')) {
                const titleText = el.getAttribute('title');
                el.setAttribute('data-tooltip', titleText);
                el.removeAttribute('title');
            }
        });

        // Global Form Loading State
        $(document).on('submit', 'form', function() {
            const form = $(this);
            const submitBtn = form.find('button[type="submit"]');
            
            if (submitBtn.length > 0) {
                if (submitBtn.prop('disabled')) return;

                if (typeof form.valid === 'function' && !form.valid()) {
                    return;
                }

                submitBtn.prop('disabled', true);
                submitBtn.addClass('cursor-wait opacity-80');
                
                const originalHtml = submitBtn.html();
                submitBtn.data('original-html', originalHtml);
                
                if (submitBtn.find('i').length > 0 && submitBtn.text().trim() === '') {
                    submitBtn.html('<i class="fas fa-spinner fa-spin"></i>');
                } else {
                    submitBtn.html('<i class="fas fa-spinner fa-spin @(isArabic ? "ml-2" : "mr-2")"></i> @Localizer["Processing"]');
                }
            }
        });
    </script>

    <script>
        (function() {
            'use strict';
            var btn = document.getElementById('langBtnInstructor');
            var modal = document.getElementById('langModalInstructor');
            if (!btn || !modal) return;

            function openLang() {
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            function closeLang() {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', openLang);

            modal.addEventListener('click', function(e) {
                if (e.target === modal) closeLang();
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && modal.classList.contains('active')) closeLang();
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
