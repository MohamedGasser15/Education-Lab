            <div class="lang-modal-grid">
                @foreach (var lang in languages)
                {
                    var isActive = currentCulture.StartsWith(lang.Code);
                    <a href="@Url.Action("SetLanguage", "Home", new { area = "Learner", culture = lang.Code, returnUrl = Context.Request.Path + Context.Request.QueryString })"
                       class="lang-opt @(isActive ? "active" : "")">@lang.Name</a>
