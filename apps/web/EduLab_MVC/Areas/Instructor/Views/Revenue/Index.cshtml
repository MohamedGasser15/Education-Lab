@using System.Globalization
@inject IStringLocalizer<SharedResources> Localizer
@using EduLab_MVC.Resources
@using Microsoft.Extensions.Localization
@{
    ViewData["Title"] = Localizer["MyRevenue"];

    var currentCulture = CultureInfo.CurrentUICulture.Name;
    var isArabic = currentCulture.StartsWith("ar");

    var months = new[] { Localizer["January"].Value, Localizer["February"].Value, Localizer["March"].Value, Localizer["April"].Value, Localizer["May"].Value, Localizer["June"].Value, Localizer["July"].Value, Localizer["August"].Value, Localizer["September"].Value, Localizer["October"].Value, Localizer["November"].Value, Localizer["December"].Value };
}

<style>
    .stat-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .stat-card:hover {
        transform: translateY(-2px);
    }

    .earning-row {
        transition: all 0.3s;
    }
    .earning-row:hover {
        background: color-mix(in srgb, var(--primary) 5%, transparent);
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .chart-area {
        animation: slideUp 0.6s ease;
    }
</style>

<div class="space-y-8 animate-in fade-in duration-1000">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-2">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">
                <i class="fas fa-dollar-sign text-emerald-500/50 ml-2"></i> @Localizer["MyRevenue"]
            </h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 font-medium">@Localizer["TrackEarningsSalesStats"]</p>
        </div>
        <div class="flex items-center gap-3">
            <select id="periodSelect" class="px-4 py-3 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 focus:ring-2 focus:ring-primary-600 outline-none dark:text-white font-bold text-sm transition-all">
                <option value="week">@Localizer["Last7Days"]</option>
                <option value="month" selected>@Localizer["ThisMonth"]</option>
                <option value="year">@Localizer["ThisYear"]</option>
                <option value="all">@Localizer["AllTime"]</option>
            </select>
            <button class="flex items-center gap-2 px-5 py-3 rounded-2xl bg-primary-600 text-white font-bold text-sm shadow-lg shadow-primary-600/30 hover:bg-primary-700 hover:scale-105 transition-all">
                <i class="fas fa-download"></i>
                <span>@Localizer["Export"]</span>
            </button>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden stat-card group">
            <div class="absolute -right-4 -top-4 w-20 h-20 bg-emerald-500/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["Revenue"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">$12,845</h3>
                    <p class="text-xs font-bold text-emerald-500 mt-1.5">
                        <i class="fas fa-arrow-up ml-0.5"></i> +12.5% @Localizer["VsLastMonth"]
                    </p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-wallet text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden stat-card group">
            <div class="absolute -right-4 -top-4 w-20 h-20 bg-blue-500/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["Sales"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">247</h3>
                    <p class="text-xs font-bold text-emerald-500 mt-1.5">
                        <i class="fas fa-arrow-up ml-0.5"></i> +8.3% @Localizer["VsLastMonth"]
                    </p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-blue-500 flex items-center justify-center shadow-lg shadow-blue-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-shopping-cart text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden stat-card group">
            <div class="absolute -right-4 -top-4 w-20 h-20 bg-purple-500/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["AvgCoursePrice"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">$52</h3>
                    <p class="text-xs font-bold text-gray-400 mt-1.5">
                        <i class="fas fa-minus ml-0.5"></i> @Localizer["Stable"]
                    </p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-purple-500 flex items-center justify-center shadow-lg shadow-purple-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-tag text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden stat-card group">
            <div class="absolute -right-4 -top-4 w-20 h-20 bg-amber-500/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["NewStudents"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">89</h3>
                    <p class="text-xs font-bold text-emerald-500 mt-1.5">
                        <i class="fas fa-arrow-up ml-0.5"></i> +5.2% @Localizer["VsLastMonth"]
                    </p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-amber-500 flex items-center justify-center shadow-lg shadow-amber-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-user-graduate text-white text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart + Top Courses -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Chart -->
        <div class="lg:col-span-2 glass-card rounded-3xl p-6 chart-area">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h3 class="text-lg font-black text-gray-900 dark:text-white">@Localizer["MonthlyRevenue"]</h3>
                    <p class="text-xs font-bold text-gray-400">@Localizer["Last12Months"]</p>
                </div>
                <div class="flex items-center gap-4 text-xs font-bold">
                    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-emerald-500"></span> @Localizer["Revenue"]</span>
                    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-primary-600/30"></span> @Localizer["Sales"]</span>
                </div>
            </div>

            <!-- Bar Chart -->
            <div class="flex items-end justify-between gap-2 h-48" id="chartBars">
                @for (int i = 0; i < 12; i++)
                {
                    var heights = new[] { 40, 55, 45, 70, 60, 80, 65, 90, 75, 85, 95, 100 };
                    var h1 = heights[i];
                    var h2 = Math.Max(20, h1 - new Random().Next(10, 30));
                    <div class="flex-1 flex flex-col items-center gap-1 group">
                        <div class="w-full flex justify-center gap-0.5">
                            <div class="w-3 sm:w-5 rounded-t-lg bg-emerald-500 transition-all duration-500 hover:bg-emerald-400 relative"
                                 style="height:@(h1 * 1.5)px"
                                 title="$@((h1 * 12).ToString("N0"))">
                                <div class="absolute -top-6 left-1/2 -translate-x-1/2 text-[9px] font-bold text-emerald-600 dark:text-emerald-400 opacity-0 group-hover:opacity-100 whitespace-nowrap transition-opacity">
                                    $@((h1 * 12).ToString("N0"))
                                </div>
                            </div>
                            <div class="w-3 sm:w-5 rounded-t-lg bg-primary-600/25 dark:bg-primary-600/20 transition-all duration-500"
                                 style="height:@(h2 * 1.5)px"
                                 title="@(h2 * 3)">
                            </div>
                        </div>
                        <span class="text-[9px] font-bold text-gray-400 mt-2">@months[i].Substring(0, 3)</span>
                    </div>
                }
            </div>
        </div>

        <!-- Top Courses -->
        <div class="glass-card rounded-3xl p-6">
            <h3 class="text-lg font-black text-gray-900 dark:text-white mb-6">@Localizer["TopCourses"]</h3>
            <div class="space-y-5">
                @{
                    var topCourses = new[]
                    {
                        new { name = Localizer["ComprehensiveWebDev"].Value, color = "emerald", students = 128, revenue = "$6,420", bar = 100 },
                        new { name = Localizer["UIUXDesignCourse"].Value, color = "blue", students = 94, revenue = "$3,760", bar = 72 },
                        new { name = Localizer["AdvancedDigitalMarketing"].Value, color = "purple", students = 67, revenue = "$2,345", bar = 55 },
                        new { name = Localizer["MobileAppDev"].Value, color = "amber", students = 41, revenue = "$1,640", bar = 38 },
                        new { name = Localizer["DataAnalysis"].Value, color = "rose", students = 28, revenue = "$1,120", bar = 25 },
                    };
                }
                @foreach (var course in topCourses)
                {
                    <div>
                        <div class="flex items-center justify-between mb-1.5">
                            <h4 class="text-sm font-bold text-gray-900 dark:text-white truncate ml-4">@course.name</h4>
                            <span class="text-xs font-black text-gray-400 tabular-nums shrink-0">@course.revenue</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="flex-1 h-2.5 rounded-full bg-gray-100 dark:bg-white/5 overflow-hidden">
                                <div class="h-full rounded-full bg-@(course.color)-500 transition-all duration-700"
                                     style="width:@course.bar%"></div>
                            </div>
                            <span class="text-[10px] font-bold text-gray-400 tabular-nums shrink-0">@course.students @Localizer["Students"]</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="glass-card rounded-3xl overflow-hidden">
        <div class="px-8 py-6 border-b border-gray-100 dark:border-white/5 flex items-center justify-between">
            <div>
                <h3 class="text-lg font-black text-gray-900 dark:text-white">@Localizer["RecentTransactions"]</h3>
                <p class="text-xs font-bold text-gray-400">@Localizer["Last10Sales"]</p>
            </div>
            <button class="px-4 py-2 rounded-xl bg-primary-600/10 text-primary-600 font-bold text-xs hover:bg-primary-600 hover:text-white transition-all">
                @Localizer["ViewAll"]
            </button>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="text-[10px] font-black text-gray-400 uppercase tracking-widest bg-gray-50/50 dark:bg-white/5">
                        <th class="px-8 py-5 text-right">@Localizer["Students"]</th>
                        <th class="px-8 py-5 text-right">@Localizer["Courses"]</th>
                        <th class="px-8 py-5 text-right">@Localizer["Amount"]</th>
                        <th class="px-8 py-5 text-right">@Localizer["Date"]</th>
                        <th class="px-8 py-5 text-right">@Localizer["Status"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                    @{
                        var transactions = new[]
                        {
                            new { student = "Ahmed Mahmoud", course = Localizer["ComprehensiveWebDev"].Value, amount = "$52", date = "3 hours ago", status = Localizer["Completed"].Value, color = "emerald" },
                            new { student = "Sara Khaled", course = Localizer["UIUXDesignCourse"].Value, amount = "$48", date = "5 hours ago", status = Localizer["Completed"].Value, color = "emerald" },
                            new { student = "Mohamed Ali", course = Localizer["AdvancedDigitalMarketing"].Value, amount = "$45", date = "Yesterday", status = Localizer["Completed"].Value, color = "emerald" },
                            new { student = "Nora Ahmed", course = Localizer["MobileAppDev"].Value, amount = "$55", date = "Yesterday", status = Localizer["PendingReview"].Value, color = "amber" },
                            new { student = "Khaled Omar", course = Localizer["ComprehensiveWebDev"].Value, amount = "$52", date = "2 days ago", status = Localizer["Completed"].Value, color = "emerald" },
                            new { student = "Maryem Hassan", course = Localizer["DataAnalysis"].Value, amount = "$40", date = "2 days ago", status = Localizer["Completed"].Value, color = "emerald" },
                            new { student = "Youssef Ibrahim", course = Localizer["UIUXDesignCourse"].Value, amount = "$48", date = "3 days ago", status = Localizer["Rejected"].Value, color = "red" },
                            new { student = "Hoda Saeed", course = Localizer["AdvancedDigitalMarketing"].Value, amount = "$45", date = "3 days ago", status = Localizer["Completed"].Value, color = "emerald" },
                        };
                    }
                    @foreach (var t in transactions)
                    {
                        <tr class="earning-row transition-colors">
                            <td class="px-8 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl bg-gray-100 dark:bg-white/5 flex items-center justify-center text-xs font-black text-gray-400">
                                        @t.student.Substring(0, 1)
                                    </div>
                                    <span class="text-sm font-bold text-gray-900 dark:text-white">@t.student</span>
                                </div>
                            </td>
                            <td class="px-8 py-4 text-sm font-bold text-gray-600 dark:text-gray-400">@t.course</td>
                            <td class="px-8 py-4 text-sm font-black text-gray-900 dark:text-white tabular-nums">@t.amount</td>
                            <td class="px-8 py-4 text-xs font-bold text-gray-400">@t.date</td>
                            <td class="px-8 py-4">
                                <span class="px-3 py-1 rounded-full text-[10px] font-black bg-@(t.color)-500/10 text-@(t.color)-500">@t.status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Payout Summary -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="glass-card rounded-3xl p-6">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-2xl bg-emerald-500/10 flex items-center justify-center">
                    <i class="fas fa-credit-card text-emerald-500"></i>
                </div>
                <div>
                    <h3 class="text-base font-black text-gray-900 dark:text-white">@Localizer["Due"]</h3>
                    <p class="text-xs font-bold text-gray-400">@Localizer["EarningsToBeTransferred"]</p>
                </div>
            </div>
            <div class="text-center py-6">
                <div class="text-5xl font-black text-gray-900 dark:text-white tabular-nums">$3,245</div>
                <p class="text-sm font-bold text-gray-400 mt-2">@Localizer["WillBeTransferredOnDate"]</p>
            </div>
            <div class="grid grid-cols-2 gap-4 mt-2">
                <div class="p-4 rounded-2xl bg-gray-50/50 dark:bg-white/5 text-center">
                    <p class="text-xl font-black text-gray-900 dark:text-white tabular-nums">$1,280</p>
                    <p class="text-[10px] font-bold text-gray-400">@Localizer["Pending"]</p>
                </div>
                <div class="p-4 rounded-2xl bg-gray-50/50 dark:bg-white/5 text-center">
                    <p class="text-xl font-black text-gray-900 dark:text-white tabular-nums">15</p>
                    <p class="text-[10px] font-bold text-gray-400">@Localizer["ClearanceDays"]</p>
                </div>
            </div>
        </div>

        <div class="glass-card rounded-3xl p-6">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-2xl bg-blue-500/10 flex items-center justify-center">
                    <i class="fas fa-history text-blue-500"></i>
                </div>
                <div>
                    <h3 class="text-base font-black text-gray-900 dark:text-white">@Localizer["LastPayments"]</h3>
                    <p class="text-xs font-bold text-gray-400">@Localizer["PreviousTransfersLog"]</p>
                </div>
            </div>
            <div class="space-y-4">
                <div class="flex items-center justify-between py-3 border-b border-gray-100 dark:border-white/5">
                    <div>
                        <p class="text-sm font-bold text-gray-900 dark:text-white">@Localizer["BankTransfer"]</p>
                        <p class="text-[10px] font-bold text-gray-400">5 يوليو 2026</p>
                    </div>
                    <span class="text-sm font-black text-gray-900 dark:text-white tabular-nums">$2,890</span>
                </div>
                <div class="flex items-center justify-between py-3 border-b border-gray-100 dark:border-white/5">
                    <div>
                        <p class="text-sm font-bold text-gray-900 dark:text-white">@Localizer["BankTransfer"]</p>
                        <p class="text-[10px] font-bold text-gray-400">5 يونيو 2026</p>
                    </div>
                    <span class="text-sm font-black text-gray-900 dark:text-white tabular-nums">$2,450</span>
                </div>
                <div class="flex items-center justify-between py-3">
                    <div>
                        <p class="text-sm font-bold text-gray-900 dark:text-white">@Localizer["BankTransfer"]</p>
                        <p class="text-[10px] font-bold text-gray-400">5 مايو 2026</p>
                    </div>
                    <span class="text-sm font-black text-gray-900 dark:text-white tabular-nums">$3,120</span>
                </div>
            </div>
        </div>
    </div>

</div>
