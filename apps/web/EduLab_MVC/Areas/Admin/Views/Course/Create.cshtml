@{
    ViewData["Title"] = @Localizer["CreateCourseTitle"].Value;
}

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 page-enter" dir="rtl">
    <!-- Top bar -->
    <div class="sticky top-0 z-40 bg-white/80 dark:bg-gray-800/80 backdrop-blur-lg border-b border-gray-200 dark:border-gray-700 animate-fade-in-down">
        <div class="max-w-7xl mx-auto px-4 md:px-6 py-3 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-600 to-blue-400 flex items-center justify-center shadow-lg shadow-blue-500/20">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-lg font-bold text-gray-800 dark:text-white">@Localizer["CreateNewCourse"]</h1>
                    <p class="text-xs text-gray-500 dark:text-gray-400">@Localizer["FillBasicCourseInfo"]</p>
                </div>
            </div>
            <button type="button" id="createCourseBtn" onclick="document.getElementById('createCourseForm').requestSubmit()"
                    class="ripple-btn px-6 py-2.5 bg-gradient-to-r from-blue-600 to-blue-500 text-white font-semibold rounded-xl hover:from-blue-700 hover:to-blue-600 transition-all shadow-lg shadow-blue-500/25 text-sm btn-pulse whitespace-nowrap">
                <i class="fas fa-plus ml-1.5"></i>
                @Localizer["CreateCourse"]
            </button>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 md:px-6 py-6">
        <form id="createCourseForm" class="grid grid-cols-1 lg:grid-cols-3 gap-6" enctype="multipart/form-data">
            <!-- Main column -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Title card -->
                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-5 stagger-1">
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
                            <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <h2 class="text-base font-bold text-gray-800 dark:text-white">@Localizer["BasicInfo"]</h2>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">@Localizer["CourseTitle"] <span class="text-red-500">*</span></label>
                            <input type="text" id="title" name="title" required
                                   class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                                   placeholder="@Localizer["CourseTitlePlaceholder"]">
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">@Localizer["ShortDescription"] <span class="text-red-500">*</span></label>
                                <textarea id="shortDescription" name="shortDescription" rows="3" required
                                          class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none"
                                          placeholder="@Localizer["ShortDescriptionPlaceholder"]"></textarea>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">@Localizer["Description"] <span class="text-red-500">*</span></label>
                                <textarea id="description" name="description" rows="3" required
                                          class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none"
                                          placeholder="@Localizer["DescriptionPlaceholder"]"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pricing & Category card -->
                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-5 stagger-2">
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-8 h-8 rounded-lg bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center">
                            <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <h2 class="text-base font-bold text-gray-800 dark:text-white">@Localizer["PricingAndCategory"]</h2>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">@Localizer["Price"] <span class="text-red-500">*</span></label>
                            <input type="number" id="price" name="price" step="0.01" min="0" max="999999" value="0" required
                                   class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                                   placeholder="@Localizer["PricePlaceholder"]"
                                   oninput="validatePrice()">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">@Localizer["Category"] <span class="text-red-500">*</span></label>
                            <select id="categoryId" name="categoryId" required
                                    class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all">
                                <option value="">@Localizer["SelectCategory"]</option>
                                @foreach (var cat in ViewBag.Categories)
                                {
                                    <option value="@cat.Value">@cat.Text</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mt-4 p-4 bg-gray-50 dark:bg-gray-700 rounded-xl border border-gray-200 dark:border-gray-600">
                        <label class="flex items-center cursor-pointer">
                            <input type="checkbox" id="hasDiscount" class="hidden">
                            <div class="relative w-12 h-6 bg-gray-300 dark:bg-gray-600 rounded-full transition-colors duration-300 flex-shrink-0" id="discountToggle">
                                <div class="absolute top-1 left-1 w-4 h-4 bg-white rounded-full transition-transform duration-300 shadow-sm" id="discountKnob"></div>
                            </div>
                            <span class="mr-3 text-sm font-medium text-gray-700 dark:text-gray-300">@Localizer["ActivateDiscount"]</span>
                        </label>
                        <div id="discountSection" class="hidden mt-4 pt-4 border-t border-gray-200 dark:border-gray-600">
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">@Localizer["DiscountEGP"]</label>
                            <input type="number" id="discount" name="discount" step="0.01" min="0"
                                   class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                                   placeholder="0"
                                   oninput="validateDiscount()">
                            <p id="discountError" class="mt-2 text-sm text-red-600 font-medium hidden"></p>
                            <p id="priceAfterDiscount" class="mt-2 text-sm text-green-600 font-medium hidden">
                                @Localizer["PriceEGP"] بعد الخصم: <span id="afterDiscountAmount" class="font-bold"></span>
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">@Localizer["Level"] <span class="text-red-500">*</span></label>
                            <select id="level" name="level" required
                                    class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all">
                                <option value="beginner">@Localizer["Beginner"]</option>
                                <option value="intermediate">@Localizer["Intermediate"]</option>
                                <option value="advanced">@Localizer["Advanced"]</option>
                                <option value="all">@Localizer["AllLevels"]</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">@Localizer["Language"] <span class="text-red-500">*</span></label>
                            <select id="language" name="language" required
                                    class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all">
                                <option value="ar">العربية</option>
                                <option value="en">English</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Requirements & Learnings side by side -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-3">
                    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
                        <div class="flex items-center gap-2 mb-4">
                            <div class="w-8 h-8 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center">
                                <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <h2 class="text-base font-bold text-gray-800 dark:text-white">@Localizer["RequirementsHeader"] <span class="text-red-500">*</span> <span class="text-xs font-normal text-gray-500">(@Localizer["Min3"])</span></h2>
                        </div>
                        <div class="space-y-2" id="requirementsContainer">
                            <div class="flex gap-2">
                                <input type="text" id="newRequirement"
                                       class="flex-1 px-3 py-2 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all text-sm"
                                       placeholder="@Localizer["RequirementPlaceholder"]">
                                <button type="button" onclick="addRequirement()"
                                        class="px-3 py-2 bg-purple-600 text-white rounded-xl hover:bg-purple-700 transition-all text-sm whitespace-nowrap">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                            <ul id="requirementsList" class="space-y-1.5"></ul>
                        </div>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
                        <div class="flex items-center gap-2 mb-4">
                            <div class="w-8 h-8 rounded-lg bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
                                <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                                </svg>
                            </div>
                            <h2 class="text-base font-bold text-gray-800 dark:text-white">@Localizer["LearningsHeader"] <span class="text-red-500">*</span> <span class="text-xs font-normal text-gray-500">(@Localizer["Min3"])</span></h2>
                        </div>
                        <div class="space-y-2" id="learningsContainer">
                            <div class="flex gap-2">
                                <input type="text" id="newLearning"
                                       class="flex-1 px-3 py-2 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all text-sm"
                                       placeholder="@Localizer["LearningPlaceholder"]">
                                <button type="button" onclick="addLearning()"
                                        class="px-3 py-2 bg-amber-600 text-white rounded-xl hover:bg-amber-700 transition-all text-sm whitespace-nowrap">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                            <ul id="learningsList" class="space-y-1.5"></ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Side column -->
            <div class="space-y-6">
                <!-- Image -->
                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-5 stagger-1">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-8 h-8 rounded-lg bg-sky-100 dark:bg-sky-900/30 flex items-center justify-center">
                            <svg class="w-4 h-4 text-sky-600 dark:text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <h2 class="text-base font-bold text-gray-800 dark:text-white">@Localizer["CourseImage"]</h2>
                    </div>
                    <div class="relative border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-xl p-4 text-center hover:border-sky-500 hover:bg-sky-50/50 dark:hover:bg-sky-900/10 transition-all duration-300 cursor-pointer group"
                         onclick="document.getElementById('image').click()">
                        <input type="file" id="image" name="image" accept="image/*" class="hidden" onchange="previewImage(event)">
                        <div id="imagePreview" class="hidden mb-2">
                            <img class="max-h-32 mx-auto rounded-lg" />
                        </div>
                        <div id="imagePlaceholder" class="group-hover:scale-105 transition-transform">
                            <svg class="w-10 h-10 mx-auto text-gray-400 group-hover:text-sky-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1.5">@Localizer["ClickToUploadImage"]</p>
                        </div>
                    </div>
                </div>

                <!-- Target Audience + Certificate -->
                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-5 stagger-3">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-8 h-8 rounded-lg bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center">
                            <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <h2 class="text-base font-bold text-gray-800 dark:text-white">@Localizer["TargetAudience"] <span class="text-red-500">*</span></h2>
                    </div>
                    <textarea id="targetAudience" name="targetAudience" rows="3" required
                              class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all resize-none text-sm"
                              placeholder="@Localizer["TargetAudiencePlaceholder"]"></textarea>
                    <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700">
                        <label class="flex items-center cursor-pointer">
                            <input type="checkbox" id="hasCertificate" name="hasCertificate" class="hidden">
                            <div class="relative w-12 h-6 bg-gray-300 dark:bg-gray-600 rounded-full transition-colors duration-300 flex-shrink-0" id="certToggle">
                                <div class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full transition-transform duration-300 shadow-sm" id="certKnob"></div>
                            </div>
                            <span class="mr-3 text-sm text-gray-700 dark:text-gray-300">@Localizer["CourseGivesCertificate"]</span>
                        </label>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        @{
            var _ct = new System.Collections.Generic.Dictionary<string, string>
            {
                ["minReqErr"] = Localizer["MinRequirementsRequired"].Value,
                ["minLearnErr"] = Localizer["MinLearningsRequired"].Value,
                ["loading"] = Localizer["Loading"].Value,
                ["courseCreated"] = Localizer["CourseCreated"].Value,
                ["courseErr"] = Localizer["ErrorOccurred"].Value,
                ["createCourse"] = Localizer["CreateCourse"].Value,
                ["priceMaxErr"] = Localizer["PriceMaxError"].Value,
                ["discountMustBePositive"] = Localizer["DiscountMustBePositive"].Value,
                ["discountExceedsPrice"] = Localizer["DiscountExceedsPrice"].Value,
                ["imgReq"] = Localizer["ImageRequired"].Value
            };
            var _ctJson = System.Text.Json.JsonSerializer.Serialize(_ct);
        }
        const _str = @Html.Raw(_ctJson);
        let requirements = [];
        let learnings = [];

        document.getElementById('hasCertificate').addEventListener('change', function() {
            const toggle = document.getElementById('certToggle');
            const knob = document.getElementById('certKnob');
            if (this.checked) {
                toggle.classList.add('bg-blue-600');
                knob.classList.add('translate-x-6');
            } else {
                toggle.classList.remove('bg-blue-600');
                knob.classList.remove('translate-x-6');
            }
        });

        document.getElementById('hasDiscount').addEventListener('change', function() {
            const toggle = document.getElementById('discountToggle');
            const knob = document.getElementById('discountKnob');
            const section = document.getElementById('discountSection');
            if (this.checked) {
                toggle.classList.add('bg-blue-600');
                knob.classList.add('translate-x-6');
                section.classList.remove('hidden');
                setTimeout(() => section.classList.add('opacity-100', 'translate-y-0'), 50);
                section.classList.add('opacity-0', 'translate-y-4', 'transition-all', 'duration-300');
            } else {
                toggle.classList.remove('bg-blue-600');
                knob.classList.remove('translate-x-6');
                section.classList.add('hidden');
                section.classList.remove('opacity-100', 'translate-y-0');
                document.getElementById('discount').value = '';
                document.getElementById('discountError').classList.add('hidden');
                document.getElementById('priceAfterDiscount').classList.add('hidden');
            }
        });

        function validatePrice() {
            const price = document.getElementById('price').value;
            if (price > 999999) {
                showAlert('error', _str.priceMaxErr);
                document.getElementById('price').value = 999999;
            }
            validateDiscount();
        }

        function validateDiscount() {
            const hasDiscount = document.getElementById('hasDiscount').checked;
            const discountInput = document.getElementById('discount');
            const discountError = document.getElementById('discountError');
            const priceAfter = document.getElementById('priceAfterDiscount');
            const afterAmount = document.getElementById('afterDiscountAmount');
            const price = parseFloat(document.getElementById('price').value);
            const discount = parseFloat(discountInput.value);

            discountError.classList.add('hidden');
            priceAfter.classList.add('hidden');

            if (!hasDiscount || !discountInput.value) return true;

            if (isNaN(discount) || discount < 0) {
                discountError.textContent = _str.discountMustBePositive;
                discountError.classList.remove('hidden');
                return false;
            }
            if (discount > price) {
                discountError.textContent = _str.discountExceedsPrice;
                discountError.classList.remove('hidden');
                return false;
            }

            afterAmount.textContent = (price - discount).toFixed(2);
            priceAfter.classList.remove('hidden');
            return true;
        }

        function addRequirement() {
            const input = document.getElementById('newRequirement');
            const val = input.value.trim();
            if (!val) return;
            requirements.push(val);
            input.value = '';
            renderRequirements(true);
        }

        function removeRequirement(index) {
            requirements.splice(index, 1);
            renderRequirements(false);
        }

        function renderRequirements(animate) {
            const list = document.getElementById('requirementsList');
            list.innerHTML = requirements.map((r, i) =>
                `<li class="flex items-center justify-between bg-purple-50 dark:bg-purple-900/20 px-3 py-1.5 rounded-lg text-sm ${animate && i === requirements.length - 1 ? 'animate-pop-in' : ''}">
                    <span class="text-gray-700 dark:text-gray-300">${r}</span>
                    <button type="button" onclick="removeRequirement(${i})" class="text-red-500 hover:text-red-700 transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </li>`
            ).join('');
        }

        function addLearning() {
            const input = document.getElementById('newLearning');
            const val = input.value.trim();
            if (!val) return;
            learnings.push(val);
            input.value = '';
            renderLearnings(true);
        }

        function removeLearning(index) {
            learnings.splice(index, 1);
            renderLearnings(false);
        }

        function renderLearnings(animate) {
            const list = document.getElementById('learningsList');
            list.innerHTML = learnings.map((l, i) =>
                `<li class="flex items-center justify-between bg-amber-50 dark:bg-amber-900/20 px-3 py-1.5 rounded-lg text-sm ${animate && i === learnings.length - 1 ? 'animate-pop-in' : ''}">
                    <span class="text-gray-700 dark:text-gray-300">${l}</span>
                    <button type="button" onclick="removeLearning(${i})" class="text-red-500 hover:text-red-700 transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </li>`
            ).join('');
        }

        function previewImage(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('imagePlaceholder').classList.add('hidden');
                const preview = document.getElementById('imagePreview');
                preview.classList.remove('hidden');
                preview.querySelector('img').src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        document.getElementById('createCourseForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            if (requirements.length < 3) {
                showAlert('error', _str.minReqErr);
                return;
            }
            if (learnings.length < 3) {
                showAlert('error', _str.minLearnErr);
                return;
            }
            if (!document.getElementById('image').files[0]) {
                showAlert('error', _str.imgReq);
                return;
            }
            if (!validateDiscount()) {
                return;
            }

            const btn = document.getElementById('createCourseBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="inline-block animate-spin w-4 h-4 border-2 border-white border-t-transparent rounded-full ml-2"></span> ' + _str.loading;

            const formData = new FormData();
            formData.append('title', document.getElementById('title').value);
            formData.append('shortDescription', document.getElementById('shortDescription').value);
            formData.append('description', document.getElementById('description').value);
            formData.append('price', document.getElementById('price').value);
            formData.append('discount', document.getElementById('hasDiscount').checked ? document.getElementById('discount').value || '0' : '0');
            formData.append('categoryId', document.getElementById('categoryId').value);
            formData.append('level', document.getElementById('level').value);
            formData.append('language', document.getElementById('language').value);
            formData.append('targetAudience', document.getElementById('targetAudience').value);
            formData.append('hasCertificate', document.getElementById('hasCertificate').checked ? 'true' : 'false');
            requirements.forEach(r => formData.append('requirements', r));
            learnings.forEach(l => formData.append('learnings', l));
            const imageFile = document.getElementById('image').files[0];
            if (imageFile) formData.append('image', imageFile);

            try {
                const response = await fetch('@Url.Action("CreateCourse")', { method: 'POST', body: formData });
                const result = await response.json();
                if (result.success) {
                    window.location.href = '/Admin/Course/Curriculum/' + result.courseId;
                } else {
                    showAlert('error', result.message || _str.courseErr);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-plus ml-1.5"></i> ' + _str.createCourse;
                }
            } catch (err) {
                showAlert('error', _str.courseErr);
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-plus ml-1.5"></i> ' + _str.createCourse;
            }
        });

    </script>
}
