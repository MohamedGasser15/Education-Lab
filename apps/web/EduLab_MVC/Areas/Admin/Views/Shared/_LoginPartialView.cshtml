@using EduLab_MVC.Services.ServiceInterfaces
@inject IUserService _userService
@inject IConfiguration Configuration
@{
    var user = await _userService.GetCurrentUserAsync();
    var fullName = user?.FullName;
    var role = user?.Role;
    var profileImage = user?.ProfileImageUrl;
    var baseUrl = Configuration["ApiBaseUrl"];

    if (!string.IsNullOrEmpty(profileImage) && !profileImage.StartsWith("http"))
    {
        profileImage = baseUrl.TrimEnd('/') + "/" + profileImage.TrimStart('/');
    }
}

<!-- Premium User Profile Section -->
<div x-data="{ open: false }" class="relative" @@click.outside="open = false">
    <!-- Profile Trigger Card -->
    <button @@click="open = !open" 
            class="w-full group p-3 rounded-2xl bg-white/50 dark:bg-white/5 border border-white/20 dark:border-white/5 hover:bg-white dark:hover:bg-white/10 transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="flex items-center gap-3">
            <div class="relative">
                <div class="w-12 h-12 rounded-xl bg-primary-600/10 flex items-center justify-center overflow-hidden border-2 border-white dark:border-gray-800 shadow-sm group-hover:scale-105 transition-transform duration-300">
                    @if (!string.IsNullOrEmpty(profileImage))
                    {
                        <img src="@profileImage" alt="User" class="w-full h-full object-cover">
                    }
                    else
                    {
                        <div class="w-full h-full bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center">
                            <i class="fas fa-user text-white text-xl"></i>
                        </div>
                    }
                </div>
                <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-500 border-2 border-white dark:border-gray-800 rounded-full"></div>
            </div>
            
            <div class="flex-1 text-right overflow-hidden">
                <h4 class="text-sm font-bold text-gray-800 dark:text-white truncate">@fullName</h4>
                <p class="text-[10px] font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">@role</p>
            </div>

            <i class="fas fa-chevron-down text-[10px] text-gray-400 transition-transform duration-300" :class="open ? 'rotate-180' : ''"></i>
        </div>
    </button>

    <!-- Premium Dropdown Menu -->
    <div x-show="open"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 translate-y-2 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 translate-y-0 scale-100"
         x-transition:leave-end="opacity-0 translate-y-2 scale-95"
         class="absolute left-0 right-0 mt-3 z-[60] p-2 bg-white/90 dark:bg-gray-900/90 backdrop-blur-xl border border-white/20 dark:border-white/5 rounded-2xl shadow-2xl overflow-hidden"
         style="display: none;">
        
        <div class="px-3 py-2 mb-2 border-b border-gray-100 dark:border-white/5">
            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">إدارة الحساب</span>
        </div>

        <div class="space-y-1">
            <a asp-area="Learner" asp-controller="Profile" asp-action="Index"
               class="flex items-center gap-3 p-2.5 rounded-xl text-sm text-gray-600 dark:text-gray-300 hover:bg-primary-600 hover:text-white transition-all duration-200 group/item">
                <div class="w-8 h-8 rounded-lg bg-primary-600/10 flex items-center justify-center group-hover/item:bg-white/20 transition-colors">
                    <i class="fas fa-user-circle text-primary-600 dark:text-primary-400 group-hover/item:text-white"></i>
                </div>
                <span class="font-medium">الملف الشخصي</span>
            </a>

            <a asp-area="Learner" asp-controller="Settings" asp-action="Index"
               class="flex items-center gap-3 p-2.5 rounded-xl text-sm text-gray-600 dark:text-gray-300 hover:bg-primary-600 hover:text-white transition-all duration-200 group/item">
                <div class="w-8 h-8 rounded-lg bg-primary-600/10 flex items-center justify-center group-hover/item:bg-white/20 transition-colors">
                    <i class="fas fa-cog text-primary-600 dark:text-primary-400 group-hover/item:text-white"></i>
                </div>
                <span class="font-medium">إعدادات الحساب</span>
            </a>
        </div>

        <div class="mt-2 pt-2 border-t border-gray-100 dark:border-white/5">
            <form asp-area="Learner" asp-controller="Auth" asp-action="Logout" method="post">
                <button type="submit"
                        class="w-full flex items-center gap-3 p-2.5 rounded-xl text-sm text-rose-500 hover:bg-rose-500 hover:text-white transition-all duration-200 group/logout">
                    <div class="w-8 h-8 rounded-lg bg-rose-500/10 flex items-center justify-center group-hover/logout:bg-white/20 transition-colors">
                        <i class="fas fa-power-off text-rose-500 group-hover/logout:text-white"></i>
                    </div>
                    <span class="font-bold">تسجيل الخروج</span>
                </button>
            </form>
        </div>
    </div>
</div>