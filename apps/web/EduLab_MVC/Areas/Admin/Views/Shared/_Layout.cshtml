                                class="w-full flex items-center p-3.5 mx-3 rounded-2xl transition-all duration-300 @(isUserGroupActive ? "bg-primary-600/10 text-primary-600 shadow-sm shadow-primary-600/10" : "text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-white/5")">
