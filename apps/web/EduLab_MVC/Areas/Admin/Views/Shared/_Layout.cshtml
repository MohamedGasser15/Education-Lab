                {
                    <li>
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="@IsActive("Dashboard", "Index")">
                            <i class="fas fa-th-large sidebar-icon"></i>
                            <span class="font-medium">لوحة التحكم</span>
                        </a>
                    </li>
                }

                @if (User.HasClaim(c => c.Type == "ViewUsers") || User.HasClaim(c => c.Type == "ViewRoles") || User.HasClaim(c => c.Type == "ViewInstructorApplications"))
                {
                        var isUserGroupActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "User" || 
                                              ViewContext.RouteData.Values["Controller"]?.ToString() == "Role" || 
                                              ViewContext.RouteData.Values["Controller"]?.ToString() == "InstructorApplications";
                    <li x-data="{ open: @(isUserGroupActive ? "true" : "false") }">
