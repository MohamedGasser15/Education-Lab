                            <span class="font-bold text-sm">الصلاحيات والمستخدمين</span>
                            <i class="fas fa-chevron-down text-[10px] ms-auto transition-transform duration-300" :class="open ? 'rotate-180' : ''" style="margin-left:10px;"></i>
                        </button>
                        <ul x-show="open" 
                            x-collapse
                            x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="opacity-0 -translate-y-2"
                            x-transition:enter-end="opacity-100 translate-y-0"
                            class="mr-8 space-y-1 mt-2 border-r-2 border-gray-100 dark:border-gray-800/50 pr-4">
                            @if (User.HasClaim(c => c.Type == "ViewUsers"))
                            {
                                <li><a asp-area="Admin" asp-controller="User" asp-action="Index" class="@IsActiveDropdownItem("User", "Index")">المستخدمين</a></li>
                            }
                            @if (User.HasClaim(c => c.Type == "ViewRoles"))
                            {
                                <li><a asp-area="Admin" asp-controller="Role" asp-action="Index" class="@IsActiveDropdownItem("Role", "Index")">الأدوار</a></li>
                            }
                            @if (User.HasClaim(c => c.Type == "ViewInstructorApplications"))
                            {
                                <li><a asp-area="Admin" asp-controller="InstructorApplications" asp-action="Index" class="@IsActiveDropdownItem("InstructorApplications", "Index")">طلبات التدريب</a></li>
                            }
                        </ul>
                    </li>
                }

                @if (User.HasClaim(c => c.Type == "ViewCourses") || User.HasClaim(c => c.Type == "ViewCategories") || User.HasClaim(c => c.Type == "CreateCourse"))
                {
                        var isCourseGroupActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "Course" || 
                                                ViewContext.RouteData.Values["Controller"]?.ToString() == "Category";
                    <li x-data="{ open: @(isCourseGroupActive ? "true" : "false") }">
                        <button @@click="open = !open" 
                                class="w-full flex items-center p-3.5 mx-3 rounded-2xl transition-all duration-300 @(isCourseGroupActive ? "bg-primary-600/10 text-primary-600 shadow-sm shadow-primary-600/10" : "text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-white/5")">
                            <i class="fas fa-graduation-cap sidebar-icon @(isCourseGroupActive ? "text-primary-600" : "")"></i>
                            <span class="font-bold text-sm">إدارة التعليم</span>
                            <i class="fas fa-chevron-down text-[10px] ms-auto transition-transform duration-300" :class="open ? 'rotate-180' : ''" style="margin-left:10px;"></i>
                        </button>
                        <ul x-show="open" 
                            x-collapse
                            x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="opacity-0 -translate-y-2"
                            x-transition:enter-end="opacity-100 translate-y-0"
                            class="mr-8 space-y-1 mt-2 border-r-2 border-gray-100 dark:border-gray-800/50 pr-4">
                            @if (User.HasClaim(c => c.Type == "ViewCourses"))
                            {
                                <li><a asp-area="Admin" asp-controller="Course" asp-action="Index" class="@IsActiveDropdownItem("Course", "Index")">الكورسات</a></li>
                            }
                            @if (User.HasClaim(c => c.Type == "ViewCategories"))
                            {
                                <li><a asp-area="Admin" asp-controller="Category" asp-action="Index" class="@IsActiveDropdownItem("Category", "Index")">الأقسام</a></li>
                            }
                        </ul>
                    </li>
                }

                @if (User.HasClaim(c => c.Type == "ViewNotifications"))
                {
                    <li>
                        <a asp-area="Admin" asp-controller="Notification" asp-action="Index" class="@IsActive("Notification", "Index")">
                            <i class="fas fa-paper-plane sidebar-icon"></i>
                            <span class="font-medium">الإشعارات</span>
                        </a>
                    </li>
                }

                @if (User.HasClaim(c => c.Type == "ViewSystemHistory"))
                {
                    <li>
                        <a asp-area="Admin" asp-controller="History" asp-action="Index" class="@IsActive("History", "Index")">
                            <i class="fas fa-stream sidebar-icon"></i>
                            <span class="font-medium">سجلات النظام</span>
                        </a>
                    </li>
                }

                @if (User.HasClaim(c => c.Type == "ViewReports"))
                {
                    <li>
                        <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="@IsActive("Reports", "Index")">
                            <i class="fas fa-chart-pie sidebar-icon"></i>
                            <span class="font-medium">التقارير</span>
                        </a>
                    </li>
                }

                <div class="px-6 my-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">أدوات إضافية</div>

                <li>
                    <a asp-area="Admin" asp-controller="Settings" asp-action="Index" class="@IsActive("Settings", "Index")">
                        <i class="fas fa-sliders-h sidebar-icon"></i>
