                </div>

                <!-- Notifications (Placeholder) -->
                <button class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 relative group">
                    <i class="far fa-bell text-gray-600 dark:text-gray-400"></i>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white dark:border-gray-900"></span>
                </button>
