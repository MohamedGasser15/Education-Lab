@using EduLab_MVC.Services.ServiceInterfaces
@using System.Globalization
@using EduLab_MVC.Models.DTOs.Auth
@model IEnumerable<UserDTO>
@inject IUserService _userService

@{
    ViewData["Title"] = Localizer["ManageUsers"];

    var currentUser = await _userService.GetCurrentUserAsync();
    var currentUserId = currentUser?.Id;
}


<link rel="stylesheet" href="~/css/Admin/users.css">
<style>
    /* Premium Modal Enhancements */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background-color: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        padding: 1.5rem;
    }

    .modal-overlay:not(.hidden) {
        display: flex;
    }

    .modal-container {
        width: 100%;
        max-width: 32rem;
        animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes modalSlideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Modern Pagination */
    .pagination-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 12px;
        background: white;
        border: 1px solid #f1f5f9;
        color: #64748b;
        font-weight: 700;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .dark .pagination-btn {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.05);
        color: #94a3b8;
    }

    .pagination-btn:hover:not(.disabled) {
        background: #2563eb;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2);
    }

    .pagination-btn.active {
        background: #2563eb;
        color: white;
        border-color: #2563eb;
    }

    /* Custom Checkbox Premium */
    .custom-checkbox {
        width: 1.3rem;
        height: 1.3rem;
        border-radius: 6px;
        border: 2px solid #e2e8f0;
        appearance: none;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
    }

    .dark .custom-checkbox {
        border-color: rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.05);
    }

    .custom-checkbox:checked {
        background: #2563eb;
        border-color: #2563eb;
    }

    .custom-checkbox:checked::after {
        content: "✓";
        position: absolute;
        color: white;
        font-weight: 900;
        font-size: 0.8rem;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }
</style>
<!-- Premium Users Page Container -->
<div class="space-y-8 animate-in fade-in duration-1000">
    
    <!-- Header & Action Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-2">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">@Html.Raw(Localizer["ManageUsersHeading"])</h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 font-medium">@Localizer["UserPageSubtitle"]</p>
        </div>
    </div>

    <!-- Statistics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Stat Card: Total Users -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-600/10 rounded-full blur-2xl group-hover:bg-primary-600/20 transition-all"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["TotalRegistered"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count()</h3>
                    <p class="text-[10px] text-gray-400 mt-2 font-medium">@Localizer["AllRolesAndLevels"]</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-primary-600 flex items-center justify-center shadow-lg shadow-primary-600/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-users text-white text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Stat Card: Active Users -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-emerald-600/10 rounded-full blur-2xl group-hover:bg-emerald-600/20 transition-all"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["ActiveUsers"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(u => !u.IsLocked)</h3>
                    <p class="text-[10px] text-emerald-500 mt-2 font-bold"><i class="fas fa-circle text-[6px] ml-1"></i> @Localizer["CurrentlyAvailable"]</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-user-check text-white text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Stat Card: Banned Users -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-rose-600/10 rounded-full blur-2xl group-hover:bg-rose-600/20 transition-all"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["BannedUsers"]</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(u => u.IsLocked)</h3>
                    <p class="text-[10px] text-rose-500 mt-2 font-bold"><i class="fas fa-exclamation-triangle text-[10px] ml-1"></i> @Localizer["TemporarilySuspended"]</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-rose-500 flex items-center justify-center shadow-lg shadow-rose-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-user-slash text-white text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Stat Card: Latest Join -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-amber-600/10 rounded-full blur-2xl group-hover:bg-amber-600/20 transition-all"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">@Localizer["LatestJoin"]</p>
                    <h3 class="text-xl font-black text-gray-900 dark:text-white mt-1 tabular-nums">
                        @(Model.OrderByDescending(u => u.CreatedAt).FirstOrDefault()?.CreatedAt.ToString("yyyy-MM-dd") ?? "---")
                    </h3>
                    <p class="text-[10px] text-gray-400 mt-4 font-medium">@Localizer["LatestRegisteredUser"]</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-amber-500 flex items-center justify-center shadow-lg shadow-amber-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-clock text-white text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Modern Filter Bar -->
    <div class="glass-card rounded-3xl p-6 mb-8">
        <div class="flex flex-col lg:flex-row gap-4 items-center">
            <div class="relative flex-1 w-full">
                <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-gray-400">
                    <i class="fas fa-search"></i>
                </div>
                <input type="text" id="search-users" 
                       class="w-full pr-11 pl-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 focus:border-transparent dark:text-white transition-all font-medium" 
                       placeholder="@Localizer["SearchUserPlaceholder"]">
            </div>

            <div class="flex flex-wrap items-center gap-3 w-full lg:w-auto">
                <select id="role-filter" class="flex-1 lg:flex-none min-w-[140px] px-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 dark:text-white font-bold text-sm">
                    <option value="">@Localizer["AllRoles"]</option>
                    @if (ViewBag.Roles != null)
                    {
                        foreach (var Role in (List<SelectListItem>)ViewBag.Roles)
                        {
                            <option value="@Role.Value">@Role.Text</option>
                        }
                    }
                </select>

                <select id="status-filter" class="flex-1 lg:flex-none min-w-[140px] px-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 dark:text-white font-bold text-sm">
                <option value="">@Localizer["AllStatuses"]</option>
                <option value="active">@Localizer["Active"]</option>
                <option value="banned">@Localizer["Banned"]</option>
                <option value="inactive">@Localizer["Inactive"]</option>
            </select>

                <button id="reset-filters" class="w-full lg:w-auto px-6 py-3 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-bold text-sm hover:bg-primary-600 hover:text-white transition-all duration-300">
                    <i class="fas fa-undo-alt ml-2"></i>
                    @Localizer["Reset"]
                </button>
            </div>
        </div>
    </div>

    @if (User.HasClaim(c => c.Type == "BlockUser") || User.HasClaim(c => c.Type == "DeleteUser"))
    {
        <!-- Premium Bulk Actions -->
        <div id="bulk-actions-container" class="hidden animate-in slide-in-from-top-4 duration-500">
            <div class="bg-primary-600 text-white px-6 py-4 rounded-2xl shadow-xl shadow-primary-600/20 flex flex-col md:flex-row items-center justify-between gap-4 mb-6">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center">
                        <i class="fas fa-check-double text-white"></i>
                    </div>
                    <div>
                        <p class="text-xs font-bold opacity-80 uppercase tracking-widest">@Localizer["BulkActions"]</p>
                        <h4 class="text-sm font-black"><span id="selected-count">0</span> @Localizer["UserUnit"]</h4>
                    </div>
                </div>
                <div class="flex items-center gap-3 w-full md:w-auto">
                    <select id="bulk-action" class="flex-1 md:flex-none px-4 py-2 bg-white/10 border border-white/20 rounded-xl text-sm font-bold focus:ring-2 focus:ring-white/30 text-white placeholder-white/50">
                        <option value="" class="text-gray-900">@Localizer["ChooseAction"]</option>
                        @if (User.HasClaim(c => c.Type == "BlockUser"))
                        {
                            <option value="lock" class="text-gray-900">@Localizer["LockSelected"]</option>
                            <option value="unlock" class="text-gray-900">@Localizer["UnlockSelected"]</option>
                        }
                        @if (User.HasClaim(c => c.Type == "DeleteUser"))
                        {
                            <option value="delete" class="text-gray-900 text-rose-600 font-bold">@Localizer["DeletePermanently"]</option>
                        }
                    </select>
                    <button id="apply-bulk-action" class="px-6 py-2 bg-white text-primary-600 font-black text-sm rounded-xl hover:bg-gray-100 transition-colors">
                        @Localizer["Apply"]
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Premium Users Table Area -->
    <div class="glass-card rounded-3xl shadow-2xl">
        <div>
            <table class="admin-table w-full border-collapse">
                <thead>
                    <tr class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest bg-gray-50/50 dark:bg-white/5">
                        @if (User.HasClaim(c => c.Type == "BlockUser") || User.HasClaim(c => c.Type == "DeleteUser"))
                        {
                            <th class="px-8 py-5 w-16">
                                <input type="checkbox" id="select-all" class="custom-checkbox">
                            </th>
                        }
                        <th class="px-8 py-5">@Localizer["UserColon"]</th>
                        <th class="px-8 py-5">@Localizer["ContactInfo"]</th>
                        <th class="px-8 py-5">@Localizer["OfficialRole"]</th>
                        <th class="px-8 py-5 text-center">@Localizer["Status"]</th>
                        <th class="px-8 py-5 text-center">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                    @foreach (var user in Model)
                    {
                        <tr data-user-id="@user.Id" 
                            data-role="@user.Role" 
                            data-status="@(user.IsLocked ? "banned" : "active")"
                            data-can-delete="@(!(user.HasEnrollments || user.HasCourses) ? "true" : "false")"
                            data-delete-reason="@(user.HasEnrollments ? Localizer["HasCoursesReason"].Value : user.HasCourses ? Localizer["HasOwnCoursesReason"].Value : "")"
                            class="hover:bg-gray-50/50 dark:hover:bg-white/5 transition-colors group border-b border-gray-100 dark:border-white/5">
                            
                            @if (User.HasClaim(c => c.Type == "DeleteUser") || User.HasClaim(c => c.Type == "BlockUser"))
                            {
                                <td class="px-8 py-5">
                                    @if (user.Id != currentUserId)
                                    {
                                        <input type="checkbox" class="user-checkbox custom-checkbox" value="@user.Id">
                                    }
                                </td>
                            }

                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    @{
                                        string avatarColor = "2563eb";
                                        if (user.Role == "Instructor") { avatarColor = "7c3aed"; }
                                        else if (user.Role == "Admin") { avatarColor = "dc2626"; }
                                        else if (user.Role == "Support") { avatarColor = "16a34a"; }
                                        else if (user.Role == "Moderator") { avatarColor = "ca8a04"; }

                                        string initials = !string.IsNullOrEmpty(user.FullName)
                                        ? user.FullName.Length >= 2 ? user.FullName.Substring(0, 2) : user.FullName
                                        : "US";
                                    }
                                    <div class="relative group">
                                        <div class="w-12 h-12 rounded-2xl overflow-hidden shadow-lg shadow-gray-200 dark:shadow-none transition-transform group-hover:scale-110">
                                            @if (string.IsNullOrEmpty(user.ProfileImageUrl))
                                            {
                                                <img src="https://api.dicebear.com/7.x/initials/svg?seed=@initials&backgroundColor=@avatarColor&textColor=ffffff&length=2&fontSize=40"
                                                     class="w-full h-full object-cover" alt="User" />
                                            }
                                            else
                                            {
                                                <img src="@user.ProfileImageUrl" class="w-full h-full object-cover" alt="User" />
                                            }
                                        </div>
                                        <div class="absolute -bottom-1 -left-1 w-4 h-4 rounded-full border-2 border-white dark:border-gray-900 @(user.IsLocked ? "bg-rose-500" : "bg-emerald-500") shadow-sm"></div>
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-black text-gray-900 dark:text-white group-hover:text-primary-600 transition-colors">@user.FullName</h4>
                                        <span class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-tight">@Localizer["UserIDPrefix"] #@user.Id.ToString().Substring(0, 8)</span>
                                    </div>
                                </div>
                            </td>

                            <td class="px-8 py-5">
                                <div class="flex flex-col">
                                    <div class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300 font-bold">
                                        <i class="far fa-envelope text-gray-400 text-xs"></i>
                                        <span>@user.Email</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-[10px] text-gray-400 font-medium mt-1">
                                        <i class="far fa-calendar-alt text-xs"></i>
                                        <span>@Localizer["JoinedOn"] @user.CreatedAt.ToString("yyyy-MM-dd")</span>
                                    </div>
                                </div>
                            </td>

                            <td class="px-8 py-5">
                                @{
                                    var (roleText, roleIcon, roleClass) = user.Role switch
                                    {
                                        "Student" => (Localizer["StudentRole"].Value, "fa-user-graduate", "bg-primary-600/10 text-primary-600 border-primary-600/20"),
                                        "Instructor" => (Localizer["InstructorRole"].Value, "fa-chalkboard-teacher", "bg-purple-600/10 text-purple-600 border-purple-600/20"),
                                        "Admin" => (Localizer["AdminRole"].Value, "fa-user-shield", "bg-rose-600/10 text-rose-600 border-rose-600/20"),
                                        "Support" => (Localizer["SupportRole"].Value, "fa-headset", "bg-emerald-600/10 text-emerald-600 border-emerald-600/20"),
                                        "Moderator" => (Localizer["ModeratorRole"].Value, "fa-user-cog", "bg-amber-600/10 text-amber-600 border-amber-600/20"),
                                        _ => (Localizer["UnspecifiedRole"].Value, "fa-user", "bg-gray-600/10 text-gray-600 border-gray-600/20")
                                    };
                                }
                                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl border text-[11px] font-black @roleClass">
                                    <i class="fas @roleIcon text-[10px]"></i>
                                    @roleText
                                </span>
                            </td>

                            <td class="px-8 py-5 text-center">
                                @if (user.IsLocked)
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-rose-500/10 text-rose-500 border border-rose-500/20 text-[10px] font-black">
                                        <i class="fas fa-ban"></i> @Localizer["Blocked"]
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-emerald-500/10 text-emerald-500 border border-emerald-500/20 text-[10px] font-black">
                                        <i class="fas fa-check"></i> @Localizer["Active"]
                                    </span>
                                }
                            </td>

                            <td class="px-8 py-5">
                                <div class="flex items-center justify-center gap-2">
                                    @if (User.HasClaim(c => c.Type == "EditUser"))
                                    {
                                        <button class="w-9 h-9 rounded-xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 flex items-center justify-center hover:bg-primary-600 hover:text-white transition-all shadow-sm hover:shadow-primary-600/20"
                                                onclick="showEditModal('@user.Id', '@user.FullName', '@user.Email', '@user.Role')"
                                                title="@Localizer["Edit"]">
                                            <i class="fas fa-pencil-alt text-xs"></i>
                                        </button>
                                    }
                                    @if (user.Id != currentUserId)
                                    {
                                        @if (User.HasClaim(c => c.Type == "BlockUser"))
                                        {
                                            @if (user.IsLocked)
                                            {
                                                <button class="w-9 h-9 rounded-xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center hover:bg-emerald-500 hover:text-white transition-all shadow-sm"
                                                        onclick="showUnlockModal('@user.Id', '@user.FullName')"
                                                        title="@Localizer["Unlock"]">
                                                    <i class="fas fa-unlock-alt text-xs"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="w-9 h-9 rounded-xl bg-amber-500/10 text-amber-500 flex items-center justify-center hover:bg-amber-500 hover:text-white transition-all shadow-sm"
                                                        onclick="showLockModal('@user.Id', '@user.FullName')"
                                                        title="@Localizer["Lock"]">
                                                    <i class="fas fa-lock text-xs"></i>
                                                </button>
                                            }
                                        }
                                        
                                        @if (User.HasClaim(c => c.Type == "DeleteUser"))
                                        {
                                            var canDelete = !(user.HasEnrollments || user.HasCourses);
                                            <button class="w-9 h-9 rounded-xl @(canDelete ? "bg-rose-500/10 text-rose-500 hover:bg-rose-500 hover:text-white" : "bg-gray-100 dark:bg-gray-800 text-gray-300 cursor-not-allowed") flex items-center justify-center transition-all shadow-sm"
                                                    onclick="@(canDelete ? $"showDeleteModal('{user.Id}', '{user.FullName}')" : "return false;")"
                                                    title="@(canDelete ? Localizer["Delete"].Value : Localizer["CannotDelete"].Value)"
                                                    @(canDelete ? "" : "disabled")>
                                                <i class="fas fa-trash-alt text-xs"></i>
                                            </button>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Premium Pagination -->
        <div class="px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-6 bg-gray-50/50 dark:bg-white/5 border-t border-gray-100 dark:border-white/5">
            <div class="text-sm font-bold text-gray-500 dark:text-gray-400 order-2 md:order-1">
                @Localizer["Showing"] <span id="showing-from" class="text-primary-600">1</span> @Localizer["To"] <span id="showing-to" class="text-primary-600">5</span> @Localizer["OutOf"] <span id="total-users" class="text-gray-900 dark:text-white">@Model.Count()</span> @Localizer["UserUnit"]
            </div>
            
            <div class="flex items-center gap-4 order-1 md:order-2">
                <div class="pagination-controls flex items-center gap-2">
                    <button id="prev-page" class="pagination-btn disabled" title="@Localizer["Previous"]">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </button>
                    <div id="pagination-numbers" class="flex gap-2"></div>
                    <button id="next-page" class="pagination-btn" title="@Localizer["Next"]">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </button>
                </div>

                <div class="h-8 w-px bg-gray-200 dark:bg-white/10 hidden sm:block"></div>

                <select id="rows-per-page" class="px-3 py-2 bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl text-xs font-black text-gray-600 dark:text-gray-300 focus:ring-2 focus:ring-primary-600 outline-none transition-all">
                    <option value="5" selected>5 @Localizer["PerPage"]</option>
                    <option value="10">10 @Localizer["PerPage"]</option>
                    <option value="20">20 @Localizer["PerPage"]</option>
                    <option value="50">50 @Localizer["PerPage"]</option>
                </select>
            </div>
        </div>
    </div>
</div>

            <!-- Add User Modal -->
            <div id="addUserModal" class="modal-overlay hidden">
                <div class="modal-container glass-card p-0 rounded-[2rem] overflow-hidden border border-white/20 shadow-2xl">
                    <div class="px-8 py-6 bg-gradient-to-r from-primary-600/10 to-transparent border-b border-white/10 flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-primary-600 text-white flex items-center justify-center shadow-lg shadow-primary-600/20">
                            <i class="fas fa-user-plus text-xl"></i>
                        </div>
                        <div>
                            <h3 class="text-xl font-black text-gray-900 dark:text-white">@Localizer["AddNewUser"]</h3>
                            <p class="text-xs text-gray-500 font-bold uppercase tracking-wider">@Localizer["CreateNewAccount"]</p>
                        </div>
                    </div>
                    <form asp-action="Create" method="post" class="p-8 space-y-6">
                        @Html.AntiForgeryToken()
                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 px-1">@Localizer["FullNameLabel"]</label>
                                <div class="relative">
