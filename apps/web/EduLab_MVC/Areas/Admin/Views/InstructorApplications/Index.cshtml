@model List<EduLab_MVC.Models.DTOs.Instructor.AdminInstructorApplicationDto>

@{
    ViewData["Title"] = "إدارة طلبات التدريب";
}

<link rel="stylesheet" href="~/css/Admin/users.css">
<style>
    /* Premium Modal Enhancements */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background-color: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        padding: 1.5rem;
    }

    .modal-overlay:not(.hidden) {
        display: flex;
    }

    .modal-container {
        width: 100%;
        max-width: 36rem;
        animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes modalSlideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Modern Pagination */
    .pagination-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 12px;
        background: white;
        border: 1px solid #f1f5f9;
        color: #64748b;
        font-weight: 700;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .dark .pagination-btn {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.05);
        color: #94a3b8;
    }

    .pagination-btn:hover:not(.disabled) {
        background: #2563eb;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2);
    }

    .pagination-btn.active {
        background: #2563eb;
        color: white;
        border-color: #2563eb;
    }

    /* Status Badge Premium */
    .premium-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.025em;
        transition: all 0.3s;
    }

    .badge-pending {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
        border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .badge-approved {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .badge-rejected {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }
</style>

<!-- Premium Applications Page Container -->
<div class="space-y-8 animate-in fade-in duration-1000">
    
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-2">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">إدارة <span class="text-primary-600">طلبات التدريب</span> <i class="fas fa-user-graduate text-primary-600/50 mr-2"></i></h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 font-medium">مراجعة والتحقق من طلبات الانضمام لهيئة التدريس في الأكاديمية.</p>
        </div>
    </div>

    <!-- Statistics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Stat Card: Total Applications -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">إجمالي الطلبات</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count()</h3>
                    <p class="text-[10px] text-gray-400 mt-2 font-medium">جميع الطلبات المقدمة</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-primary-600 flex items-center justify-center shadow-lg shadow-primary-600/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-file-invoice text-white text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Stat Card: Pending -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-amber-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">قيد المراجعة</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(a => a.Status == "Pending")</h3>
                    <p class="text-[10px] text-amber-500 mt-2 font-bold"><i class="fas fa-circle text-[6px] ml-1"></i> تحتاج إلى قرار</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-amber-500 flex items-center justify-center shadow-lg shadow-amber-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-hourglass-half text-white text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Stat Card: Approved -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-emerald-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">طلبات مقبولة</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(a => a.Status == "Approved")</h3>
                    <p class="text-[10px] text-emerald-500 mt-2 font-bold"><i class="fas fa-check-double text-[10px] ml-1"></i> انضموا للأكاديمية</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-user-check text-white text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Stat Card: Rejected -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-rose-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">طلبات مرفوضة</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(a => a.Status == "Rejected")</h3>
                    <p class="text-[10px] text-rose-500 mt-2 font-bold"><i class="fas fa-times-circle text-[10px] ml-1"></i> لم يتم قبولهم</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-rose-500 flex items-center justify-center shadow-lg shadow-rose-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-user-times text-white text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Modern Filter Bar -->
    <div class="glass-card rounded-3xl p-6 mb-8">
        <div class="flex flex-col lg:flex-row gap-4 items-center">
            <div class="relative flex-1 w-full">
                <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-gray-400">
                    <i class="fas fa-search"></i>
                </div>
                <input type="text" id="search-applications" 
                       class="w-full pr-11 pl-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white transition-all font-medium" 
                       placeholder="ابحث باسم المتقدم، البريد، أو التخصص...">
            </div>

            <select id="status-filter" class="w-full lg:w-48 px-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white font-bold text-sm transition-all">
                <option value="all">جميع الحالات</option>
                <option value="Pending">قيد المراجعة</option>
                <option value="Approved">مقبولة</option>
                <option value="Rejected">مرفوضة</option>
            </select>

            <button id="reset-filters" class="w-full lg:w-auto px-6 py-3 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-bold text-sm hover:bg-primary-600 hover:text-white transition-all duration-300">
                <i class="fas fa-undo-alt ml-2"></i>
                إعادة تعيين
            </button>
        </div>
    </div>

    <!-- Applications Table Area -->
    <div class="glass-card rounded-3xl overflow-hidden shadow-2xl">
        <div class="overflow-x-auto">
            <table class="w-full text-right border-collapse">
                <thead>
                    <tr class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest bg-gray-50/50 dark:bg-white/5">
                        <th class="px-8 py-5">المتقدم</th>
                        <th class="px-8 py-5">التخصص والخبرة</th>
                        <th class="px-8 py-5">تاريخ التقديم</th>
                        <th class="px-8 py-5 text-center">الحالة</th>
                        <th class="px-8 py-5 text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                    @foreach (var app in Model)
                    {
                        <tr data-application-id="@app.Id" 
                            data-full-name="@app.FullName"
                            data-email="@app.Email"
                            data-specialization="@app.Specialization"
                            data-status="@app.Status"
                            class="hover:bg-gray-50/50 dark:hover:bg-white/5 transition-colors group border-b border-gray-100 dark:border-white/5">
                            
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="relative">
                                        @if (string.IsNullOrEmpty(app.ProfileImageUrl))
                                        {
                                            <div class="w-12 h-12 rounded-2xl bg-primary-600/10 text-primary-600 flex items-center justify-center font-black text-xl shadow-sm">
                                                @app.FullName[0]
                                            </div>
                                        }
                                        else
                                        {
                                            <img src="@app.ProfileImageUrl" class="w-12 h-12 rounded-2xl object-cover shadow-sm ring-2 ring-white dark:ring-white/10" alt="@app.FullName">
                                        }
                                        <div class="absolute -bottom-1 -left-1 w-4 h-4 rounded-full border-2 border-white dark:border-gray-900 @(app.Status == "Pending" ? "bg-amber-500" : app.Status == "Approved" ? "bg-emerald-500" : "bg-rose-500")"></div>
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-black text-gray-900 dark:text-white group-hover:text-primary-600 transition-colors">@app.FullName</h4>
                                        <p class="text-[11px] text-gray-500 font-bold">@app.Email</p>
                                    </div>
                                </div>
                            </td>

                            <td class="px-8 py-5">
                                <div class="space-y-1">
                                    <p class="text-xs font-black text-gray-700 dark:text-gray-300">@app.Specialization</p>
                                    <span class="inline-block px-2 py-0.5 rounded-lg bg-gray-100 dark:bg-white/5 text-[10px] text-gray-500 font-bold italic">خبرة @app.Experience</span>
                                </div>
                            </td>

                            <td class="px-8 py-5">
                                <span class="text-xs font-bold text-gray-500 dark:text-gray-400">@app.AppliedDate.ToString("yyyy-MM-dd")</span>
                            </td>

                            <td class="px-8 py-5 text-center">
                                @if (app.Status == "Pending")
                                {
                                    <span class="premium-badge badge-pending">
                                        <i class="fas fa-clock text-[10px]"></i> قيد المراجعة
                                    </span>
                                }
                                else if (app.Status == "Approved")
                                {
                                    <span class="premium-badge badge-approved">
                                        <i class="fas fa-check-circle text-[10px]"></i> تم القبول
                                    </span>
                                }
                                else
                                {
                                    <span class="premium-badge badge-rejected">
                                        <i class="fas fa-times-circle text-[10px]"></i> مرفوض
                                    </span>
                                }
                            </td>

                            <td class="px-8 py-5">
                                <div class="flex items-center justify-center gap-2">
                                    <button onclick="openDetailsModal('@app.Id')" 
                                            class="w-9 h-9 rounded-xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 flex items-center justify-center hover:bg-primary-600 hover:text-white transition-all shadow-sm"
                                            title="عرض التفاصيل">
                                        <i class="fas fa-eye text-xs"></i>
                                    </button>

                                    @if (app.Status == "Pending" && User.HasClaim(c => c.Type == "HandleInstructorApplications"))
                                    {
                                        <button onclick="openModal('approveModal-@app.Id')"
                                                class="w-9 h-9 rounded-xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center hover:bg-emerald-500 hover:text-white transition-all shadow-sm"
                                                title="قبول الطلب">
                                            <i class="fas fa-check text-xs"></i>
                                        </button>
                                        
                                        <button onclick="openModal('rejectModal-@app.Id')"
                                                class="w-9 h-9 rounded-xl bg-rose-500/10 text-rose-500 flex items-center justify-center hover:bg-rose-500 hover:text-white transition-all shadow-sm"
                                                title="رفض الطلب">
                                            <i class="fas fa-times text-xs"></i>
                                        </button>
                                    }

                                    @if (User.HasClaim(c => c.Type == "DownloadInstructorCV"))
                                    {
                                        <a href="@app.CvUrl" target="_blank"
                                           class="w-9 h-9 rounded-xl bg-purple-500/10 text-purple-500 flex items-center justify-center hover:bg-purple-500 hover:text-white transition-all shadow-sm"
                                           title="تحميل السيرة الذاتية">
                                            <i class="fas fa-file-download text-xs"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Premium Pagination -->
        <div class="px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-6 bg-gray-50/50 dark:bg-white/5 border-t border-gray-100 dark:border-white/5">
            <div class="text-sm font-bold text-gray-500 dark:text-gray-400 order-2 md:order-1">
                عرض <span id="showing-from" class="text-primary-600">1</span> إلى <span id="showing-to" class="text-primary-600">5</span> من أصل <span id="total-items" class="text-gray-900 dark:text-white">@Model.Count()</span> طلب
            </div>
            
            <div class="flex items-center gap-4 order-1 md:order-2">
                <div class="pagination-controls flex items-center gap-2">
                    <button id="prev-page" class="pagination-btn disabled" title="السابق">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </button>
                    <div id="pagination-numbers" class="flex gap-2"></div>
                    <button id="next-page" class="pagination-btn" title="التالي">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </button>
                </div>

                <div class="h-8 w-px bg-gray-200 dark:bg-white/10 hidden sm:block"></div>

                <select id="rows-per-page" class="px-3 py-2 bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl text-xs font-black text-gray-600 dark:text-gray-300 focus:ring-2 focus:ring-primary-600 outline-none transition-all">
                    <option value="5" selected>5 / صفحة</option>
                    <option value="10">10 / صفحة</option>
                    <option value="20">20 / صفحة</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div id="detailsModal" class="modal-overlay hidden">
    <div class="modal-container glass-card p-0 rounded-[2.5rem] overflow-hidden border border-white/20 shadow-2xl">
        <div class="px-8 py-6 bg-gradient-to-r from-primary-600/10 to-transparent border-b border-white/10 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-primary-600 text-white flex items-center justify-center shadow-lg shadow-primary-600/20">
                    <i class="fas fa-id-card text-xl"></i>
                </div>
                <div>
                    <h3 class="text-xl font-black text-gray-900 dark:text-white">تفاصيل الطلب</h3>
                    <p class="text-xs text-gray-500 font-bold uppercase tracking-wider">مراجعة البيانات المهنية</p>
                </div>
            </div>
            <button onclick="closeModal('detailsModal')" class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-white/5 text-gray-400 hover:text-rose-500 transition-all">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <div id="detailsModalContent" class="p-8 overflow-y-auto max-h-[70vh]">
            <!-- Dynamic Content -->
        </div>
    </div>
</div>

<!-- Approve Application Modals -->
@foreach (var app in Model.Where(a => a.Status == "Pending"))
{
    <div id="approveModal-@app.Id" class="modal-overlay hidden">
        <div class="modal-container glass-card p-8 rounded-[2.5rem] border border-white/20 shadow-2xl text-center">
            <div class="w-24 h-24 rounded-[2rem] mx-auto flex items-center justify-center text-4xl mb-6 bg-emerald-500 text-white shadow-xl shadow-emerald-500/30">
                <i class="fas fa-user-check"></i>
            </div>
            <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2">قبول المدرس</h3>
            <p class="text-gray-500 font-bold mb-8">هل أنت متأكد من قبول <span class="text-emerald-600 font-black">@app.FullName</span> كمدرب رسمي في الأكاديمية؟</p>
            
            <div class="flex items-center gap-3">
                <button type="button" onclick="closeModal('approveModal-@app.Id')" class="flex-1 py-4 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-black text-sm">إلغاء</button>
                <form method="post" asp-action="Approve" asp-route-id="@app.Id" class="flex-[2]">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full py-4 rounded-2xl bg-emerald-500 text-white font-black text-sm shadow-xl shadow-emerald-500/20 hover:bg-emerald-600 transition-all">تأكيد القبول</button>
                </form>
            </div>
        </div>
    </div>

    <div id="rejectModal-@app.Id" class="modal-overlay hidden">
        <div class="modal-container glass-card p-8 rounded-[2.5rem] border border-white/20 shadow-2xl text-center">
            <div class="w-24 h-24 rounded-[2rem] mx-auto flex items-center justify-center text-4xl mb-6 bg-rose-500 text-white shadow-xl shadow-rose-500/30">
                <i class="fas fa-user-times"></i>
            </div>
            <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2">رفض الطلب</h3>
            <p class="text-gray-500 font-bold mb-8">هل أنت متأكد من رفض طلب انضمام <span class="text-rose-600 font-black">@app.FullName</span>؟</p>
            
            <div class="flex items-center gap-3">
                <button type="button" onclick="closeModal('rejectModal-@app.Id')" class="flex-1 py-4 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-black text-sm">تراجع</button>
                <form method="post" asp-action="Reject" asp-route-id="@app.Id" class="flex-[2]">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full py-4 rounded-2xl bg-rose-500 text-white font-black text-sm shadow-xl shadow-rose-500/20 hover:bg-rose-600 transition-all">تأكيد الرفض</button>
                </form>
            </div>
        </div>
    </div>
}

<script>
    // Modal Functions
    function openModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) modal.classList.remove('hidden');
    }

    function closeModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) modal.classList.add('hidden');
    }

    function openDetailsModal(appId) {
        const content = document.getElementById('detailsModalContent');
        content.innerHTML = `
            <div class="flex flex-col items-center justify-center py-12 space-y-4">
                <div class="w-12 h-12 border-4 border-primary-600/20 border-t-primary-600 rounded-full animate-spin"></div>
                <p class="text-sm font-black text-gray-400 uppercase tracking-widest">جاري جلب التفاصيل...</p>
            </div>
        `;
        openModal('detailsModal');

        fetch(`/Admin/InstructorApplications/GetApplicationDetails?id=${appId}`)
            .then(res => res.json())
            .then(data => {
                let skillsHtml = (data.skills || '').split(',').map(s => 
                    `<span class="px-3 py-1 bg-primary-600/10 text-primary-600 rounded-xl text-[10px] font-black">${s.trim()}</span>`
                ).join('');

                content.innerHTML = `
                    <div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
                        <div class="flex items-center gap-6">
                            <img src="${data.profileImageUrl || '/img/default-user.png'}" class="w-24 h-24 rounded-3xl object-cover shadow-2xl ring-4 ring-primary-600/10" onerror="this.src='/img/default-user.png'">
                            <div>
                                <h4 class="text-2xl font-black text-gray-900 dark:text-white">${data.fullName}</h4>
                                <p class="text-primary-600 font-bold">${data.specialization}</p>
                                <div class="flex items-center gap-4 mt-2">
                                    <span class="text-xs font-bold text-gray-400"><i class="fas fa-briefcase ml-1"></i> خبرة ${data.experience}</span>
                                    <span class="text-xs font-bold text-gray-400"><i class="fas fa-calendar-alt ml-1"></i> انضم ${new Date(data.appliedDate).toLocaleDateString('ar-EG')}</span>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="glass-card p-5 rounded-2xl border border-white/10">
                                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3">نبذة تعريفية</p>
                                <p class="text-sm font-bold text-gray-600 dark:text-gray-300 leading-relaxed">${data.bio || 'لا توجد نبذة متوفرة'}</p>
                            </div>
                            <div class="glass-card p-5 rounded-2xl border border-white/10">
                                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3">المهارات والقدرات</p>
                                <div class="flex flex-wrap gap-2">${skillsHtml || 'لم يتم تحديد مهارات'}</div>
                            </div>
                        </div>

                        <div class="glass-card p-6 rounded-2xl border border-white/10 flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-xl bg-purple-600/10 text-purple-600 flex items-center justify-center text-xl">
                                    <i class="fas fa-file-pdf"></i>
                                </div>
                                <div>
                                    <h5 class="text-sm font-black text-gray-900 dark:text-white">السيرة الذاتية (CV)</h5>
                                    <p class="text-[10px] text-gray-400 font-bold italic">ملف المتقدم الرسمي للوظيفة</p>
                                </div>
                            </div>
                            <a href="${data.cvUrl}" target="_blank" class="px-6 py-2 bg-purple-600 text-white rounded-xl text-xs font-black shadow-lg shadow-purple-600/20 hover:bg-purple-700 transition-all">تحميل الملف</a>
                        </div>
                    </div>
                `;
            });
    }

    // List Logic
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('search-applications');
        const statusFilter = document.getElementById('status-filter');
        const resetBtn = document.getElementById('reset-filters');
        
        let currentPage = 1;
        let rowsPerPage = 5;
        let filteredRows = Array.from(document.querySelectorAll('tbody tr[data-application-id]'));

        function updateUI() {
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            
            document.querySelectorAll('tbody tr[data-application-id]').forEach(row => row.style.display = 'none');
            filteredRows.slice(start, end).forEach(row => row.style.display = 'table-row');
            
            document.getElementById('showing-from').textContent = filteredRows.length === 0 ? 0 : start + 1;
            document.getElementById('showing-to').textContent = Math.min(end, filteredRows.length);
            document.getElementById('total-items').textContent = filteredRows.length;
            
            renderPagination();
        }

        function renderPagination() {
            const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
            const container = document.getElementById('pagination-numbers');
            container.innerHTML = '';
            
            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('button');
                btn.className = `pagination-btn ${i === currentPage ? 'active' : ''}`;
                btn.textContent = i;
                btn.onclick = () => { currentPage = i; updateUI(); };
                container.appendChild(btn);
            }
            
            document.getElementById('prev-page').classList.toggle('disabled', currentPage === 1);
            document.getElementById('next-page').classList.toggle('disabled', currentPage === totalPages || totalPages === 0);
        }

        function applyFilters() {
            const term = searchInput.value.toLowerCase();
            const status = statusFilter.value;
            
            filteredRows = Array.from(document.querySelectorAll('tbody tr[data-application-id]')).filter(row => {
                const name = row.getAttribute('data-full-name').toLowerCase();
                const email = row.getAttribute('data-email').toLowerCase();
                const spec = row.getAttribute('data-specialization').toLowerCase();
                const rowStatus = row.getAttribute('data-status');
                
                const matchesSearch = name.includes(term) || email.includes(term) || spec.includes(term);
                const matchesStatus = status === 'all' || rowStatus === status;
                
                return matchesSearch && matchesStatus;
            });
            
            currentPage = 1;
            updateUI();
        }

        searchInput.addEventListener('input', applyFilters);
        statusFilter.addEventListener('change', applyFilters);
        resetBtn.addEventListener('click', () => {
            searchInput.value = '';
            statusFilter.value = 'all';
            applyFilters();
        });

        document.getElementById('rows-per-page').addEventListener('change', function() {
            rowsPerPage = parseInt(this.value);
            currentPage = 1;
            updateUI();
        });

        document.getElementById('prev-page').onclick = () => { if (currentPage > 1) { currentPage--; updateUI(); } };
        document.getElementById('next-page').onclick = () => { 
            const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
            if (currentPage < totalPages) { currentPage++; updateUI(); } 
        };

        window.onclick = (e) => {
            if (e.target.classList.contains('modal-overlay')) {
                document.querySelectorAll('.modal-overlay').forEach(m => m.classList.add('hidden'));
            }
        };

        updateUI();
    });
</script>