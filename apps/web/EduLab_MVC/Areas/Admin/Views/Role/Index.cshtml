@model List<EduLab_MVC.Models.DTOs.Roles.RoleDto>

@{
    ViewData["Title"] = "إدارة الأدوار والصلاحيات";
}

<link rel="stylesheet" href="~/css/Admin/users.css">
<style>
    /* Premium Modal Enhancements */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background-color: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 1000;
        padding: 1.5rem;
    }

    .modal-overlay:not(.hidden) {
        display: flex;
    }

    .modal-container {
        width: 100%;
        max-width: 30rem;
        animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes modalSlideUp {
        from { opacity: 0; transform: translateY(20px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Modern Pagination */
    .pagination-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 12px;
        background: white;
        border: 1px solid #f1f5f9;
        color: #64748b;
        font-weight: 700;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .dark .pagination-btn {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.05);
        color: #94a3b8;
    }

    .pagination-btn:hover:not(.disabled) {
        background: #2563eb;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2);
    }

    .pagination-btn.active {
        background: #2563eb;
        color: white;
        border-color: #2563eb;
    }

    /* Custom Checkbox Premium */
    .custom-checkbox {
        width: 1.3rem;
        height: 1.3rem;
        border-radius: 6px;
        border: 2px solid #e2e8f0;
        appearance: none;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
    }

    .dark .custom-checkbox {
        border-color: rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.05);
    }

    .custom-checkbox:checked {
        background: #2563eb;
        border-color: #2563eb;
    }

    .custom-checkbox:checked::after {
        content: "✓";
        position: absolute;
        color: white;
        font-weight: 900;
        font-size: 0.8rem;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }
</style>

<!-- Premium Roles Page Container -->
<div class="space-y-8 animate-in fade-in duration-1000">
    
    <!-- Header & Action Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-2">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">إدارة <span class="text-primary-600">الأدوار</span> <i class="fas fa-shield-alt text-primary-600/50 mr-2"></i></h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 font-medium">تحكم في مستويات الوصول وصلاحيات النظام لكل فئة من المستخدمين.</p>
        </div>
        <div class="flex items-center gap-3">
            @if (User.HasClaim(c => c.Type == "CreateRole"))
            {
                <button onclick="openModal('addRoleModal')" class="flex items-center gap-2 px-5 py-3 rounded-2xl bg-primary-600 text-white font-bold text-sm shadow-lg shadow-primary-600/30 hover:bg-primary-700 hover:scale-105 transition-all">
                    <i class="fas fa-plus"></i>
                    <span>إضافة دور جديد</span>
                </button>
            }
        </div>
    </div>

    <!-- Statistics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Stat Card: Total Roles -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-600/10 rounded-full blur-2xl group-hover:bg-primary-600/20 transition-all"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">إجمالي الأدوار</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count()</h3>
                    <p class="text-[10px] text-gray-400 mt-2 font-medium">الأدوار المعرفة بالنظام</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-primary-600 flex items-center justify-center shadow-lg shadow-primary-600/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-user-shield text-white text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Stat Card: Active Roles -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-emerald-600/10 rounded-full blur-2xl group-hover:bg-emerald-600/20 transition-all"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">أدوار مستخدمة</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(r => r.UserCount > 0)</h3>
                    <p class="text-[10px] text-emerald-500 mt-2 font-bold"><i class="fas fa-circle text-[6px] ml-1"></i> مرتبطة بمستخدمين</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-check-double text-white text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Stat Card: Protected Roles -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-amber-600/10 rounded-full blur-2xl group-hover:bg-amber-600/20 transition-all"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">أدوار إدارية</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(r => r.Name.Contains("Admin") || r.Name.Contains("مدير"))</h3>
                    <p class="text-[10px] text-amber-500 mt-2 font-bold"><i class="fas fa-shield-alt text-[10px] ml-1"></i> صلاحيات كاملة</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-amber-500 flex items-center justify-center shadow-lg shadow-amber-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-shield-alt text-white text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Stat Card: Update Status -->
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-rose-600/10 rounded-full blur-2xl group-hover:bg-rose-600/20 transition-all"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">أحدث تعديل</p>
                    <h3 class="text-xl font-black text-gray-900 dark:text-white mt-1 tabular-nums">
                        @(DateTime.Now.ToString("yyyy-MM-dd"))
                    </h3>
                    <p class="text-[10px] text-gray-400 mt-4 font-medium">حالة الصلاحيات اليوم</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-rose-500 flex items-center justify-center shadow-lg shadow-rose-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-sync-alt text-white text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Modern Filter Bar -->
    <div class="glass-card rounded-3xl p-6 mb-8">
        <div class="flex flex-col lg:flex-row gap-4 items-center">
            <div class="relative flex-1 w-full">
                <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-gray-400">
                    <i class="fas fa-search"></i>
                </div>
                <input type="text" id="search-roles" 
                       class="w-full pr-11 pl-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 focus:border-transparent dark:text-white transition-all font-medium" 
                       placeholder="ابحث عن اسم الدور أو الوصف...">
            </div>

            <button id="reset-filters" class="w-full lg:w-auto px-6 py-3 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-bold text-sm hover:bg-primary-600 hover:text-white transition-all duration-300">
                <i class="fas fa-undo-alt ml-2"></i>
                إعادة تعيين
            </button>
        </div>
    </div>

    @if (User.HasClaim(c => c.Type == "DeleteRole"))
    {
        <!-- Premium Bulk Actions -->
        <div id="bulk-actions-container" class="hidden animate-in slide-in-from-top-4 duration-500">
            <div class="bg-primary-600 text-white px-6 py-4 rounded-2xl shadow-xl shadow-primary-600/20 flex flex-col md:flex-row items-center justify-between gap-4 mb-6">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center">
                        <i class="fas fa-check-double text-white"></i>
                    </div>
                    <div>
                        <p class="text-xs font-bold opacity-80 uppercase tracking-widest">إجراءات جماعية</p>
                        <h4 class="text-sm font-black"><span id="selected-count">0</span> دور محدد حالياً</h4>
                    </div>
                </div>
                <div class="flex items-center gap-3 w-full md:w-auto">
                    <button id="apply-bulk-delete" class="px-6 py-2 bg-rose-500 text-white font-black text-sm rounded-xl hover:bg-rose-600 transition-colors shadow-lg shadow-rose-600/20">
                        حذف الأدوار المختارة
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Premium Roles Table Area -->
    <div class="glass-card rounded-3xl overflow-hidden shadow-2xl">
        <div class="overflow-x-auto">
            <table class="w-full text-right border-collapse">
                <thead>
                    <tr class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest bg-gray-50/50 dark:bg-white/5">
                        @if (User.HasClaim(c => c.Type == "DeleteRole"))
                        {
                            <th class="px-8 py-5 w-16">
                                <input type="checkbox" id="select-all" class="custom-checkbox">
                            </th>
                        }
                        <th class="px-8 py-5">الدور الرسمي</th>
                        <th class="px-8 py-5">معرف الدور</th>
                        <th class="px-8 py-5 text-center">المستخدمين المرتبطين</th>
                        <th class="px-8 py-5 text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                    @foreach (var role in Model)
                    {
                        <tr data-role-id="@role.Id" 
                            data-role-name="@role.Name"
                            data-can-delete="@(role.UserCount == 0 ? "true" : "false")"
                            class="hover:bg-gray-50/50 dark:hover:bg-white/5 transition-colors group border-b border-gray-100 dark:border-white/5">
                            
                            @if (User.HasClaim(c => c.Type == "DeleteRole"))
                            {
                                <td class="px-8 py-5">
                                    <input type="checkbox" class="role-checkbox custom-checkbox" value="@role.Id" @(role.UserCount > 0 ? "disabled" : "")>
                                </td>
                            }

                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-2xl bg-primary-600/10 text-primary-600 flex items-center justify-center shadow-sm transition-transform group-hover:scale-110">
                                        <i class="fas fa-user-tag text-xl"></i>
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-black text-gray-900 dark:text-white group-hover:text-primary-600 transition-colors">@role.Name</h4>
                                        <span class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-tight">صلاحيات محددة</span>
                                    </div>
                                </div>
                            </td>

                            <td class="px-8 py-5">
                                <span class="text-xs font-mono text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-white/5 px-2 py-1 rounded-lg">#@role.Id.Substring(0, 8)</span>
                            </td>

                            <td class="px-8 py-5 text-center">
                                @if (role.UserCount == 0)
                                {
                                    <span class="inline-flex items-center gap-1 px-3 py-1 rounded-xl bg-gray-100 dark:bg-white/5 text-gray-500 text-[11px] font-black">
                                        <i class="fas fa-user-slash opacity-50"></i> لا يوجد مستخدمين
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-primary-600/10 text-primary-600 border border-primary-600/20 text-[11px] font-black">
                                        <i class="fas fa-users text-[10px]"></i>
                                        @role.UserCount مستخدم
                                    </span>
                                }
                            </td>

                            <td class="px-8 py-5">
                                <div class="flex items-center justify-center gap-2">
                                    @if (User.HasClaim(c => c.Type == "EditRole"))
                                    {
                                        <button class="w-9 h-9 rounded-xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 flex items-center justify-center hover:bg-primary-600 hover:text-white transition-all shadow-sm hover:shadow-primary-600/20"
                                                onclick="showEditModal('@role.Id', '@role.Name')"
                                                title="تعديل الاسم">
                                            <i class="fas fa-pencil-alt text-xs"></i>
                                        </button>
                                    }

                                    @if (User.HasClaim(c => c.Type == "ManageRoleClaims"))
                                    {
                                        <a asp-action="ManagePermissions" asp-route-id="@role.Id"
                                           class="w-9 h-9 rounded-xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center hover:bg-emerald-500 hover:text-white transition-all shadow-sm"
                                           title="إدارة الصلاحيات">
                                            <i class="fas fa-shield-virus text-xs"></i>
                                        </a>
                                    }
                                    
                                    @if (User.HasClaim(c => c.Type == "DeleteRole"))
                                    {
                                        <button class="w-9 h-9 rounded-xl @(role.UserCount == 0 ? "bg-rose-500/10 text-rose-500 hover:bg-rose-500 hover:text-white" : "bg-gray-100 dark:bg-gray-800 text-gray-300 cursor-not-allowed") flex items-center justify-center transition-all shadow-sm"
                                                onclick="@(role.UserCount == 0 ? $"showDeleteModal('{role.Id}', '{role.Name}')" : "return false;")"
                                                title="@(role.UserCount == 0 ? "حذف" : "لا يمكن حذف دور مستخدم")"
                                                @(role.UserCount == 0 ? "" : "disabled")>
                                            <i class="fas fa-trash-alt text-xs"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Premium Pagination -->
        <div class="px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-6 bg-gray-50/50 dark:bg-white/5 border-t border-gray-100 dark:border-white/5">
            <div class="text-sm font-bold text-gray-500 dark:text-gray-400 order-2 md:order-1">
                عرض <span id="showing-from" class="text-primary-600">1</span> إلى <span id="showing-to" class="text-primary-600">5</span> من أصل <span id="total-items" class="text-gray-900 dark:text-white">@Model.Count()</span> دور
            </div>
            
            <div class="flex items-center gap-4 order-1 md:order-2">
                <div class="pagination-controls flex items-center gap-2">
                    <button id="prev-page" class="pagination-btn disabled" title="السابق">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </button>
                    <div id="pagination-numbers" class="flex gap-2"></div>
                    <button id="next-page" class="pagination-btn" title="التالي">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </button>
                </div>

                <div class="h-8 w-px bg-gray-200 dark:bg-white/10 hidden sm:block"></div>

                <select id="rows-per-page" class="px-3 py-2 bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl text-xs font-black text-gray-600 dark:text-gray-300 focus:ring-2 focus:ring-primary-600 outline-none transition-all">
                    <option value="5" selected>5 / صفحة</option>
                    <option value="10">10 / صفحة</option>
                    <option value="20">20 / صفحة</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Modals Container -->
<div id="modals-container">
    <!-- Add Role Modal -->
    <div id="addRoleModal" class="modal-overlay hidden">
        <div class="modal-container glass-card p-0 rounded-[2rem] overflow-hidden border border-white/20 shadow-2xl">
            <div class="px-8 py-6 bg-gradient-to-r from-primary-600/10 to-transparent border-b border-white/10 flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-primary-600 text-white flex items-center justify-center shadow-lg shadow-primary-600/20">
                    <i class="fas fa-shield-alt text-xl"></i>
                </div>
                <div>
                    <h3 class="text-xl font-black text-gray-900 dark:text-white">إضافة دور جديد</h3>
                    <p class="text-xs text-gray-500 font-bold uppercase tracking-wider">إنشاء فئة وصول جديدة</p>
                </div>
            </div>
            <form asp-action="Create" method="post" class="p-8 space-y-6">
                @Html.AntiForgeryToken()
                <div>
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 px-1">اسم الدور (بالعربية أو الإنجليزية)</label>
                    <div class="relative">
                        <i class="fas fa-tag absolute right-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <input type="text" name="roleName" required placeholder="مثال: مدير محتوى، مشرف مالي..."
                               class="w-full pr-12 pl-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none transition-all font-bold text-gray-900 dark:text-white">
                    </div>
                </div>

                <div class="flex items-center gap-3 pt-4">
                    <button type="button" onclick="closeModal('addRoleModal')" 
                            class="flex-1 py-4 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-black text-sm hover:bg-gray-200 transition-all">إلغاء</button>
                    <button type="submit" 
                            class="flex-[2] py-4 rounded-2xl bg-primary-600 text-white font-black text-sm shadow-xl shadow-primary-600/20 hover:bg-primary-700 transition-all">إنشاء الدور</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Role Modal -->
    <div id="editRoleModal" class="modal-overlay hidden">
        <div class="modal-container glass-card p-0 rounded-[2rem] overflow-hidden border border-white/20 shadow-2xl">
            <div class="px-8 py-6 bg-gradient-to-r from-primary-600/10 to-transparent border-b border-white/10 flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-primary-600 text-white flex items-center justify-center shadow-lg shadow-primary-600/20">
                    <i class="fas fa-edit text-xl"></i>
                </div>
                <div>
                    <h3 class="text-xl font-black text-gray-900 dark:text-white">تعديل اسم الدور</h3>
                    <p class="text-xs text-gray-500 font-bold uppercase tracking-wider">تحديث المسمى الوظيفي</p>
                </div>
            </div>
            <form asp-action="Edit" method="post" class="p-8 space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" id="edit-role-id" name="id">
                <div>
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-widest mb-2 px-1">الاسم الجديد</label>
                    <div class="relative">
                        <i class="fas fa-tag absolute right-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <input type="text" id="edit-role-name" name="roleName" required
                               class="w-full pr-12 pl-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none transition-all font-bold text-gray-900 dark:text-white">
                    </div>
                </div>

                <div class="flex items-center gap-3 pt-4">
                    <button type="button" onclick="closeModal('editRoleModal')" 
                            class="flex-1 py-4 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-black text-sm hover:bg-gray-200 transition-all">إلغاء</button>
                    <button type="submit" 
                            class="flex-[2] py-4 rounded-2xl bg-primary-600 text-white font-black text-sm shadow-xl shadow-primary-600/20 hover:bg-primary-700 transition-all">تحديث الاسم</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete Role Modal -->
    <div id="deleteRoleModal" class="modal-overlay hidden">
        <div class="modal-container glass-card p-8 rounded-[2rem] border border-white/20 shadow-2xl text-center">
            <div class="w-20 h-20 rounded-3xl mx-auto flex items-center justify-center text-3xl mb-6 bg-rose-500/10 text-rose-500">
                <i class="fas fa-trash-alt"></i>
            </div>
            <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2">حذف الدور</h3>
            <p class="text-gray-500 font-bold mb-8">هل أنت متأكد من حذف دور <span id="delete-role-name" class="text-rose-600"></span>؟ <br> <span class="text-xs text-rose-500/70 mt-2 block">سيتم سحب جميع الصلاحيات المرتبطة بهذا الدور</span></p>
            
            <div class="flex items-center gap-3">
                <button type="button" onclick="closeModal('deleteRoleModal')" class="flex-1 py-4 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-black text-sm">تراجع</button>
                <form method="post" asp-action="Delete" class="flex-[2]">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="delete-role-id" name="id">
                    <button type="submit" class="w-full py-4 rounded-2xl bg-rose-500 text-white font-black text-sm shadow-xl shadow-rose-500/20 hover:bg-rose-600 transition-all">تأكيد الحذف</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Bulk Delete Modal -->
    <div id="bulkDeleteModal" class="modal-overlay hidden">
        <div class="modal-container glass-card p-8 rounded-[2rem] border border-white/20 shadow-2xl text-center">
            <div class="w-20 h-20 rounded-3xl mx-auto flex items-center justify-center text-3xl mb-6 bg-rose-600 text-white shadow-xl shadow-rose-600/30">
                <i class="fas fa-users-slash"></i>
            </div>
            <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2">حذف جماعي للأدوار</h3>
            <p class="text-gray-500 font-bold mb-8">أنت على وشك حذف <span id="bulk-delete-count" class="text-rose-600">0</span> أدوار نهائياً.</p>
            
            <div class="flex items-center gap-3">
                <button type="button" onclick="closeModal('bulkDeleteModal')" class="flex-1 py-4 rounded-2xl bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400 font-black text-sm">إلغاء</button>
                <form method="post" asp-action="BulkDelete" class="flex-[2]">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="bulk-delete-ids" name="roleIds">
                    <button type="submit" class="w-full py-4 rounded-2xl bg-rose-600 text-white font-black text-sm shadow-xl shadow-rose-600/20 hover:bg-rose-700 transition-all">تأكيد الحذف الجماعي</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // Modal Management
    function openModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) modal.classList.remove('hidden');
    }

    function closeModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) modal.classList.add('hidden');
    }

    // Specific Modal Showers
    function showEditModal(id, name) {
        document.getElementById('edit-role-id').value = id;
        document.getElementById('edit-role-name').value = name;
        openModal('editRoleModal');
    }

    function showDeleteModal(id, name) {
        document.getElementById('delete-role-id').value = id;
        document.getElementById('delete-role-name').textContent = name;
        openModal('deleteRoleModal');
    }

    // Main Functionality
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('search-roles');
        const resetBtn = document.getElementById('reset-filters');
        const selectAllCheckbox = document.getElementById('select-all');
        const roleCheckboxes = document.querySelectorAll('.role-checkbox');
        const bulkContainer = document.getElementById('bulk-actions-container');
        const selectedCountText = document.getElementById('selected-count');
        const bulkDeleteBtn = document.getElementById('apply-bulk-delete');
        
        let currentPage = 1;
        let rowsPerPage = 5;
        let filteredRows = Array.from(document.querySelectorAll('tbody tr[data-role-id]'));

        function updateUI() {
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            
            const allRows = document.querySelectorAll('tbody tr[data-role-id]');
            allRows.forEach(row => row.style.display = 'none');
            
            filteredRows.slice(start, end).forEach(row => row.style.display = 'table-row');
            
            document.getElementById('showing-from').textContent = filteredRows.length === 0 ? 0 : start + 1;
            document.getElementById('showing-to').textContent = Math.min(end, filteredRows.length);
            document.getElementById('total-items').textContent = filteredRows.length;
            
            renderPagination();
            updateBulkActions();
        }

        function renderPagination() {
            const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
            const container = document.getElementById('pagination-numbers');
            container.innerHTML = '';
            
            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('button');
                btn.className = `pagination-btn ${i === currentPage ? 'active' : ''}`;
                btn.textContent = i;
                btn.onclick = () => { currentPage = i; updateUI(); };
                container.appendChild(btn);
            }
            
            document.getElementById('prev-page').classList.toggle('disabled', currentPage === 1);
            document.getElementById('next-page').classList.toggle('disabled', currentPage === totalPages || totalPages === 0);
        }

        function filterRoles() {
            const term = searchInput.value.toLowerCase();
            filteredRows = Array.from(document.querySelectorAll('tbody tr[data-role-id]')).filter(row => {
                const name = row.getAttribute('data-role-name').toLowerCase();
                return name.includes(term);
            });
            currentPage = 1;
            updateUI();
        }

        function updateBulkActions() {
            const checked = document.querySelectorAll('.role-checkbox:checked').length;
            if (bulkContainer) {
                bulkContainer.classList.toggle('hidden', checked === 0);
                if (selectedCountText) selectedCountText.textContent = checked;
            }
        }

        // Event Listeners
        searchInput.addEventListener('input', filterRoles);
        resetBtn.addEventListener('click', () => {
            searchInput.value = '';
            filterRoles();
        });

        document.getElementById('rows-per-page').addEventListener('change', function() {
            rowsPerPage = parseInt(this.value);
            currentPage = 1;
            updateUI();
        });

        document.getElementById('prev-page').onclick = () => { if (currentPage > 1) { currentPage--; updateUI(); } };
        document.getElementById('next-page').onclick = () => { 
            const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
            if (currentPage < totalPages) { currentPage++; updateUI(); } 
        };

        if (selectAllCheckbox) {
            selectAllCheckbox.onclick = function() {
                const isChecked = this.checked;
                roleCheckboxes.forEach(cb => {
                    if (!cb.disabled) cb.checked = isChecked;
                });
                updateBulkActions();
            };
        }

        roleCheckboxes.forEach(cb => {
            cb.onclick = updateBulkActions;
        });

        if (bulkDeleteBtn) {
            bulkDeleteBtn.onclick = () => {
                const selectedIds = Array.from(document.querySelectorAll('.role-checkbox:checked')).map(cb => cb.value);
                document.getElementById('bulk-delete-ids').value = selectedIds.join(',');
                document.getElementById('bulk-delete-count').textContent = selectedIds.length;
                openModal('bulkDeleteModal');
            };
        }

        // Close on escape or outside click
        window.onclick = (e) => {
            if (e.target.classList.contains('modal-overlay')) {
                document.querySelectorAll('.modal-overlay').forEach(m => m.classList.add('hidden'));
            }
        };

        // Init
        updateUI();
    });
</script>
