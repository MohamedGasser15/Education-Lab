@model List<EduLab_MVC.Models.DTOs.History.HistoryDTO>
@{
    ViewData["Title"] = "سجل أحداث النظام";
}

<link rel="stylesheet" href="~/css/Admin/users.css">
<style>
    /* Modern Pagination */
    .pagination-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 12px;
        background: white;
        border: 1px solid #f1f5f9;
        color: #64748b;
        font-weight: 700;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .dark .pagination-btn {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.05);
        color: #94a3b8;
    }

    .pagination-btn:hover:not(.disabled) {
        background: #2563eb;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2);
    }

    .pagination-btn.active {
        background: #2563eb;
        color: white;
        border-color: #2563eb;
    }

    /* Operation Badges */
    .op-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.8rem;
        border-radius: 10px;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.025em;
    }

    .op-create { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
    .op-update { background: rgba(37, 99, 235, 0.1); color: #2563eb; border: 1px solid rgba(37, 99, 235, 0.2); }
    .op-delete { background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }
    .op-login { background: rgba(124, 58, 237, 0.1); color: #7c3aed; border: 1px solid rgba(124, 58, 237, 0.2); }
    .op-default { background: rgba(100, 116, 139, 0.1); color: #64748b; border: 1px solid rgba(100, 116, 139, 0.2); }
</style>

<!-- Premium History Page Container -->
<div class="space-y-8 animate-in fade-in duration-1000">
    
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-2">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">سجل <span class="text-primary-600">أحداث النظام</span> <i class="fas fa-history text-primary-600/50 mr-2"></i></h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1 font-medium">مراقبة وتتبع جميع العمليات التي تمت داخل لوحة التحكم.</p>
        </div>
        <div class="flex items-center gap-3">
             <button onclick="window.print()" class="flex items-center gap-2 px-5 py-3 rounded-2xl bg-white dark:bg-white/5 text-gray-600 dark:text-gray-300 font-bold text-sm shadow-sm hover:bg-gray-50 transition-all border border-gray-100 dark:border-white/5">
                <i class="fas fa-print"></i>
                <span>تصدير السجل</span>
            </button>
        </div>
    </div>

    <!-- Statistics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">إجمالي الأحداث</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count</h3>
                    <p class="text-[10px] text-gray-400 mt-2 font-medium">منذ إنشاء النظام</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-primary-600 flex items-center justify-center shadow-lg shadow-primary-600/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-list-ul text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-emerald-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">أحداث اليوم</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Count(h => h.Date == DateOnly.FromDateTime(DateTime.Today))</h3>
                    <p class="text-[10px] text-emerald-500 mt-2 font-bold"><i class="fas fa-circle text-[6px] ml-1"></i> نشاط حالي</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-bolt text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-purple-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">مستخدمين نشطين</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Select(h => h.UserName).Distinct().Count()</h3>
                    <p class="text-[10px] text-purple-500 mt-2 font-bold"><i class="fas fa-user-shield text-[10px] ml-1"></i> قاموا بعمليات</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-purple-600 flex items-center justify-center shadow-lg shadow-purple-600/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-user-shield text-white text-xl"></i>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 rounded-3xl relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-rose-600/10 rounded-full blur-2xl"></div>
            <div class="flex items-start justify-between relative z-10">
                <div>
                    <p class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">أنواع العمليات</p>
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white tabular-nums">@Model.Select(h => h.Operation).Distinct().Count()</h3>
                    <p class="text-[10px] text-rose-500 mt-2 font-bold"><i class="fas fa-cogs text-[10px] ml-1"></i> متنوعة</p>
                </div>
                <div class="w-12 h-12 rounded-2xl bg-rose-500 flex items-center justify-center shadow-lg shadow-rose-500/30 group-hover:rotate-6 transition-transform">
                    <i class="fas fa-cogs text-white text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Modern Filter Bar -->
    <div class="glass-card rounded-3xl p-6 mb-8">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 items-end">
            <div class="lg:col-span-2 space-y-2">
                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">بحث في السجلات</label>
                <div class="relative w-full">
                    <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-gray-400">
                        <i class="fas fa-search"></i>
                    </div>
                    <input type="text" id="search-input" 
                           class="w-full pr-11 pl-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white transition-all font-medium" 
                           placeholder="ابحث باسم المستخدم أو نوع العملية...">
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">تصفية بالمستخدم</label>
                <select id="user-filter" class="w-full px-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white font-bold text-sm transition-all">
                    <option value="">جميع المستخدمين</option>
                    @foreach (var user in Model.Select(h => h.UserName).Distinct())
                    {
                        <option value="@user">@user</option>
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">النطاق الزمني</label>
                <select id="date-filter" class="w-full px-4 py-3 bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/5 rounded-2xl focus:ring-2 focus:ring-primary-600 outline-none dark:text-white font-bold text-sm transition-all">
                    <option value="all">كل التواريخ</option>
                    <option value="today">اليوم</option>
                    <option value="yesterday">أمس</option>
                    <option value="week">آخر 7 أيام</option>
                    <option value="month">آخر 30 يوم</option>
                    <option value="custom">مخصص...</option>
                </select>
            </div>
        </div>

        <!-- Custom Date Range (Hidden) -->
        <div id="custom-date-container" class="hidden mt-6 animate-in slide-in-from-top-2 duration-300">
            <div class="flex flex-col md:flex-row items-center gap-4 p-4 rounded-2xl bg-primary-600/5 border border-primary-600/10">
                <div class="flex-1 w-full space-y-1">
                    <label class="text-[10px] font-bold text-primary-600 uppercase mr-1">من تاريخ</label>
                    <input type="date" id="from-date" class="w-full px-4 py-2 rounded-xl border-none bg-white dark:bg-gray-800 text-sm font-bold shadow-sm">
                </div>
                <div class="flex-1 w-full space-y-1">
                    <label class="text-[10px] font-bold text-primary-600 uppercase mr-1">إلى تاريخ</label>
                    <input type="date" id="to-date" class="w-full px-4 py-2 rounded-xl border-none bg-white dark:bg-gray-800 text-sm font-bold shadow-sm">
                </div>
                <button id="apply-custom-date" class="mt-5 md:mt-0 px-6 py-2 bg-primary-600 text-white rounded-xl text-xs font-black shadow-lg shadow-primary-600/20">تطبيق</button>
            </div>
        </div>
    </div>

    <!-- Premium History Table Area -->
    <div class="glass-card rounded-3xl overflow-hidden shadow-2xl">
        <div class="overflow-x-auto">
            <table class="w-full text-right border-collapse">
                <thead>
                    <tr class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest bg-gray-50/50 dark:bg-white/5">
                        <th class="px-8 py-5 w-20">ID</th>
                        <th class="px-8 py-5">المسؤول</th>
                        <th class="px-8 py-5">العملية المنفذة</th>
                        <th class="px-8 py-5">التاريخ والوقت</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/5">
                    @foreach (var log in Model.OrderByDescending(h => h.Date).ThenByDescending(h => h.Time))
                    {
                        <tr class="history-row hover:bg-gray-50/50 dark:hover:bg-white/5 transition-colors group border-b border-gray-100 dark:border-white/5"
                            data-user="@log.UserName"
                            data-date="@log.Date.ToString("yyyy-MM-dd")"
                            data-operation="@log.Operation">
                            
                            <td class="px-8 py-5">
                                <span class="text-xs font-black text-gray-400">#@log.Id</span>
                            </td>

                            <td class="px-8 py-5">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-primary-600/10 text-primary-600 flex items-center justify-center overflow-hidden shadow-sm">
                                        @if (!string.IsNullOrEmpty(log.ProfileImageUrl))
                                        {
                                            <img src="@log.ProfileImageUrl" class="w-full h-full object-cover">
                                        }
                                        else
                                        {
                                            <i class="fas fa-user-shield text-sm"></i>
                                        }
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-black text-gray-900 dark:text-white group-hover:text-primary-600 transition-colors">@log.UserName</h4>
                                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Admin User</p>
                                    </div>
                                </div>
                            </td>

                            <td class="px-8 py-5">
                                @{
                                    var op = log.Operation.ToLower();
                                    var opClass = op.Contains("create") || op.Contains("إضافة") ? "op-create" :
                                                 op.Contains("update") || op.Contains("تعديل") ? "op-update" :
                                                 op.Contains("delete") || op.Contains("حذف") ? "op-delete" :
                                                 op.Contains("login") || op.Contains("دخول") ? "op-login" : "op-default";
                                    var icon = op.Contains("create") || op.Contains("إضافة") ? "fa-plus-circle" :
                                               op.Contains("update") || op.Contains("تعديل") ? "fa-edit" :
                                               op.Contains("delete") || op.Contains("حذف") ? "fa-trash-alt" :
                                               op.Contains("login") || op.Contains("دخول") ? "fa-sign-in-alt" : "fa-info-circle";
                                }
                                <span class="op-badge @opClass">
                                    <i class="fas @icon text-[10px]"></i>
                                    @log.Operation
                                </span>
                            </td>

                            <td class="px-8 py-5">
                                <div class="flex flex-col">
                                    <span class="text-xs font-black text-gray-700 dark:text-gray-300">@log.Date.ToString("yyyy-MM-dd")</span>
                                    <span class="text-[10px] text-gray-400 font-bold italic tracking-tighter">
                                        <i class="far fa-clock ml-1"></i> @log.Time.ToString("HH:mm:ss")
                                    </span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Premium Pagination -->
        <div class="px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-6 bg-gray-50/50 dark:bg-white/5 border-t border-gray-100 dark:border-white/5">
            <div class="text-sm font-bold text-gray-500 dark:text-gray-400 order-2 md:order-1">
                عرض <span id="showing-from" class="text-primary-600">1</span> إلى <span id="showing-to" class="text-primary-600">5</span> من أصل <span id="total-items" class="text-gray-900 dark:text-white">@Model.Count</span> حدث
            </div>
            
            <div class="flex items-center gap-4 order-1 md:order-2">
                <div class="pagination-controls flex items-center gap-2">
                    <button id="prev-page" class="pagination-btn disabled" title="السابق">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </button>
                    <div id="pagination-numbers" class="flex gap-2"></div>
                    <button id="next-page" class="pagination-btn" title="التالي">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </button>
                </div>

                <div class="h-8 w-px bg-gray-200 dark:bg-white/10 hidden sm:block"></div>

                <select id="rows-per-page" class="px-3 py-2 bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl text-xs font-black text-gray-600 dark:text-gray-300 focus:ring-2 focus:ring-primary-600 outline-none transition-all">
                    <option value="5" selected>5 / صفحة</option>
                    <option value="10">10 / صفحة</option>
                    <option value="20">20 / صفحة</option>
                </select>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    $(document).ready(function() {
        let currentPage = 1;
        let rowsPerPage = 5;
        let filteredRows = $('.history-row');

        function updateUI() {
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            
            $('.history-row').hide();
            filteredRows.slice(start, end).fadeIn(300).css('display', 'table-row');
            
            $('#showing-from').text(filteredRows.length === 0 ? 0 : start + 1);
            $('#showing-to').text(Math.min(end, filteredRows.length));
            $('#total-items').text(filteredRows.length);
            
            renderPagination();
        }

        function renderPagination() {
            const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
            const container = $('#pagination-numbers');
            container.empty();
            
            let start = Math.max(1, currentPage - 1);
            let end = Math.min(totalPages, start + 2);
            if (end - start < 2) start = Math.max(1, end - 2);

            for (let i = start; i <= end; i++) {
                const btn = $('<button>').addClass(`pagination-btn ${i === currentPage ? 'active' : ''}`).text(i);
                btn.click(() => { currentPage = i; updateUI(); });
                container.append(btn);
            }
            
            $('#prev-page').toggleClass('disabled', currentPage === 1);
            $('#next-page').toggleClass('disabled', currentPage === totalPages || totalPages === 0);
        }

        function applyFilters() {
            const term = $('#search-input').val().toLowerCase();
            const user = $('#user-filter').val();
            const dateRange = $('#date-filter').val();
            
            filteredRows = $('.history-row').filter(function() {
                const row = $(this);
                const text = row.text().toLowerCase();
                const rowUser = row.data('user');
                const rowDate = new Date(row.data('date'));
                rowDate.setHours(0,0,0,0);
                
                const matchesSearch = text.includes(term);
                const matchesUser = !user || rowUser === user;
                
                let matchesDate = true;
                const today = new Date();
                today.setHours(0,0,0,0);

                if (dateRange !== 'all') {
                    switch(dateRange) {
                        case 'today':
                            matchesDate = rowDate.getTime() === today.getTime();
                            break;
                        case 'yesterday':
                            const yesterday = new Date(today);
                            yesterday.setDate(yesterday.getDate() - 1);
                            matchesDate = rowDate.getTime() === yesterday.getTime();
                            break;
                        case 'week':
                            const weekAgo = new Date(today);
                            weekAgo.setDate(weekAgo.getDate() - 7);
                            matchesDate = rowDate >= weekAgo;
                            break;
                        case 'month':
                            const monthAgo = new Date(today);
                            monthAgo.setDate(monthAgo.getDate() - 30);
                            matchesDate = rowDate >= monthAgo;
                            break;
                        case 'custom':
                            const from = new Date($('#from-date').val());
                            const to = new Date($('#to-date').val());
                            if ($('#from-date').val() && $('#to-date').val()) {
                                from.setHours(0,0,0,0);
                                to.setHours(0,0,0,0);
                                matchesDate = rowDate >= from && rowDate <= to;
                            }
                            break;
                    }
                }
                
                return matchesSearch && matchesUser && matchesDate;
            });
            
            currentPage = 1;
            updateUI();
        }

        $('#search-input').on('input', applyFilters);
        $('#user-filter, #date-filter').change(function() {
            $('#custom-date-container').toggleClass('hidden', $('#date-filter').val() !== 'custom');
            applyFilters();
        });
        
        $('#apply-custom-date').click(applyFilters);
        
        $('#reset-filters').click(function() {
            $('#search-input').val('');
            $('#user-filter').val('');
            $('#date-filter').val('all');
            $('#custom-date-container').addClass('hidden');
            applyFilters();
        });

        $('#rows-per-page').change(function() {
            rowsPerPage = parseInt($(this).val());
            currentPage = 1;
            updateUI();
        });

        $('#prev-page').click(() => { if (currentPage > 1) { currentPage--; updateUI(); } });
        $('#next-page').click(() => { 
            const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
            if (currentPage < totalPages) { currentPage++; updateUI(); } 
        });

        updateUI();
    });
</script>
