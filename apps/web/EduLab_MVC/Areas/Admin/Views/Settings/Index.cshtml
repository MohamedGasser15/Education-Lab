@using System.Globalization
@model EduLab_MVC.Models.DTOs.Settings.SiteSettingsDTO
@{
    ViewData["Title"] = Localizer["GeneralSettings"];
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<link rel="stylesheet" href="~/css/Admin/settings.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">

<div class="space-y-8 animate-in fade-in duration-700">


    <!-- ===== Navigation Filter Tabs ===== -->
    <div class="settings-tabs">
        <button class="settings-tab active" onclick="switchTab('all', this)">
            <i class="fas fa-layer-group tab-icon"></i>
            <span>@Localizer["AllSettings"]</span>
        </button>
        <button class="settings-tab" onclick="switchTab('card-site-info', this)">
            <i class="fas fa-globe tab-icon text-primary-500"></i>
            <span>@Localizer["SiteInformation"]</span>
        </button>
        <button class="settings-tab" onclick="switchTab('card-appearance', this)">
            <i class="fas fa-palette tab-icon text-emerald-500"></i>
            <span>@Localizer["Appearance"]</span>
        </button>
        <button class="settings-tab" onclick="switchTab('card-logo', this)">
            <i class="fas fa-image tab-icon text-amber-500"></i>
            <span>@Localizer["Logo"]</span>
        </button>
        <button class="settings-tab" onclick="switchTab('card-seo', this)">
            <i class="fas fa-tag tab-icon text-purple-500"></i>
            <span>@Localizer["SEOMeta"]</span>
        </button>
        <button class="settings-tab" onclick="switchTab('card-status', this)">
            <i class="fas fa-shield-halved tab-icon text-rose-500"></i>
            <span>@Localizer["SiteStatus"]</span>
        </button>
    </div>

    <!-- ===== Main Content Grid ===== -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- ─── Left / Main Column (8 cols) ─── -->
        <div class="lg:col-span-8 space-y-8">

            <!-- Card: Site Information -->
            <div id="card-site-info" class="settings-card p-6 lg:p-8">
                <div class="card-accent"></div>
                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-7">
                        <div class="flex items-center gap-4">
                            <div class="icon-wrapper bg-primary-500/10 dark:bg-primary-500/20 text-primary-600 dark:text-primary-400">
                                <i class="fas fa-globe text-lg"></i>
                            </div>
                            <div>
                                <h2 class="text-lg font-bold text-gray-900 dark:text-white">@Localizer["SiteInformation"]</h2>
                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@Localizer["SiteInformationDesc"]</p>
                            </div>
                        </div>
                        <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">@Localizer["Core"]</span>
                    </div>

                    <div class="space-y-5">
                        <div class="setting-field">
                            <label class="setting-label">
                                <span>@Localizer["SiteName"] <span class="text-red-500">*</span></span>
                                <span class="text-[11px] text-gray-400 font-normal" id="siteNameCount">6 / 60</span>
                            </label>
                            <input type="text" class="setting-input" id="siteName" value="@Model.SiteName" placeholder="@Localizer["SiteNamePlaceholder"]" maxlength="60" oninput="updateLivePreview(); trackChanges();">
                        </div>

                        <div class="setting-field">
                            <label class="setting-label">
                                <span>@Localizer["SiteDescription"]</span>
                                <span class="text-[11px] text-gray-400 font-normal" id="siteDescCount">75 / 250</span>
                            </label>
                            <textarea class="setting-input" id="siteDescription" rows="3" placeholder="@Localizer["SiteDescriptionPlaceholder"]" maxlength="250" oninput="trackChanges();">@Model.SiteDescription</textarea>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="setting-field">
                                <label class="setting-label">
                                    <span>@Localizer["DefaultLanguage"]</span>
                                </label>
                                <select class="setting-input" id="defaultLanguage" onchange="trackChanges();">
                                    <option value="en" selected="@(Model.DefaultLanguage == "en")">@Localizer["LanguageEnglish"]</option>
                                    <option value="ar" selected="@(Model.DefaultLanguage == "ar")">@Localizer["LanguageArabic"]</option>
                                    <option value="fr" selected="@(Model.DefaultLanguage == "fr")">@Localizer["LanguageFrench"]</option>
                                    <option value="es" selected="@(Model.DefaultLanguage == "es")">@Localizer["LanguageSpanish"]</option>
                                    <option value="de" selected="@(Model.DefaultLanguage == "de")">@Localizer["LanguageGerman"]</option>
                                </select>
                            </div>

                            <div class="setting-field">
                                <label class="setting-label">
                                    <span>@Localizer["Timezone"]</span>
                                </label>
                                <select class="setting-input" id="timezone" onchange="trackChanges();">
                                    <option value="UTC" selected="@(Model.Timezone == "UTC")">@Localizer["TimezoneUTC"]</option>
                                    <option value="Africa/Cairo" selected="@(Model.Timezone == "Africa/Cairo")">@Localizer["TimezoneCairo"]</option>
                                    <option value="America/New_York" selected="@(Model.Timezone == "America/New_York")">@Localizer["TimezoneNewYork"]</option>
                                    <option value="Europe/London" selected="@(Model.Timezone == "Europe/London")">@Localizer["TimezoneLondon"]</option>
                                    <option value="Asia/Dubai" selected="@(Model.Timezone == "Asia/Dubai")">@Localizer["TimezoneDubai"]</option>
                                    <option value="Asia/Riyadh" selected="@(Model.Timezone == "Asia/Riyadh")">@Localizer["TimezoneRiyadh"]</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card: Appearance -->
            <div id="card-appearance" class="settings-card p-6 lg:p-8">
                <div class="card-accent" style="background: linear-gradient(90deg, transparent, rgba(16, 185, 129, 0.6), transparent);"></div>
                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-7">
                        <div class="flex items-center gap-4">
                            <div class="icon-wrapper bg-emerald-500/10 dark:bg-emerald-500/20 text-emerald-500">
                                <i class="fas fa-palette text-lg"></i>
                            </div>
                            <div>
                                <h2 class="text-lg font-bold text-gray-900 dark:text-white">@Localizer["Appearance"]</h2>
                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@Localizer["AppearanceDesc"]</p>
                            </div>
                        </div>
                        <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400">@Localizer["Branding"]</span>
                    </div>

                    <div class="space-y-6">
                        <!-- Primary Color Selector & Swatches -->
                        <div class="setting-field">
                            <label class="setting-label mb-2">
                                <span>@Localizer["PrimaryColor"]</span>
                                <span class="text-[11px] font-mono text-gray-400" id="colorHexDisplay">#2563eb</span>
                            </label>

                            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                                <div class="flex items-center gap-3">
                                    <div class="relative">
                                        <input type="color" class="w-12 h-12 rounded-xl border-2 border-gray-200 dark:border-gray-700 cursor-pointer bg-transparent p-1" id="primaryColor" value="@Model.PrimaryColor" oninput="syncColorInput(this.value)">
                                    </div>
                                    <input type="text" class="setting-input font-mono w-28 uppercase text-center" id="primaryColorHex" value="@Model.PrimaryColor" maxlength="7" oninput="syncHexInput(this.value)">
                                </div>

                                <!-- Preset Color Chips -->
                                <div class="flex items-center gap-2.5 pt-1 sm:pt-0 sm:border-l sm:border-gray-200 dark:sm:border-gray-700 sm:pl-4">
                                    <button type="button" class="color-swatch selected" style="background-color: #2563eb;" title="@Localizer["EduBlue"]" onclick="selectColorSwatch('#2563eb', this)"></button>
                                    <button type="button" class="color-swatch" style="background-color: #10b981;" title="@Localizer["EmeraldGreen"]" onclick="selectColorSwatch('#10b981', this)"></button>
                                    <button type="button" class="color-swatch" style="background-color: #8b5cf6;" title="@Localizer["RoyalViolet"]" onclick="selectColorSwatch('#8b5cf6', this)"></button>
                                    <button type="button" class="color-swatch" style="background-color: #f43f5e;" title="@Localizer["CrimsonRose"]" onclick="selectColorSwatch('#f43f5e', this)"></button>
                                    <button type="button" class="color-swatch" style="background-color: #f59e0b;" title="@Localizer["AmberSunset"]" onclick="selectColorSwatch('#f59e0b', this)"></button>
                                    <button type="button" class="color-swatch" style="background-color: #0f172a;" title="@Localizer["DarkSlate"]" onclick="selectColorSwatch('#0f172a', this)"></button>
                                </div>
                            </div>
                        </div>

                        <!-- Theme Selection -->
                        <div class="setting-field">
                            <label class="setting-label mb-2">
                                <span>@Localizer["DefaultTheme"]</span>
                            </label>
                            <div class="grid grid-cols-3 gap-3">
                                <label class="theme-option cursor-pointer">
                                    <input type="radio" name="themeRadio" value="light" class="peer hidden" @(Model.DefaultTheme == "light" ? "checked" : "") onchange="setThemeMode('light'); trackChanges();">
                                    <div class="p-3.5 rounded-2xl border-2 border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-center transition-all peer-checked:border-primary-600 peer-checked:bg-primary-500/5 dark:peer-checked:bg-primary-500/10">
                                        <i class="fas fa-sun text-amber-500 text-xl mb-1.5 block"></i>
                                        <span class="text-xs font-bold text-gray-800 dark:text-gray-200 block">@Localizer["Light"]</span>
                                    </div>
                                </label>

                                <label class="theme-option cursor-pointer">
                                    <input type="radio" name="themeRadio" value="dark" class="peer hidden" @(Model.DefaultTheme == "dark" ? "checked" : "") onchange="setThemeMode('dark'); trackChanges();">
                                    <div class="p-3.5 rounded-2xl border-2 border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-center transition-all peer-checked:border-primary-600 peer-checked:bg-primary-500/5 dark:peer-checked:bg-primary-500/10">
                                        <i class="fas fa-moon text-indigo-500 text-xl mb-1.5 block"></i>
                                        <span class="text-xs font-bold text-gray-800 dark:text-gray-200 block">@Localizer["Dark"]</span>
                                    </div>
                                </label>

                                <label class="theme-option cursor-pointer">
                                    <input type="radio" name="themeRadio" value="system" class="peer hidden" @(Model.DefaultTheme == "system" ? "checked" : "") onchange="setThemeMode('system'); trackChanges();">
                                    <div class="p-3.5 rounded-2xl border-2 border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-center transition-all peer-checked:border-primary-600 peer-checked:bg-primary-500/5 dark:peer-checked:bg-primary-500/10">
                                        <i class="fas fa-desktop text-primary-500 text-xl mb-1.5 block"></i>
                                        <span class="text-xs font-bold text-gray-800 dark:text-gray-200 block">@Localizer["SystemPreference"]</span>
                                    </div>
                                </label>
                            </div>
                            <select class="setting-input hidden" id="defaultTheme">
                                <option value="light" selected="@(Model.DefaultTheme == "light" ? "selected" : null)">@Localizer["Light"]</option>
                                <option value="dark" selected="@(Model.DefaultTheme == "dark" ? "selected" : null)">@Localizer["Dark"]</option>
                                <option value="system" selected="@(Model.DefaultTheme == "system" ? "selected" : null)">@Localizer["SystemPreference"]</option>
                            </select>
                        </div>

                        <!-- Favicon Upload -->
                        <div class="setting-field pt-2">
                            <label class="setting-label mb-2">
                                <span>@Localizer["Favicon"]</span>
                                <span class="text-[11px] text-gray-400">@Localizer["RecommendedSize", "16x16, 32x32"]</span>
                            </label>
                            <div class="flex items-center gap-5 p-4 rounded-2xl bg-gray-50/80 dark:bg-gray-800/40 border border-gray-100 dark:border-gray-700/50">
                                <div class="logo-upload w-16 h-16 rounded-xl flex-shrink-0 @(!string.IsNullOrEmpty(Model.FaviconUrl) ? "has-image" : "")" onclick="document.getElementById('faviconInput').click()">
                                    <img id="faviconPreview" src="@(!string.IsNullOrEmpty(Model.FaviconUrl) ? Model.FaviconUrl : "~/Img/Logo/favicon-32x32.png")" alt="Favicon" class="w-8 h-8 object-contain @(string.IsNullOrEmpty(Model.FaviconUrl) ? "hidden" : "")">
                                    <i id="faviconPlaceholder" class="fas fa-image text-xl text-gray-400 @(!string.IsNullOrEmpty(Model.FaviconUrl) ? "hidden" : "")"></i>
                                    <input type="file" id="faviconInput" accept="image/*" class="hidden" onchange="openCropModal(this, 'faviconPreview', 'faviconPlaceholder', null, true); trackChanges();">
                                </div>
                                <div class="flex-1">
                                    <p class="text-xs font-bold text-gray-800 dark:text-gray-200">@Localizer["SystemBrowserIcon"]</p>
                                    <p class="text-[11px] text-gray-400 mt-0.5">@Localizer["SystemBrowserIconDesc"]</p>
                                    <button type="button" onclick="document.getElementById('faviconInput').click()" class="mt-2 text-xs font-bold text-primary-600 hover:text-primary-700 dark:text-primary-400 hover:underline">
                                        <i class="fas fa-upload @(isArabic ? "ml-1" : "mr-1")"></i> @Localizer["ChangeFavicon"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card: SEO Meta -->
            <div id="card-seo" class="settings-card p-6 lg:p-8">
                <div class="card-accent" style="background: linear-gradient(90deg, transparent, rgba(168, 85, 247, 0.6), transparent);"></div>
                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-7">
                        <div class="flex items-center gap-4">
                            <div class="icon-wrapper bg-purple-500/10 dark:bg-purple-500/20 text-purple-500">
                                <i class="fas fa-search text-lg"></i>
                            </div>
                            <div>
                                <h2 class="text-lg font-bold text-gray-900 dark:text-white">@Localizer["SEOMeta"]</h2>
                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@Localizer["SEOMetaDesc"]</p>
                            </div>
                        </div>
                        <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-purple-500/10 text-purple-600 dark:text-purple-400">@Localizer["Indexing"]</span>
                    </div>

                    <div class="space-y-5">
                        <div class="setting-field">
                            <label class="setting-label">
                                <span>@Localizer["MetaKeywords"]</span>
                                <span class="text-[11px] text-gray-400 font-normal">@Localizer["CommaSeparated"]</span>
                            </label>
                            <input type="text" class="setting-input" id="metaKeywords" value="@Model.MetaKeywords" placeholder="@Localizer["MetaKeywordsPlaceholder"]" oninput="trackChanges();">
                        </div>

                        <div class="setting-field">
                            <label class="setting-label">
                                <span>@Localizer["MetaDescription"]</span>
                            </label>
                            <textarea class="setting-input" id="metaDescription" rows="3" placeholder="@Localizer["MetaDescriptionPlaceholder"]" oninput="trackChanges();">@Model.MetaDescription</textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card: Site Status & Maintenance -->
            <div id="card-status" class="settings-card p-6 lg:p-8">
                <div class="card-accent" style="background: linear-gradient(90deg, transparent, rgba(244, 63, 94, 0.6), transparent);"></div>
                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-6">
                        <div class="flex items-center gap-4">
                            <div class="icon-wrapper bg-rose-500/10 dark:bg-rose-500/20 text-rose-500">
                                <i class="fas fa-shield-halved text-lg"></i>
                            </div>
                            <div>
                                <h2 class="text-lg font-bold text-gray-900 dark:text-white">@Localizer["SiteStatus"]</h2>
                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@Localizer["SiteStatusDesc"]</p>
                            </div>
                        </div>
                        <span id="systemStatusBadge" class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400">
                            @Localizer["Active"]
                        </span>
                    </div>

                    <div class="space-y-5">
                        <div class="flex items-center justify-between p-4.5 rounded-2xl bg-gray-50/80 dark:bg-gray-800/40 border border-gray-100 dark:border-gray-700/50">
                            <div class="flex items-center gap-3.5">
                                <div class="w-10 h-10 rounded-xl bg-amber-500/10 text-amber-500 flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-wrench text-base"></i>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-gray-800 dark:text-white">@Localizer["MaintenanceMode"]</p>
                                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@Localizer["MaintenanceModeToggleDesc"]</p>
                                </div>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" id="maintenanceMode" @(Model.MaintenanceMode ? "checked" : "") onchange="toggleMaintenanceMode(this.checked); trackChanges();">
                                <div class="toggle-track"><div class="toggle-knob"></div></div>
                            </label>
                        </div>

                        <!-- Maintenance Message Container -->
                        <div id="maintenanceMessageContainer" class="hidden space-y-3 transition-all duration-300">
                            <div class="p-4 rounded-2xl bg-amber-500/10 border border-amber-500/20 text-amber-800 dark:text-amber-300 text-xs flex items-start gap-3">
                                <i class="fas fa-exclamation-triangle text-amber-500 text-base mt-0.5"></i>
                                <div>
                                    <span class="font-bold block mb-0.5">@Localizer["MaintenanceModeEnabled"]</span>
                                    <span>@Localizer["MaintenanceModeEnabledDesc"]</span>
                                </div>
                            </div>

                            <div class="setting-field">
                                <label class="setting-label">
                                    <span>@Localizer["MaintenanceMessage"]</span>
                                </label>
                                <textarea class="setting-input" id="maintenanceMessage" rows="2" placeholder="@Localizer["MaintenanceMessagePlaceholder"]" oninput="trackChanges();">@Model.MaintenanceMessage</textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ─── Right / Sidebar Column (4 cols) ─── -->
        <div class="lg:col-span-4 space-y-8">

            <!-- Card: Live Preview -->
            <div id="card-live-preview" class="settings-card p-5">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-xs font-extrabold uppercase tracking-wider text-gray-400">@Localizer["LiveHeaderPreview"]</h3>
                    <div class="flex items-center gap-1.5 text-[10px] text-gray-400">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                        <span>Live</span>
                    </div>
                </div>

                <div class="rounded-2xl overflow-hidden border border-gray-200/60 dark:border-gray-700/50 shadow-sm">
                    <!-- Browser bar -->
                    <div class="flex items-center gap-1.5 px-3 py-2 bg-gray-100 dark:bg-gray-800 border-b border-gray-200/60 dark:border-gray-700/50">
                        <span class="w-2 h-2 rounded-full bg-red-400"></span>
                        <span class="w-2 h-2 rounded-full bg-yellow-400"></span>
                        <span class="w-2 h-2 rounded-full bg-green-400"></span>
                        <span class="mx-auto text-[9px] text-gray-400 font-mono flex items-center gap-1">
                            <i class="fas fa-lock text-[7px] text-emerald-500"></i> edulab.local
                        </span>
                    </div>

                    <!-- Mock navbar -->
                    <div class="flex items-center justify-between px-4 py-3 bg-white dark:bg-gray-900">
                        <div class="flex items-center gap-2">
                            <div class="w-6 h-6 rounded-lg overflow-hidden flex items-center justify-center text-primary-600" id="previewLogoBox">
                                <i class="fas fa-graduation-cap text-xs" id="previewLogoIcon"></i>
                                <img id="previewLogoImg" src="" alt="" class="w-full h-full object-contain hidden">
                            </div>
                            <span class="font-bold text-sm text-gray-900 dark:text-white" id="previewSiteName">@Model.SiteName</span>
                        </div>
                        <span class="text-[9px] px-2.5 py-1 rounded-md text-white font-bold transition-colors" id="previewBrandBtn" style="background-color:#2563eb">
                            @Localizer["Explore"]
                        </span>
                    </div>

                    <!-- Mock body -->
                    <div class="px-4 py-3 bg-gray-50/80 dark:bg-gray-900/50 space-y-2">
                        <div class="h-1.5 w-3/4 rounded-full bg-gray-200 dark:bg-gray-800"></div>
                        <div class="h-1.5 w-1/2 rounded-full bg-gray-200 dark:bg-gray-800"></div>
                    </div>
                </div>
            </div>

            <!-- Card: Brand Logo Upload -->
            <div id="card-logo" class="settings-card p-6 lg:p-8">
                <div class="card-accent" style="background: linear-gradient(90deg, transparent, rgba(245, 158, 11, 0.6), transparent);"></div>
                <div class="relative z-10">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="icon-wrapper bg-amber-500/10 dark:bg-amber-500/20 text-amber-500">
                            <i class="fas fa-image text-lg"></i>
                        </div>
                        <div>
                            <h2 class="text-lg font-bold text-gray-900 dark:text-white">@Localizer["Logo"]</h2>
                            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@Localizer["LogoDesc"]</p>
                        </div>
                    </div>

                    <div class="flex flex-col items-center gap-5">
                        <div class="logo-upload w-full h-36 group @(!string.IsNullOrEmpty(Model.LogoUrl) ? "has-image" : "")" id="logoDropZone" onclick="document.getElementById('logoInput').click()">
                            <img id="logoPreview" src="@Model.LogoUrl" alt="Logo" class="w-full h-full object-contain p-3 @(string.IsNullOrEmpty(Model.LogoUrl) ? "hidden" : "")">
                            <div id="logoPlaceholder" class="text-center @(!string.IsNullOrEmpty(Model.LogoUrl) ? "hidden" : "")">
                                <div class="w-12 h-12 rounded-2xl bg-amber-500/10 text-amber-500 flex items-center justify-center mx-auto mb-1.5 group-hover:scale-110 transition-transform">
                                    <i class="fas fa-cloud-upload-alt text-xl"></i>
                                </div>
                                <span class="text-xs font-bold text-gray-700 dark:text-gray-300 block">@Localizer["ClickToUpload"]</span>
                                <span class="text-[10px] text-gray-400 mt-0.5 block">@Localizer["DragDropImageHere"]</span>
                            </div>
                            <input type="file" id="logoInput" accept="image/*" class="hidden" onchange="openCropModal(this, 'logoPreview', 'logoPlaceholder', 'logoDropZone'); trackChanges();">
                        </div>

                        <div class="p-3.5 rounded-2xl bg-gray-50 dark:bg-gray-800/40 border border-gray-100 dark:border-gray-700/50 w-full text-center">
                            <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
                                @Localizer["LogoRecommended"]
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card: System Info & Quick Action Tools -->
            <div class="settings-card p-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-8 h-8 rounded-xl bg-blue-500/10 text-blue-500 flex items-center justify-center">
                        <i class="fas fa-bolt text-xs"></i>
                    </div>
                    <h3 class="text-sm font-bold text-gray-800 dark:text-white">@Localizer["SystemTools"]</h3>
                </div>

                <div class="space-y-3 text-xs">
                    <div class="flex items-center justify-between p-2.5 rounded-xl bg-gray-50 dark:bg-gray-800/40 text-gray-600 dark:text-gray-400 font-medium">
                        <span>@Localizer["Framework"]</span>
                        <span class="font-bold text-gray-900 dark:text-white">ASP.NET Core MVC 9</span>
                    </div>

                    <div class="flex items-center justify-between p-2.5 rounded-xl bg-gray-50 dark:bg-gray-800/40 text-gray-600 dark:text-gray-400 font-medium">
                        <span>@Localizer["DatabaseConnection"]</span>
                        <span class="font-bold text-emerald-500 flex items-center gap-1">
                            <i class="fas fa-check-circle"></i> @Localizer["Connected"]
                        </span>
                    </div>

                    <button type="button" onclick="clearCache(this)" class="w-full mt-2 py-2.5 px-4 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-bold hover:bg-gray-100 dark:hover:bg-gray-800 transition-all flex items-center justify-center gap-2">
                        <i class="fas fa-broom text-amber-500"></i>
                        <span>@Localizer["ClearApplicationCache"]</span>
                    </button>
                </div>
            </div>

        </div>
    </div>

    <!-- ===== Sticky Floating Save Bar ===== -->
    <div id="saveBar" class="save-bar">
        <div class="changes-count">
            <span class="dot"></span>
            <span>@Localizer["UnsavedChanges"]</span>
            <span id="changesBadgeCount" class="px-2 py-0.5 text-xs bg-amber-500/20 text-amber-300 rounded-full font-extrabold ml-1">1</span>
        </div>
        <div class="flex items-center gap-3">
            <button onclick="resetForm()" class="px-4 py-2 rounded-xl border border-gray-600 text-gray-300 font-bold text-xs hover:bg-gray-800 transition-all">
                <i class="fas fa-undo @(isArabic ? "ml-1" : "mr-1")"></i> @Localizer["Reset"]
            </button>
            <button onclick="saveSettings()" class="ripple-btn px-6 py-2 rounded-xl bg-gradient-to-r from-primary-600 to-primary-500 text-white font-bold text-xs hover:from-primary-700 hover:to-primary-600 transition-all shadow-lg shadow-primary-600/30">
                <i class="fas fa-save @(isArabic ? "ml-1" : "mr-1")"></i> @Localizer["SaveSettings"]
            </button>
        </div>
    </div>

</div>

<!-- Crop Modal -->
<div id="cropModal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 hidden" style="backdrop-filter:blur(8px)">
    <div class="bg-white dark:bg-gray-800 rounded-3xl w-full max-w-2xl mx-4 overflow-hidden shadow-2xl animate-scale-in">
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">@Localizer["CropImage"]</h3>
            <button type="button" onclick="closeCropModal()" class="w-8 h-8 rounded-xl bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-500 hover:text-red-500 transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="p-6">
            <div id="cropContainer" class="max-h-[400px] mx-auto">
                <img id="cropImage" src="" alt="Crop">
            </div>
        </div>
        <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700 flex items-center justify-end gap-3">
            <button type="button" onclick="closeCropModal()" class="px-5 py-2 rounded-xl border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-bold text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-all">
                @Localizer["Cancel"]
            </button>
            <button type="button" onclick="applyCrop()" class="px-6 py-2 rounded-xl bg-primary-600 text-white font-bold text-sm hover:bg-primary-700 transition-all shadow-lg shadow-primary-600/20">
                <i class="fas fa-check @(isArabic ? "ml-2" : "mr-2")"></i> @Localizer["Apply"]
            </button>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

@section Scripts {
    <script>
        let cropper = null;
        let cropResolve = null;
        let isFormDirty = false;

        // Initialize state & previews
        document.addEventListener('DOMContentLoaded', () => {
            updateLivePreview();
            setupDragAndDrop();
            updateCharCounters();

            // Init maintenance mode state
            @if (Model.MaintenanceMode)
            {
                <text>
                toggleMaintenanceMode(true);
                document.getElementById('maintenanceMode').checked = true;
                </text>
            }

            // Keyboard shortcut Ctrl+S / Cmd+S
            document.addEventListener('keydown', (e) => {
                if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                    e.preventDefault();
                    saveSettings();
                }
            });
        });

        // Tab Switching & Smooth Filtering
        function switchTab(tabId, btn) {
            document.querySelectorAll('.settings-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');

            const cards = document.querySelectorAll('.settings-card');
            if (tabId === 'all') {
                cards.forEach(card => card.style.display = 'block');
            } else {
                cards.forEach(card => {
                    if (card.id === tabId || card.id === 'card-live-preview') {
                        card.style.display = 'block';
                    } else {
                        card.style.display = 'none';
                    }
                });
            }
        }

        // Live Search Filter
        function filterSettings(query) {
            const term = query.toLowerCase().trim();
            const cards = document.querySelectorAll('.settings-card');

            cards.forEach(card => {
                const text = card.innerText.toLowerCase();
                if (!term || text.includes(term)) {
                    card.style.display = 'block';
                    if (term) card.classList.add('search-highlight');
                    else card.classList.remove('search-highlight');
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // Color Syncing & Swatches
        function syncColorInput(hex) {
            document.getElementById('primaryColorHex').value = hex;
            document.getElementById('colorHexDisplay').innerText = hex;
            updateLivePreview();
            trackChanges();
        }

        function syncHexInput(hex) {
            if (/^#[0-9a-f]{6}$/i.test(hex)) {
                document.getElementById('primaryColor').value = hex;
                document.getElementById('colorHexDisplay').innerText = hex;
                updateLivePreview();
                trackChanges();
            }
        }

        function selectColorSwatch(hex, swatchBtn) {
            document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
            swatchBtn.classList.add('selected');
            document.getElementById('primaryColor').value = hex;
            document.getElementById('primaryColorHex').value = hex;
            document.getElementById('colorHexDisplay').innerText = hex;
            updateLivePreview();
            trackChanges();
        }

        // Theme Radio Sync
        function setThemeMode(mode) {
            const select = document.getElementById('defaultTheme');
            if (select) select.value = mode;
        }

        // Maintenance Toggle Switch
        function toggleMaintenanceMode(checked) {
            const container = document.getElementById('maintenanceMessageContainer');
            const badge = document.getElementById('systemStatusBadge');
            
            if (checked) {
                container.classList.remove('hidden');
                badge.innerText = '@Html.Raw(Localizer["Maintenance"].Value)';
                badge.className = 'text-[10px] font-bold px-2.5 py-1 rounded-full bg-amber-500/10 text-amber-600 dark:text-amber-400';
            } else {
                container.classList.add('hidden');
                badge.innerText = '@Html.Raw(Localizer["Active"].Value)';
                badge.className = 'text-[10px] font-bold px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400';
            }
        }

        // Live Header Preview Update
        function updateLivePreview() {
            const siteName = document.getElementById('siteName')?.value || 'EduLab';
            const primaryColor = document.getElementById('primaryColor')?.value || '#2563eb';

            const previewSiteName = document.getElementById('previewSiteName');
            const previewBrandBtn = document.getElementById('previewBrandBtn');

            if (previewSiteName) previewSiteName.innerText = siteName;
            if (previewBrandBtn) previewBrandBtn.style.backgroundColor = primaryColor;

            updateCharCounters();
        }

        function updateCharCounters() {
            const siteName = document.getElementById('siteName');
            const siteDesc = document.getElementById('siteDescription');

            if (siteName) document.getElementById('siteNameCount').innerText = `${siteName.value.length} / 60`;
            if (siteDesc) document.getElementById('siteDescCount').innerText = `${siteDesc.value.length} / 250`;
        }

        // Track changes to show floating save bar
        function trackChanges() {
            isFormDirty = true;
            const saveBar = document.getElementById('saveBar');
            if (saveBar) saveBar.classList.add('visible');
        }

        // Image Preview Handler
        function previewImage(input, imgId, placeholderId, dropzoneId) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = document.getElementById(imgId);
                const placeholder = document.getElementById(placeholderId);
                if (img) { img.src = e.target.result; img.classList.remove('hidden'); }
                if (placeholder) placeholder.classList.add('hidden');
                if (dropzoneId) document.getElementById(dropzoneId)?.classList.add('has-image');
            };
            reader.readAsDataURL(file);
        }

        // ─── Cropper ───
        let cropperInst = null;
        let cropCtx = {};

        function openCropModal(input, imgId, placeholderId, dropzoneId, isSquare) {
            const file = input.files[0];
            if (!file) return;
            cropCtx = { input, imgId, placeholderId, dropzoneId, isSquare };
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('cropImage').src = e.target.result;
                document.getElementById('cropModal').classList.remove('hidden');
                if (cropperInst) cropperInst.destroy();
                setTimeout(() => {
                    cropperInst = new Cropper(document.getElementById('cropImage'), {
                        aspectRatio: isSquare ? 1 : NaN,
                        viewMode: 1, guides: true, background: false, autoCropArea: 1
                    });
                }, 200);
            };
            reader.readAsDataURL(file);
        }

        function closeCropModal() {
            document.getElementById('cropModal').classList.add('hidden');
            if (cropperInst) { cropperInst.destroy(); cropperInst = null; }
        }

        function applyCrop() {
            if (!cropperInst) return;
            const canvas = cropperInst.getCroppedCanvas({ maxWidth: 1024, maxHeight: 1024 });
            canvas.toBlob(function(blob) {
                cropCtx.croppedFile = new File([blob], 'cropped.png', { type: 'image/png' });
                const img = document.getElementById(cropCtx.imgId);
                const placeholder = document.getElementById(cropCtx.placeholderId);
                img.src = canvas.toDataURL('image/png');
                img.classList.remove('hidden');
                if (placeholder) placeholder.classList.add('hidden');
                if (cropCtx.dropzoneId) document.getElementById(cropCtx.dropzoneId)?.classList.add('has-image');
                updateLivePreview();
                closeCropModal();
            });
        }

        window.uploadFile = async function(input) {
            var file = cropCtx.croppedFile || input?.files?.[0];
            if (input) {
                if (input.id === 'logoInput' && cropCtx.croppedFile) file = cropCtx.croppedFile;
                else if (input.id === 'faviconInput' && cropCtx.croppedFile) file = cropCtx.croppedFile;
                else if (!file) file = input.files?.[0];
            }
            if (!file) return null;
            var fd = new FormData();
            fd.append('file', file);
            var res = await fetch('@Url.Action("UploadImage", "Settings", new { area = "Admin" })', { method: 'POST', body: fd });
            var j = await res.json();
            cropCtx.croppedFile = null;
            return j.success ? j.url : null;
        };

        // Drag and drop helper
        function setupDragAndDrop() {
            const dropZone = document.getElementById('logoDropZone');
            if (!dropZone) return;

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                dropZone.addEventListener(eventName, () => dropZone.classList.add('drag-over'), false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, () => dropZone.classList.remove('drag-over'), false);
            });

            dropZone.addEventListener('drop', (e) => {
                const dt = e.dataTransfer;
                const files = dt.files;
                if (files.length > 0) {
                    const logoInput = document.getElementById('logoInput');
                    logoInput.files = files;
                    openCropModal(logoInput, 'logoPreview', 'logoPlaceholder', 'logoDropZone');
                    updateLivePreview();
                    trackChanges();
                }
            });
        }

        // Clear Cache Quick Tool Action
        async function clearCache(btn) {
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span>@Html.Raw(Localizer["Clearing"].Value)...</span>';

            await new Promise(resolve => setTimeout(resolve, 800));

            btn.disabled = false;
            btn.innerHTML = originalText;
            showAlert('success', '@Html.Raw(Localizer["CacheClearedSuccessfully"].Value)');
        }

        // Save Settings Action
        async function saveSettings() {
            const btn = event.currentTarget;
            const originalText = btn.innerHTML;

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin @(isArabic ? "ml-2" : "mr-2")"></i> @Localizer["Processing"]';
            btn.classList.add('opacity-80', 'cursor-wait');

            try {
                const logoUrl = await uploadFile(document.getElementById('logoInput'));
                const faviconUrl = await uploadFile(document.getElementById('faviconInput'));

                const data = {
                    id: 1,
                    siteName: document.getElementById('siteName')?.value || 'EduLab',
                    siteDescription: document.getElementById('siteDescription')?.value || '',
                    defaultLanguage: document.getElementById('defaultLanguage')?.value || 'en',
                    timezone: document.getElementById('timezone')?.value || 'UTC',
                    primaryColor: document.getElementById('primaryColor')?.value || '#2563eb',
                    defaultTheme: document.getElementById('defaultTheme')?.value || 'system',
                    metaKeywords: document.getElementById('metaKeywords')?.value || '',
                    metaDescription: document.getElementById('metaDescription')?.value || '',
                    maintenanceMode: document.getElementById('maintenanceMode')?.checked || false,
                    maintenanceMessage: document.getElementById('maintenanceMessage')?.value || '',
                    logoUrl: logoUrl || '@Model.LogoUrl',
                    faviconUrl: faviconUrl || '@Model.FaviconUrl'
                };

                const response = await fetch('@Url.Action("Save", "Settings", new { area = "Admin" })', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (result.success) {
                    showAlert('success', result.message || '@Html.Raw(Localizer["SettingsSavedSuccessfully"].Value)');
                    isFormDirty = false;
                    document.getElementById('saveBar')?.classList.remove('visible');
                    setTimeout(() => location.reload(), 800);
                } else {
                    showAlert('error', result.message || '@Html.Raw(Localizer["FailedToSaveSettings"].Value)');
                }
            } catch (err) {
                showAlert('error', '@Html.Raw(Localizer["ErrorSavingSettings"].Value)');
            }

            btn.disabled = false;
            btn.innerHTML = originalText;
            btn.classList.remove('opacity-80', 'cursor-wait');
        }

        // Reset form Action
        function resetForm() {
            Swal.fire({
                title: '@Html.Raw(Localizer["ConfirmResetTitle"].Value)',
                text: '@Html.Raw(Localizer["ConfirmResetText"].Value)',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: '@Html.Raw(Localizer["YesReset"].Value)',
                cancelButtonText: '@Html.Raw(Localizer["Cancel"].Value)',
                background: document.documentElement.classList.contains('dark') ? '#1e293b' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#f1f5f9' : '#1e293b'
            }).then((result) => {
                if (result.isConfirmed) {
                    location.reload();
                }
            });
        }

        window.previewImage = previewImage;
        window.saveSettings = saveSettings;
        window.resetForm = resetForm;
        window.clearCache = clearCache;
    </script>
}
