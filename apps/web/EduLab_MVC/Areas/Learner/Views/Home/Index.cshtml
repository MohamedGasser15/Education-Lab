            <div class="faq-item border border-gray-200 dark:border-white/10 rounded-2xl bg-white dark:bg-gray-800/50 overflow-hidden">
                <button class="faq-btn w-full p-5 text-right flex items-center justify-between font-bold text-gray-800 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                    <span>هل يمكنني الوصول للدورات مدى الحياة؟</span>
                    <i class="fas fa-plus text-blue-600 dark:text-blue-400 transition-transform"></i>
                </button>
                <div class="faq-content max-h-0 overflow-hidden transition-all duration-300">
                    <p class="px-5 pb-5 text-gray-600 dark:text-gray-400">نعم، بمجرد اشتراكك تحصل على وصول دائم للمحتوى والتحديثات.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    (function() {
        'use strict';

        // ========== BRAND INFINITE SCROLL ==========
        const logos = [
            { src: '/Img/brands/Coursera.png', alt: 'Coursera' },
            { src: '/Img/brands/Udemy.png', alt: 'Udemy' },
            { src: '/Img/brands/Github.png', alt: 'Github' },
            { src: '/Img/brands/Microsoft.png', alt: 'Microsoft' },
            { src: '/Img/brands/Google.png', alt: 'Google' },
            { src: '/Img/brands/Amazon.png', alt: 'Amazon' },
            { src: '/Img/brands/stackoverflow.png', alt: 'Stack Overflow' },
            { src: '/Img/brands/IBM.png', alt: 'IBM' }
        ];

        const container = document.getElementById('infiniteScrollContent');
        if (container) {
            let html = '';
            for (let i = 0; i < 4; i++) {
                logos.forEach(logo => {
                    html += `<img src="${logo.src}" alt="${logo.alt}" class="h-8 md:h-10 opacity-80 hover:opacity-100 transition-opacity">`;
                });
            }
            container.innerHTML = html;

            let position = 0;
            const speed = 0.3;
            let animationId = null;
            let isPlaying = true;
            let halfWidth = 0;
            let isRtl = document.documentElement.getAttribute('dir') === 'rtl';

            function updateHalfWidth() {
                const fullWidth = container.scrollWidth;
                const repeats = 4;
                halfWidth = fullWidth / repeats;
                if (halfWidth <= 0) halfWidth = fullWidth / 2;
            }

            window.addEventListener('load', updateHalfWidth);
            window.addEventListener('resize', () => setTimeout(updateHalfWidth, 100));

            function animate() {
                if (!isPlaying) return;
                if (halfWidth === 0) updateHalfWidth();

                if (isRtl) {
                    position += speed;
                    if (position >= halfWidth) position -= halfWidth;
                } else {
                    position -= speed;
                    if (position <= -halfWidth) position += halfWidth;
                }

                container.style.transform = `translateX(${position}px)`;
                animationId = requestAnimationFrame(animate);
            }

            isPlaying = true;
            animate();

            const wrapper = container.parentElement;
            wrapper.addEventListener('mouseenter', () => { isPlaying = false; if(animationId) cancelAnimationFrame(animationId); });
            wrapper.addEventListener('mouseleave', () => { if(isPlaying) return; isPlaying = true; animate(); });
        }

        // ========== FAQ TOGGLE ==========
        document.querySelectorAll('.faq-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const item = btn.parentElement;
                const content = item.querySelector('.faq-content');
                const icon = btn.querySelector('i');
                
                document.querySelectorAll('.faq-item').forEach(other => {
                    if (other !== item) {
                        other.querySelector('.faq-content').style.maxHeight = null;
                        other.querySelector('i').style.transform = 'rotate(0deg)';
                    }
                });

                if (content.style.maxHeight) {
                    content.style.maxHeight = null;
                    icon.style.transform = 'rotate(0deg)';
                } else {
                    content.style.maxHeight = content.scrollHeight + "px";
                    icon.style.transform = 'rotate(45deg)';
                }
            });
        });

        // ========== SCROLL ANIMATION ==========
        const scrollElements = document.querySelectorAll('.scroll-animate');
        const elementInView = (el, dividend = 1) => {
            const elementTop = el.getBoundingClientRect().top;
            return elementTop <= (window.innerHeight || document.documentElement.clientHeight) / dividend;
        };
        const displayScrollElement = (element) => {
            element.classList.add('animated');
            element.dataset.animated = "true";
        };
        const handleScrollAnimation = () => {
            scrollElements.forEach((el) => {
                if (elementInView(el, 1.25) && !el.dataset.animated) {
                    displayScrollElement(el);
                }
            });
        };
        window.addEventListener('scroll', handleScrollAnimation);
        handleScrollAnimation();

        // ========== SEARCH ==========
        const searchBtn = document.getElementById('heroSearchBtn');
        const searchInput = document.getElementById('searchInput');
        if (searchBtn && searchInput) {
            searchBtn.addEventListener('click', function(e) {
                e.preventDefault();
                const query = searchInput.value.trim();
                if (query) window.location.href = `/Course/Index?search=${encodeURIComponent(query)}`;
            });
        }

        // ========== SWIPER INIT ==========
        if (typeof Swiper !== 'undefined') {
            new Swiper('.featuredCoursesSwiper', {
                slidesPerView: 1,
                spaceBetween: 24,
                navigation: { nextEl: '.featured-courses-next', prevEl: '.featured-courses-prev' },
                pagination: { el: '.swiper-pagination', clickable: true },
                breakpoints: { 640: { slidesPerView: 2 }, 1024: { slidesPerView: 3 }, 1280: { slidesPerView: 4 } }
            });
            new Swiper('.newCoursesSwiper', {
                slidesPerView: 1,
                spaceBetween: 24,
                navigation: { nextEl: '.new-courses-next', prevEl: '.new-courses-prev' },
                pagination: { el: '.swiper-pagination', clickable: true },
                breakpoints: { 640: { slidesPerView: 2 }, 1024: { slidesPerView: 3 }, 1280: { slidesPerView: 4 } }
            });
        }

        // ========== COUNTER ==========
        const counters = document.querySelectorAll('.counter');
        const startCounter = (counter) => {
            const target = +counter.getAttribute('data-target');
            const count = +counter.innerText.replace(/[+%,]/g, '');
            const inc = target / 50;
            if (count < target) {
                counter.innerText = Math.ceil(count + inc).toLocaleString() + (counter.innerText.includes('%') ? '%' : '+');
                setTimeout(() => startCounter(counter), 20);
            } else {
                counter.innerText = target.toLocaleString() + (counter.innerText.includes('%') ? '%' : '+');
            }
        };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if(entry.isIntersecting) startCounter(entry.target); });
        }, { threshold: 0.5 });
        counters.forEach(c => observer.observe(c));
    })();

    // ========== UPDATE OFFER (GLOBAL) ==========
    function updateOffer(type) {
            const title = document.getElementById('offerTitle');
            const desc = document.getElementById('offerDesc');
            const icon = document.getElementById('offerIcon');
            const container = document.getElementById('radarSelection');

            container.classList.add('scale-95', 'opacity-50');

            setTimeout(() => {
                if(type === 'dev') {
                    title.innerText = "هندسة البرمجيات";
                    desc.innerHTML = "خصم <span class='text-blue-400 font-bold'>60%</span> على مسارات Full-Stack و Flutter لفترة محدودة.";
                    icon.className = "w-20 h-20 bg-blue-600 rounded-3xl mx-auto -mt-16 flex items-center justify-center shadow-lg rotate-0 transition-all duration-500";
                    icon.innerHTML = '<i class="fas fa-code text-white text-3xl"></i>';
                } else if(type === 'design') {
                    title.innerText = "التصميم الإبداعي";
                    desc.innerHTML = "اتقن الـ <span class='text-pink-400 font-bold'>UI/UX</span> و Graphic Design مع أقوى الخبراء.";
                    icon.className = "w-20 h-20 bg-pink-600 rounded-3xl mx-auto -mt-16 flex items-center justify-center shadow-lg rotate-0 transition-all duration-500";
                    icon.innerHTML = '<i class="fas fa-palette text-white text-3xl"></i>';
                } else if(type === 'biz') {
                    title.innerText = "إدارة الأعمال";
                    desc.innerHTML = "تعلم القيادة والتسويق بخصم <span class='text-green-400 font-bold'>50%</span> للمشتركين الجدد.";
                    icon.className = "w-20 h-20 bg-green-600 rounded-3xl mx-auto -mt-16 flex items-center justify-center shadow-lg rotate-0 transition-all duration-500";
                    icon.innerHTML = '<i class="fas fa-chart-line text-white text-3xl"></i>';
                } else if(type === 'lang') {
                    title.innerText = "إتقان اللغات";
                    desc.innerHTML = "كورسات <span class='text-yellow-400 font-bold'>الإنجليزية والألمانية</span> بأسلوب تفاعلي حديث.";
                    icon.className = "w-20 h-20 bg-yellow-600 rounded-3xl mx-auto -mt-16 flex items-center justify-center shadow-lg rotate-0 transition-all duration-500";
                    icon.innerHTML = '<i class="fas fa-language text-white text-3xl"></i>';
                } else if(type === 'ai') {
                    title.innerText = "الذكاء الاصطناعي";
                    desc.innerHTML = "اقتحم مجال المستقبل وتعلم <span class='text-purple-400 font-bold'>Data Science & AI</span> بخصم 40%.";
                    icon.className = "w-20 h-20 bg-purple-600 rounded-3xl mx-auto -mt-16 flex items-center justify-center shadow-lg rotate-0 transition-all duration-500";
                    icon.innerHTML = '<i class="fas fa-robot text-white text-3xl"></i>';
                }
            
                container.classList.remove('scale-95', 'opacity-50');
            }, 300);
        }
</script>