        </div>
        @await Component.InvokeAsync("CategoriesDropdown", new { type = "Home" })
    </div>
</section>

<!-- Featured Courses Section -->
<section class="py-20 bg-gray-50 dark:bg-gray-900/50 relative overflow-hidden scroll-animate">
    <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-blue-500/5 blur-[100px] rounded-full"></div>
    <div class="container mx-auto px-4 relative z-10">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
            <div>
                <span class="section-badge mb-3">الأكثر طلباً</span>
                <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white">
                    دورات <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-600 to-cyan-400">مميزة</span>
                </h2>
