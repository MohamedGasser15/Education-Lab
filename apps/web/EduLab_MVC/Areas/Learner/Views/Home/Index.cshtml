@using EduLab_MVC.Common;
@model List<EduLab_MVC.Models.DTOs.Course.CourseDTO>

@{
    ViewData["Title"] = "الرئيسية";
    var token = Context.Request.Cookies["AuthToken"];
    var isLoggedIn = !string.IsNullOrEmpty(token);
    var role = Context.Request.Cookies["UserRole"];
}

<style>
    /* ========== BASE ANIMATIONS ========== */
    @@keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
    }

    /* Scroll Animation Classes */
    .scroll-animate {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }

        .scroll-animate.animated {
            opacity: 1;
            transform: translateY(0);
        }

    /* ========== HERO SECTION ENHANCED ========== */
    .hero-gradient-bg {
        background: radial-gradient(circle at 20% 30%, rgba(37, 99, 235, 0.15) 0%, transparent 50%), radial-gradient(circle at 80% 70%, rgba(6, 182, 212, 0.1) 0%, transparent 50%), linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }

    .hero-glass-card {
        backdrop-filter: blur(12px);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .hero-btn-primary {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        box-shadow: 0 10px 20px -8px rgba(37, 99, 235, 0.4);
        transition: all 0.3s ease;
    }

        .hero-btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 30px -10px rgba(37, 99, 235, 0.5);
        }

    .hero-btn-secondary {
        backdrop-filter: blur(8px);
        background: rgba(255, 255, 255, 0.08);
        border: 1.5px solid rgba(255, 255, 255, 0.2);
        transition: all 0.3s ease;
    }

        .hero-btn-secondary:hover {
            background: rgba(255, 255, 255, 0.15);
            border-color: rgba(255, 255, 255, 0.4);
            transform: translateY(-3px);
        }

    /* Topic Pills */
    .hero-topic-pill {
        backdrop-filter: blur(8px);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.2s ease;
    }

        .hero-topic-pill:hover {
            background: rgba(37, 99, 235, 0.3);
            border-color: rgba(37, 99, 235, 0.5);
            transform: translateY(-2px);
        }

    /* ========== COURSE CARDS ENHANCED ========== */
    .course-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .dark .course-card {
        border-color: rgba(255, 255, 255, 0.05);
    }

    .course-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 35px -12px rgba(0, 0, 0, 0.15);
        border-color: rgba(37, 99, 235, 0.3);
    }

    .dark .course-card:hover {
        box-shadow: 0 25px 35px -12px rgba(0, 0, 0, 0.5);
    }

    /* ========== SECTION TITLES ========== */
/* ========== تصميم section-badge الجديد (واضح في كل الخلفيات) ========== */
.section-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.2rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #1e3a8a; /* أزرق غامق واضح على الفاتح */
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 40px;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

/* حدود متدرجة */
.section-badge::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 40px;
    padding: 1.5px;
    background: linear-gradient(135deg, #3b82f6, #06b6d4, #8b5cf6);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.6;
    pointer-events: none;
}

.section-badge i {
    font-size: 0.9rem;
    color: #2563eb;
    filter: drop-shadow(0 0 6px rgba(37, 99, 235, 0.4));
}

/* الوضع الداكن */
.dark .section-badge {
    color: #f1f5f9;
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
}

.dark .section-badge i {
    color: #93c5fd;
}

/* تأثير hover */
.section-badge:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.35);
    box-shadow: 0 12px 25px rgba(59, 130, 246, 0.2);
}

.dark .section-badge:hover {
    background: rgba(255, 255, 255, 0.08);
}

    /* Swiper Navigation Custom */
    .swiper-button-next,
    .swiper-button-prev {
        width: 48px !important;
        height: 48px !important;
        background: white !important;
        border-radius: 16px !important;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1) !important;
        border: 1px solid rgba(0,0,0,0.05) !important;
        transition: all 0.3s !important;
    }

        .swiper-button-next:hover,
        .swiper-button-prev:hover {
            background: #2563eb !important;
            transform: scale(1.1) !important;
        }

            .swiper-button-next:hover::after,
            .swiper-button-prev:hover::after {
                color: white !important;
            }

        .swiper-button-next::after,
        .swiper-button-prev::after {
            font-size: 18px !important;
            font-weight: bold !important;
            color: #2563eb !important;
        }

    .dark .swiper-button-next,
    .dark .swiper-button-prev {
        background: #1e293b !important;
        border-color: rgba(255,255,255,0.1) !important;
    }

        .dark .swiper-button-next::after,
        .dark .swiper-button-prev::after {
            color: #60a5fa !important;
        }

    /* Progress Bar */
    .progress-bar {
        background: linear-gradient(90deg, #2563eb, #06b6d4);
    }

    /* ========== RESPONSIVE FIXES ========== */
    @@media (max-width: 768px) {
        .hero-title-container h1 {
            font-size: 2.5rem;
            line-height: 1.2;
        }
    }
        @@keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    @@keyframes float-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }

    @@keyframes bounce-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
    }

    .animate-float { animation: float 5s ease-in-out infinite; }
    .animate-float-slow { animation: float-slow 7s ease-in-out infinite; }
    .animate-bounce-slow { animation: bounce-slow 4s ease-in-out infinite; }
    @@keyframes move-dots {
        0% {
            background-position: 0 0;
        }
        100% {
            background-position: 40px 40px; 
        }
    }

    .animated-dots-grid {
        background-image: radial-gradient(rgba(255, 255, 255, 0.4) 1.5px, transparent 1.5px);
        background-size: 40px 40px;
        animation: move-dots 4s linear infinite;
    }
</style>

<!-- Hero Section - Redesigned -->
<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden hero-gradient-bg">

    <div class="absolute inset-0 opacity-20 animated-dots-grid"></div>
    <div class="container mx-auto px-4 md:px-8 relative z-20 py-12 md:py-16">
        <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
            
            <!-- Right Content (Text) -->
            <div class="lg:w-1/2 text-center lg:text-right space-y-6 animate-fade-in-up">
                <span class="section-badge" style="color: white !important;">
                    <i class="fas fa-graduation-cap ml-2" style="color: white !important;"></i> منصة تعليم المستقبل
                </span>
                
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight text-white">
                    <span>تعلّم </span>
                    <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-400 via-cyan-400 to-blue-400">مهارات المستقبل</span>
                    <br class="hidden sm:block">
                    <span class="text-white/90">بكل سهولة واحترافية</span>
                </h1>
                
                <p class="text-base md:text-lg text-gray-300 max-w-xl mx-auto lg:mx-0 leading-relaxed">
                    انضم إلى <span class="font-bold text-blue-300">EduLab</span> واكتشف دورات تعليمية مصممة خصيصاً لتطوير مهاراتك التقنية والعملية.
                </p>

                <!-- Search Box -->
                <div class="hero-glass-card w-full max-w-xl mx-auto lg:mx-0 rounded-2xl p-1.5 flex items-center gap-2">
                    <div class="flex-grow relative">
                        <i class="fas fa-search absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 text-base"></i>
                        <input type="text" id="searchInput" placeholder="ما الذي تريد تعلمه اليوم؟"
                               class="w-full bg-transparent py-3 pr-12 pl-4 text-white placeholder:text-gray-400 rounded-xl text-base focus:outline-none">
                    </div>
                    <button type="submit" id="heroSearchBtn" class="hero-btn-primary text-white px-6 py-3 rounded-xl font-bold text-sm flex items-center gap-2 whitespace-nowrap">
                        <span>بحث</span>
                        <i class="fas fa-arrow-left"></i>
                    </button>
                </div>

                <!-- Popular Topics -->
                <div class="flex flex-wrap justify-center lg:justify-start items-center gap-2 pt-2">
                    <span class="text-white/50 text-sm">الأكثر بحثاً:</span>
                    <a href="#" class="hero-topic-pill px-4 py-1.5 rounded-full text-white/90 text-sm flex items-center gap-1.5"><i class="fas fa-code text-blue-400 text-xs"></i> برمجة</a>
                    <a href="#" class="hero-topic-pill px-4 py-1.5 rounded-full text-white/90 text-sm flex items-center gap-1.5"><i class="fas fa-robot text-purple-400 text-xs"></i> ذكاء اصطناعي</a>
                    <a href="#" class="hero-topic-pill px-4 py-1.5 rounded-full text-white/90 text-sm flex items-center gap-1.5"><i class="fas fa-language text-yellow-400 text-xs"></i> لغات</a>
                </div>

                <!-- CTA Buttons -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start pt-4">
                    @if (!isLoggedIn)
                    {
                        <a asp-controller="Auth" asp-action="Register" class="hero-btn-primary text-white px-8 py-3.5 rounded-xl font-bold text-center flex items-center justify-center gap-2 transition-all">
                            <i class="fas fa-rocket"></i> <span>ابدأ مجاناً</span>
                        </a>
                        <a asp-controller="Course" asp-action="Index" class="hero-btn-secondary text-white px-8 py-3.5 rounded-xl font-bold text-center flex items-center justify-center gap-2">
                            <i class="fas fa-play-circle"></i> <span>تصفح الدورات</span>
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Course" asp-action="Index" class="hero-btn-primary text-white px-8 py-3.5 rounded-xl font-bold text-center flex items-center justify-center gap-2">
                            <i class="fas fa-graduation-cap"></i> <span>استكشف الدورات</span>
                        </a>
                    }
                </div>
            </div>

            <!-- Left Content (Interactive Card) -->
<!-- Left Content (Interactive Card) - مخفي على الموبايل، يظهر من md فما فوق -->
<div class="hidden md:flex md:w-1/2 animate-fade-in-up delay-200 w-full relative h-[600px] items-center justify-center overflow-visible">
    
    @if (!isLoggedIn)
    {
        <div id="radarSelection" class="relative w-full h-full flex items-center justify-center transition-all duration-700">
            
            <div onclick="updateOffer('design')" class="absolute top-10 left-5 md:left-10 w-16 h-16 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl flex items-center justify-center animate-float shadow-xl cursor-pointer hover:bg-pink-600/30 transition-all group z-30">
                <i class="fas fa-palette text-pink-400 text-2xl group-hover:scale-110"></i>
            </div>
            
            <div onclick="updateOffer('biz')" class="absolute bottom-16 left-0 md:left-5 w-14 h-14 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl flex items-center justify-center animate-bounce-slow shadow-xl cursor-pointer hover:bg-green-600/30 transition-all group z-30">
                <i class="fas fa-chart-line text-green-400 text-xl group-hover:scale-110"></i>
            </div>
            
            <div onclick="updateOffer('dev')" class="absolute top-16 right-0 md:right-5 w-16 h-16 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl flex items-center justify-center animate-float-slow shadow-xl cursor-pointer hover:bg-blue-600/30 transition-all group z-30">
                <i class="fas fa-code text-blue-400 text-2xl group-hover:scale-110"></i>
            </div>

            <div onclick="updateOffer('lang')" class="absolute bottom-20 right-5 md:right-10 w-14 h-14 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl flex items-center justify-center animate-float shadow-xl cursor-pointer hover:bg-yellow-600/30 transition-all group z-30">
                <i class="fas fa-language text-yellow-400 text-xl group-hover:scale-110"></i>
            </div>

            <div onclick="updateOffer('ai')" class="absolute -top-5 left-1/2 -translate-x-1/2 w-14 h-14 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl flex items-center justify-center animate-bounce-slow shadow-xl cursor-pointer hover:bg-purple-600/30 transition-all group z-30">
                <i class="fas fa-robot text-purple-400 text-xl group-hover:scale-110"></i>
            </div>

            <div class="relative w-80 bg-white/10 backdrop-blur-2xl border border-white/20 p-8 rounded-[3rem] shadow-2xl text-center group">
                <div id="offerIcon" class="w-20 h-20 bg-blue-600 rounded-3xl mx-auto -mt-16 flex items-center justify-center shadow-lg group-hover:rotate-0 transition-all duration-500">
                    <i class="fas fa-gift text-white text-3xl"></i>
                </div>
                <h3 id="offerTitle" class="text-xl font-black text-white mt-6 transition-all duration-300">حدد اهتمامك!</h3>
                <p id="offerDesc" class="text-white/60 text-xs mt-2 leading-relaxed transition-all duration-300">اضغط على أي أيقونة حول الكارت لعرض <span class="text-blue-400 font-bold">عرض خاص</span> لهذا المجال.</p>
                <a asp-controller="Auth" asp-action="Register" class="block w-full mt-6 py-4 bg-white text-blue-900 rounded-2xl font-black hover:bg-blue-50 transition-all shadow-lg active:scale-95">
                    ابدأ الرحلة الآن
                </a>
            </div>
        </div>
    }
    else
    {
        var userEnrollments = ViewBag.UserEnrollments as List<EduLab_MVC.Models.DTOs.Enrollment.EnrollmentDto>;
        var hasEnrollments = userEnrollments != null && userEnrollments.Any();

        @if (hasEnrollments)
        {
            // المستخدم عنده كورسات مسجل فيها - نعرضله أول كورس لم يكمله بعد
            var nextCourse = userEnrollments.FirstOrDefault(e => e.ProgressPercentage < 100) ?? userEnrollments.First();
            var progress = nextCourse.ProgressPercentage;

            <div class="relative w-80 md:w-[380px] bg-white/10 backdrop-blur-2xl border border-white/20 p-6 rounded-[2.5rem] shadow-2xl z-30 transform hover:scale-[1.02] transition-all">
                <div class="flex items-center gap-4 mb-6 border-b border-white/10 pb-4">
                    <img src="@nextCourse.ThumbnailUrl" alt="@nextCourse.Title" class="w-16 h-16 rounded-xl object-cover border-2 border-blue-500">
                    <div class="flex-1 min-w-0">
                        <h4 class="text-white font-bold text-sm truncate">@nextCourse.Title</h4>
                        <p class="text-white/40 text-[10px] mt-1">نسبة الإنجاز: @progress%</p>
                    </div>
                </div>

                <!-- Progress Bar -->
                <div class="mb-6">
                    <div class="flex justify-between text-xs text-white/60 mb-2">
                        <span>التقدم</span>
                        <span>@progress%</span>
                    </div>
                    <div class="w-full bg-white/10 rounded-full h-2.5 overflow-hidden">
                        <div class="bg-gradient-to-r from-blue-500 to-cyan-400 h-2.5 rounded-full transition-all duration-500" style="width: @progress%"></div>
                    </div>
                </div>

                <a asp-controller="Course" asp-action="Learn" asp-route-id="@nextCourse.CourseId" class="block w-full py-4 bg-gradient-to-r from-blue-600 to-blue-500 text-white rounded-xl font-bold text-sm hover:from-blue-500 hover:to-blue-400 transition-all shadow-lg active:scale-95 text-center">
                    <i class="fas fa-play ml-2"></i> استكمال الكورس
                </a>

                @if (userEnrollments.Count > 1)
                {
                    <p class="text-white/30 text-[10px] text-center mt-3">
                        لديك @(userEnrollments.Count - 1) كورسات أخرى
                    </p>
                }
            </div>
        }
        else
        {
            // المستخدم مش عنده أي كورسات - نعرضله حاجة تشجعه يسجل
            <div class="relative w-80 md:w-[380px] bg-white/10 backdrop-blur-2xl border border-white/20 p-8 rounded-[2.5rem] shadow-2xl z-30 transform hover:scale-[1.02] transition-all text-center">
                <div class="w-20 h-20 bg-gradient-to-br from-yellow-400 to-orange-500 rounded-full mx-auto flex items-center justify-center shadow-lg animate-bounce-slow">
                    <i class="fas fa-gift text-white text-3xl"></i>
                </div>
                <h3 class="text-xl font-black text-white mt-6">ابدأ رحلتك التعليمية!</h3>
                <p class="text-white/60 text-sm mt-3 leading-relaxed">
                    سجل الآن في أول كورس واحصل على
                    <span class="text-yellow-400 font-bold">خصم 20%</span>
                </p>
                <a asp-controller="Course" asp-action="Index" class="block w-full mt-6 py-4 bg-gradient-to-r from-yellow-500 to-orange-500 text-white rounded-xl font-bold text-sm hover:from-yellow-400 hover:to-orange-400 transition-all shadow-lg active:scale-95">
                    <i class="fas fa-search ml-2"></i> تصفح الكورسات
                </a>
                <p class="text-white/30 text-[10px] mt-3">
                    <i class="fas fa-fire text-orange-400 ml-1"></i> أكثر من 1000 دورة في انتظارك
                </p>
            </div>
        }
    }

    <div class="absolute inset-0 bg-gradient-to-tr from-blue-500/10 via-purple-500/10 to-pink-500/10 rounded-full blur-[100px] -z-10"></div>
</div>
</div>
    </div>
    
    <!-- Wave Decoration -->
    <div class="absolute bottom-[-1px] left-0 right-0">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120" fill="none" preserveAspectRatio="none" class="block w-full">
            <path d="M0 120L60 105C120 90 240 60 360 52.5C480 45 600 60 720 67.5C840 75 960 75 1080 67.5C1200 60 1320 45 1380 37.5L1440 30V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white" class="dark:fill-gray-900" />
        </svg>
    </div>
</section>

