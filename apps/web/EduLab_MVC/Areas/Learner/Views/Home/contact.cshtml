                            <p class="text-gray-500 dark:text-gray-400" dir="ltr">+20 123 456 7890</p>
                            <p class="text-gray-500 dark:text-gray-400" dir="ltr">+20 987 654 3210</p>
                        </div>
                    </div>
                </div>

                <!-- Info Item 3 -->
                <div class="contact-card p-8 rounded-[2.5rem] scroll-animate" style="transition-delay: 0.3s">
                    <div class="flex items-center gap-6">
                        <div class="w-16 h-16 bg-purple-100 dark:bg-purple-500/20 rounded-2xl flex items-center justify-center text-purple-600 dark:text-purple-400 text-2xl">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">البريد الإلكتروني</h3>
                            <p class="text-gray-500 dark:text-gray-400">support@edulab.com</p>
