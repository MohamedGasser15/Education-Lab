@{
    ViewData["Title"] = Localizer["FAQTitle"].Value;
}

<style>
    /* ========== BASE ANIMATIONS ========== */
    @@keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
    }

    /* Scroll Animation Classes */
    .scroll-animate {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }

    .scroll-animate.animated {
        opacity: 1;
        transform: translateY(0);
    }

    /* ========== HERO SECTION ENHANCED ========== */
    .hero-gradient-bg {
        background: radial-gradient(circle at 20% 30%, rgba(37, 99, 235, 0.15) 0%, transparent 50%), 
                    radial-gradient(circle at 80% 70%, rgba(6, 182, 212, 0.1) 0%, transparent 50%), 
                    linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }

    /* ========== SECTION BADGE ========== */
    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.2rem;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #1e3a8a;
        background: rgba(255, 255, 255, 0.25);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 40px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .dark .section-badge {
        color: #f1f5f9;
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
    }

    /* ========== ANIMATED DOTS GRID ========== */
    @@keyframes move-dots {
        0% { background-position: 0 0; }
        100% { background-position: 40px 40px; }
    }

    .animated-dots-grid {
        background-image: radial-gradient(rgba(255, 255, 255, 0.2) 1.5px, transparent 1.5px);
        background-size: 40px 40px;
        animation: move-dots 4s linear infinite;
    }

    .hero-glass-card {
        backdrop-filter: blur(12px);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .faq-item.hidden-by-filter {
        display: none;
    }
</style>

<!-- Hero Section -->
<section class="relative min-h-[40vh] flex items-center justify-center overflow-hidden hero-gradient-bg">
    <div class="absolute inset-0 opacity-20 animated-dots-grid"></div>
    <div class="container mx-auto px-4 relative z-20 py-20 text-center animate-fade-in-up">
        <span class="section-badge mb-6" style="color: white !important;">
            <i class="fas fa-question-circle ml-2" style="color: white !important;"></i> @Localizer["FAQ"]
        </span>
        <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-8">
            @Localizer["YouHave"] <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-400 via-cyan-400 to-blue-400">@Localizer["QuestionsQ"]</span> @Localizer["WeAreHereToAnswer"]
        </h1>
        
        <!-- Search Box -->
        <div class="hero-glass-card w-full max-w-2xl mx-auto rounded-2xl p-1.5 flex items-center gap-2">
            <div class="flex-grow relative">
                <i class="fas fa-search absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg"></i>
                <input type="text" id="faqSearch" placeholder="@Localizer["SearchForQuickAnswers"]"
                       class="w-full bg-transparent py-4 pr-12 pl-4 text-white placeholder:text-gray-400 rounded-xl text-lg focus:outline-none">
            </div>
        </div>
    </div>
    
    <!-- Wave Decoration -->
    <div class="absolute bottom-[-1px] left-0 right-0">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120" fill="none" preserveAspectRatio="none" class="block w-full">
            <path d="M0 120L60 105C120 90 240 60 360 52.5C480 45 600 60 720 67.5C840 75 960 75 1080 67.5C1200 60 1320 45 1380 37.5L1440 30V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white" class="dark:fill-gray-900" />
        </svg>
    </div>
</section>

<!-- Content Section -->
<section class="py-24 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 max-w-4xl">
        
        <!-- Filter Chips -->
        <div class="flex flex-wrap justify-center gap-3 mb-16 scroll-animate" id="faqFilters">
            <button data-filter="all" class="filter-btn active px-6 py-2.5 bg-blue-600 text-white rounded-full font-bold text-sm shadow-lg shadow-blue-600/20 transition-all">@Localizer["All"]</button>
            <button data-filter="account" class="filter-btn px-6 py-2.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-full font-bold text-sm hover:bg-gray-200 dark:hover:bg-gray-700 transition-all">@Localizer["Accounts"]</button>
            <button data-filter="courses" class="filter-btn px-6 py-2.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-full font-bold text-sm hover:bg-gray-200 dark:hover:bg-gray-700 transition-all">@Localizer["Courses"]</button>
            <button data-filter="certs" class="filter-btn px-6 py-2.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-full font-bold text-sm hover:bg-gray-200 dark:hover:bg-gray-700 transition-all">@Localizer["Certificates"]</button>
            <button data-filter="payment" class="filter-btn px-6 py-2.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-full font-bold text-sm hover:bg-gray-200 dark:hover:bg-gray-700 transition-all">@Localizer["Payment"]</button>
            <button data-filter="technical" class="filter-btn px-6 py-2.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-full font-bold text-sm hover:bg-gray-200 dark:hover:bg-gray-700 transition-all">@Localizer["Technical"]</button>
        </div>

        <div class="space-y-6" id="faqContainer">
            <!-- Account Category -->
            <div class="faq-item" data-category="account">
                <div class="group border border-gray-100 dark:border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all">
                    <button class="faq-toggle w-full flex justify-between items-center p-8 text-right bg-white dark:bg-gray-800 transition-colors">
                        <span class="font-black text-gray-900 dark:text-white text-lg group-hover:text-blue-600 transition-colors">@Localizer["FAQHowToRegister"]</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center transition-transform duration-300 icon-box">
                            <i class="fas fa-plus text-gray-400 text-sm"></i>
                        </div>
                    </button>
                    <div class="faq-content px-8 pb-8 bg-white dark:bg-gray-800 hidden">
                        <div class="pt-6 border-t border-gray-50 dark:border-white/5 text-gray-600 dark:text-gray-400 leading-relaxed text-lg">
                            @Localizer["FAQRegisterAnswer"]
                        </div>
                    </div>
                </div>
            </div>

            <div class="faq-item" data-category="account">
                <div class="group border border-gray-100 dark:border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all">
                    <button class="faq-toggle w-full flex justify-between items-center p-8 text-right bg-white dark:bg-gray-800 transition-colors">
                        <span class="font-black text-gray-900 dark:text-white text-lg group-hover:text-blue-600 transition-colors">@Localizer["FAQChangeEmail"]</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center transition-transform duration-300 icon-box">
                            <i class="fas fa-plus text-gray-400 text-sm"></i>
                        </div>
                    </button>
                    <div class="faq-content px-8 pb-8 bg-white dark:bg-gray-800 hidden">
                        <div class="pt-6 border-t border-gray-50 dark:border-white/5 text-gray-600 dark:text-gray-400 leading-relaxed text-lg">
                            @Localizer["FAQChangeEmailAnswer"]
                        </div>
                    </div>
                </div>
            </div>

            <!-- Courses Category -->
            <div class="faq-item" data-category="courses">
                <div class="group border border-gray-100 dark:border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all">
                    <button class="faq-toggle w-full flex justify-between items-center p-8 text-right bg-white dark:bg-gray-800 transition-colors">
                        <span class="font-black text-gray-900 dark:text-white text-lg group-hover:text-blue-600 transition-colors">@Localizer["FAQRecordedOrLive"]</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center transition-transform duration-300 icon-box">
                            <i class="fas fa-plus text-gray-400 text-sm"></i>
                        </div>
                    </button>
                    <div class="faq-content px-8 pb-8 bg-white dark:bg-gray-800 hidden">
                        <div class="pt-6 border-t border-gray-50 dark:border-white/5 text-gray-600 dark:text-gray-400 leading-relaxed text-lg">
                            @Localizer["FAQRecordedOrLiveAnswer"]
                        </div>
                    </div>
                </div>
            </div>

            <div class="faq-item" data-category="courses">
                <div class="group border border-gray-100 dark:border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all">
                    <button class="faq-toggle w-full flex justify-between items-center p-8 text-right bg-white dark:bg-gray-800 transition-colors">
                        <span class="font-black text-gray-900 dark:text-white text-lg group-hover:text-blue-600 transition-colors">@Localizer["FAQAccessExpiry"]</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center transition-transform duration-300 icon-box">
                            <i class="fas fa-plus text-gray-400 text-sm"></i>
                        </div>
                    </button>
                    <div class="faq-content px-8 pb-8 bg-white dark:bg-gray-800 hidden">
                        <div class="pt-6 border-t border-gray-50 dark:border-white/5 text-gray-600 dark:text-gray-400 leading-relaxed text-lg">
                            @Localizer["FAQAccessExpiryAnswer"]
                        </div>
                    </div>
                </div>
            </div>

            <!-- Certs Category -->
            <div class="faq-item" data-category="certs">
                <div class="group border border-gray-100 dark:border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all">
                    <button class="faq-toggle w-full flex justify-between items-center p-8 text-right bg-white dark:bg-gray-800 transition-colors">
                        <span class="font-black text-gray-900 dark:text-white text-lg group-hover:text-blue-600 transition-colors">@Localizer["FAQGetCertificate"]</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center transition-transform duration-300 icon-box">
                            <i class="fas fa-plus text-gray-400 text-sm"></i>
                        </div>
                    </button>
                    <div class="faq-content px-8 pb-8 bg-white dark:bg-gray-800 hidden">
                        <div class="pt-6 border-t border-gray-50 dark:border-white/5 text-gray-600 dark:text-gray-400 leading-relaxed text-lg">
                            @Localizer["FAQGetCertificateAnswer"]
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Category -->
            <div class="faq-item" data-category="payment">
                <div class="group border border-gray-100 dark:border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all">
                    <button class="faq-toggle w-full flex justify-between items-center p-8 text-right bg-white dark:bg-gray-800 transition-colors">
                        <span class="font-black text-gray-900 dark:text-white text-lg group-hover:text-blue-600 transition-colors">@Localizer["FAQPaymentMethods"]</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center transition-transform duration-300 icon-box">
                            <i class="fas fa-plus text-gray-400 text-sm"></i>
                        </div>
                    </button>
                    <div class="faq-content px-8 pb-8 bg-white dark:bg-gray-800 hidden">
                        <div class="pt-6 border-t border-gray-50 dark:border-white/5 text-gray-600 dark:text-gray-400 leading-relaxed text-lg">
                            @Localizer["FAQPaymentMethodsAnswer"]
                        </div>
                    </div>
                </div>
            </div>

            <div class="faq-item" data-category="payment">
                <div class="group border border-gray-100 dark:border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all">
                    <button class="faq-toggle w-full flex justify-between items-center p-8 text-right bg-white dark:bg-gray-800 transition-colors">
                        <span class="font-black text-gray-900 dark:text-white text-lg group-hover:text-blue-600 transition-colors">@Localizer["FAQRefund"]</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center transition-transform duration-300 icon-box">
                            <i class="fas fa-plus text-gray-400 text-sm"></i>
                        </div>
                    </button>
                    <div class="faq-content px-8 pb-8 bg-white dark:bg-gray-800 hidden">
                        <div class="pt-6 border-t border-gray-50 dark:border-white/5 text-gray-600 dark:text-gray-400 leading-relaxed text-lg">
                            @Localizer["FAQRefundAnswer"]
                        </div>
                    </div>
                </div>
            </div>

            <!-- Technical Category -->
            <div class="faq-item" data-category="technical">
                <div class="group border border-gray-100 dark:border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all">
                    <button class="faq-toggle w-full flex justify-between items-center p-8 text-right bg-white dark:bg-gray-800 transition-colors">
                        <span class="font-black text-gray-900 dark:text-white text-lg group-hover:text-blue-600 transition-colors">@Localizer["FAQVideoIssue"]</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center transition-transform duration-300 icon-box">
                            <i class="fas fa-plus text-gray-400 text-sm"></i>
                        </div>
                    </button>
                    <div class="faq-content px-8 pb-8 bg-white dark:bg-gray-800 hidden">
                        <div class="pt-6 border-t border-gray-50 dark:border-white/5 text-gray-600 dark:text-gray-400 leading-relaxed text-lg">
                            @Localizer["FAQVideoIssueAnswer"]
                        </div>
                    </div>
                </div>
            </div>

            <div class="faq-item" data-category="technical">
                <div class="group border border-gray-100 dark:border-white/5 rounded-3xl overflow-hidden hover:border-blue-500/30 transition-all">
                    <button class="faq-toggle w-full flex justify-between items-center p-8 text-right bg-white dark:bg-gray-800 transition-colors">
                        <span class="font-black text-gray-900 dark:text-white text-lg group-hover:text-blue-600 transition-colors">@Localizer["FAQMobileApp"]</span>
                        <div class="w-8 h-8 rounded-full bg-gray-50 dark:bg-white/5 flex items-center justify-center transition-transform duration-300 icon-box">
                            <i class="fas fa-plus text-gray-400 text-sm"></i>
                        </div>
                    </button>
                    <div class="faq-content px-8 pb-8 bg-white dark:bg-gray-800 hidden">
                        <div class="pt-6 border-t border-gray-50 dark:border-white/5 text-gray-600 dark:text-gray-400 leading-relaxed text-lg">
                            @Localizer["FAQMobileAppAnswer"]
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- No Results -->
        <div id="noResults" class="hidden py-20 text-center animate-fade-in-up">
            <div class="w-24 h-24 bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="fas fa-search-minus text-gray-400 text-3xl"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">@Localizer["NoResultsFound"]</h3>
            <p class="text-gray-500 dark:text-gray-400">@Localizer["TryOtherSearchTerms"]</p>
        </div>

        <!-- CTA Section -->
        <div class="mt-24 relative overflow-hidden rounded-[3rem] bg-gray-900 p-8 md:p-16 scroll-animate text-center">
            <div class="absolute inset-0 opacity-20 animated-dots-grid"></div>
            <div class="relative z-10">
                <div class="w-20 h-20 bg-blue-600/20 rounded-3xl flex items-center justify-center mx-auto mb-8">
                    <i class="fas fa-comments text-blue-500 text-3xl"></i>
                </div>
                <h2 class="text-3xl font-black text-white mb-4">@Localizer["StillLookingForAnswer"]</h2>
                <p class="text-gray-400 text-lg mb-10 max-w-xl mx-auto">@Localizer["SupportTeamReady"]</p>
                <a asp-action="contact" class="px-10 py-4 bg-blue-600 text-white font-bold rounded-2xl hover:bg-blue-500 transition-all shadow-xl shadow-blue-600/30">
                    @Localizer["ContactUsNow"]
                </a>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // FAQ Accordion logic
        const toggles = document.querySelectorAll('.faq-toggle');
        toggles.forEach(toggle => {
            toggle.addEventListener('click', () => {
                const content = toggle.nextElementSibling;
                const iconBox = toggle.querySelector('.icon-box');
                const icon = toggle.querySelector('i');
                
                // Toggle Content
                const isHidden = content.classList.contains('hidden');
                
                // Close all others first (optional, but cleaner)
                // document.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
                // document.querySelectorAll('.icon-box').forEach(i => i.style.transform = 'rotate(0deg)');
                // document.querySelectorAll('.faq-toggle i').forEach(i => i.classList.replace('fa-minus', 'fa-plus'));

                if(isHidden) {
                    content.classList.remove('hidden');
                    icon.classList.replace('fa-plus', 'fa-minus');
                    iconBox.style.transform = 'rotate(180deg)';
                } else {
                    content.classList.add('hidden');
                    icon.classList.replace('fa-minus', 'fa-plus');
                    iconBox.style.transform = 'rotate(0deg)';
                }
            });
        });

        // Search & Filter Logic
        const searchInput = document.getElementById('faqSearch');
        const filterBtns = document.querySelectorAll('.filter-btn');
        const faqItems = document.querySelectorAll('.faq-item');
        const noResults = document.getElementById('noResults');

        const filterFaq = () => {
            const searchTerm = searchInput.value.toLowerCase();
            const activeFilter = document.querySelector('.filter-btn.active').dataset.filter;
            let visibleCount = 0;

            faqItems.forEach(item => {
                const text = item.innerText.toLowerCase();
                const category = item.dataset.category;
                const matchesSearch = text.includes(searchTerm);
                const matchesFilter = activeFilter === 'all' || category === activeFilter;

                if(matchesSearch && matchesFilter) {
                    item.classList.remove('hidden-by-filter');
                    visibleCount++;
                } else {
                    item.classList.add('hidden-by-filter');
                }
            });

            noResults.classList.toggle('hidden', visibleCount > 0);
        };

        searchInput.addEventListener('input', filterFaq);

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active', 'bg-blue-600', 'text-white'));
                filterBtns.forEach(b => b.classList.add('bg-gray-100', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-400'));
                
                btn.classList.add('active', 'bg-blue-600', 'text-white');
                btn.classList.remove('bg-gray-100', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-400');
                
                filterFaq();
            });
        });

        // Scroll Animation
        const scrollElements = document.querySelectorAll('.scroll-animate');
        const handleScrollAnimation = () => {
            scrollElements.forEach((el) => {
                const elementTop = el.getBoundingClientRect().top;
                if (elementTop <= (window.innerHeight || document.documentElement.clientHeight) / 1.15) {
                    el.classList.add('animated');
                }
            });
        };
        window.addEventListener('scroll', handleScrollAnimation);
        handleScrollAnimation();
    });
</script>