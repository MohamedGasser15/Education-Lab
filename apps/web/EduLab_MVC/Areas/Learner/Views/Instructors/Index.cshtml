@using EduLab_MVC.Common
@using EduLab_MVC.Models.DTOs.Instructor
@model List<InstructorDTO>
@{
    ViewData["Title"] = "المدربون - EduLab";
    var token = Context.Request.Cookies["AuthToken"];
    var isLoggedIn = !string.IsNullOrEmpty(token);
    var role = Context.Request.Cookies["UserRole"];
}

<style>
    /* ========== BASE ANIMATIONS ========== */
    @@keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
    }

    /* Scroll Animation Classes */
    .scroll-animate {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }

    .scroll-animate.animated {
        opacity: 1;
        transform: translateY(0);
    }

    /* ========== HERO SECTION ENHANCED ========== */
    .hero-gradient-bg {
        background: radial-gradient(circle at 20% 30%, rgba(37, 99, 235, 0.15) 0%, transparent 50%), 
                    radial-gradient(circle at 80% 70%, rgba(6, 182, 212, 0.1) 0%, transparent 50%), 
                    linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }

    /* ========== SECTION BADGE ========== */
    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.2rem;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #1e3a8a;
        background: rgba(255, 255, 255, 0.25);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 40px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .dark .section-badge {
        color: #f1f5f9;
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
    }

    /* ========== INSTRUCTOR CARDS ========== */
    .instructor-card {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .dark .instructor-card {
        border-color: rgba(255, 255, 255, 0.05);
    }

    .instructor-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.15);
        border-color: rgba(37, 99, 235, 0.3);
    }

    /* ========== ANIMATED DOTS GRID ========== */
    @@keyframes move-dots {
        0% { background-position: 0 0; }
        100% { background-position: 40px 40px; }
    }

    .animated-dots-grid {
        background-image: radial-gradient(rgba(255, 255, 255, 0.2) 1.5px, transparent 1.5px);
        background-size: 40px 40px;
        animation: move-dots 4s linear infinite;
    }

    .hero-glass-card {
        backdrop-filter: blur(12px);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
</style>

<!-- Hero Section -->
<section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden hero-gradient-bg">
    <div class="absolute inset-0 opacity-20 animated-dots-grid"></div>
    <div class="container mx-auto px-4 relative z-20 py-24 text-center animate-fade-in-up">
        <span class="section-badge mb-6" style="color: white !important;">
            <i class="fas fa-chalkboard-teacher ml-2" style="color: white !important;"></i> مجتمع الخبراء
        </span>
        <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-8 leading-tight">
            تعلم من <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-400 via-cyan-400 to-blue-400">نخبة المدربين</span> <br /> وابقَ في المقدمة
        </h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed mb-12">
            اكتشف شغفك وتعلم مهارات جديدة مع نخبة من أفضل المدربين المتخصصين في مجالات التكنولوجيا والتصميم والأعمال.
        </p>
        
        <!-- Quick Stats Hero -->
        <div class="flex flex-wrap justify-center gap-6">
            <div class="hero-glass-card px-8 py-4 rounded-2xl">
                <span class="block text-white font-black text-2xl">+150</span>
                <span class="text-gray-400 text-xs font-bold uppercase tracking-widest">مدرب خبير</span>
            </div>
            <div class="hero-glass-card px-8 py-4 rounded-2xl">
                <span class="block text-white font-black text-2xl">4.9/5</span>
                <span class="text-gray-400 text-xs font-bold uppercase tracking-widest">متوسط التقييم</span>
            </div>
            <div class="hero-glass-card px-8 py-4 rounded-2xl">
                <span class="block text-white font-black text-2xl">24/7</span>
                <span class="text-gray-400 text-xs font-bold uppercase tracking-widest">دعم تعليمي</span>
            </div>
        </div>
    </div>
    
    <!-- Wave Decoration -->
    <div class="absolute bottom-[-1px] left-0 right-0">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120" fill="none" preserveAspectRatio="none" class="block w-full">
            <path d="M0 120L60 105C120 90 240 60 360 52.5C480 45 600 60 720 67.5C840 75 960 75 1080 67.5C1200 60 1320 45 1380 37.5L1440 30V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white" class="dark:fill-gray-900" />
        </svg>
    </div>
</section>

<!-- Main Section -->
<section class="py-24 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
        
        <!-- Search & Filter Area -->
        <div class="flex flex-col lg:flex-row justify-between items-center mb-20 gap-8 scroll-animate">
            <div class="relative w-full lg:w-1/3">
                <i class="fas fa-search absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg"></i>
                <input type="text" placeholder="ابحث عن مدرب بالاسم أو التخصص..." 
                       class="w-full pr-12 pl-4 py-5 bg-gray-50 dark:bg-gray-800 border-none rounded-[2rem] focus:ring-2 focus:ring-blue-500 transition-all dark:text-white text-lg">
            </div>
            <div class="flex flex-wrap items-center justify-center gap-4">
                <div class="relative">
                    <select class="appearance-none px-8 py-5 bg-gray-50 dark:bg-gray-800 border-none rounded-[1.5rem] text-gray-600 dark:text-gray-300 font-bold pr-12 cursor-pointer focus:ring-2 focus:ring-blue-500 transition-all">
                        <option>جميع التخصصات</option>
                        <option>برمجة</option>
                        <option>تصميم</option>
                        <option>أعمال</option>
                    </select>
                    <i class="fas fa-chevron-down absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                </div>
                <button class="px-10 py-5 bg-blue-600 text-white rounded-[1.5rem] font-bold shadow-xl shadow-blue-600/30 hover:bg-blue-500 transition-all">
                    تطبيق الفلتر
                </button>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div id="instructor-items" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-10">
                @foreach (var instructor in Model)
                {
                    <div class="instructor-card group bg-white dark:bg-gray-800 rounded-[3rem] p-8 text-center scroll-animate">
                        <div class="relative w-32 h-32 mx-auto mb-6">
                            <div class="absolute inset-0 bg-blue-600 rounded-full blur-xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                            <img src="@(string.IsNullOrEmpty(instructor.ProfileImageUrl) ? "https://ui-avatars.com/api/?name=" + instructor.FullName + "&background=0D8ABC&color=fff" : instructor.ProfileImageUrl)" 
                                 alt="@instructor.FullName" class="relative w-full h-full rounded-full object-cover border-4 border-white dark:border-gray-700 shadow-xl transition-transform duration-500 group-hover:scale-105">
                            <div class="absolute -bottom-2 -right-2 w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs border-4 border-white dark:border-gray-800">
                                <i class="fas fa-check"></i>
                            </div>
                        </div>
                        
                        <h3 class="text-xl font-black text-gray-900 dark:text-white mb-2 group-hover:text-blue-600 transition-colors">@instructor.FullName</h3>
                        <p class="text-blue-600 dark:text-blue-400 font-bold text-sm mb-6 uppercase tracking-wider line-clamp-1">@instructor.Title</p>
                        
                        <div class="grid grid-cols-3 gap-4 py-6 border-y border-gray-50 dark:border-white/5 mb-8">
                            <div>
                                <span class="block text-gray-900 dark:text-white font-black text-lg">@instructor.TotalStudents.ToString("N0")</span>
                                <span class="text-[10px] text-gray-500 uppercase font-bold">طالب</span>
                            </div>
                            <div>
                                <span class="block text-gray-900 dark:text-white font-black text-lg">@instructor.Rating.ToString("0.0")</span>
                                <span class="text-[10px] text-gray-500 uppercase font-bold">تقييم</span>
                            </div>
                            <div>
                                <span class="block text-gray-900 dark:text-white font-black text-lg">@instructor.TotalCourses</span>
                                <span class="text-[10px] text-gray-500 uppercase font-bold">دورة</span>
                            </div>
                        </div>

                        <div class="flex flex-wrap items-center justify-center gap-2 mb-8 h-8 overflow-hidden">
                            @foreach (var subject in instructor.InstructorSubjects.Take(2))
                            {
                                <span class="px-3 py-1 bg-gray-50 dark:bg-white/5 text-[10px] text-gray-600 dark:text-gray-400 rounded-lg font-bold">@subject</span>
                            }
                        </div>

                        <a asp-area="Learner" asp-controller="Profile" asp-action="InstructorProfile" asp-route-id="@instructor.Id"
                           class="block w-full py-4 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold rounded-2xl hover:bg-blue-600 dark:hover:bg-blue-500 dark:hover:text-white transition-all shadow-xl">
                            الملف الشخصي
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-32 bg-gray-50 dark:bg-gray-800/50 rounded-[4rem] scroll-animate">
                <div class="w-24 h-24 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center mx-auto mb-8">
                    <i class="fas fa-users-slash text-blue-600 dark:text-blue-300 text-4xl"></i>
                </div>
                <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-4">لا يوجد مدربون متاحون حالياً</h3>
                <p class="text-gray-500 dark:text-gray-400 max-w-md mx-auto">سيتم إضافة مدربين جدد قريباً. يمكنك متابعتنا لمعرفة آخر التحديثات.</p>
            </div>
        }

        <!-- Pagination Area -->
        <div class="flex justify-center mt-24 scroll-animate">
            <nav class="flex items-center gap-3 pagination-container"></nav>
        </div>
    </div>
</section>

<!-- Become Instructor CTA -->
@if (isLoggedIn && role == SD.Student)
{
    <section class="py-24 bg-white dark:bg-gray-900">
        <div class="container mx-auto px-4">
            <div class="relative overflow-hidden rounded-[4rem] bg-gray-900 p-12 md:p-24 scroll-animate">
                <div class="absolute inset-0 opacity-20 animated-dots-grid"></div>
                <div class="absolute top-0 right-0 w-96 h-96 bg-blue-600/10 blur-[150px] rounded-full"></div>
                
                <div class="relative z-10 flex flex-col lg:flex-row items-center gap-16">
                    <div class="lg:w-2/3 text-right">
                        <span class="px-5 py-2 bg-blue-600/20 text-blue-400 text-xs font-black rounded-full uppercase tracking-widest mb-6 inline-block">انضم إلينا</span>
                        <h2 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">شارك معرفتك وابدأ <br /> بربح دخل إضافي</h2>
                        <p class="text-gray-400 text-xl leading-relaxed mb-10">
                            نحن نوفر لك كل الأدوات التي تحتاجها لإنشاء وبيع دوراتك التعليمية. انضم إلى مجتمعنا من الخبراء وابدأ في تغيير حياة آلاف الطلاب اليوم.
                        </p>
                        <a asp-area="Learner" asp-controller="InstructorApplication" asp-action="Apply" 
                           class="inline-flex items-center gap-4 px-12 py-5 bg-blue-600 text-white font-black rounded-2xl hover:bg-blue-500 transition-all shadow-2xl shadow-blue-600/40 transform hover:-translate-y-1">
                            <span>ابدأ رحلتك التدريبية الآن</span>
                            <i class="fas fa-arrow-left"></i>
                        </a>
                    </div>
                    <div class="lg:w-1/3 grid grid-cols-2 gap-4">
                        <div class="bg-white/5 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white/5 text-center">
                            <i class="fas fa-rocket text-blue-500 text-3xl mb-4"></i>
                            <h4 class="text-white font-bold text-sm">سرعة الإطلاق</h4>
                        </div>
                        <div class="bg-white/5 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white/5 text-center translate-y-8">
                            <i class="fas fa-wallet text-green-500 text-3xl mb-4"></i>
                            <h4 class="text-white font-bold text-sm">أرباح مجزية</h4>
                        </div>
                        <div class="bg-white/5 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white/5 text-center">
                            <i class="fas fa-chart-line text-purple-500 text-3xl mb-4"></i>
                            <h4 class="text-white font-bold text-sm">تحليلات نمو</h4>
                        </div>
                        <div class="bg-white/5 backdrop-blur-xl p-8 rounded-[2.5rem] border border-white/5 text-center translate-y-8">
                            <i class="fas fa-headset text-yellow-500 text-3xl mb-4"></i>
                            <h4 class="text-white font-bold text-sm">دعم مستمر</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Pagination Logic
        const instructorItems = document.querySelectorAll("#instructor-items > div");
        const paginationContainer = document.querySelector(".pagination-container");
        let currentPage = 1;

        if (!instructorItems.length) return;

        function getItemsPerPage() {
            const width = window.innerWidth;
            if (width >= 1280) return 8;
            if (width >= 1024) return 6;
            if (width >= 640) return 4;
            return 4;
        }

        function displayPage(page) {
            const itemsPerPage = getItemsPerPage();
            instructorItems.forEach((item, index) => {
                const isVisible = (index >= (page - 1) * itemsPerPage) && (index < page * itemsPerPage);
                item.style.display = isVisible ? 'block' : 'none';
                if(isVisible) {
                     item.classList.add('animated');
                }
            });
        }

        function setupPagination() {
            if (!paginationContainer) return;
            paginationContainer.innerHTML = '';

            const itemsPerPage = getItemsPerPage();
            const pageCount = Math.ceil(instructorItems.length / itemsPerPage);

            if (pageCount <= 1) {
                paginationContainer.style.display = 'none';
                return;
            }
            paginationContainer.style.display = 'flex';

            const createBtn = (content, page, isActive = false) => {
                const btn = document.createElement('a');
                btn.href = "#";
                btn.className = `w-12 h-12 flex items-center justify-center rounded-xl font-bold transition-all shadow-sm ${isActive ? 'bg-blue-600 text-white shadow-blue-600/20' : 'bg-white dark:bg-gray-800 text-gray-500 hover:text-blue-600 border border-gray-100 dark:border-white/5'}`;
                btn.innerHTML = content;
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    if(page === 'prev' && currentPage > 1) currentPage--;
                    else if(page === 'next' && currentPage < pageCount) currentPage++;
                    else if(typeof page === 'number') currentPage = page;
                    
                    displayPage(currentPage);
                    setupPagination();
                    window.scrollTo({ top: document.getElementById('instructor-items').offsetTop - 100, behavior: 'smooth' });
                });
                return btn;
            };

            paginationContainer.appendChild(createBtn('<i class="fas fa-chevron-right"></i>', 'prev'));
            for (let i = 1; i <= pageCount; i++) {
                paginationContainer.appendChild(createBtn(i, i, i === currentPage));
            }
            paginationContainer.appendChild(createBtn('<i class="fas fa-chevron-left"></i>', 'next'));
        }

        // Initial setup
        setupPagination();
        displayPage(currentPage);
        window.addEventListener('resize', () => { setupPagination(); displayPage(currentPage); });

        // Scroll Animation
        const scrollElements = document.querySelectorAll('.scroll-animate');
        const handleScrollAnimation = () => {
            scrollElements.forEach((el) => {
                const elementTop = el.getBoundingClientRect().top;
                if (elementTop <= (window.innerHeight || document.documentElement.clientHeight) / 1.15) {
                    el.classList.add('animated');
                }
            });
        };
        window.addEventListener('scroll', handleScrollAnimation);
        handleScrollAnimation();
    });
</script>