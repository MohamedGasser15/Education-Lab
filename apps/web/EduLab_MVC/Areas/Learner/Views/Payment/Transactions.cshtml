@model IEnumerable<EduLab_MVC.Models.DTOs.Payment.PaymentDto>
@{
    ViewData["Title"] = "سجل المعاملات - EduLab";
}

<!-- ========== BACKGROUND STYLES - مطابق للـ Settings Page ========== -->
<style>
    /* === Page Wrapper with Animated Background === */
    .transactions-page-wrapper {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        background: 
            radial-gradient(circle at 20% 30%, rgba(37, 99, 235, 0.08) 0%, transparent 50%),
            radial-gradient(circle at 80% 70%, rgba(6, 182, 212, 0.06) 0%, transparent 50%),
            linear-gradient(135deg, #f8fafc 0%, #f1f5f9 50%, #e2e8f0 100%);
        transition: background 0.5s ease;
    }
    
    .dark .transactions-page-wrapper {
        background: 
            radial-gradient(circle at 20% 30%, rgba(37, 99, 235, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 80% 70%, rgba(6, 182, 212, 0.10) 0%, transparent 50%),
            linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
    }

    /* === Animated Dots Pattern === */
    .transactions-page-wrapper::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: 
            radial-gradient(rgba(59, 130, 246, 0.12) 1.5px, transparent 1.5px),
            radial-gradient(rgba(6, 182, 212, 0.08) 1.5px, transparent 1.5px);
        background-size: 40px 40px;
        background-position: 0 0, 20px 20px;
        animation: moveDots 25s linear infinite;
        pointer-events: none;
        z-index: 0;
        opacity: 0.7;
    }
    
    .dark .transactions-page-wrapper::before {
        background-image: 
            radial-gradient(rgba(255, 255, 255, 0.06) 1.5px, transparent 1.5px),
            radial-gradient(rgba(99, 102, 241, 0.04) 1.5px, transparent 1.5px);
        opacity: 0.35;
    }
    
    @@keyframes moveDots {
        0% { background-position: 0 0, 20px 20px; }
        100% { background-position: 40px 40px, 60px 60px; }
    }

    /* === Floating Gradient Orbs === */
    .orb-glow {
        position: absolute;
        width: 700px;
        height: 700px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
        filter: blur(60px);
        opacity: 0.5;
        animation: floatGlow 20s ease-in-out infinite;
    }
    
    .orb-glow.primary {
        top: -250px;
        left: -150px;
        background: radial-gradient(circle, rgba(37, 99, 235, 0.4) 0%, transparent 70%);
    }
    
    .orb-glow.secondary {
        bottom: -200px;
        right: -100px;
        background: radial-gradient(circle, rgba(6, 182, 212, 0.3) 0%, transparent 70%);
        animation-delay: -10s;
        animation-duration: 25s;
    }

    /* === Content Layer === */
    .transactions-content-layer {
        position: relative;
        z-index: 10;
    }

    /* === Glass Cards === */
    .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 1.5rem;
        box-shadow: 
            0 4px 6px -1px rgba(0, 0, 0, 0.05),
            0 2px 4px -2px rgba(0, 0, 0, 0.03);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .dark .glass-card {
        background: rgba(30, 41, 59, 0.75);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .glass-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }

    .stat-card {
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s ease;
    }

    .stat-icon {
        width: 3.5rem;
        height: 3.5rem;
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1.5rem;
    }

    .btn-refund {
        background: rgba(37, 99, 235, 0.1);
        color: #2563eb;
        padding: 0.5rem 1rem;
        border-radius: 0.75rem;
        font-weight: 600;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

    .btn-refund:hover {
        background: #2563eb;
        color: white;
    }

    .dark .btn-refund {
        background: rgba(37, 99, 235, 0.2);
        color: #60a5fa;
    }

    .dark .btn-refund:hover {
        background: #2563eb;
        color: white;
    }

    /* Modal Styling */
    .modal-content-glass {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 2rem;
    }

    .dark .modal-content-glass {
        background: rgba(15, 23, 42, 0.95);
        border-color: rgba(255, 255, 255, 0.1);
    }
</style>

<div class="transactions-page-wrapper pt-10 pb-20 px-4">
    <!-- Floating Orbs -->
    <div class="orb-glow primary"></div>
    <div class="orb-glow secondary"></div>

    <div class="transactions-content-layer max-w-6xl mx-auto">
        <!-- Page Header -->
        <div class="text-center mb-12">
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/60 dark:bg-gray-800/60 backdrop-blur-sm rounded-full border border-white/40 dark:border-white/10 text-sm font-medium text-gray-700 dark:text-gray-300 mb-4 shadow-sm">
                <i class="fas fa-history text-blue-500"></i>
                لوحة التحكم
            </span>
            <h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 dark:text-white">
                سجل <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-600 to-cyan-500">المعاملات</span>
            </h1>
            <p class="text-gray-600 dark:text-gray-400 mt-3 text-lg">تتبع مشترياتك وطلبات الاسترداد الخاصة بك</p>
        </div>

        <!-- Stats Bar -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="glass-card stat-card">
                <div class="stat-icon bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400">
                    <i class="fas fa-check-circle"></i>
                </div>
                <p class="text-sm text-gray-500 dark:text-gray-400">المكتملة</p>
                <p class="text-2xl font-bold text-gray-900 dark:text-white">@Model.Count(p => p.Status == "Succeeded" || p.Status == "Paid")</p>
            </div>
            
            <div class="glass-card stat-card">
                <div class="stat-icon bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400">
                    <i class="fas fa-undo"></i>
                </div>
                <p class="text-sm text-gray-500 dark:text-gray-400">المستردة</p>
                <p class="text-2xl font-bold text-gray-900 dark:text-white">@Model.Count(p => p.Status == "Refunded")</p>
            </div>

            <div class="glass-card stat-card">
                <div class="stat-icon bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <p class="text-sm text-gray-500 dark:text-gray-400">إجمالي الإنفاق</p>
                <p class="text-2xl font-bold text-gray-900 dark:text-white">$@Model.Where(p => p.Status != "Refunded").Sum(p => p.Amount).ToString("F2")</p>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="glass-card p-16 text-center border-dashed border-2">
                <div class="w-24 h-24 bg-slate-100 dark:bg-slate-800/50 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="fas fa-receipt text-4xl text-slate-400"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-800 dark:text-white mb-2">لا توجد معاملات بعد</h3>
                <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-sm mx-auto">ابدأ رحلتك التعليمية اليوم واستكشف الكورسات المتميزة</p>
                <a href="@Url.Action("Index", "Course", new { area = "Learner" })" class="inline-flex items-center gap-3 px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all hover:scale-105 shadow-xl shadow-blue-500/25">
                    تصفح الكورسات
                    <i class="fas fa-arrow-left"></i>
                </a>
            </div>
        }
        else
        {
            <div class="glass-card overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-right border-collapse">
                        <thead>
                            <tr class="bg-white/40 dark:bg-slate-900/40 border-b border-white/20 dark:border-white/10">
                                <th class="px-6 py-5 text-sm font-bold text-slate-600 dark:text-slate-300">الكورس</th>
                                <th class="px-6 py-5 text-sm font-bold text-slate-600 dark:text-slate-300">التاريخ</th>
                                <th class="px-6 py-5 text-sm font-bold text-slate-600 dark:text-slate-300">المبلغ</th>
                                <th class="px-6 py-5 text-sm font-bold text-slate-600 dark:text-slate-300">الحالة</th>
                                <th class="px-6 py-5 text-sm font-bold text-slate-600 dark:text-slate-300">الإجراء</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-800/50">
                            @foreach (var payment in Model)
                            {
                                <tr class="hover:bg-white/30 dark:hover:bg-slate-800/20 transition-colors">
                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-4">
                                            <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 border-2 border-white dark:border-slate-700 shadow-sm">
                                                <img src="@(string.IsNullOrEmpty(payment.CourseThumbnail) ? "/images/default-course.jpg" : payment.CourseThumbnail)" 
                                                     alt="@payment.CourseTitle" class="w-full h-full object-cover" />
                                            </div>
                                            <div>
                                                <p class="font-bold text-slate-800 dark:text-white line-clamp-1">@payment.CourseTitle</p>
                                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 font-mono">#ID: @payment.Id</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <div class="text-sm font-semibold text-slate-700 dark:text-slate-300">@payment.PaidAt.ToString("dd MMM yyyy")</div>
                                        <div class="text-xs text-slate-400 mt-1">@payment.PaidAt.ToString("HH:mm")</div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <span class="text-lg font-black text-slate-900 dark:text-white">$@payment.Amount.ToString("F2")</span>
                                    </td>
                                    <td class="px-6 py-5">
                                        @switch (payment.Status)
                                        {
                                            case "Succeeded":
                                            case "Paid":
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-xs font-bold">
                                                    مكتمل
                                                </span>
                                                break;
                                            case "Refunded":
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-400 text-xs font-bold">
                                                    مسترد
                                                </span>
                                                break;
                                            default:
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 text-xs font-bold">
                                                    @payment.Status
                                                </span>
                                                break;
                                        }
                                    </td>
                                    <td class="px-6 py-5 text-left">
                                        @if (payment.IsRefundable)
                                        {
                                            <button onclick="openRefundModal(@payment.Id, '@payment.CourseTitle', @payment.Amount)" 
                                                    class="btn-refund">
                                                <i class="fas fa-undo ml-2"></i>
                                                طلب استرداد
                                            </button>
                                        }
                                        else if (payment.Status == "Refunded")
                                        {
                                            <span class="text-slate-400 dark:text-slate-500 text-xs italic">تمت المعالجة</span>
                                        }
                                        else
                                        {
                                            <span class="text-slate-400 dark:text-slate-500 text-xs flex items-center gap-1 opacity-60" title="لا يمكن الاسترداد بعد 7 أيام أو عند تجاوز 25% من التقدم">
                                                <i class="fas fa-info-circle"></i>
                                                غير متاح
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- Refund Modal - Matching Theme -->
    <div id="refundModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 transition-opacity bg-slate-900/80 backdrop-blur-md" onclick="closeRefundModal()"></div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

            <div class="inline-block align-bottom modal-content-glass text-right overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border-t-4 border-blue-500">
                <div class="px-8 pt-10 pb-6">
                    <div class="flex items-center gap-5 mb-8">
                        <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/40 rounded-2xl flex items-center justify-center text-blue-600 dark:text-blue-400 shrink-0 shadow-inner">
                            <i class="fas fa-undo-alt text-3xl"></i>
                        </div>
                        <div>
                            <h3 class="text-2xl font-bold text-slate-800 dark:text-white" id="modal-title">طلب استرداد الأموال</h3>
                            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1 font-medium">خطوة سريعة لاسترداد قيمة مشترياتك</p>
                        </div>
                    </div>

                    <div class="bg-blue-600/5 dark:bg-blue-400/5 border-r-4 border-blue-500 rounded-xl p-5 mb-8">
                        <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed font-medium">
                            <i class="fas fa-info-circle ml-2 text-blue-500"></i>
                            تذكر: يمكنك الاسترداد فقط إذا تم الطلب خلال <strong>7 أيام</strong> من الشراء، وبشرط أن يكون تقدمك <strong>أقل من 25%</strong>.
                        </p>
                    </div>

                    <div class="space-y-6">
                        <div class="p-5 bg-white/40 dark:bg-slate-900/40 rounded-2xl border border-white/20 dark:border-white/10 shadow-sm">
                            <p class="text-xs font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">الكورس المحدد</p>
                            <p class="text-lg font-bold text-slate-800 dark:text-white" id="refundCourseTitle"></p>
                        </div>

                        <div class="p-5 bg-white/40 dark:bg-slate-900/40 rounded-2xl border border-white/20 dark:border-white/10 shadow-sm">
                            <p class="text-xs font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-2">المبلغ المسترد</p>
                            <p class="text-3xl font-black text-slate-900 dark:text-white" id="refundAmountText"></p>
                        </div>

                        <div class="space-y-3">
                            <label class="text-sm font-bold text-slate-700 dark:text-slate-300 mr-1">سبب الاسترداد (اختياري)</label>
                            <textarea id="refundReason" rows="3" class="w-full px-5 py-4 bg-white/50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 rounded-2xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all dark:text-white placeholder-slate-400" placeholder="ما الذي لم يعجبك في الكورس؟ نود سماع رأيك لتحسين خدمتنا."></textarea>
                        </div>
                    </div>
                </div>

                <div class="px-8 py-8 bg-slate-50/50 dark:bg-slate-900/50 flex flex-row-reverse gap-4">
                    <button id="confirmRefundBtn" onclick="submitRefund()" class="flex-1 px-6 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all shadow-lg shadow-blue-500/30 flex items-center justify-center gap-3 active:scale-95">
                        <span>تأكيد الاسترداد</span>
                        <div id="refundSpinner" class="hidden w-5 h-5 border-3 border-white/30 border-t-white rounded-full animate-spin"></div>
                    </button>
                    <button onclick="closeRefundModal()" class="flex-1 px-6 py-4 bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-bold border border-slate-200 dark:border-slate-700 rounded-2xl hover:bg-slate-100 dark:hover:bg-slate-700 transition-all active:scale-95">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let currentRefundId = null;

        function openRefundModal(id, title, amount) {
            currentRefundId = id;
            document.getElementById('refundCourseTitle').textContent = title;
            document.getElementById('refundAmountText').textContent = '$' + amount.toFixed(2);
            document.getElementById('refundModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            
            // Animation for modal entrance
            const modalContent = document.querySelector('.modal-content-glass');
            modalContent.animate([
                { opacity: 0, transform: 'scale(0.95) translateY(20px)' },
                { opacity: 1, transform: 'scale(1) translateY(0)' }
            ], { duration: 300, easing: 'cubic-bezier(0.4, 0, 0.2, 1)' });
        }

        function closeRefundModal() {
            const modalContent = document.querySelector('.modal-content-glass');
            const animation = modalContent.animate([
                { opacity: 1, transform: 'scale(1) translateY(0)' },
                { opacity: 0, transform: 'scale(0.95) translateY(20px)' }
            ], { duration: 250, easing: 'cubic-bezier(0.4, 0, 0.2, 1)' });
            
            animation.onfinish = () => {
                document.getElementById('refundModal').classList.add('hidden');
                document.body.style.overflow = 'auto';
                document.getElementById('refundReason').value = '';
            };
        }

        async function submitRefund() {
            const btn = document.getElementById('confirmRefundBtn');
            const spinner = document.getElementById('refundSpinner');
            const reason = document.getElementById('refundReason').value;

            btn.disabled = true;
            spinner.classList.remove('hidden');

            try {
                const response = await fetch('@Url.Action("RequestRefund", "Payment")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        paymentId: currentRefundId,
                        reason: reason
                    })
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        title: 'تمت العملية بنجاح!',
                        text: result.message || 'تمت معالجة طلب الاسترداد، سيصلك المبلغ قريباً.',
                        icon: 'success',
                        confirmButtonText: 'ممتاز',
                        confirmButtonColor: '#2563eb',
                        customClass: {
                            popup: 'rounded-3xl',
                            confirmButton: 'rounded-2xl px-10 py-3 font-bold'
                        }
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire({
                        title: 'عذراً!',
                        text: result.message || 'لم نتمكن من معالجة طلبك حالياً.',
                        icon: 'error',
                        confirmButtonText: 'فهمت',
                        confirmButtonColor: '#2563eb',
                        customClass: {
                            popup: 'rounded-3xl',
                            confirmButton: 'rounded-2xl px-10 py-3 font-bold'
                        }
                    });
                }
            } catch (error) {
                console.error('Error submitting refund:', error);
                Swal.fire({
                    title: 'خطأ تقني!',
                    text: 'حدث خطأ غير متوقع أثناء معالجة الطلب. يرجى المحاولة لاحقاً.',
                    icon: 'error',
                    confirmButtonText: 'حسناً',
                    confirmButtonColor: '#2563eb'
                });
            } finally {
                btn.disabled = false;
                spinner.classList.add('hidden');
                closeRefundModal();
            }
        }
    </script>
}

@Html.AntiForgeryToken()
