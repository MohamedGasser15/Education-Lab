@using System.Globalization
@using EduLab_MVC.Services.ServiceInterfaces
@using EduLab_MVC.Common;
@using EduLab_MVC.Resources
@using Microsoft.Extensions.Localization
@inject IUserService _userService
@inject IConfiguration Configuration
@inject IStringLocalizer<SharedResources> Localizer

@{
    var user = await _userService.GetCurrentUserAsync();
    var token = Context.Request.Cookies["AuthToken"];
    var isLoggedIn = !string.IsNullOrEmpty(token);
    var fullName = user?.FullName ?? Localizer["User"].Value;
    var role = user?.Role;
    var profileImage = user?.ProfileImageUrl;
    var baseUrl = Configuration["ApiBaseUrl"];

    if (!string.IsNullOrEmpty(profileImage) && !profileImage.StartsWith("http"))
    {
        profileImage = baseUrl.TrimEnd('/') + "/" + profileImage.TrimStart('/');
    }

    var currentCulture = CultureInfo.CurrentUICulture.Name;
    var languages = new List<(string Name, string Code)>
    {
        ("English", "en"),
        ("العربية", "ar"),
        ("中文", "zh"),
        ("Nederlands", "nl"),
        ("Français", "fr"),
        ("Deutsch", "de"),
        ("हिन्दी", "hi"),
        ("Bahasa Indonesia", "id"),
        ("Italiano", "it"),
        ("日本語", "ja"),
        ("한국어", "ko"),
        ("Bahasa Melayu", "ms"),
        ("Português (Brasil)", "pt"),
        ("Русский", "ru"),
        ("Español", "es"),
        ("Tiếng Việt", "vi"),
        ("Türkçe", "tr"),
        ("Українська", "uk"),
        ("اردو", "ur"),
        ("Polski", "pl")
    };
}

<style>
    /* ========== LOGIN PARTIAL BASE STYLES ========== */
    .user-profile-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 4px 8px 4px 12px;
        background: transparent;
        border-radius: 40px;
        transition: all 0.2s;
        cursor: pointer;
    }

        .user-profile-btn:hover {
            background: #f3f4f6;
        }

    .dark .user-profile-btn:hover {
        background: #374151;
    }

    .user-avatar {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        overflow: hidden;
        border: 2px solid white;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .dark .user-avatar {
        border-color: #374151;
    }

    .user-name {
        font-weight: 600;
        font-size: 14px;
        color: #1f2937;
        max-width: 120px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .dark .user-name {
        color: #f3f4f6;
    }

    .user-dropdown {
        position: absolute;
        top: calc(100% + 12px);
        left: 0;
        width: 260px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 35px -8px rgba(0,0,0,0.15);
        border: 1px solid #f0f0f0;
        overflow: hidden;
        z-index: 100;
    }

    .dark .user-dropdown {
        background: #1f2937;
        border-color: #374151;
        box-shadow: 0 20px 35px -8px rgba(0,0,0,0.5);
    }

    .user-dropdown-header {
        padding: 16px;
        border-bottom: 1px solid #f3f4f6;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .dark .user-dropdown-header {
        border-bottom-color: #374151;
    }

    .user-dropdown-avatar {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        border: 2px solid #e5e7eb;
    }

    .dark .user-dropdown-avatar {
        border-color: #4b5563;
    }

    .user-dropdown-info h4 {
        font-weight: 700;
        color: #111827;
        font-size: 15px;
        word-break: break-word;
        max-width: 150px;
    }

    .dark .user-dropdown-info h4 {
        color: white;
    }

    .user-dropdown-info p {
        font-size: 13px;
        color: #6b7280;
    }

    .dark .user-dropdown-info p {
        color: #9ca3af;
    }

    .user-dropdown-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        color: #374151;
        font-size: 14px;
        font-weight: 500;
        transition: background 0.15s;
    }

    .dark .user-dropdown-item {
        color: #e5e7eb;
    }

    .user-dropdown-item:hover {
        background: #f9fafb;
    }

    .dark .user-dropdown-item:hover {
        background: #283141;
    }

    .user-dropdown-item i {
        width: 22px;
        color: #6b7280;
    }

    .dark .user-dropdown-item i {
        color: #9ca3af;
    }

    .user-dropdown-divider {
        height: 1px;
        background: #f3f4f6;
        margin: 6px 0;
    }

    .dark .user-dropdown-divider {
        background: #374151;
    }

    .logout-btn {
        color: #dc2626 !important;
    }

        .logout-btn i {
            color: #dc2626 !important;
        }

    /* Mobile Menu Card */
    .mobile-menu-card {
        background: white;
        border-radius: 24px;
        padding: 20px;
        margin: 10px;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
    }

    .dark .mobile-menu-card {
        background: #1f2937;
    }

    .mobile-user-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
    }

    .mobile-avatar {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        border: 3px solid #2563eb;
    }

    /* Guest Buttons */
    .login-btn {
        padding: 8px 18px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 14px;
        color: #374151;
        background: transparent;
        border: 1px solid #e5e7eb;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .dark .login-btn {
        color: #e5e7eb;
        border-color: #4b5563;
    }

    .login-btn:hover {
        background: #f3f4f6;
        border-color: #d1d5db;
    }

    .dark .login-btn:hover {
        background: #374151;
    }

    .register-btn {
        padding: 8px 18px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 14px;
        background: #2563eb;
        color: white;
        box-shadow: 0 4px 8px -2px rgba(37,99,235,0.3);
        transition: all 0.2s;
        white-space: nowrap;
    }

        .register-btn:hover {
            background: #1d4ed8;
            transform: translateY(-1px);
            box-shadow: 0 8px 12px -4px rgba(37,99,235,0.4);
        }

    /* ========== RESPONSIVE ADJUSTMENTS ========== */
    @@media (max-width: 640px) {
        .user-dropdown {
            width: 240px;
            right: 0;
            left: auto;
        }

        .user-dropdown-header {
            padding: 14px;
        }

        .user-dropdown-avatar {
            width: 44px;
            height: 44px;
        }

        .user-dropdown-info h4 {
            font-size: 14px;
        }

        .user-dropdown-item {
            padding: 10px 14px;
            font-size: 13px;
        }

        .user-name {
            max-width: 80px;
        }

        .login-btn, .register-btn {
            padding: 6px 14px;
            font-size: 13px;
        }
    }

    @@media (max-width: 480px) {
        .user-profile-btn {
            gap: 6px;
            padding: 2px 6px 2px 8px;
        }

        .user-avatar {
            width: 34px;
            height: 34px;
        }

        .user-name {
            display: none; /* نخفي الاسم في الشاشات الصغيرة جداً ونعتمد فقط على الصورة */
        }

        .mobile-menu-card {
            padding: 16px;
            margin: 6px;
        }

        .mobile-avatar {
            width: 56px;
            height: 56px;
        }
    }

    /* للشاشات الكبيرة جداً (أجهزة سطح المكتب العريضة) */
    @@media (min-width: 1280px) {
        .user-name {
            max-width: 160px;
        }

        .user-dropdown {
            width: 280px;
        }
    }

    /* تحسين ظهور القائمة على أجهزة iPad والأجهزة اللوحية */
    @@media (min-width: 768px) and (max-width: 1024px) {
        .user-dropdown {
            width: 250px;
        }
    }

    /* Language Modal */
    .language-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 200;
        background: rgba(0, 0, 0, 0.5);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }

    .language-modal-overlay.active {
        display: flex;
    }

    .language-modal-box {
        background: white;
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        width: 100%;
        max-width: 560px;
        overflow: hidden;
        animation: modalFadeIn 0.2s ease-out;
    }

    .dark .language-modal-box {
        background: #1f2937;
    }

    @@keyframes modalFadeIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .language-modal-title {
        padding: 20px 20px 16px;
        text-align: center;
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        border-bottom: 1px solid #f3f4f6;
    }

    .dark .language-modal-title {
        color: white;
        border-bottom-color: #374151;
    }

    .language-modal-list {
        padding: 12px;
        max-height: 380px;
        overflow-y: auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 6px;
    }

    .language-option {
        display: block;
        padding: 10px 4px;
        text-align: center;
        border-radius: 10px;
        color: #374151;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.15s;
        text-decoration: none;
        cursor: pointer;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .dark .language-option {
        color: #e5e7eb;
    }

    .language-option:hover {
        background: #f3f4f6;
    }

    .dark .language-option:hover {
        background: #374151;
    }

    .language-option.active {
        background: #eff6ff;
        color: #2563eb;
        font-weight: 700;
    }

    .dark .language-option.active {
        background: #1e3a5f;
        color: #60a5fa;
    }

    @@media (max-width: 640px) {
        .language-modal-list {
            grid-template-columns: repeat(2, 1fr);
        }
        .language-option {
            font-size: 12px;
            padding: 8px 2px;
        }
    }

    @@media (max-width: 400px) {
        .language-modal-list {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

@if (isLoggedIn)
{
    <!-- Desktop User Menu -->
    <div class="relative dropdown  hidden md:block">
        <div class="user-profile-btn dropdown-toggle">
            <div class="user-avatar">
                <img src="@(string.IsNullOrEmpty(profileImage) ? Url.Content("~/img/User Logo.png") : profileImage)"
                     class="w-full h-full object-cover" alt="User">
            </div>
            <span class="user-name">@fullName</span>
            <i class="fas fa-chevron-down text-gray-400 text-xs"></i>
        </div>

        <div class="dropdown-content user-dropdown">
            <div class="user-dropdown-header">
                <img src="@(string.IsNullOrEmpty(profileImage) ? Url.Content("~/img/User Logo.png") : profileImage)"
                     class="user-dropdown-avatar object-cover" alt="User">
                <div class="user-dropdown-info">
                    <h4>@fullName</h4>
                    <p>@role</p>
                </div>
            </div>

            <div class="py-2">
                @if (role == SD.Admin)
                {
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="user-dropdown-item">
                        <i class="fas fa-tachometer-alt"></i> @Localizer["AdminDashboard"]
                    </a>
                    <a asp-area="Learner" asp-controller="Profile" asp-action="Index" class="user-dropdown-item">
                        <i class="fas fa-user"></i> @Localizer["Profile"]
                    </a>
                }
                else if (role == SD.Instructor)
                {
                    <a href="/Instructor/Dashboard/Index" class="user-dropdown-item">
                        <i class="fas fa-chalkboard-teacher"></i> @Localizer["InstructorDashboard"]
                    </a>
                    <a asp-area="Learner" asp-controller="Profile" asp-action="Instructor" class="user-dropdown-item">
                        <i class="fas fa-user"></i> @Localizer["Profile"]
                    </a>
                }
                else if (role == SD.Student)
                {
                    <a asp-area="Learner" asp-controller="Profile" asp-action="Index" class="user-dropdown-item">
                        <i class="fas fa-user"></i> @Localizer["Profile"]
                    </a>
                    <a asp-area="Learner" asp-controller="InstructorApplication" asp-action="Apply" class="user-dropdown-item">
                        <i class="fas fa-file-signature"></i> @Localizer["ApplyAsInstructor"]
                    </a>
                }
                @if (role == SD.InstructorPending)
                {
                    <a asp-area="Learner" asp-controller="Profile" asp-action="Index" class="user-dropdown-item">
                        <i class="fas fa-user"></i> @Localizer["Profile"]
                    </a>
                    <a asp-area="Learner" asp-controller="InstructorApplication" asp-action="MyApplications" class="user-dropdown-item">
                        <i class="fas fa-file-alt"></i> @Localizer["MyApplications"]
                    </a>
                }

                <a asp-area="Learner" asp-controller="Enrollment" asp-action="Index" class="user-dropdown-item">
                    <i class="fas fa-book-open"></i> @Localizer["MyCourses"]
                </a>

                <a asp-area="Learner" asp-controller="Payment" asp-action="Transactions" class="user-dropdown-item">
                    <i class="fas fa-history"></i> @Localizer["TransactionHistory"]
                </a>

                <div class="user-dropdown-divider"></div>

                <a asp-controller="Settings" asp-action="Index" class="user-dropdown-item">
                    <i class="fas fa-cog"></i> @Localizer["Settings"]
                </a>
                <a href="javascript:void(0)" onclick="openLanguageModal()" class="user-dropdown-item">
                    <i class="fas fa-globe"></i> @Localizer["Language"]
                </a>
                <form asp-controller="Auth" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="user-dropdown-item logout-btn w-full text-right">
                        <i class="fas fa-sign-out-alt"></i> @Localizer["Logout"]
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Mobile Menu (سيتم نقل محتواه إلى الـ Sidebar عبر JS) -->
    <div id="mobile-menu" class="hidden">
        <div class="mobile-menu-card">
            <div class="mobile-user-header">
                <img src="@(string.IsNullOrEmpty(profileImage) ? Url.Content("~/img/User Logo.png") : profileImage)"
                     class="mobile-avatar object-cover" alt="User">
                <div>
                    <h3 class="font-bold text-lg text-gray-900 dark:text-white">@fullName</h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400">@role</p>
                </div>
            </div>

            <div class="space-y-1">
                @* نفس الروابط السابقة لكن بتصميم متوافق مع الموبايل *@
                @if (role == SD.Admin)
                {
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                        <i class="fas fa-tachometer-alt w-5 text-blue-600"></i> @Localizer["AdminDashboard"]
                    </a>
                    <a asp-area="Learner" asp-controller="Profile" asp-action="Index" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                        <i class="fas fa-user w-5 text-blue-600"></i> @Localizer["Profile"]
                    </a>
                }
                else if (role == SD.Instructor)
                {
                    <a href="/Instructor/Dashboard/Index" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                        <i class="fas fa-chalkboard-teacher w-5 text-blue-600"></i> @Localizer["InstructorDashboard"]
                    </a>
                    <a asp-area="Learner" asp-controller="Profile" asp-action="Instructor" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                        <i class="fas fa-user w-5 text-blue-600"></i> @Localizer["Profile"]
                    </a>
                }
                else if (role == SD.Student)
                {
                    <a asp-area="Learner" asp-controller="Profile" asp-action="Index" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                        <i class="fas fa-user w-5 text-blue-600"></i> @Localizer["Profile"]
                    </a>
                    <a asp-area="Learner" asp-controller="InstructorApplication" asp-action="Apply" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                        <i class="fas fa-file-signature w-5 text-blue-600"></i> @Localizer["ApplyAsInstructor"]
                    </a>
                }
                @if (role == SD.InstructorPending)
                {
                    <a asp-area="Learner" asp-controller="Profile" asp-action="Index" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                        <i class="fas fa-user w-5 text-blue-600"></i> @Localizer["Profile"]
                    </a>
                    <a asp-area="Learner" asp-controller="InstructorApplication" asp-action="MyApplications" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                        <i class="fas fa-file-alt w-5 text-blue-600"></i> @Localizer["MyApplications"]
                    </a>
                }

                <a asp-area="Learner" asp-controller="Enrollment" asp-action="Index" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                    <i class="fas fa-book-open w-5 text-blue-600"></i> @Localizer["MyCourses"]
                </a>

                <a asp-area="Learner" asp-controller="Payment" asp-action="Transactions" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                    <i class="fas fa-history w-5 text-blue-600"></i> @Localizer["TransactionHistory"]
                </a>

                <div class="my-2 border-t dark:border-gray-700"></div>

                <a asp-controller="Settings" asp-action="Index" class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                    <i class="fas fa-cog w-5 text-gray-500"></i> @Localizer["Settings"]
                </a>
                <button onclick="openLanguageModal()" class="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800">
                    <i class="fas fa-globe w-5 text-gray-500"></i> @Localizer["Language"]
                </button>
                <form asp-controller="Auth" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full flex items-center gap-3 p-3 rounded-xl text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20">
                        <i class="fas fa-sign-out-alt w-5"></i> @Localizer["Logout"]
                    </button>
                </form>
            </div>
        </div>
    </div>
}
else
{
    <!-- Guest Desktop -->
    <div class="hidden md:flex items-center gap-3">
        <a asp-controller="Auth" asp-action="Login" class="login-btn">@Localizer["Login"]</a>
        <a asp-controller="Auth" asp-action="Register" class="register-btn">@Localizer["Register"]</a>
    </div>

    <!-- Guest Mobile Menu -->
    <div id="mobile-menu" class="hidden">
        <div class="mobile-menu-card">
            <div class="text-center mb-4">
                <i class="fas fa-graduation-cap text-4xl text-blue-600"></i>
                <h3 class="font-bold text-lg mt-2">@Localizer["JoinEduLab"]</h3>
                <p class="text-sm text-gray-500">@Localizer["StartLearningJourney"]</p>
            </div>
            <a asp-controller="Auth" asp-action="Login" class="flex items-center justify-center gap-2 w-full p-3 mb-2 border border-gray-300 dark:border-gray-600 rounded-xl font-medium hover:bg-gray-50 dark:hover:bg-gray-800">
                <i class="fas fa-sign-in-alt"></i> @Localizer["Login"]
            </a>
            <a asp-controller="Auth" asp-action="Register" class="flex items-center justify-center gap-2 w-full p-3 bg-blue-600 text-white rounded-xl font-medium shadow-md hover:bg-blue-700">
                <i class="fas fa-user-plus"></i> @Localizer["Register"]
            </a>
            <div class="mt-4 pt-4 border-t dark:border-gray-700 text-sm space-y-2">
                <a href="#" class="block text-gray-600 dark:text-gray-400">@Localizer["Terms"]</a>
                <a href="#" class="block text-gray-600 dark:text-gray-400">@Localizer["Privacy"]</a>
                <a href="#" class="block text-gray-600 dark:text-gray-400">@Localizer["Contact"]</a>
            </div>
        </div>
    </div>
}

<!-- Language Selection Modal (no icons) -->
<div id="languageModal" class="language-modal-overlay" onclick="closeLanguageModal(event)">
    <div class="language-modal-box" onclick="event.stopPropagation()">
        <div class="language-modal-title">@Localizer["SelectLanguage"]</div>
        <div class="language-modal-list">
            @foreach (var lang in languages)
            {
                var isActive = currentCulture.StartsWith(lang.Code);
                <a href="@Url.Action("SetLanguage", "Home", new { culture = lang.Code, returnUrl = Context.Request.Path + Context.Request.QueryString })"
                   class="language-option @(isActive ? "active" : "")">@lang.Name</a>
            }
        </div>
    </div>
</div>

<script>
    function openLanguageModal() {
        document.getElementById('languageModal').classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeLanguageModal(event) {
        if (event && event.target !== event.currentTarget) return;
        document.getElementById('languageModal').classList.remove('active');
        document.body.style.overflow = '';
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
            var modal = document.getElementById('languageModal');
            if (modal.classList.contains('active')) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
        }
    });
</script>