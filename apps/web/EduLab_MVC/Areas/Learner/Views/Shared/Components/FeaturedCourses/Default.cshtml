@model EduLab_MVC.Models.ViewModels.FeaturedCoursesViewModel

@if (Model.Courses != null && Model.Courses.Any())
{
    @foreach (var course in Model.Courses)
    {
        <div class="swiper-slide">
            @await Html.PartialAsync("_CourseCard", course, new ViewDataDictionary(ViewData) {
                { "IsFeatured", Model.IsFeatured },
                { "IsNew", Model.IsNew }
            })
        </div>
    }
}
else
{
    <div class="w-full py-20 flex flex-col items-center justify-center text-center space-y-4">
        <div class="w-24 h-24 bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center mb-4">
            <i class="fas fa-book-open text-3xl text-gray-400 dark:text-gray-600"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-800 dark:text-white">لا توجد دورات مميزة حالياً</h3>
        <p class="text-gray-500 dark:text-gray-400 max-w-xs mx-auto">
            نحن نعمل على تجهيز أقوى المحتويات التعليمية لك، انتظرنا قريباً!
        </p>
        <a asp-controller="Course" asp-action="Index" class="text-blue-600 font-bold hover:underline">
            تصفح جميع الدورات المتاحة
        </a>
    </div>
}