@* EduLab_MVC/Views/Shared/Components/Notification/Default.cshtml *@
@model EduLab_MVC.ViewComponents.NotificationDropdownViewModel

<style>
    /* ========== NOTIFICATION DROPDOWN ========== */
    .notif-btn {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 14px;
        color: #4b5563;
        background: transparent;
        transition: all 0.2s;
    }
    .dark .notif-btn {
        color: #d1d5db;
    }
    .notif-btn:hover {
        background: #f3f4f6;
        color: #2563eb;
    }
    .dark .notif-btn:hover {
        background: #374151;
        color: #60a5fa;
    }

    .notif-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        min-width: 20px;
        height: 20px;
        padding: 0 5px;
        background: #ef4444;
        color: white;
        font-size: 11px;
        font-weight: 700;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 6px rgba(239, 68, 68, 0.4);
        border: 2px solid white;
    }
    .dark .notif-badge {
        border-color: #1f2937;
    }

    .notif-dropdown {
        position: absolute;
        top: calc(100% + 12px);
        right: -20px;
        width: 380px;
        background: white;
        border-radius: 24px;
        box-shadow: 0 20px 35px -8px rgba(0, 0, 0, 0.15);
        border: 1px solid #f0f0f0;
        overflow: hidden;
        z-index: 100;
    }
    .dark .notif-dropdown {
        background: #1f2937;
        border-color: #374151;
        box-shadow: 0 20px 35px -8px rgba(0, 0, 0, 0.5);
    }

    .notif-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 20px;
        border-bottom: 1px solid #f3f4f6;
    }
    .dark .notif-header {
        border-bottom-color: #374151;
    }

    .notif-header-title {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .notif-header-title i {
        font-size: 20px;
        color: #2563eb;
    }
    .dark .notif-header-title i {
        color: #60a5fa;
    }

    .notif-header-title h3 {
        font-weight: 700;
        font-size: 18px;
        color: #111827;
    }
    .dark .notif-header-title h3 {
        color: #f9fafb;
    }

    .notif-new-badge {
        background: #eff6ff;
        color: #2563eb;
        font-size: 12px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 40px;
    }
    .dark .notif-new-badge {
        background: #1e3a8a;
        color: #bfdbfe;
    }

    .notif-list {
        max-height: 380px;
        overflow-y: auto;
    }

    .notif-item {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 16px 20px;
        border-bottom: 1px solid #f9fafb;
        cursor: pointer;
        transition: background 0.15s;
    }
    .dark .notif-item {
        border-bottom-color: #2d3748;
    }
    .notif-item:hover {
        background: #fafafa;
    }
    .dark .notif-item:hover {
        background: #283141;
    }

    .notif-icon {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .notif-icon i {
        font-size: 18px;
    }

    .notif-content {
        flex: 1;
    }

    .notif-title {
        font-weight: 700;
        font-size: 14px;
        color: #1f2937;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .dark .notif-title {
        color: #f3f4f6;
    }

    .notif-message {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.4;
        margin-bottom: 6px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .dark .notif-message {
        color: #9ca3af;
    }

    .notif-time {
        font-size: 11px;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .dark .notif-time {
        color: #6b7280;
    }

    .notif-dot {
        width: 8px;
        height: 8px;
        background: #3b82f6;
        border-radius: 50%;
        display: inline-block;
        animation: pulse-blue 1.8s infinite;
    }
    @@keyframes pulse-blue {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    .notif-footer {
        padding: 14px 20px;
        background: #fafafa;
        border-top: 1px solid #f0f0f0;
    }
    .dark .notif-footer {
        background: #111827;
        border-top-color: #374151;
    }

    .notif-footer-link {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 12px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        color: #2563eb;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s;
    }
    .dark .notif-footer-link {
        background: #1f2937;
        border-color: #374151;
        color: #93c5fd;
    }
    .notif-footer-link:hover {
        background: #2563eb;
        color: white;
        border-color: #2563eb;
    }
    .dark .notif-footer-link:hover {
        background: #2563eb;
        color: white;
    }

    .notif-empty {
        padding: 40px 20px;
        text-align: center;
    }
    .notif-empty i {
        font-size: 40px;
        color: #d1d5db;
        margin-bottom: 12px;
    }
    .dark .notif-empty i {
        color: #4b5563;
    }
    .notif-empty p {
        color: #6b7280;
        font-weight: 500;
    }

    @@media (max-width: 480px) {
        .notif-dropdown {
            width: calc(100vw - 40px);
            right: -10px;
        }
    }
</style>

<div class="relative dropdown">
    <a asp-controller="Notifications" asp-action="Index"
       class="text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 dropdown-toggle p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 transition relative">
        <i class="fas fa-bell text-xl"></i>
        @if (Model.UnreadCount > 0)
        {
            <span class="absolute top-[-5px] right-0 bg-blue-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">
                @(Model.UnreadCount > 9 ? "9+" : Model.UnreadCount.ToString())
            </span>
        }
    </a>

    <div class="dropdown-content notif-dropdown">
        <!-- Header -->
        <div class="notif-header">
            <div class="notif-header-title">
                <i class="fas fa-bell"></i>
                <h3>الإشعارات</h3>
            </div>
            @if (Model.UnreadCount > 0)
            {
                <span class="notif-new-badge">@Model.UnreadCount جديد</span>
            }
        </div>

        <!-- List -->
        <div class="notif-list">
            @if (Model.Notifications.Any())
            {
                var displayItems = Model.Notifications.Take(3).ToList();
                foreach (var notification in displayItems)
                {
                    <div class="notif-item" data-notification-id="@notification.Id">
                        <div class="notif-icon @notification.ColorClass">
                            <i class="@notification.IconClass"></i>
                        </div>
                        <div class="notif-content">
                            <div class="notif-title">
                                <span>@notification.Title</span>
                                @if (notification.Status == EduLab_MVC.Models.DTOs.Notifications.NotificationStatusDto.Unread)
                                {
                                    <span class="notif-dot"></span>
                                }
                            </div>
                            <div class="notif-message">@notification.Message</div>
                            <div class="notif-time">
                                <i class="far fa-clock"></i>
                                <span>@notification.TimeAgo</span>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.Notifications.Count > 3)
                {
                    <a asp-controller="Notifications" asp-action="Index" 
                       class="block text-center text-sm text-blue-600 dark:text-blue-400 py-3 hover:bg-gray-50 dark:hover:bg-gray-800 transition font-medium">
                        عرض @(Model.Notifications.Count - 3) إشعارات أخرى
                        <i class="fas fa-arrow-left mr-1 text-xs"></i>
                    </a>
                }
            }
            else
            {
                <div class="notif-empty">
                    <i class="far fa-bell-slash"></i>
                    <p>لا توجد إشعارات حالياً</p>
                    <p class="text-xs text-gray-400 mt-2">ستظهر الإشعارات الجديدة هنا</p>
                </div>
            }
        </div>

        @if (Model.Notifications.Any())
        {
            <div class="notif-footer">
                <a asp-controller="Notifications" asp-action="Index" class="notif-footer-link">
                    <span>عرض جميع الإشعارات</span>
                    <i class="fas fa-arrow-left"></i>
                </a>
            </div>
        }
    </div>
</div>

<script>
    // نفس وظائف JavaScript السابقة (markAsRead, updateUnreadCount) 
    // مع تعديل بسيط لتناسب الكلاسات الجديدة
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.notif-item').forEach(item => {
            item.addEventListener('click', function(e) {
                const id = this.dataset.notificationId;
                if (id) markAsRead(id);
            });
        });

        document.addEventListener('click', () => {
            document.querySelectorAll('.dropdown-content').forEach(c => c.classList.add('hidden'));
        });
    });

    async function markAsRead(id) {
        try {
            await fetch(`/Notifications/MarkAsRead/${id}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value,
                    'Content-Type': 'application/json'
                }
            });
            const item = document.querySelector(`[data-notification-id="${id}"]`);
            if (item) {
                const dot = item.querySelector('.notif-dot');
                if (dot) dot.remove();
            }
            updateUnreadCount();
        } catch (e) {
            console.error(e);
        }
    }

    function updateUnreadCount() {
        const badge = document.querySelector('.notif-badge');
        if (!badge) return;
        let count = parseInt(badge.textContent);
        if (badge.textContent === '9+') count = 10;
        const newCount = count - 1;
        if (newCount <= 0) {
            badge.remove();
            const headerBadge = document.querySelector('.notif-new-badge');
            if (headerBadge) headerBadge.remove();
        } else {
            badge.textContent = newCount > 9 ? '9+' : newCount;
            const headerBadge = document.querySelector('.notif-new-badge');
            if (headerBadge) headerBadge.textContent = newCount + ' جديد';
        }
    }
</script>