@model List<EduLab_MVC.Models.DTOs.Category.CategoryDTO>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    @foreach (var category in Model)
    {
        <a href="@Url.Action("ByCategory", new { id = category.Category_Id })"
               class="group block bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-lg hover:border-blue-200 dark:hover:border-blue-500/30 transition-all duration-300 transform hover:-translate-y-1">
            
            <!-- أيقونة -->
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br @GetCategoryGradient(category.Category_Name) flex items-center justify-center mb-5 shadow-sm group-hover:shadow-md transition-shadow">
                <i class="fas @GetCategoryIcon(category.Category_Name) text-white text-xl"></i>
            </div>
            
            <!-- اسم التصنيف -->
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                @category.Category_Name
            </h3>
            
            <!-- عدد الدورات -->
            <p class="text-gray-500 dark:text-gray-400 text-sm mb-4">
                @category.CoursesCount دورة
            </p>
            
            <!-- رابط اكتشف الآن -->
            <div class="flex items-center gap-2 text-blue-600 dark:text-blue-400 font-medium text-sm">
                <span>اكتشف الآن</span>
                <i class="fas fa-arrow-left text-xs transition-transform group-hover:-translate-x-1"></i>
            </div>
        </a>
    }
</div>

@functions {
    // نفس دوال GetCategoryIcon و GetCategoryGradient لكن مع تدرجات أكثر حيوية (ألوان صلبة)
    public string GetCategoryIcon(string categoryName)
    {
        var lowerName = categoryName.ToLower();
        if (lowerName.Contains("برمجة") || lowerName.Contains("تطوير")) return "fa-code";
        if (lowerName.Contains("ذكاء") || lowerName.Contains("ai")) return "fa-robot";
        if (lowerName.Contains("بيانات")) return "fa-database";
        if (lowerName.Contains("أمن")) return "fa-shield-alt";
        if (lowerName.Contains("تصميم")) return "fa-paint-brush";
        if (lowerName.Contains("أعمال") || lowerName.Contains("إدارة")) return "fa-briefcase";
        if (lowerName.Contains("تسويق")) return "fa-bullhorn";
        if (lowerName.Contains("مالية") || lowerName.Contains("محاسبة")) return "fa-chart-line";
        if (lowerName.Contains("لغات")) return "fa-language";
        if (lowerName.Contains("رياضيات")) return "fa-square-root-alt";
        if (lowerName.Contains("علوم")) return "fa-flask";
        if (lowerName.Contains("طب")) return "fa-heartbeat";
        if (lowerName.Contains("هندسة")) return "fa-ruler-combined";
        if (lowerName.Contains("موسيقى")) return "fa-music";
        if (lowerName.Contains("تطوير ذاتي")) return "fa-user-graduate";
        if (lowerName.Contains("أطفال")) return "fa-child";
        return "fa-folder";
    }

    public string GetCategoryGradient(string categoryName)
    {
        var lower = categoryName.ToLower();
        if (lower.Contains("برمجة") || lower.Contains("تطوير")) return "from-blue-500 to-blue-600";
        if (lower.Contains("ذكاء") || lower.Contains("ai")) return "from-indigo-500 to-indigo-600";
        if (lower.Contains("بيانات")) return "from-sky-500 to-sky-600";
        if (lower.Contains("أمن")) return "from-emerald-500 to-emerald-600";
        if (lower.Contains("تصميم")) return "from-purple-500 to-purple-600";
        if (lower.Contains("أعمال")) return "from-amber-500 to-amber-600";
        if (lower.Contains("تسويق")) return "from-green-500 to-green-600";
        if (lower.Contains("مالية")) return "from-teal-500 to-teal-600";
        if (lower.Contains("لغات")) return "from-cyan-500 to-cyan-600";
        if (lower.Contains("رياضيات")) return "from-pink-500 to-pink-600";
        if (lower.Contains("علوم")) return "from-teal-500 to-teal-600";
        if (lower.Contains("طب")) return "from-rose-500 to-rose-600";
        if (lower.Contains("هندسة")) return "from-orange-500 to-orange-600";
        if (lower.Contains("موسيقى")) return "from-emerald-500 to-emerald-600";
        if (lower.Contains("تطوير ذاتي")) return "from-sky-500 to-sky-600";
        if (lower.Contains("أطفال")) return "from-cyan-500 to-cyan-600";
        return "from-gray-500 to-gray-600";
    }
}