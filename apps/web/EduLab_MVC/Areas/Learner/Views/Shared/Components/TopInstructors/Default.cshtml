@model List<EduLab_MVC.Models.DTOs.Instructor.InstructorDTO>

@if (Model != null && Model.Any())
{
    @foreach (var instructor in Model)
    {
        <div class="group relative perspective-1000 scroll-animate">
            <div class="relative bg-white dark:bg-gray-800/40 backdrop-blur-xl rounded-[2.5rem] p-8 border border-white/20 dark:border-white/10 shadow-xl transition-all duration-500 group-hover:-rotate-y-12 group-hover:shadow-2xl overflow-hidden h-full flex flex-col items-center text-center">
            
                <div class="absolute -top-24 -right-24 w-48 h-48 bg-blue-500/20 blur-[60px] group-hover:bg-blue-500/40 transition-all duration-700"></div>

                <div class="relative mb-6">
                    <div class="w-32 h-32 rounded-[2rem] overflow-hidden border-4 border-white dark:border-gray-700 shadow-2xl transform group-hover:scale-105 group-hover:rotate-3 transition-all duration-500">
                        <img src="@instructor.ProfileImageUrl" alt="@instructor.FullName" class="w-full h-full object-cover">
                    </div>
                    <div class="absolute -bottom-2 -right-2 bg-yellow-400 text-gray-900 text-[10px] font-bold px-2 py-1 rounded-lg shadow-lg">
                        <i class="fas fa-star ml-1"></i> 4.9
                    </div>
                </div>

                <h3 class="text-xl font-extrabold text-gray-900 dark:text-white mb-1 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                    @instructor.FullName
                </h3>
                <p class="text-blue-600 dark:text-blue-400 text-xs font-bold uppercase tracking-widest mb-4">
                    @instructor.Title
                </p>

                <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed mb-8 line-clamp-3">
                    @instructor.About
                </p>

                <div class="mt-auto flex items-center justify-center gap-3">
                    @if (!string.IsNullOrEmpty(instructor.FacebookUrl))
                    {
                        <a href="@instructor.FacebookUrl" class="w-9 h-9 rounded-xl bg-gray-100 dark:bg-white/5 flex items-center justify-center text-gray-600 dark:text-gray-400 hover:bg-blue-600 hover:text-white transition-all duration-300">
                            <i class="fab fa-facebook-f text-sm"></i>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(instructor.LinkedInUrl))
                    {
                        <a href="@instructor.LinkedInUrl" class="w-9 h-9 rounded-xl bg-gray-100 dark:bg-white/5 flex items-center justify-center text-gray-600 dark:text-gray-400 hover:bg-[#0077b5] hover:text-white transition-all duration-300">
                            <i class="fab fa-linkedin-in text-sm"></i>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(instructor.GitHubUrl))
                    {
                        <a href="@instructor.GitHubUrl" class="w-9 h-9 rounded-xl bg-gray-100 dark:bg-white/5 flex items-center justify-center text-gray-600 dark:text-gray-400 hover:bg-gray-900 hover:text-white transition-all duration-300">
                            <i class="fab fa-github text-sm"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="col-span-full py-16 flex flex-col items-center justify-center text-center">
        <div class="relative mb-6">
            <div class="w-24 h-24 bg-indigo-100 dark:bg-indigo-500/10 rounded-full flex items-center justify-center">
                <i class="fas fa-user-tie text-4xl text-indigo-500 opacity-50"></i>
            </div>
            <i class="fas fa-search text-sm text-indigo-400 absolute bottom-0 right-0 animate-bounce"></i>
        </div>
        <h3 class="text-2xl font-bold text-gray-800 dark:text-white">نحن نستقطب الأفضل!</h3>
        <p class="text-gray-500 dark:text-gray-400 max-w-md mx-auto mt-2">
            قريباً ستجد هنا نخبة من أمهر المحاضرين والخبراء في الوطن العربي. كن أول المنضمين إلينا.
        </p>
        <button class="mt-8 px-8 py-3 bg-indigo-600 text-white rounded-2xl font-bold hover:bg-indigo-500 transition-all shadow-lg shadow-indigo-500/20 active:scale-95">
            هل أنت محاضر؟ انضم إلينا
        </button>
    </div>
}