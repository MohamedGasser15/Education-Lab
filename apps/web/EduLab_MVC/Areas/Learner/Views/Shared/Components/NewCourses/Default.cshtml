@model EduLab_MVC.Models.ViewModels.NewCoursesViewModel

<div class="swiper-wrapper">
    @if (Model.Courses != null && Model.Courses.Any())
    {
        @foreach (var course in Model.Courses)
        {
            <div class="swiper-slide">
                @{
                    ViewData["SwiperMode"] = true;
                }
                @await Html.PartialAsync("_CourseCard", course, new ViewDataDictionary(ViewData) {
                    { "IsFeatured", Model.IsFeatured },
                    { "IsNew", Model.IsNew }
                })
            </div>
        }
    }
    else
    {
        <div class="w-full flex flex-col items-center justify-center py-12 px-4 border-2 border-dashed border-gray-200 dark:border-white/10 rounded-[2rem]">
            <div class="relative mb-4">
                <i class="fas fa-sparkles text-yellow-400 absolute -top-2 -right-2 animate-pulse"></i>
                <div class="w-16 h-16 bg-blue-50 dark:bg-blue-900/20 rounded-2xl flex items-center justify-center">
                    <i class="fas fa-clock text-2xl text-blue-500"></i>
                </div>
            </div>
            <h3 class="text-lg font-bold text-gray-800 dark:text-white">قادم بقوة!</h3>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">
                نحن نجهز الآن مجموعة من الدورات الحديثة التي ستنطلق قريباً.
            </p>
        </div>
    }
</div>