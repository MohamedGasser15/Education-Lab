@model EduLab_MVC.Models.DTOs.Cart.CartDto

<style>
    /* ========== CART DROPDOWN ========== */
    .cart-btn {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 14px;
        color: #4b5563;
        background: transparent;
        transition: all 0.2s;
    }

    .dark .cart-btn {
        color: #d1d5db;
    }

    .cart-btn:hover {
        background: #f3f4f6;
        color: #2563eb;
    }

    .dark .cart-btn:hover {
        background: #374151;
        color: #60a5fa;
    }

    .cart-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        min-width: 20px;
        height: 20px;
        padding: 0 5px;
        background: #2563eb;
        color: white;
        font-size: 11px;
        font-weight: 700;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 6px rgba(37, 99, 235, 0.4);
        border: 2px solid white;
    }

    .dark .cart-badge {
        border-color: #1f2937;
    }

    .cart-dropdown {
        position: absolute;
        top: calc(100% + 12px);
        right: -20px;
        width: 340px;
        background: white;
        border-radius: 24px;
        box-shadow: 0 20px 35px -8px rgba(0, 0, 0, 0.15);
        border: 1px solid #f0f0f0;
        overflow: hidden;
        z-index: 100;
    }

    .dark .cart-dropdown {
        background: #1f2937;
        border-color: #374151;
        box-shadow: 0 20px 35px -8px rgba(0, 0, 0, 0.5);
    }

    .cart-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 20px;
        border-bottom: 1px solid #f3f4f6;
    }

    .dark .cart-header {
        border-bottom-color: #374151;
    }

    .cart-header-title {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .cart-header-title i {
            font-size: 20px;
            color: #2563eb;
        }

    .dark .cart-header-title i {
        color: #60a5fa;
    }

    .cart-header-title h3 {
        font-weight: 700;
        font-size: 18px;
        color: #111827;
    }

    .dark .cart-header-title h3 {
        color: #f9fafb;
    }

    .cart-items-count {
        background: #eff6ff;
        color: #2563eb;
        font-size: 12px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 40px;
    }

    .dark .cart-items-count {
        background: #1e3a8a;
        color: #bfdbfe;
    }

    .cart-list {
        max-height: 340px;
        overflow-y: auto;
        padding: 8px 0;
    }

    .cart-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 20px;
        border-bottom: 1px solid #f9fafb;
        transition: background 0.15s;
    }

    .dark .cart-item {
        border-bottom-color: #2d3748;
    }

    .cart-item:hover {
        background: #fafafa;
    }

    .dark .cart-item:hover {
        background: #283141;
    }

    .cart-item-img {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        object-fit: cover;
        border: 1px solid #e5e7eb;
        flex-shrink: 0;
    }

    .dark .cart-item-img {
        border-color: #4b5563;
    }

    .cart-item-info {
        flex: 1;
        min-width: 0;
    }

    .cart-item-title {
        font-weight: 700;
        font-size: 14px;
        color: #1f2937;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .dark .cart-item-title {
        color: #f3f4f6;
    }

    .cart-item-price {
        font-weight: 700;
        font-size: 15px;
        color: #2563eb;
    }

    .dark .cart-item-price {
        color: #60a5fa;
    }

    .cart-more-link {
        display: block;
        text-align: center;
        padding: 12px;
        font-size: 13px;
        font-weight: 500;
        color: #2563eb;
        background: #fafafa;
        border-top: 1px solid #f0f0f0;
        transition: background 0.2s;
    }

    .dark .cart-more-link {
        background: #111827;
        border-top-color: #374151;
        color: #93c5fd;
    }

    .cart-more-link:hover {
        background: #f3f4f6;
    }

    .dark .cart-more-link:hover {
        background: #1e293b;
    }

    .cart-footer {
        padding: 16px 20px;
        background: #fafafa;
        border-top: 1px solid #f0f0f0;
    }

    .dark .cart-footer {
        background: #111827;
        border-top-color: #374151;
    }

    .cart-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        font-size: 15px;
    }

    .cart-total-label {
        color: #6b7280;
        font-weight: 500;
    }

    .dark .cart-total-label {
        color: #9ca3af;
    }

    .cart-total-value {
        font-weight: 800;
        font-size: 18px;
        color: #111827;
    }

    .dark .cart-total-value {
        color: white;
    }

    .cart-checkout-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 14px;
        background: #2563eb;
        color: white;
        border-radius: 16px;
        font-weight: 700;
        font-size: 15px;
        transition: all 0.2s;
        box-shadow: 0 8px 16px -6px rgba(37, 99, 235, 0.3);
    }

        .cart-checkout-btn:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
            box-shadow: 0 12px 20px -8px rgba(37, 99, 235, 0.4);
        }

    .cart-empty {
        padding: 40px 20px;
        text-align: center;
    }

        .cart-empty i {
            font-size: 40px;
            color: #d1d5db;
            margin-bottom: 12px;
        }

    .dark .cart-empty i {
        color: #4b5563;
    }

    .cart-empty p {
        color: #6b7280;
        font-weight: 500;
    }

    @@media (max-width: 480px) {
        .cart-dropdown {
            width: calc(100vw - 40px);
            right: -10px;
        }
    }
</style>

<div class="relative dropdown">
    <a asp-area="Learner" asp-controller="Cart" asp-action="Index" class="text-gray-700 dropdown-toggle dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 transition relative">
        <i class="fas fa-shopping-cart text-xl"></i>
        <span data-cart-count
              class="absolute top-[-5px] right-0 bg-blue-500 text-white text-xs rounded-full w-5 h-5 flex items-center justify-center">
            @(Model?.Items?.Count() ?? 0)
        </span>

    </a>

    <div class="dropdown-content cart-dropdown">
        <!-- Header -->
        <div class="cart-header">
            <div class="cart-header-title">
                <i class="fas fa-shopping-cart"></i>
                <h3>عربة التسوق</h3>
            </div>
            @if (Model?.Items?.Any() == true)
            {
                <span class="cart-items-count">@Model.Items.Count() عناصر</span>
            }
        </div>

        <!-- Items List -->
        <div class="cart-list">
            @if (Model?.Items != null && Model.Items.Any())
            {
                var itemsToShow = Model.Items.Take(3).ToList();

                foreach (var item in itemsToShow)
                {
                    <a asp-area="Learner" asp-controller="Cart" asp-action="Index" class="cart-item">
                        <img src="@item.ThumbnailUrl" alt="@item.CourseTitle" class="cart-item-img">
                        <div class="cart-item-info">
                            <div class="cart-item-title">@item.CourseTitle</div>
                            <div class="cart-item-price">@item.CoursePrice.ToString("N0") ج.م</div>
                        </div>
                    </a>
                }

                if (Model.Items.Count() > 3)
                {
                    <a asp-area="Learner" asp-controller="Cart" asp-action="Index" class="cart-more-link">
                        + @(Model.Items.Count() - 3) عناصر أخرى
                        <i class="fas fa-arrow-left mr-1 text-xs"></i>
                    </a>
                }
            }
            else
            {
                <div class="cart-empty">
                    <i class="fas fa-shopping-cart"></i>
                    <p>العربة فارغة</p>
                    <p class="text-xs text-gray-400 mt-2">ابدأ بإضافة دورات للعربة</p>
                </div>
            }
        </div>

        <!-- Footer -->
        @if (Model?.Items != null && Model.Items.Any())
        {
            <div class="cart-footer">
                <div class="cart-total">
                    <span class="cart-total-label">المجموع الكلي</span>
                    <span class="cart-total-value">@(Model.TotalPrice.ToString("N0")) ج.م</span>
                </div>
                <a asp-area="Learner" asp-controller="Cart" asp-action="Index" class="cart-checkout-btn">
                    <span>إتمام الشراء</span>
                    <i class="fas fa-arrow-left"></i>
                </a>
            </div>
        }
    </div>
</div>