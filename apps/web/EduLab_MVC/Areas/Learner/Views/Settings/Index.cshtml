                        </div>
                        <div class="text-center p-6 bg-red-50 dark:bg-red-900/20 rounded-2xl border border-red-100 dark:border-red-900/30 hover:border-red-300 dark:hover:border-red-700 transition">
                            <div class="w-14 h-14 rounded-2xl bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400 flex items-center justify-center text-xl mx-auto mb-4">
                                <i class="fas fa-trash-alt"></i>
