                                <option selected>🇸🇦 العربية</option>
                                <option>🇬🇧 English</option>
                                <option>🇫🇷 Français</option>
                            </select>
                        </div>
                        <div>
                            <label class="block font-semibold mb-2 text-gray-700 dark:text-gray-300"><i class="fas fa-clock ml-2 text-pink-500"></i>المنطقة الزمنية</label>
                            <select class="input-modern cursor-pointer" dir="ltr">
                                <option selected>(UTC+02:00) القاهرة</option>
                                <option>(UTC+03:00) الرياض</option>
                                <option>(UTC+00:00) لندن</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block font-semibold mb-4 text-gray-700 dark:text-gray-300"><i class="fas fa-palette ml-2 text-pink-500"></i>الوضع (فاتح/داكن)</label>
                        <div class="flex gap-3">
                            <button class="theme-opt px-5 py-2.5 rounded-xl border-2 border-transparent bg-white dark:bg-gray-800 text-gray-800 dark:text-white hover:border-blue-400 transition shadow-sm" onclick="setTheme('light')">
                                <i class="fas fa-sun ml-1"></i> فاتح
                            </button>
