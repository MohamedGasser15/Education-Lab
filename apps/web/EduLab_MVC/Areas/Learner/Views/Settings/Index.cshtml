<!-- ========== 2FA Setup Modal ========== -->
<div id="twoFactorModal" class="modal-overlay">
    <div class="modal-content">
        <button class="modal-close" id="modalCloseBtn" aria-label="إغلاق">
            <i class="fas fa-times"></i>
        </button>
        
        <h3 class="modal-title"><i class="fas fa-shield-alt text-blue-500 ml-2"></i> إعداد المصادقة الثنائية</h3>
        <p class="modal-description">امسح رمز الـ QR عبر تطبيق المصادقة (Google Authenticator / Authy)</p>
        
        <div class="modal-qr-container">
            <img id="modalQrCodeImg" src="" class="w-28 h-28 rounded-xl object-contain" alt="QR Code">
        </div>
        
        <p class="text-xs text-center text-gray-500 dark:text-gray-400 mb-1">أو أدخل المفتاح يدوياً:</p>
        <div id="modalSecretKey" class="modal-secret" onclick="copySecretKey()">XXXX-XXXX-XXXX</div>
        <p class="text-xs text-center text-blue-500" id="copyHint"><i class="fas fa-copy ml-1"></i>اضغط للنسخ</p>
        
        <div class="flex justify-center gap-2 sm:gap-3 my-5" style="direction: ltr;">
            <input type="text" class="otp-input w-12 h-14 sm:w-14 sm:h-16 text-center text-2xl font-bold bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 rounded-xl focus:border-blue-500 focus:outline-none transition-all dark:text-white" maxlength="1" inputmode="numeric" />
            <input type="text" class="otp-input w-12 h-14 sm:w-14 sm:h-16 text-center text-2xl font-bold bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 rounded-xl focus:border-blue-500 focus:outline-none transition-all dark:text-white" maxlength="1" inputmode="numeric" />
            <input type="text" class="otp-input w-12 h-14 sm:w-14 sm:h-16 text-center text-2xl font-bold bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 rounded-xl focus:border-blue-500 focus:outline-none transition-all dark:text-white" maxlength="1" inputmode="numeric" />
            <input type="text" class="otp-input w-12 h-14 sm:w-14 sm:h-16 text-center text-2xl font-bold bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 rounded-xl focus:border-blue-500 focus:outline-none transition-all dark:text-white" maxlength="1" inputmode="numeric" />
            <input type="text" class="otp-input w-12 h-14 sm:w-14 sm:h-16 text-center text-2xl font-bold bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 rounded-xl focus:border-blue-500 focus:outline-none transition-all dark:text-white" maxlength="1" inputmode="numeric" />
            <input type="text" class="otp-input w-12 h-14 sm:w-14 sm:h-16 text-center text-2xl font-bold bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 rounded-xl focus:border-blue-500 focus:outline-none transition-all dark:text-white" maxlength="1" inputmode="numeric" />
        </div>
        <input type="hidden" id="modalVerificationCode">
        <p id="otpErrorMsg" class="text-red-500 text-sm text-center font-bold hidden mb-4 transition-all"></p>
        
        <div id="modalRecoveryArea"></div>
        
        <div class="modal-actions">
            <button class="btn-secondary" id="modalCancelBtn">إلغاء</button>
            <button class="btn-primary" id="modalEnableBtn">
                <i class="fas fa-check-circle"></i> تفعيل
            </button>
        </div>
    </div>
</div>
<!-- ========== JavaScript ========== -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.min.js"></script>
<script>
$(document).ready(function() {
    // TempData Notifications
    @if (TempData["SuccessMessage"] != null)
    {
        <text>
        setTimeout(() => showToast('@Html.Raw(TempData["SuccessMessage"])', 'success'), 100);
        </text>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <text>
        setTimeout(() => showToast('@Html.Raw(TempData["ErrorMessage"])', 'error'), 100);
        </text>
    }

    // Tab Switching
    const defaultTab = '@Html.Raw(ViewBag.ActiveTab ?? "profile")';
    const urlParams = new URLSearchParams(window.location.search);
    const initialTab = urlParams.get('tab') || defaultTab;
    
    function activateTab(tabId) {
        $('.settings-tab').removeClass('active');
        $(`.settings-tab[data-tab="${tabId}"]`).addClass('active');
        $('.tab-content').removeClass('active-tab');
        $(`#tab-${tabId}`).addClass('active-tab');
    }
    
    if (initialTab) {
        activateTab(initialTab);
    }

    $('.settings-tab').click(function() {
        const tabId = $(this).data('tab');
        
        const url = new URL(window.location);
        url.searchParams.set('tab', tabId);
        window.history.pushState({}, '', url);

        activateTab(tabId);
        
        if(window.innerWidth < 768) {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    });
    // Password Toggle
    $('.toggle-pwd').click(function() {
        const input = $(this).siblings('input');
        const icon = $(this).find('i');
        if(input.attr('type') === 'password') {
            input.attr('type', 'text');
            icon.removeClass('fa-eye-slash').addClass('fa-eye');
        } else {
            input.attr('type', 'password');
            icon.removeClass('fa-eye').addClass('fa-eye-slash');
        }
    });

    // Password Strength Meter
    $('#newPass').on('input', function() {
        const val = $(this).val();
        let strength = 0;
        if(val.length >= 8) strength += 25;
        if(/[A-Z]/.test(val)) strength += 25;
        if(/[0-9]/.test(val)) strength += 25;
        if(/[^A-Za-z0-9]/.test(val)) strength += 25;
        
        const bar = $('.strength-bar');
        bar.removeClass('weak fair good strong');
        
        if(strength < 50) { bar.addClass('weak'); $('#strengthText').text('ضعيفة').css('color','#ef4444'); }
        else if(strength < 75) { bar.addClass('fair'); $('#strengthText').text('متوسطة').css('color','#f59e0b'); }
        else if(strength < 100) { bar.addClass('good'); $('#strengthText').text('جيدة').css('color','#84cc16'); }
        else { bar.addClass('strong'); $('#strengthText').text('قوية ✓').css('color','#10b981'); }
    });

    // Password Match Check
    $('#confirmPass').on('input', function() {
        const match = $(this).val() === $('#newPass').val();
        if($(this).val().length === 0) { $('#matchMsg').text(''); }
        else if(match) { $('#matchMsg').text('✓ متطابقتان').css('color','#10b981'); }
        else { $('#matchMsg').text('✗ غير متطابقتان').css('color','#ef4444'); }
    });

 // Two Factor Auth Logic
let twoFactorEnabled = @Json.Serialize(isTwoFactorEnabled);
const $toggle = $('#twoFactorToggle');
const $enabled = $('#twoFactorEnabledMsg');
const $disabled = $('#twoFactorDisabledMsg');

// Modal Elements
const $modal = $('#twoFactorModal');
const $modalQr = $('#modalQrCodeImg');
const $modalSecret = $('#modalSecretKey');
const $modalCode = $('#modalVerificationCode');
const $modalRecovery = $('#modalRecoveryArea');
const $otpInputs = $('.otp-input');
const $otpError = $('#otpErrorMsg');

function clearOTP() {
    $otpInputs.val('').removeClass('error animate-shake');
    $otpError.addClass('hidden').text('');
}

$otpInputs.on('input', function(e) {
    this.value = this.value.replace(/[^0-9]/g, '');
    if(this.value !== '') {
        $otpInputs.removeClass('error');
        $otpError.addClass('hidden');
        const next = $(this).next('.otp-input');
        if(next.length) next.focus();
    }
});

$otpInputs.on('keydown', function(e) {
    if(e.key === 'Backspace' && this.value === '') {
        const prev = $(this).prev('.otp-input');
        if(prev.length) {
            prev.focus();
            prev.val('');
        }
    } else if (e.key === 'Enter') {
        $modalEnable.click();
    }
});

$otpInputs.on('paste', function(e) {
    e.preventDefault();
    const pastedData = (e.originalEvent.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '').slice(0, 6);
    if(!pastedData) return;
    $otpInputs.val('');
    for(let i = 0; i < pastedData.length; i++) {
        $otpInputs.eq(i).val(pastedData[i]);
    }
    if(pastedData.length === 6) {
        $otpInputs.last().focus();
        $modalEnable.click();
    } else {
        $otpInputs.eq(pastedData.length).focus();
    }
});
const $modalEnable = $('#modalEnableBtn');
const $modalCancel = $('#modalCancelBtn');
const $modalClose = $('#modalCloseBtn');

// Update UI based on 2FA status
function update2FAUI() {
    if(twoFactorEnabled) {
        $enabled.removeClass('hidden');
        $disabled.addClass('hidden');
    } else {
        $enabled.addClass('hidden');
        $disabled.removeClass('hidden');
    }
}

// Open Modal with 2FA Setup Data
function open2FAModal() {
    $modalEnable.prop('disabled', true).addClass('btn-loading');
    clearOTP();
    $modalRecovery.html('');
    setTimeout(() => $otpInputs.first().focus(), 100);
    
    $.get('@Url.Action("GetTwoFactorSetup", "Settings", new { area = "Learner" })', function(res) {
        if(res.qrCodeUrl) $modalQr.attr('src', res.qrCodeUrl);
        if(res.secret) $modalSecret.text(res.secret);
        if(res.recoveryCodes) {
            $modalRecovery.html(`
                <div class="modal-recovery">
                    <strong>⚠️ رموز الاستعادة (احتفظ بها):</strong>
                    <div class="modal-recovery-codes">
                        ${res.recoveryCodes.map(c => `<span>${c}</span>`).join('')}
                    </div>
                </div>
            `);
        }
        $modalEnable.prop('disabled', false).removeClass('btn-loading');
        $modal.addClass('active');
    }).fail(() => { 
        showToast('خطأ في تحميل الإعدادات', 'error'); 
        $toggle.prop('checked', false); 
        update2FAUI();
    });
}

// Close Modal
function close2FAModal(resetToggle = false) {
    $modal.removeClass('active');
    if(resetToggle) {
        $toggle.prop('checked', false);
        update2FAUI();
    }
}

// Copy Secret Key
window.copySecretKey = function() {
    const secret = $modalSecret.text();
    navigator.clipboard?.writeText(secret).then(() => {
        $modalSecret.addClass('copied').text('✓ تم النسخ!');
        $('#copyHint').text('تم النسخ ✓').css('color', '#10b981');
        setTimeout(() => {
            $modalSecret.removeClass('copied').text(secret);
            $('#copyHint').text('اضغط للنسخ 📋').css('color', '');
        }, 2000);
    });
}

// Custom Confirm Modal Logic
window.showConfirmModal = function(title, message, isDanger, callback) {
    const $modal = $('#confirmModal');
    $('#confirmModalTitle').text(title);
    $('#confirmModalMessage').text(message);
    
    if (isDanger) {
        $('#confirmModalIcon').html('<i class="fas fa-exclamation-triangle"></i>').removeClass('bg-blue-100 text-blue-500').addClass('bg-red-100 dark:bg-red-900/30 text-red-500');
        $('#confirmModalConfirm').removeClass('bg-blue-600 hover:bg-blue-700 shadow-blue-500/30').addClass('bg-red-500 hover:bg-red-600 shadow-red-500/30');
    } else {
        $('#confirmModalIcon').html('<i class="fas fa-question-circle"></i>').removeClass('bg-red-100 text-red-500').addClass('bg-blue-100 dark:bg-blue-900/30 text-blue-500');
        $('#confirmModalConfirm').removeClass('bg-red-500 hover:bg-red-600 shadow-red-500/30').addClass('bg-blue-600 hover:bg-blue-700 shadow-blue-500/30');
    }

    $modal.addClass('active');

    $('#confirmModalConfirm').off('click').on('click', function() {
        $modal.removeClass('active');
        if(callback) callback();
    });

    $('#confirmModalCancel').off('click').on('click', function() {
        $modal.removeClass('active');
    });
};

// Toggle Change Handler
$toggle.on('click', function(e) {
    e.preventDefault();
    if (this.checked && !twoFactorEnabled) {
        // Open modal for setup
        open2FAModal();
    } else if (!this.checked && twoFactorEnabled) {
        // Confirm disable
        showConfirmModal('إيقاف المصادقة الثنائية', 'هل أنت متأكد من إيقاف المصادقة الثنائية؟ سيؤدي ذلك إلى تقليل مستوى أمان حسابك.', true, function() {
            const token = $('input[name="__RequestVerificationToken"]').first().val();
            const form = $('<form method="post" action="@Url.Action("DisableTwoFactor", "Settings", new { area = "Learner" })"></form>');
            form.append($('<input type="hidden" name="__RequestVerificationToken" />').val(token));
            $('body').append(form);
            form.submit();
        });
    }
});

// Modal Event Handlers
$modalCancel.add($modalClose).click(() => close2FAModal(true));
$modal.click(function(e) {
    if(e.target === this) close2FAModal(true);
});

// Enable 2FA from Modal
$modalEnable.click(function() {
    let code = '';
    $otpInputs.each(function() { code += $(this).val(); });
    
    if(code.length !== 6) { 
        $otpInputs.addClass('error animate-shake');
        $otpError.text('هذا الحقل مطلوب ويجب إدخال 6 أرقام').removeClass('hidden');
        setTimeout(() => $otpInputs.removeClass('animate-shake'), 400);
        return; 
    }
    
    $otpInputs.removeClass('error');
    $otpError.addClass('hidden');
    $modalCode.val(code);

    $(this).addClass('btn-loading').prop('disabled', true);
    
    const token = $('input[name="__RequestVerificationToken"]').first().val();
    const form = $('<form method="post" action="@Url.Action("EnableTwoFactor", "Settings", new { area = "Learner" })"></form>');
    form.append($('<input type="hidden" name="__RequestVerificationToken" />').val(token));
    form.append($('<input type="hidden" name="Code" />').val(code));
    $('body').append(form);
    form.submit();
});



// Disable 2FA Button (from enabled state)
$('#disable2faBtn').click(function() {
    showConfirmModal('إيقاف المصادقة الثنائية', 'تأكيد إيقاف المصادقة الثنائية؟ سيؤدي ذلك إلى تقليل مستوى أمان حسابك.', true, function() {
        const token = $('input[name="__RequestVerificationToken"]').first().val();
        const form = $('<form method="post" action="@Url.Action("DisableTwoFactor", "Settings", new { area = "Learner" })"></form>');
        form.append($('<input type="hidden" name="__RequestVerificationToken" />').val(token));
        $('body').append(form);
        form.submit();
    });
});

// Initialize UI
update2FAUI();

    // Revoke Sessions
    $('.revokeBtn').click(function() {
        const id = $(this).data('id');
        showConfirmModal('تسجيل الخروج', 'هل أنت متأكد من تسجيل الخروج من هذا الجهاز؟', true, function() {
            const token = $('input[name="__RequestVerificationToken"]').first().val();
            const form = $('<form method="post" action="@Url.Action("RevokeSession", "Settings", new { area = "Learner" })"></form>');
            form.append($('<input type="hidden" name="__RequestVerificationToken" />').val(token));
            form.append($('<input type="hidden" name="sessionId" />').val(id));
            $('body').append(form);
            form.submit();
        });
    });
    
    $('#revokeAllBtn').click(function() {
        showConfirmModal('إنهاء جميع الجلسات', 'هل أنت متأكد من إنهاء جميع الجلسات الأخرى؟', true, function() {
            const token = $('input[name="__RequestVerificationToken"]').first().val();
            const form = $('<form method="post" action="@Url.Action("RevokeAllSessions", "Settings", new { area = "Learner" })"></form>');
            form.append($('<input type="hidden" name="__RequestVerificationToken" />').val(token));
            $('body').append(form);
            form.submit();
        });
    });
    // تعيين رسائل التحقق باللغة العربية
$.validator.messages.required = "هذا الحقل مطلوب";
$.validator.messages.email = "البريد الإلكتروني غير صالح";
$.validator.messages.minlength = "يجب أن يكون طوله على الأقل {0} أحرف";
$.validator.messages.equalTo = "كلمات المرور غير متطابقة";

// إعدادات عامة للـ validator لجعل الخطأ أحمر
$.validator.setDefaults({
    errorClass: "text-red-500 text-xs mt-1 block",
    errorElement: "span"
});
    // Standard Form Submissions (No AJAX)
// Standard Form Submissions (No AJAX)
$('#generalForm').validate({
    rules: { Email: { required: true, email: true }, FullName: { required: true } },
    errorClass: "text-red-500 text-xs mt-1 block",
    errorElement: "span",
    submitHandler: function(form) {
        $(form).find('button[type="submit"]').addClass('btn-loading');
        form.submit();
    }
});

$('#passwordForm').validate({
    rules: { 
        CurrentPassword: { required: true }, 
        NewPassword: { required: true, minlength: 8 }, 
        ConfirmPassword: { equalTo: "#newPass" } 
    },
    errorClass: "text-red-500 text-xs mt-1 block",
    errorElement: "span",
    submitHandler: function(form) {
        $(form).find('button[type="submit"]').addClass('btn-loading');
        form.submit();
    }
});

    // Theme Switcher
    window.setTheme = function(mode) {
        if(mode === 'dark') {
            document.documentElement.classList.add('dark');
            localStorage.setItem('theme', 'dark');
        } else if(mode === 'light') {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('theme', 'light');
        } else {
            localStorage.removeItem('theme');
            if(window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        }
        showToast(`تم تطبيق الوضع: ${mode === 'light' ? 'فاتح' : mode === 'dark' ? 'داكن' : 'تلقائي'}`, 'success');
    };

    // Load saved theme
    (function initTheme() {
        const saved = localStorage.getItem('theme');
        if(saved === 'dark') setTheme('dark');
        else if(saved === 'light') setTheme('light');
    })();

    // Toast Notification System
    window.showToast = function(message, type = 'success') {
        const colors = {
            success: { bg: '#10b981', icon: 'fa-check-circle' },
            error: { bg: '#ef4444', icon: 'fa-exclamation-circle' },
            warning: { bg: '#f59e0b', icon: 'fa-exclamation-triangle' }
        };
        const cfg = colors[type] || colors.success;
        
        const toast = $(`
            <div class="fixed top-5 left-1/2 -translate-x-1/2 text-white px-5 py-3 rounded-xl shadow-2xl z-50 flex items-center gap-3 animate-fade-in" 
                 style="background: ${cfg.bg}">
                <i class="fas ${cfg.icon}"></i>
                <span>${message}</span>
                <button onclick="$(this).closest('div').fadeOut(200, function(){$(this).remove();})" class="ml-2 hover:opacity-80">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        `);
        $('body').append(toast);
        setTimeout(() => toast.fadeOut(300, function(){ $(this).remove(); }), 3500);
    };

    // Placeholder functions
    window.saveNotificationSettings = () => showToast('تم حفظ الإعدادات', 'success');
    window.saveAppearanceSettings = () => showToast('تم تطبيق المظهر', 'success');
    window.requestDataExport = () => showToast('جاري تجهيز البيانات...', 'success');
    
    window.showDeleteConfirmation = function() {
        showConfirmModal('حذف الحساب نهائياً', 'تحذير: هذا الإجراء لا يمكن التراجع عنه! سيتم حذف حسابك وجميع بياناتك. هل أنت متأكد من المتابعة؟', true, function() {
            showToast('جاري الحذف...', 'warning');
            // Add actual delete logic here
        });
    };

    // Keyboard Shortcuts
    $(document).keydown(function(e) {
        if((e.ctrlKey || e.metaKey) && e.key === 's') {
            e.preventDefault();
            const activeForm = $('.tab-content.active-tab form');
            if(activeForm.length) activeForm.submit();
        }
    });
});
</script>