@{
    Layout = "~/Areas/Learner/Views/Shared/_ErrorLayout.cshtml";
    ViewData["Title"] = Localizer["MaintenanceTitle"];
}
<div class="error-card text-center">
    <div class="error-icon">
        <div class="icon-bg" style="background: radial-gradient(circle, rgba(245,158,11,0.2), transparent 70%);" ></div>
        <i class="fas fa-wrench text-6xl text-amber-500 relative z-10"></i>
    </div>

    <h1 class="text-2xl font-extrabold text-gray-900 dark:text-white mt-6">@Localizer["MaintenanceHeading"]</h1>
    <p class="text-gray-500 dark:text-gray-400 mt-2 max-w-md mx-auto">@Localizer["MaintenanceDesc"]</p>
</div>
