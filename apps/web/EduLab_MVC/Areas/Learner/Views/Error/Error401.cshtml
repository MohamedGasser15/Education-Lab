@{
    Layout = "~/Areas/Learner/Views/Shared/_ErrorLayout.cshtml";
    ViewData["Title"] = Localizer["Error401Title"].Value;
}
<div class="error-card">
    <div class="error-icon">
        <div class="icon-bg"></div>
        <h2 class="error-code">401</h2>
    </div>

    <h1>@Localizer["Error401Heading"]</h1>
    <p>@Localizer["Error401Desc"]</p>

    <div class="btn-group">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary" style="background-color:#2563eb;border-color:#2563eb;">
            <span>@Localizer["HomePage"]</span>
        </a>
        <a asp-area="Learner" asp-controller="Auth" asp-action="Login" class="btn btn-secondary">
            <span>@Localizer["Login"]</span>
        </a>
    </div>
</div>