@using EduLab_MVC.Models.DTOs.Category
@model List<EduLab_MVC.Models.DTOs.Course.CourseDTO>
@{
    ViewData["Title"] = "تصفح الكورسات";
    var coursesByCategory = Model.GroupBy(c => c.CategoryId).ToList();
    var singleCategoryMode = ViewBag.CategoryId != null;
}

<style>
    /* ========== BASE ANIMATIONS ========== */
    @@keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
    }

    @@keyframes move-dots {
        0% { background-position: 0 0; }
        100% { background-position: 40px 40px; }
    }
    .animated-dots-grid {
        background-image: radial-gradient(rgba(255, 255, 255, 0.4) 1.5px, transparent 1.5px);
        background-size: 40px 40px;
        animation: move-dots 4s linear infinite;
    }

    /* ========== HERO SECTION (مطابق لـ Home) ========== */
    .hero-gradient-bg {
        background: radial-gradient(circle at 20% 30%, rgba(37, 99, 235, 0.15) 0%, transparent 50%),
                    radial-gradient(circle at 80% 70%, rgba(6, 182, 212, 0.1) 0%, transparent 50%),
                    linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }
    .hero-glass-card {
        backdrop-filter: blur(12px);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .hero-btn-primary {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        box-shadow: 0 10px 20px -8px rgba(37, 99, 235, 0.4);
        transition: all 0.3s ease;
    }
    .hero-btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 20px 30px -10px rgba(37, 99, 235, 0.5);
    }

    /* ========== CATEGORY PILLS (مستوحاة من Hero Topics) ========== */
    .category-pill {
        backdrop-filter: blur(8px);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
    }
    .dark .category-pill {
        background: rgba(255, 255, 255, 0.03);
    }
    .category-pill:hover {
        background: rgba(37, 99, 235, 0.2);
        border-color: rgba(37, 99, 235, 0.4);
        transform: translateY(-2px);
    }
    .category-pill.active {
        background: #2563eb !important;
        color: white !important;
        border-color: #2563eb !important;
    }

    /* ========== COURSE CARD ENHANCED (مطابق لـ Home) ========== */
    .course-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }
    .dark .course-card {
        border-color: rgba(255, 255, 255, 0.05);
    }
    .course-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 35px -12px rgba(0, 0, 0, 0.15);
        border-color: rgba(37, 99, 235, 0.3);
    }
    .dark .course-card:hover {
        box-shadow: 0 25px 35px -12px rgba(0, 0, 0, 0.5);
    }

    /* ========== SWIPER NAVIGATION (مطابق لـ Home) ========== */
    .swiper-button-next,
    .swiper-button-prev {
        width: 48px !important;
        height: 48px !important;
        background: white !important;
        border-radius: 16px !important;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1) !important;
        border: 1px solid rgba(0,0,0,0.05) !important;
        transition: all 0.3s !important;
    }
    .swiper-button-next:hover,
    .swiper-button-prev:hover {
        background: #2563eb !important;
        transform: scale(1.1) !important;
    }
    .swiper-button-next:hover::after,
    .swiper-button-prev:hover::after {
        color: white !important;
    }
    .swiper-button-next::after,
    .swiper-button-prev::after {
        font-size: 18px !important;
        font-weight: bold !important;
        color: #2563eb !important;
    }
    .dark .swiper-button-next,
    .dark .swiper-button-prev {
        background: #1e293b !important;
        border-color: rgba(255,255,255,0.1) !important;
    }
    .dark .swiper-button-next::after,
    .dark .swiper-button-prev::after {
        color: #60a5fa !important;
    }

    /* ========== GRID MODE SWIPER (تحويل الـ swiper إلى grid عند الحاجة) ========== */
    .swiper-container.grid-mode .swiper-wrapper {
        display: grid !important;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)) !important;
        gap: 1.5rem !important;
        transform: none !important;
        padding: 1rem 0 !important;
    }
    .swiper-container.grid-mode .swiper-slide {
        width: 100% !important;
        height: auto !important;
        margin: 0 !important;
    }
    .swiper-container.grid-mode ~ .swiper-button-prev,
    .swiper-container.grid-mode ~ .swiper-button-next {
        display: none !important;
    }

    /* ========== SCROLL ANIMATION ========== */
    .scroll-animate {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .scroll-animate.animated {
        opacity: 1;
        transform: translateY(0);
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 640px) {
        .swiper-button-next,
        .swiper-button-prev {
            display: none;
        }
        .swiper-container.grid-mode .swiper-wrapper {
            grid-template-columns: 1fr !important;
        }
    }/* ========== FULL WIDTH ADJUSTMENTS ========== */
.courses-section-fullwidth {
    width: 100%;
}

/* إزالة القيود عن الحاوية */
section.courses-section-bg > .container {
    max-width: 100% !important;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
}

/* البلوكات تأخذ العرض الكامل */
.category-block {
    width: 100%;
    margin-bottom: 4rem;
    padding: 2rem 2rem;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(8px);
    border-radius: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 20px 35px -8px rgba(0, 0, 0, 0.05);
    transition: box-shadow 0.3s ease;
}

/* جعل الشبكة الداخلية تستفيد من العرض الكامل */
.category-block .grid,
.category-block .swiper-container {
    width: 100%;
}

/* تحسين استجابة للأجهزة المختلفة */
@@media (max-width: 768px) {
    section.courses-section-bg > .container {
        padding-left: 1rem;
        padding-right: 1rem;
    }
    .category-block {
        padding: 1.5rem 1rem;
    }
}/* ========== CATEGORY BLOCK SEPARATION ========== */
.category-block {
    margin-bottom: 4rem;
    padding: 2rem 1.5rem;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(8px);
    border-radius: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 20px 35px -8px rgba(0, 0, 0, 0.05);
    transition: box-shadow 0.3s ease;
}
.dark .category-block {
    background: rgba(17, 24, 39, 0.4);
    border-color: rgba(255, 255, 255, 0.05);
    box-shadow: 0 20px 35px -8px rgba(0, 0, 0, 0.2);
}
.category-block:hover {
    box-shadow: 0 25px 40px -12px rgba(37, 99, 235, 0.1);
}

/* عنوان الفئة داخل البلوك */
.category-block-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid rgba(37, 99, 235, 0.2);
}
.dark .category-block-header {
    border-bottom-color: rgba(59, 130, 246, 0.2);
}

.category-block-header h3 {
    font-size: 1.8rem;
    font-weight: 800;
    color: #1e293b;
}
.dark .category-block-header h3 {
    color: #f1f5f9;
}

.category-block-header .category-icon {
    width: 3rem;
    height: 3rem;
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    border-radius: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.4rem;
    box-shadow: 0 8px 15px -5px rgba(37, 99, 235, 0.3);
}

.category-block-header .course-count {
    background: rgba(37, 99, 235, 0.1);
    color: #2563eb;
    padding: 0.25rem 1rem;
    border-radius: 40px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-right: auto;
}
.dark .course-count {
    background: rgba(59, 130, 246, 0.15);
    color: #93c5fd;
}
</style>

<!-- Hero Section - بنفس تصميم Home -->
<!-- Hero Section - Fully Responsive (No custom breakpoints) -->
<section class="relative min-h-[50vh] md:min-h-[60vh] flex items-center justify-center overflow-hidden hero-gradient-bg">
    <div class="absolute inset-0 opacity-20 animated-dots-grid"></div>
    <div class="container mx-auto px-4 md:px-6 relative z-20 py-8 sm:py-12 md:py-16">
        <div class="flex flex-col items-center text-center space-y-4 sm:space-y-6 animate-fade-in-up">
            <span class="section-badge text-white !bg-white/10 backdrop-blur-sm px-4 py-1.5 rounded-full text-sm">
                <i class="fas fa-layer-group ml-2"></i> مكتبة الدورات
            </span>
            
            <h1 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold leading-tight text-white max-w-4xl px-2">
                <span>استكشف </span>
                <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-400 via-cyan-400 to-blue-400">آلاف الدورات</span>
                <br class="hidden sm:block">
                <span class="text-white/90">وابدأ رحلة التعلم اليوم</span>
            </h1>
            
            <p class="text-sm sm:text-base md:text-lg text-gray-300 max-w-2xl leading-relaxed px-4">
                اختر من بين <span class="font-bold text-blue-300">@Model.Count دورة</span> في مختلف المجالات، صممها خبراء لتناسب احتياجاتك.
            </p>

            <!-- Search Box - Responsive (Column on small screens, row on sm and up) -->
            <div class="hero-glass-card w-full max-w-2xl rounded-2xl p-2 sm:p-1.5 flex flex-col sm:flex-row items-stretch sm:items-center gap-2">
                <div class="flex-grow relative">
                    <i class="fas fa-search absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm sm:text-base"></i>
                    <input type="text" id="searchInput" placeholder="ما الذي تريد تعلمه اليوم؟"
                           class="w-full bg-transparent py-2.5 sm:py-3 pr-10 sm:pr-12 pl-4 text-white placeholder:text-gray-400 rounded-xl text-sm sm:text-base focus:outline-none">
                </div>
                <button type="submit" id="heroSearchBtn" class="hero-btn-primary text-white px-4 sm:px-6 py-2.5 sm:py-3 rounded-xl font-bold text-sm flex items-center justify-center gap-2 whitespace-nowrap">
                    <span>بحث</span>
                    <i class="fas fa-arrow-left text-xs sm:text-sm"></i>
                </button>
            </div>
        </div>
    </div>
    
    <div class="absolute bottom-[-1px] left-0 right-0">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120" fill="none" preserveAspectRatio="none" class="block w-full h-auto">
            <path d="M0 120L60 105C120 90 240 60 360 52.5C480 45 600 60 720 67.5C840 75 960 75 1080 67.5C1200 60 1320 45 1380 37.5L1440 30V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white" class="dark:fill-gray-900" />
        </svg>
    </div>
</section>

<!-- Categories Section (بتصميم عصري) -->
<section class="py-12 bg-white dark:bg-gray-900 scroll-animate">
    <div class="container mx-auto px-4">
        <div class="text-center mb-8">
            <span class="section-badge mb-3">التصنيفات</span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-3">
                تصفح حسب <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-600 to-cyan-400">المجالات</span>
            </h2>
        </div>
        
        <div class="flex flex-wrap justify-center gap-3">
            <a href="@Url.Action("Index")" 
               class="category-pill @(ViewBag.CategoryId == null ? "active" : "") px-6 py-3 rounded-full text-gray-700 dark:text-gray-200 font-medium text-sm flex items-center gap-2 shadow-sm">
                <i class="fas fa-th-large"></i> الكل
            </a>
            @foreach (var category in ViewBag.Categories)
            {
                <a href="@Url.Action("ByCategory", new { id = category.Category_Id })"
                   class="category-pill @(ViewBag.CategoryId == category.Category_Id ? "active" : "") px-6 py-3 rounded-full text-gray-700 dark:text-gray-200 font-medium text-sm flex items-center gap-2 shadow-sm">
                    <i class="fas fa-tag"></i> @category.Category_Name
                </a>
            }
        </div>
    </div>
</section>
<!-- Courses Display Section - Enhanced with Clear Separation -->
<!-- Courses Display Section - Full Width Enhanced -->
<section class="py-8 bg-gray-50 dark:bg-gray-900/50 scroll-animate courses-section-bg">
    <div class="container mx-auto relative z-10" style="max-width: 100%; padding-left: 2rem; padding-right: 2rem;">
        @if (singleCategoryMode)
        {
            var categories = ViewBag.Categories as IEnumerable<CategoryDTO>;
            var category = categories?.FirstOrDefault(c => c.Category_Id == (int)ViewBag.CategoryId);
            var categoryName = category?.Category_Name ?? "غير معروف";
            
            <div class="single-category-header mb-10">
                <div class="flex flex-col md:flex-row justify-between items-end gap-4">
                    <div>
                        <span class="section-badge mb-3">تصنيف</span>
                        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white">
                            @categoryName
                        </h2>
                        <p class="text-gray-600 dark:text-gray-400 mt-2 text-lg">@Model.Count دورة متاحة للتعلم</p>
                    </div>
                    <a href="@Url.Action("Index")" class="group flex items-center gap-2 px-6 py-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-white/10 rounded-xl shadow-md hover:shadow-xl hover:border-blue-500/50 transition-all">
                        <span class="text-gray-700 dark:text-gray-200 font-medium group-hover:text-blue-600">استعراض كل التصنيفات</span>
                        <i class="fas fa-arrow-left text-blue-600 group-hover:-translate-x-1 transition-transform"></i>
                    </a>
                </div>
            </div>

                            <div class="swiper-container grid-mode py-2">
                    <div class="swiper-wrapper">
                @foreach (var course in Model)
                {
                    ViewData["SwiperMode"] = false;
                    @await Html.PartialAsync("_CourseCard", course)
                }
            </div>
            </div>

        }
        else
        {
            @foreach (var categoryGroup in coursesByCategory)
            {
                var categories = ViewBag.Categories as IEnumerable<CategoryDTO>;
                var category = categories?.FirstOrDefault(c => c.Category_Id == categoryGroup.Key);
                var categoryName = category?.Category_Name ?? "غير معروف";
                var swiperId = $"swiper-{categoryGroup.Key}";

                <div class="category-block">
                    <div class="category-block-header">
                        <div class="category-icon">
                            <i class="fas fa-code"></i>
                        </div>
                        <h3>@categoryName</h3>
                        <span class="course-count">@categoryGroup.Count() دورة</span>
                        <a href="@Url.Action("ByCategory", new { id = categoryGroup.Key })" class="mr-auto md:mr-0 group flex items-center gap-2 text-gray-700 dark:text-gray-300 font-medium hover:text-blue-600 dark:hover:text-blue-400 transition-colors bg-white/60 dark:bg-gray-800/60 backdrop-blur-sm px-5 py-2 rounded-xl border border-gray-200/60 dark:border-gray-700/60 shadow-sm">
                            <span>تصفح الكل</span>
                            <i class="fas fa-arrow-left text-sm group-hover:-translate-x-1 transition-transform"></i>
                        </a>
                    </div>

                    <div class="relative">
                        <div class="swiper-container grid-mode py-2" id="@swiperId">
                            <div class="swiper-wrapper">
                                @foreach (var course in categoryGroup.Take(10))
                                {
                                    @await Html.PartialAsync("_CourseCard", course)
                                }
                            </div>
                        </div>
                        <div class="swiper-button-prev !-right-12 !left-auto"></div>
                        <div class="swiper-button-next !-left-12 !right-auto"></div>
                    </div>
                </div>
            }
        }
    </div>
</section><!-- Featured Categories Component (اختياري) -->
<section class="py-12 bg-white dark:bg-gray-900 scroll-animate">
    <div class="container mx-auto px-4">
        <div class="text-center mb-8">
            <span class="section-badge mb-3">تصنيفات مميزة</span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white">
                اكتشف <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-600 to-purple-500">المجالات</span> الرائجة
            </h2>
        </div>
        @await Component.InvokeAsync("CategoriesDropdown", new { type = "featured" })
    </div>
</section>

<script>
    (function() {
        'use strict';

        // ========== SCROLL ANIMATION ==========
        const scrollElements = document.querySelectorAll('.scroll-animate');
        const elementInView = (el, dividend = 1) => {
            const elementTop = el.getBoundingClientRect().top;
            return elementTop <= (window.innerHeight || document.documentElement.clientHeight) / dividend;
        };
        const displayScrollElement = (element) => {
            element.classList.add('animated');
            element.dataset.animated = "true";
        };
        const handleScrollAnimation = () => {
            scrollElements.forEach((el) => {
                if (elementInView(el, 1.25) && !el.dataset.animated) {
                    displayScrollElement(el);
                }
            });
        };
        window.addEventListener('scroll', handleScrollAnimation);
        handleScrollAnimation();

        // ========== SEARCH ==========
        const searchBtn = document.getElementById('heroSearchBtn');
        const searchInput = document.getElementById('searchInput');
        if (searchBtn && searchInput) {
            searchBtn.addEventListener('click', function(e) {
                e.preventDefault();
                const query = searchInput.value.trim();
                if (query) {
                    window.location.href = `/Course/Index?search=${encodeURIComponent(query)}`;
                }
            });
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    searchBtn.click();
                }
            });
        }

        // ========== SWIPER INIT (لجميع الـ containers داخل الصفحة) ==========
        if (typeof Swiper !== 'undefined') {
            document.querySelectorAll('.swiper-container').forEach(container => {
                // إذا كان في وضع grid (يعني عرض التصنيفات المتعددة) نعطيه إعدادات السلايدر
                if (container.classList.contains('grid-mode')) {
                    const nextEl = container.parentElement.querySelector('.swiper-button-next');
                    const prevEl = container.parentElement.querySelector('.swiper-button-prev');
                    
                    new Swiper(container, {
                        slidesPerView: 1,
                        spaceBetween: 24,
                        navigation: {
                            nextEl: nextEl,
                            prevEl: prevEl,
                        },
                        breakpoints: {
                            640: { slidesPerView: 2 },
                            1024: { slidesPerView: 3 },
                            1280: { slidesPerView: 4 }
                        },
                        // نمنع التمرير إذا كان grid-mode مفعل (نحن نستخدم grid عبر CSS، لكن Swiper قد يعطل)
                        // لذلك نعطل touch/wheel إذا أردنا grid فقط، لكننا نريد سلوك السلايدر العادي
                        // نتركه يعمل كسلايدر عادي
                    });
                }
            });
        }

        // ========== DYNAMIC HOVER TOOLTIP (للتوافق مع _CourseCard) ==========
        function updateTooltipDirections() {
            document.querySelectorAll('.swiper-slide').forEach(slide => {
                const tooltip = slide.querySelector('.course-hover-info');
                if (!tooltip) return;
                const container = slide.closest('.swiper-container');
                if (!container) return;
                const containerRect = container.getBoundingClientRect();
                const slideRect = slide.getBoundingClientRect();
                tooltip.classList.remove('force-left', 'force-right');
                if (slideRect.right > containerRect.right - 300) {
                    tooltip.classList.add('force-left');
                } else if (slideRect.left < containerRect.left + 300) {
                    tooltip.classList.add('force-right');
                }
            });
        }
        window.addEventListener('resize', updateTooltipDirections);
        document.querySelectorAll('.swiper-container').forEach(c => {
            c.addEventListener('mouseenter', updateTooltipDirections, { passive: true });
        });
        setTimeout(updateTooltipDirections, 100);

        // ========== FORMAT DURATION (موجود مسبقاً) ==========
        window.formatDuration = function(seconds) {
            const hours = Math.floor(seconds / 3600);
            const minutes = Math.floor((seconds % 3600) / 60);
            const secs = seconds % 60;
            return [
                hours.toString().padStart(2, '0'),
                minutes.toString().padStart(2, '0'),
                secs.toString().padStart(2, '0')
            ].join(':');
        };
    })();
</script>