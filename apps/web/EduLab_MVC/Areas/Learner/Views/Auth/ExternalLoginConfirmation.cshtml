@model EduLab_MVC.Models.DTOs.Auth.ExternalLoginConfirmationDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>إكمال التسجيل · EduLab</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { font-family: 'Inter', system-ui, sans-serif; }
        
        @@keyframes float1 {
            0% { transform: translateY(0px) translateX(0px) rotate(0deg); }
            33% { transform: translateY(-20px) translateX(10px) rotate(5deg); }
            66% { transform: translateY(15px) translateX(-15px) rotate(-5deg); }
            100% { transform: translateY(0px) translateX(0px) rotate(0deg); }
        }
        @@keyframes float2 {
            0% { transform: translateY(0px) translateX(0px) scale(1); }
            50% { transform: translateY(-30px) translateX(-20px) scale(1.05); }
            100% { transform: translateY(0px) translateX(0px) scale(1); }
        }
        @@keyframes float3 {
            0% { transform: translate(0,0) rotate(0deg); }
            40% { transform: translate(25px, -25px) rotate(10deg); }
            80% { transform: translate(-15px, 15px) rotate(-8deg); }
            100% { transform: translate(0,0) rotate(0deg); }
        }
        @@keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        @@keyframes move-dots {
            0% { background-position: 0 0; }
            100% { background-position: 40px 40px; }
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-5px); }
            40%, 80% { transform: translateX(5px); }
        }
        .animate-float1 { animation: float1 12s infinite ease-in-out; }
        .animate-float2 { animation: float2 14s infinite ease-in-out; }
        .animate-float3 { animation: float3 18s infinite ease-in-out; }
        .animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
        .gradient-animate {
            background-size: 200% 200%;
            animation: gradientShift 8s ease infinite;
        }
        .animated-dots-grid {
            background-image: radial-gradient(rgba(255, 255, 255, 0.4) 1.5px, transparent 1.5px);
            background-size: 40px 40px;
            animation: move-dots 4s linear infinite;
        }
        .form-content {
            animation: fadeInUp 0.5s ease-out;
        }
        .field-validation-error {
            color: #ef4444;
            font-size: 0.75rem;
            margin-top: 0.25rem;
        }
        .readonly-email {
            background-color: #f3f4f6 !important;
            cursor: not-allowed;
        }
        @@media (max-width: 640px) {
            .grid-cols-2 { gap: 0.5rem; }
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: { 600: '#2563eb', 700: '#1d4ed8' }
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen antialiased bg-gray-50">

<main class="flex flex-col md:flex-row min-h-screen w-full relative">

    <!-- Form Section (Right Side / Full width on mobile) -->
    <section class="w-full md:w-[30%] flex items-center justify-center px-6 md:px-12 bg-gray-50 order-2 md:order-1 relative z-20 font-sans overflow-hidden py-8 md:py-0">
        
        <!-- خلفية أيقونات خفيفة -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-[0.15] md:opacity-[0.6] z-0">
            <i class="fas fa-code absolute top-[15%] left-[10%] text-gray-400 text-6xl -rotate-12 animate-float1"></i>
            <i class="fas fa-pen-nib absolute bottom-[25%] right-[15%] text-gray-400 text-5xl rotate-12 animate-float2"></i>
            <i class="fas fa-laptop-code absolute bottom-[15%] left-[20%] text-gray-400 text-4xl -rotate-6 animate-float1"></i>
            <i class="fas fa-atom absolute top-[30%] right-[10%] text-gray-400 text-5xl rotate-45 animate-float3"></i>
            <i class="fas fa-graduation-cap absolute top-[5%] right-[25%] text-gray-300 text-4xl -rotate-12 animate-float2"></i>
        </div>

        <div class="w-full max-w-md relative z-10">

            <div class="mb-8 md:mb-14 text-center">
                <h2 class="text-3xl md:text-4xl font-black text-gray-950 tracking-tight leading-[1.1]">
                    إكمال
                    <span class="text-blue-600 block mt-2">التسجيل</span>
                </h2>
                <p class="text-gray-500 mt-4 text-base md:text-lg">
                    خطوة أخيرة لبدء رحلتك التعليمية
                </p>
            </div>

            <!-- نموذج إكمال التسجيل -->
            <form asp-action="ExternalLoginConfirmation" method="post" id="externalLoginForm" class="form-content space-y-6">
                @Html.AntiForgeryToken()

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm flex items-center justify-between animate-shake">
                        <div class="flex items-center gap-2">
                            <i class="fas fa-exclamation-circle text-red-500"></i>
                            <span>@ViewBag.ErrorMessage</span>
                        </div>
                        <button type="button" class="text-red-500 hover:text-red-700" onclick="this.parentElement.style.display='none'">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                }

                <!-- Email Field (Readonly) -->
                <div class="group">
                    <label asp-for="Email" class="block text-xs text-gray-400 mb-2 uppercase tracking-wider font-bold text-right">
                        البريد الإلكتروني
                    </label>
                    <div class="flex items-center border-b border-gray-300 focus-within:border-blue-600 transition">
                        <i class="fas fa-envelope text-gray-400 ml-3"></i>
                        <input asp-for="Email" type="email" readonly
                               class="w-full py-3 bg-transparent focus:outline-none text-gray-500 placeholder-gray-400 text-left readonly-email" 
                               placeholder="example@edulab.com" dir="ltr">
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <!-- Full Name Field -->
                <div class="group">
                    <label asp-for="Name" class="block text-xs text-gray-400 mb-2 uppercase tracking-wider font-bold text-right">
                        الاسم الكامل
                    </label>
                    <div class="flex items-center border-b border-gray-300 focus-within:border-blue-600 transition">
                        <i class="fas fa-user text-gray-400 ml-3"></i>
                        <input asp-for="Name" type="text" placeholder="أحمد محمد علي"
                               class="w-full py-3 bg-transparent focus:outline-none text-gray-900 placeholder-gray-400 text-right">
                    </div>
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <!-- Submit Button -->
                <div class="pt-4">
                    <button type="submit" id="externalLoginBtn"
                            class="w-full py-3.5 rounded-2xl bg-blue-600 text-white hover:bg-blue-700 hover:shadow-2xl hover:shadow-blue-500/40 active:scale-[0.97] transition-all duration-300 flex items-center justify-center gap-3 font-bold">
                        إكمال التسجيل
                    </button>
                </div>
            </form>

            <!-- Login Link -->
            <p class="text-center text-sm text-gray-400 pt-4 md:pt-6">
                لديك حساب بالفعل؟
                <a asp-controller="Auth" asp-action="Login" class="text-blue-600 hover:underline underline-offset-8 transition-all font-bold">سجل الدخول</a>
            </p>
        </div>
    </section>

    <!-- Hero Section (Left Side) -->
    <section class="hidden md:flex w-full md:w-[70%] relative overflow-hidden items-center justify-center p-6 md:p-12 order-1 md:order-2" style="background: radial-gradient(circle at 30% 40%, rgba(32, 87, 224, 0.25) 0%, transparent 50%), linear-gradient(180deg, #0B132B 0%, #111C3A 100%);">
        <div class="absolute inset-y-0 right-0 w-24 lg:w-32 text-gray-50 hidden md:block z-20 pointer-events-none" style="margin-right: -1px;">
            <svg viewBox="0 0 100 1000" preserveAspectRatio="none" class="w-full h-full fill-current">
                <path d="M100,0 C-10,250 110,750 0,1000 L100,1000 Z" />
            </svg>
        </div>
        
        <div class="absolute inset-0 opacity-20 animated-dots-grid z-0"></div>

        <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-10">
            <svg class="absolute top-[10%] left-[10%] w-24 h-24 text-white animate-float1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 3L1 9L12 15L21 10.09V17H23V9M5 13.18V17.18L12 21L19 17.18V13.18L12 17L5 13.18Z"/>
            </svg>
            <svg class="absolute bottom-[15%] right-[15%] w-32 h-32 text-blue-400 animate-float3" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19,2L14,6.5V17.5L19,13V2M6.5,5C4.85,5 3.5,6.35 3.5,8V18C3.5,19.65 4.85,21 6.5,21H18V19H6.5C5.95,19 5.5,18.55 5.5,18V8C5.5,7.45 5.95,7 6.5,7H18V5H6.5Z"/>
            </svg>
        </div>

        <div class="absolute inset-0 pointer-events-none z-0">
            <div class="absolute top-20 right-10 w-80 h-80 bg-blue-600/10 rounded-full blur-[100px] animate-pulse" style="animation-duration: 4s;"></div>
            <div class="absolute bottom-20 left-10 w-[400px] h-[400px] bg-indigo-500/10 rounded-full blur-[120px] animate-pulse" style="animation-duration: 6s;"></div>
        </div>

        <div class="relative z-10 w-full max-w-2xl mx-auto flex flex-col items-center md:items-start text-center md:text-right">
            
            <div class="inline-flex items-center px-4 py-1.5 bg-white/5 backdrop-blur-md rounded-full text-xs font-bold tracking-wide mb-6 border border-white/10 text-white">
                <i class="fas fa-graduation-cap ml-2 text-blue-400"></i>
                منصة تعليم المستقبل
            </div>

            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight mb-4 text-white">
                أهلاً بك في
                <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-400 via-cyan-400 to-blue-500">EduLab</span>
            </h1>

            <p class="text-base md:text-lg text-gray-400 mb-10 max-w-lg leading-relaxed">
                أنت على بُعد خطوة واحدة من الانضمام إلى مجتمع يضم آلاف المتعلمين.
            </p>

            <div class="flex gap-8 md:gap-12 items-center mb-8 justify-center md:justify-start">
                <div class="flex flex-col">
                    <div class="text-3xl md:text-4xl font-bold text-white tracking-tight">10K+</div>
                    <div class="text-[10px] md:text-xs font-medium text-blue-300 uppercase tracking-widest mt-1">طالب نشط</div>
                </div>
                <div class="w-px h-10 bg-white/20"></div>
                <div class="flex flex-col">
                    <div class="text-3xl md:text-4xl font-bold text-white tracking-tight">500+</div>
                    <div class="text-[10px] md:text-xs font-medium text-blue-300 uppercase tracking-widest mt-1">دورة متاحة</div>
                </div>
                <div class="w-px h-10 bg-white/20"></div>
                <div class="flex flex-col">
                    <div class="text-3xl md:text-4xl font-bold text-white tracking-tight">96%</div>
                    <div class="text-[10px] md:text-xs font-medium text-blue-300 uppercase tracking-widest mt-1">نسبة الرضا</div>
                </div>
            </div>
        </div>
    </section>
</main>

<!-- Scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

<script>
    (function() {
        const form = document.getElementById('externalLoginForm');
        const submitBtn = document.getElementById('externalLoginBtn');
        const originalBtnContent = submitBtn.innerHTML;

        // Handle form submission (show loading state)
        form.addEventListener('submit', function(e) {
            // التحقق من صحة النموذج قبل التعطيل
            if (!$(form).valid()) {
                e.preventDefault();
                return false;
            }

            // فقط إذا كان هناك اسم تم إدخاله (حقل مطلوب)
            const nameInput = document.querySelector('[name="Name"]');
            if (nameInput && nameInput.value.trim() !== '') {
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin ml-2"></i> جاري إكمال التسجيل...';
                submitBtn.disabled = true;
            }
            // السماح بالإرسال الطبيعي
        });

        // إعادة تعيين الزر إذا فشل الإرسال (عند العودة للصفحة مع وجود أخطاء)
        window.addEventListener('pageshow', function() {
            if (submitBtn.disabled) {
                submitBtn.innerHTML = originalBtnContent;
                submitBtn.disabled = false;
            }
        });

        // إخفاء رسالة الخطأ تلقائياً بعد 5 ثوانٍ
        const errorMsgDiv = document.querySelector('.bg-red-50');
        if (errorMsgDiv) {
            setTimeout(() => {
                errorMsgDiv.style.transition = 'opacity 0.3s ease';
                errorMsgDiv.style.opacity = '0';
                setTimeout(() => errorMsgDiv.style.display = 'none', 300);
            }, 5000);
        }
    })();
</script>
</body>
</html>