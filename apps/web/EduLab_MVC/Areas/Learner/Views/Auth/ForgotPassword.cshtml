@using System.Globalization
@model EduLab_MVC.Models.DTOs.Auth.ForgotPasswordDTO
@{
    Layout = null;
    var currentCulture = CultureInfo.CurrentUICulture.Name;
    var isArabic = currentCulture.StartsWith("ar");
}
<!DOCTYPE html>
<html lang="@currentCulture" dir="@(isArabic ? "rtl" : "ltr")">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>@Localizer["ForgotPasswordTitle"] · EduLab</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { font-family: 'Inter', system-ui, sans-serif; }
        
        @@keyframes float1 {
            0% { transform: translateY(0px) translateX(0px) rotate(0deg); }
            33% { transform: translateY(-20px) translateX(10px) rotate(5deg); }
            66% { transform: translateY(15px) translateX(-15px) rotate(-5deg); }
            100% { transform: translateY(0px) translateX(0px) rotate(0deg); }
        }
        @@keyframes float2 {
            0% { transform: translateY(0px) translateX(0px) scale(1); }
            50% { transform: translateY(-30px) translateX(-20px) scale(1.05); }
            100% { transform: translateY(0px) translateX(0px) scale(1); }
        }
        @@keyframes float3 {
            0% { transform: translate(0,0) rotate(0deg); }
            40% { transform: translate(25px, -25px) rotate(10deg); }
            80% { transform: translate(-15px, 15px) rotate(-8deg); }
            100% { transform: translate(0,0) rotate(0deg); }
        }
        @@keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        @@keyframes move-dots {
            0% { background-position: 0 0; }
            100% { background-position: 40px 40px; }
        }
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-5px); }
            40%, 80% { transform: translateX(5px); }
        }
        .animate-float1 { animation: float1 12s infinite ease-in-out; }
        .animate-float2 { animation: float2 14s infinite ease-in-out; }
        .animate-float3 { animation: float3 18s infinite ease-in-out; }
        .animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
        .gradient-animate {
            background-size: 200% 200%;
            animation: gradientShift 8s ease infinite;
        }
        .animated-dots-grid {
            background-image: radial-gradient(rgba(255, 255, 255, 0.4) 1.5px, transparent 1.5px);
            background-size: 40px 40px;
            animation: move-dots 4s linear infinite;
        }
        .step-content {
            animation: fadeInUp 0.5s ease-out;
        }
        .code-input:focus {
            transform: translateY(-2px);
            box-shadow: 0 4px 6px rgba(59, 130, 246, 0.3);
        }
        .field-validation-error {
            color: #ef4444;
            font-size: 0.75rem;
            margin-top: 0.25rem;
        }
        @@media (max-width: 640px) {
            .grid-cols-2 { gap: 0.5rem; }
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: { 600: '#2563eb', 700: '#1d4ed8' }
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen antialiased bg-gray-50">

<main class="flex flex-col md:flex-row min-h-screen w-full relative">

    <!-- Form Section (Right Side / Full width on mobile) -->
    <section class="w-full md:w-[30%] flex items-center justify-center px-6 md:px-12 bg-gray-50 order-2 md:order-1 relative z-20 font-sans overflow-hidden py-8 md:py-0">
        
        <!-- خلفية أيقونات خفيفة -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-[0.15] md:opacity-[0.6] z-0">
            <i class="fas fa-code absolute top-[15%] left-[10%] text-gray-400 text-6xl -rotate-12 animate-float1"></i>
            <i class="fas fa-pen-nib absolute bottom-[25%] right-[15%] text-gray-400 text-5xl rotate-12 animate-float2"></i>
            <i class="fas fa-laptop-code absolute bottom-[15%] left-[20%] text-gray-400 text-4xl -rotate-6 animate-float1"></i>
            <i class="fas fa-atom absolute top-[30%] right-[10%] text-gray-400 text-5xl rotate-45 animate-float3"></i>
            <i class="fas fa-graduation-cap absolute top-[5%] right-[25%] text-gray-300 text-4xl -rotate-12 animate-float2"></i>
        </div>

        <div class="w-full max-w-md relative z-10">
             @Html.AntiForgeryToken()

            <div class="mb-8 md:mb-14 text-center">
                <h2 class="text-3xl md:text-4xl font-black text-gray-950 tracking-tight leading-[1.1]">
                    @Localizer["RecoverPassword"]
                    <span class="text-blue-600 block mt-2">@Localizer["ThePassword"]</span>
                </h2>
                <p class="text-gray-500 mt-4 text-base md:text-lg">
                    @Localizer["WeWillHelpYouRecover"]
                </p>
            </div>

            <!-- ========== STEP 1: EMAIL ========== -->
            <div id="emailStep" class="step-content">
                <div class="text-center mb-6">
                    <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-envelope text-blue-600 text-2xl"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-800 mb-2">@Localizer["EnterYourEmail"]</h2>
                    <p class="text-gray-600">@Localizer["WeWillSendCode"]</p>
                </div>

                <div class="mb-6">
                    <label for="resetEmail" class="block text-xs text-gray-400 mb-2 uppercase tracking-wider font-bold @(isArabic ? "text-right" : "text-left")">
                        @Localizer["Email"]
                    </label>
                    <div class="flex items-center border-b border-gray-300 focus-within:border-blue-600 transition">
                        <i class="fas fa-envelope text-gray-400 @(isArabic ? "ml-3" : "mr-3")"></i>
                        <input type="email" id="resetEmail" name="Email" asp-for="Email"
                               class="w-full py-3 bg-transparent focus:outline-none text-gray-900 placeholder-gray-400" 
                               placeholder="name@example.com">
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                    <div id="emailError" class="text-red-500 text-xs mt-2 hidden @(isArabic ? "text-right" : "text-left")"></div>
                </div>

                <button id="sendCodeBtn" class="w-full py-3.5 rounded-2xl bg-blue-600 text-white hover:bg-blue-700 hover:shadow-2xl hover:shadow-blue-500/40 active:scale-[0.97] transition-all duration-300 flex items-center justify-center gap-3 font-bold">
                    <span id="btnText">@Localizer["SendVerificationCode"]</span>
                    <span id="spinner" class="hidden">
                        <i class="fas fa-spinner fa-spin"></i>
                    </span>
                </button>
            </div>

            <!-- ========== STEP 2: VERIFICATION CODE ========== -->
            <div id="codeStep" class="step-content hidden">
                <div class="text-center mb-6">
                    <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-shield-alt text-blue-600 text-2xl"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-800 mb-2">@Localizer["EnterVerificationCode"]</h2>
                    <p class="text-gray-600">
                        @Localizer["CodeSentTo"] 
                        <span id="userEmailDisplay" class="font-medium text-blue-600"></span>
                    </p>
                </div>

                <div class="mb-6">
                    <label class="block text-xs text-gray-400 mb-2 uppercase tracking-wider font-bold @(isArabic ? "text-right" : "text-left")">
                        @Localizer["VerificationCode"]
                    </label>
                    <div class="flex space-x-2 justify-center" dir="ltr">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 code-input" oninput="moveToNext(this, 1)" onkeypress="return isNumberKey(event)">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 code-input" oninput="moveToNext(this, 2)" onkeypress="return isNumberKey(event)">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 code-input" oninput="moveToNext(this, 3)" onkeypress="return isNumberKey(event)">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 code-input" oninput="moveToNext(this, 4)" onkeypress="return isNumberKey(event)">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 code-input" oninput="moveToNext(this, 5)" onkeypress="return isNumberKey(event)">
                        <input type="text" maxlength="1" class="w-12 h-12 text-center text-xl border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 code-input" onkeypress="return isNumberKey(event)">
                    </div>
                    <div id="codeError" class="text-red-500 text-xs mt-2 hidden @(isArabic ? "text-right" : "text-left")"></div>
                </div>

                <div class="flex justify-between items-center mb-6">
                    <button id="resendCodeBtn" class="text-blue-600 hover:underline text-sm">
                        <span id="resendText">@Localizer["ResendCode"]</span>
                    </button>
                    <span id="countdown" class="text-gray-500 text-sm hidden">
                        <span id="countdownMinutes">01</span>:<span id="countdownSeconds">30</span>
                    </span>
                </div>

                <button id="verifyCodeBtn" class="w-full py-3.5 rounded-2xl bg-blue-600 text-white hover:bg-blue-700 hover:shadow-2xl hover:shadow-blue-500/40 active:scale-[0.97] transition-all duration-300 flex items-center justify-center gap-3 font-bold">
                    @Localizer["ConfirmCode"]
                </button>
            </div>

            <!-- ========== STEP 3: NEW PASSWORD ========== -->
            <div id="passwordStep" class="step-content hidden">
                <div class="text-center mb-6">
                    <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-lock text-blue-600 text-2xl"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-800 mb-2">@Localizer["CreateNewPassword"]</h2>
                    <p class="text-gray-600">@Localizer["ChooseStrongPassword"]</p>
                </div>

                <form id="resetPasswordForm" class="space-y-5">
                    <input type="hidden" id="finalEmail" name="Email">
                    <input type="hidden" id="finalCode" name="Code">

                    <div class="group">
                        <label for="newPassword" class="block text-xs text-gray-400 mb-2 uppercase tracking-wider font-bold @(isArabic ? "text-right" : "text-left")">
                            @Localizer["NewPasswordLabel"]
                        </label>
                        <div class="flex items-center border-b border-gray-300 focus-within:border-blue-600 transition relative">
                            <i class="fas fa-lock text-gray-400 @(isArabic ? "ml-3" : "mr-3")"></i>
                            <input type="password" id="newPassword" name="NewPassword" placeholder="••••••••"
                                   class="w-full py-3 bg-transparent focus:outline-none text-gray-900 placeholder-gray-400 @(isArabic ? "pr-10 text-right" : "pl-10 text-left")">
                            <button type="button" class="absolute @(isArabic ? "left-0" : "right-0") top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-blue-600 transition toggle-password">
                                <i class="fas fa-eye-slash"></i>
                            </button>
                        </div>
                        <div id="passwordError" class="text-red-500 text-xs mt-1 hidden @(isArabic ? "text-right" : "text-left")"></div>
                    </div>

                    <div class="group">
                        <label for="confirmPassword" class="block text-xs text-gray-400 mb-2 uppercase tracking-wider font-bold @(isArabic ? "text-right" : "text-left")">
                            @Localizer["ConfirmNewPasswordLabel"]
                        </label>
                        <div class="flex items-center border-b border-gray-300 focus-within:border-blue-600 transition relative">
                            <i class="fas fa-lock text-gray-400 @(isArabic ? "ml-3" : "mr-3")"></i>
                            <input type="password" id="confirmPassword" name="ConfirmPassword" placeholder="••••••••"
                                   class="w-full py-3 bg-transparent focus:outline-none text-gray-900 placeholder-gray-400 @(isArabic ? "pr-10 text-right" : "pl-10 text-left")">
                            <button type="button" class="absolute @(isArabic ? "left-0" : "right-0") top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-blue-600 transition toggle-password">
                                <i class="fas fa-eye-slash"></i>
                            </button>
                        </div>
                        <div id="confirmPasswordError" class="text-red-500 text-xs mt-1 hidden @(isArabic ? "text-right" : "text-left")"></div>
                    </div>

                    <div class="pt-4">
                        <button type="submit" id="resetPasswordBtn"
                                class="w-full py-3.5 rounded-2xl bg-blue-600 text-white hover:bg-blue-700 hover:shadow-2xl hover:shadow-blue-500/40 active:scale-[0.97] transition-all duration-300 flex items-center justify-center gap-3 font-bold">
                            @Localizer["ChangePasswordButton"]
                        </button>
                    </div>
                </form>
            </div>

            <!-- ========== STEP 4: SUCCESS ========== -->
            <div id="successStep" class="step-content hidden">
                <div class="text-center mb-6">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-check-circle text-green-600 text-2xl"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-800 mb-2">@Localizer["PasswordChangedSuccess"]</h2>
                    <p class="text-gray-600">@Localizer["NowYouCanLogin"]</p>
                </div>

                <a asp-controller="Auth" asp-action="Login" 
                   class="w-full py-3.5 rounded-2xl bg-blue-600 text-white hover:bg-blue-700 hover:shadow-2xl hover:shadow-blue-500/40 active:scale-[0.97] transition-all duration-300 flex items-center justify-center gap-3 font-bold">
                    @Localizer["GoToLogin"]
                </a>
            </div>

            <!-- Login Link -->
            <p class="text-center text-sm text-gray-400 pt-4 md:pt-6">
                @Localizer["RememberedPassword"]
                <a asp-controller="Auth" asp-action="Login" class="text-blue-600 hover:underline underline-offset-8 transition-all font-bold">@Localizer["SignIn"]</a>
            </p>
        </div>
    </section>

    <!-- Hero Section (Left Side) - identical to login/register -->
<!-- Hero Section (Left Side) - مع توسيط كامل للمحتوى -->
<section class="hidden md:flex w-full md:w-[70%] relative overflow-hidden items-center justify-center p-6 md:p-12 order-1 md:order-2" style="background: radial-gradient(circle at 30% 40%, rgba(32, 87, 224, 0.25) 0%, transparent 50%), linear-gradient(180deg, #0B132B 0%, #111C3A 100%);">
    <div class="absolute inset-y-0 @(isArabic ? "right-0" : "left-0") w-24 lg:w-32 text-gray-50 hidden md:block z-20 pointer-events-none" style="@(isArabic ? "margin-right: -1px" : "margin-left: -1px")">
        <svg viewBox="0 0 100 1000" preserveAspectRatio="none" class="w-full h-full fill-current">
            <path d="@(isArabic ? "M100,0 C-10,250 110,750 0,1000 L100,1000 Z" : "M0,0 C110,250 -10,750 100,1000 L0,1000 Z")" />
        </svg>
    </div>
    
    <div class="absolute inset-0 opacity-20 animated-dots-grid z-0"></div>

    <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-10">
        <svg class="absolute top-[10%] left-[10%] w-24 h-24 text-white animate-float1" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 3L1 9L12 15L21 10.09V17H23V9M5 13.18V17.18L12 21L19 17.18V13.18L12 17L5 13.18Z"/>
        </svg>
        <svg class="absolute bottom-[15%] right-[15%] w-32 h-32 text-blue-400 animate-float3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19,2L14,6.5V17.5L19,13V2M6.5,5C4.85,5 3.5,6.35 3.5,8V18C3.5,19.65 4.85,21 6.5,21H18V19H6.5C5.95,19 5.5,18.55 5.5,18V8C5.5,7.45 5.95,7 6.5,7H18V5H6.5Z"/>
        </svg>
    </div>

    <div class="absolute inset-0 pointer-events-none z-0">
        <div class="absolute top-20 right-10 w-80 h-80 bg-blue-600/10 rounded-full blur-[100px] animate-pulse" style="animation-duration: 4s;"></div>
        <div class="absolute bottom-20 left-10 w-[400px] h-[400px] bg-indigo-500/10 rounded-full blur-[120px] animate-pulse" style="animation-duration: 6s;"></div>
    </div>

    <!-- المحتوى المركز أفقيًا وعموديًا -->
    <div class="relative z-10 w-full text-center px-4 md:px-8">
        
        <div class="inline-flex items-center px-4 py-1.5 bg-white/5 backdrop-blur-md rounded-full text-xs font-bold tracking-wide mb-6 border border-white/10 text-white mx-auto">
            <i class="fas fa-graduation-cap ml-2 text-blue-400"></i>
            @Localizer["FutureEducationPlatform"]
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight mb-4 text-white">
            @Localizer["RecoverPassword"]
            <span class="text-transparent bg-clip-text bg-gradient-to-l from-blue-400 via-cyan-400 to-blue-500">@Localizer["ThePassword"]</span> @Localizer["Easily"]
        </h1>

        <p class="text-base md:text-lg text-gray-400 mb-10 max-w-lg leading-relaxed mx-auto">
            @Localizer["DontWorryWeHelp"]
        </p>

        <div class="flex gap-8 md:gap-12 items-center justify-center mb-8 flex-wrap">
            <div class="flex flex-col items-center">
                <i class="fas fa-envelope text-3xl text-blue-400"></i>
                <div class="text-xs font-medium text-blue-300 uppercase tracking-widest mt-2">@Localizer["LinkToEmail"]</div>
            </div>
            <div class="w-px h-10 bg-white/20 hidden sm:block"></div>
            <div class="flex flex-col items-center">
                <i class="fas fa-key text-3xl text-blue-400"></i>
                <div class="text-xs font-medium text-blue-300 uppercase tracking-widest mt-2">@Localizer["NewPassword"]</div>
            </div>
            <div class="w-px h-10 bg-white/20 hidden sm:block"></div>
            <div class="flex flex-col items-center">
                <i class="fas fa-shield-alt text-3xl text-blue-400"></i>
                <div class="text-xs font-medium text-blue-300 uppercase tracking-widest mt-2">@Localizer["ProtectYourAccount"]</div>
            </div>
        </div>
    </div>
</section></main>

<!-- Scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

<script>
    (function() {
        // ---------- HELPER FUNCTIONS ----------
        function isNumberKey(evt) {
            const charCode = (evt.which) ? evt.which : evt.keyCode;
            return !(charCode > 31 && (charCode < 48 || charCode > 57));
        }

        function moveToNext(current, nextIndex) {
            if (current.value.length >= current.maxLength) {
                const next = current.parentElement.querySelector(`input:nth-child(${nextIndex + 1})`);
                if (next) next.focus();
            }
        }

        function isValidEmail(email) {
            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
        }

        function isValidPassword(password) {
            return password.length >= 6;
        }

        function getAntiForgeryToken() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            return token ? token.value : '';
        }

        // Toggle password visibility
        document.querySelectorAll('.toggle-password').forEach(button => {
            button.addEventListener('click', function() {
                const input = this.closest('.group')?.querySelector('input');
                const icon = this.querySelector('i');
                if (!input) return;
                
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                } else {
                    input.type = 'password';
                    icon.classList.remove('fa-eye');
                    icon.classList.add('fa-eye-slash');
                }
            });
        });

        // ---------- STEP MANAGEMENT ----------
        const emailStep = document.getElementById('emailStep');
        const codeStep = document.getElementById('codeStep');
        const passwordStep = document.getElementById('passwordStep');
        const successStep = document.getElementById('successStep');

        const resetEmail = document.getElementById('resetEmail');
        const sendCodeBtn = document.getElementById('sendCodeBtn');
        const btnText = document.getElementById('btnText');
        const spinner = document.getElementById('spinner');
        const emailError = document.getElementById('emailError');
        const userEmailDisplay = document.getElementById('userEmailDisplay');
        const verifyCodeBtn = document.getElementById('verifyCodeBtn');
        const resendCodeBtn = document.getElementById('resendCodeBtn');
        const resendText = document.getElementById('resendText');
        const countdown = document.getElementById('countdown');
        const countdownMinutes = document.getElementById('countdownMinutes');
        const countdownSeconds = document.getElementById('countdownSeconds');
        const codeError = document.getElementById('codeError');
        const resetPasswordForm = document.getElementById('resetPasswordForm');
        const resetPasswordBtn = document.getElementById('resetPasswordBtn');
        const newPassword = document.getElementById('newPassword');
        const confirmPassword = document.getElementById('confirmPassword');
        const passwordError = document.getElementById('passwordError');
        const confirmPasswordError = document.getElementById('confirmPasswordError');
        const finalEmail = document.getElementById('finalEmail');
        const finalCode = document.getElementById('finalCode');

        let verifiedEmail = '';
        let countdownInterval = null;

        function startCountdown(seconds) {
            if (countdownInterval) clearInterval(countdownInterval);
            let remaining = seconds;
            countdown.classList.remove('hidden');

            countdownInterval = setInterval(() => {
                const minutes = Math.floor(remaining / 60);
                const secs = remaining % 60;
                countdownMinutes.textContent = minutes.toString().padStart(2, '0');
                countdownSeconds.textContent = secs.toString().padStart(2, '0');

                if (remaining <= 0) {
                    clearInterval(countdownInterval);
                    countdown.classList.add('hidden');
                    resendCodeBtn.disabled = false;
                } else {
                    resendCodeBtn.disabled = true;
                }
                remaining--;
            }, 1000);
        }

        // Step 1: Send Reset Code
        sendCodeBtn.addEventListener('click', async () => {
            const email = resetEmail.value.trim();
            if (!isValidEmail(email)) {
                emailError.textContent = "@Localizer["InvalidEmail"]";
                emailError.classList.remove('hidden');
                resetEmail.classList.add('animate-shake');
                setTimeout(() => resetEmail.classList.remove('animate-shake'), 500);
                return;
            }

            emailError.classList.add('hidden');
            resetEmail.classList.remove('border-red-500');
            btnText.textContent = '@Localizer["Sending"]...';
            spinner.classList.remove('hidden');
            sendCodeBtn.disabled = true;

            try {
                const response = await fetch('/Learner/Auth/SendResetCode', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify({ Email: email })
                });
                const data = await response.json();
                if (!data.isSuccess) throw new Error(data.errorMessages?.[0] || data.message || '@Localizer["SendFailed"]');

                verifiedEmail = email;
                emailStep.classList.add('hidden');
                codeStep.classList.remove('hidden');
                userEmailDisplay.textContent = email;
                startCountdown(90);
            } catch (error) {
                emailError.textContent = error.message;
                emailError.classList.remove('hidden');
                resetEmail.classList.add('animate-shake');
                setTimeout(() => resetEmail.classList.remove('animate-shake'), 500);
            } finally {
                btnText.textContent = '@Localizer["SendVerificationCode"]';
                spinner.classList.add('hidden');
                sendCodeBtn.disabled = false;
            }
        });

        // Step 2: Verify Code
        verifyCodeBtn.addEventListener('click', async () => {
            const inputs = document.querySelectorAll('#codeStep input[type="text"]');
            let code = '';
            inputs.forEach(i => code += i.value);
            if (code.length !== 6) {
                codeError.textContent = '@Localizer["PleaseEnter6DigitCode"]';
                codeError.classList.remove('hidden');
                return;
            }

            verifyCodeBtn.disabled = true;
            verifyCodeBtn.innerHTML = '<i class="fas fa-spinner fa-spin ml-2"></i> @Localizer["Verifying"]...';

            try {
                const response = await fetch('/Learner/Auth/VerifyResetCode', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify({ Email: verifiedEmail, Code: code })
                });
                const data = await response.json();
                if (!data.isSuccess) throw new Error(data.errorMessages?.[0] || '@Localizer["InvalidCode"]');

                codeError.classList.add('hidden');
                codeStep.classList.add('hidden');
                passwordStep.classList.remove('hidden');
                finalEmail.value = verifiedEmail;
                finalCode.value = code;
                if (countdownInterval) clearInterval(countdownInterval);
            } catch (error) {
                codeError.textContent = error.message;
                codeError.classList.remove('hidden');
            } finally {
                verifyCodeBtn.disabled = false;
                verifyCodeBtn.innerHTML = '@Localizer["ConfirmCode"]';
            }
        });

        // Resend Code
        resendCodeBtn.addEventListener('click', async () => {
            resendText.textContent = '@Localizer["Sending"]...';
            resendCodeBtn.disabled = true;
            try {
                const response = await fetch('/Learner/Auth/SendResetCode', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify({ Email: verifiedEmail })
                });
                const data = await response.json();
                if (!data.isSuccess) throw new Error(data.errorMessages?.[0] || '@Localizer["SendFailed"]');
                startCountdown(90);
            } catch (error) {
                alert(error.message);
            } finally {
                resendText.textContent = '@Localizer["ResendCode"]';
                resendCodeBtn.disabled = false;
            }
        });

        // Step 3: Reset Password
        resetPasswordForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const password = newPassword.value;
            const confirm = confirmPassword.value;

            passwordError.classList.add('hidden');
            confirmPasswordError.classList.add('hidden');
            newPassword.classList.remove('border-red-500');
            confirmPassword.classList.remove('border-red-500');

            let hasError = false;
            if (!isValidPassword(password)) {
                passwordError.textContent = '@Localizer["PasswordMinLength"]';
                passwordError.classList.remove('hidden');
                newPassword.classList.add('border-red-500', 'animate-shake');
                hasError = true;
            }
            if (password !== confirm) {
                confirmPasswordError.textContent = '@Localizer["PasswordsDoNotMatch"]';
                confirmPasswordError.classList.remove('hidden');
                confirmPassword.classList.add('border-red-500', 'animate-shake');
                hasError = true;
            }
            if (hasError) {
                setTimeout(() => {
                    newPassword.classList.remove('animate-shake');
                    confirmPassword.classList.remove('animate-shake');
                }, 500);
                return;
            }

            resetPasswordBtn.disabled = true;
            resetPasswordBtn.innerHTML = '<i class="fas fa-spinner fa-spin ml-2"></i> @Localizer["Changing"]...';

            try {
                const response = await fetch('/Learner/Auth/ResetPassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify({
                        Email: finalEmail.value,
                        Code: finalCode.value,
                        NewPassword: password,
                        ConfirmPassword: confirm
                    })
                });
                const data = await response.json();
                if (!data.isSuccess) throw new Error(data.errorMessages?.[0] || '@Localizer["PasswordChangeFailed"]');

                passwordStep.classList.add('hidden');
                successStep.classList.remove('hidden');
            } catch (error) {
                alert(error.message);
            } finally {
                resetPasswordBtn.disabled = false;
                resetPasswordBtn.innerHTML = '@Localizer["ChangePasswordButton"]';
            }
        });

        // Expose helpers globally
        window.isNumberKey = isNumberKey;
        window.moveToNext = moveToNext;
    })();
</script>
</body>
</html>